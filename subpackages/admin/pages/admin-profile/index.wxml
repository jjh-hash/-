<!--pages/admin-profile/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  

  <!-- 页面内容 -->
  <view class="page-content">
    <!-- 管理员信息卡片 -->
    <view class="admin-info-section">
      <view class="admin-card">
        <view class="admin-avatar">
          <image src="/pages/小标/wode.png" mode="aspectFit"></image>
        </view>
        <view class="admin-details">
          <text class="admin-name">{{adminInfo.username}}</text>
          <text class="admin-role">{{adminInfo.role === 'super_admin' ? '超级管理员' : '普通管理员'}}</text>
          <text class="admin-login-time">最后登录：{{adminInfo.lastLoginTime}}</text>
        </view>
      </view>
    </view>

    <!-- 系统信息 -->
    <view class="system-info-section">
      <text class="section-title">系统信息</text>
      <view class="info-cards">
        <view class="info-card">
          <text class="info-label">系统版本</text>
          <text class="info-value">{{systemInfo.version}}</text>
        </view>
        
        <view class="info-card">
          <text class="info-label">构建时间</text>
          <text class="info-value">{{systemInfo.buildTime}}</text>
        </view>
        
        <view class="info-card">
          <text class="info-label">运行环境</text>
          <text class="info-value">{{systemInfo.environment}}</text>
        </view>
        
        <view class="info-card">
          <text class="info-label">运行时长</text>
          <text class="info-value">{{systemInfo.uptime}}</text>
        </view>
      </view>
    </view>

    <!-- 最近操作 -->
    <view class="operation-logs-section">
      <text class="section-title">最近操作</text>
      <view class="logs-list">
        <view class="log-item" wx:for="{{displayLogs}}" wx:key="id">
          <view class="log-content">
            <text class="log-action">{{item.action}}</text>
            <text class="log-target">{{item.target}}</text>
            <text class="log-time">{{item.time}}</text>
          </view>
          <view class="log-result {{item.result === '成功' || item.result === '通过' || item.result === '完成' ? 'success' : 'warning'}}">
            {{item.result}}
          </view>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="function-menu-section">
      <text class="section-title">功能菜单</text>
      <view class="menu-list">
        <view class="menu-item" bindtap="onChangePassword">
          <view class="menu-icon">🔒</view>
          <text class="menu-text">修改密码</text>
          <view class="menu-arrow">></view>
        </view>
        
        <view class="menu-item" bindtap="onViewLogs">
          <view class="menu-icon">📋</view>
          <text class="menu-text">操作日志</text>
          <view class="menu-arrow">></view>
        </view>
        
        <view class="menu-item" bindtap="onAbout">
          <view class="menu-icon">ℹ️</view>
          <text class="menu-text">关于我们</text>
          <view class="menu-arrow">></view>
        </view>
        

      </view>
    </view>
  </view>
</view>