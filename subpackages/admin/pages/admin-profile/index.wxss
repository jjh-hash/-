/* pages/admin-profile/index.wxss */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 100rpx;
}

.status-bar {
  background: var(--color-primary);
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--color-primary);
  color: #fff;
}

.back-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 10rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.nav-actions {
  display: flex;
  align-items: center;
}

.logout-btn {
  font-size: 28rpx;
  color: #fff;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 20rpx;
}

.page-content {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 30rpx;
  display: block;
  padding-left: 10rpx;
}

/* 管理员信息 */
.admin-info-section {
  margin-bottom: 40rpx;
}

.admin-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 40rpx;
  box-shadow: var(--shadow-card);
  border-left: 6rpx solid var(--color-primary);
}

.admin-avatar {
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
}

.admin-avatar image {
  width: 100%;
  height: 100%;
}

.admin-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.admin-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.admin-role { font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 8rpx; }

.admin-login-time { font-size: 24rpx; color: var(--color-text-placeholder); }

/* 系统信息 */
.system-info-section {
  margin-bottom: 40rpx;
}

.info-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
}

.info-label { font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 8rpx; }

.info-value { font-size: 28rpx; font-weight: bold; color: var(--color-text); }

/* 操作日志 */
.operation-logs-section {
  margin-bottom: 40rpx;
}

.logs-list {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  box-shadow: var(--shadow-card);
}

.log-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.log-item:last-child {
  border-bottom: none;
}

.log-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.log-action {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.log-target { font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 4rpx; }

.log-time { font-size: 22rpx; color: var(--color-text-placeholder); }

.log-result {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-tag);
  font-weight: bold;
}

.log-result.success {
  background: var(--color-primary-light);
  color: var(--color-success);
}

.log-result.warning {
  background: rgba(250, 140, 22, 0.12);
  color: var(--color-warning);
}

/* 查看全部操作链接 */
.view-all-logs {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  margin-top: 10rpx;
  border-top: 1rpx solid var(--color-border);
  cursor: pointer;
  transition: all 0.3s ease;
}

.view-all-logs:active { background: var(--color-bg-page); }

.view-all-text { font-size: 28rpx; color: var(--color-primary); margin-right: 8rpx; }

.view-all-arrow { font-size: 28rpx; color: var(--color-primary); margin-left: 8rpx; }

/* 功能菜单 */
.function-menu-section {
  margin-bottom: 40rpx;
}

.menu-list {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--color-border);
  transition: all 0.3s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--color-bg-page);
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 24rpx;
  width: 40rpx;
  text-align: center;
}

.menu-text { flex: 1; font-size: 28rpx; color: var(--color-text); }

.menu-arrow { font-size: 24rpx; color: var(--color-text-placeholder); }