/* pages/admin-profile/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 100rpx; /* 为tabBar留出空间 */
}

.status-bar {
  background: transparent;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.back-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 10rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.nav-actions {
  display: flex;
  align-items: center;
}

.logout-btn {
  font-size: 28rpx;
  color: #fff;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

.page-content {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
  display: block;
}

/* 管理员信息 */
.admin-info-section {
  margin-bottom: 40rpx;
}

.admin-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.admin-avatar {
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
}

.admin-avatar image {
  width: 100%;
  height: 100%;
}

.admin-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.admin-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.admin-role {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.admin-login-time {
  font-size: 24rpx;
  color: #999;
}

/* 系统信息 */
.system-info-section {
  margin-bottom: 40rpx;
}

.info-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 操作日志 */
.operation-logs-section {
  margin-bottom: 40rpx;
}

.logs-list {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.log-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.log-item:last-child {
  border-bottom: none;
}

.log-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.log-action {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.log-target {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.log-time {
  font-size: 22rpx;
  color: #999;
}

.log-result {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.log-result.success {
  background: #E8F5E8;
  color: #4CAF50;
}

.log-result.warning {
  background: #FFF3E0;
  color: #FF9800;
}

/* 查看全部操作链接 */
.view-all-logs {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  margin-top: 10rpx;
  border-top: 1rpx solid #f0f0f0;
  cursor: pointer;
  transition: all 0.3s ease;
}

.view-all-logs:active {
  background: rgba(0, 0, 0, 0.02);
}

.view-all-text {
  font-size: 28rpx;
  color: #667eea;
  margin-right: 8rpx;
}

.view-all-arrow {
  font-size: 28rpx;
  color: #667eea;
  margin-left: 8rpx;
}

/* 功能菜单 */
.function-menu-section {
  margin-bottom: 40rpx;
}

.menu-list {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(0, 0, 0, 0.05);
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 24rpx;
  width: 40rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 24rpx;
  color: #999;
}