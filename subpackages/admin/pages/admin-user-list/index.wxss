/* 管理端用户列表 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar { background: transparent; }
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
  position: relative;
}
.back-btn { position: absolute; left: 30rpx; color: var(--color-text); font-size: 28rpx; padding: 10rpx; }
.title { color: var(--color-text); font-size: 36rpx; font-weight: bold; text-align: center; }

.filter-section {
  display: flex;
  padding: 20rpx 30rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
  gap: 20rpx;
}
.search-box { flex: 1; position: relative; }
.search-icon {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: var(--color-text-placeholder);
  z-index: 1;
}
.search-input {
  width: 100%;
  height: 76rpx;
  padding: 0 24rpx 0 60rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 38rpx;
  font-size: 28rpx;
  background: var(--color-bg-page);
  box-sizing: border-box;
}
.search-input:focus {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
}
.filter-box { flex: 1; }
.picker-text {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 38rpx;
  font-size: 28rpx;
  text-align: center;
  background: var(--color-bg-page);
  color: var(--color-text);
}

.user-list { padding: 20rpx 30rpx; }
.user-item {
  background: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.user-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.user-info { display: flex; align-items: center; flex: 1; }
.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  overflow: hidden;
  margin-right: 20rpx;
  background: var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}
.user-avatar image { width: 100%; height: 100%; }
.avatar-placeholder { font-size: 36rpx; color: var(--color-text-placeholder); font-weight: bold; }
.user-details { flex: 1; }
.user-name { display: block; font-size: 32rpx; font-weight: bold; color: var(--color-text); margin-bottom: 8rpx; }
.user-phone { display: block; font-size: 26rpx; color: var(--color-text-secondary); }
.user-status { padding: 8rpx 16rpx; border-radius: 20rpx; font-size: 24rpx; font-weight: 500; }
.status-active { background: var(--color-primary-light); color: var(--color-success); }
.status-banned { background: rgba(244,67,54,0.15); color: var(--color-danger); }
.user-details-row { margin-bottom: 20rpx; }
.detail-item { display: flex; margin-bottom: 10rpx; }
.detail-label { font-size: 26rpx; color: var(--color-text-secondary); width: 160rpx; }
.detail-value { font-size: 26rpx; color: var(--color-text); flex: 1; }
.user-actions { display: flex; justify-content: space-between; align-items: center; }
.action-btn { padding: 12rpx 24rpx; border-radius: 20rpx; font-size: 26rpx; text-align: center; min-width: 120rpx; }
.detail-btn { background: var(--color-primary-light); color: var(--color-primary); }
.action-buttons { display: flex; gap: 15rpx; }
.ban-btn { background: rgba(244,67,54,0.15); color: var(--color-danger); }
.unban-btn { background: var(--color-primary-light); color: var(--color-success); }
.loading { text-align: center; padding: 60rpx; color: var(--color-text-secondary); font-size: 28rpx; }
.empty { text-align: center; padding: 100rpx 60rpx; }
.empty-icon { font-size: 120rpx; display: block; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-secondary); }
.load-more { text-align: center; padding: 40rpx; color: var(--color-text-placeholder); font-size: 26rpx; }
