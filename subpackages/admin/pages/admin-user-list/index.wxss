.page {
  min-height: 100vh;
  background: #f5f6f8;
}

.status-bar {
  background: transparent;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 30rpx;
  color: #333;
  font-size: 28rpx;
  padding: 10rpx;
}

.title {
  color: #333;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
}

.filter-section {
  display: flex;
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
  gap: 20rpx;
}

.search-box {
  flex: 1;
  position: relative;
}

.search-icon {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #999;
  z-index: 1;
}

.search-input {
  width: 100%;
  height: 76rpx;
  padding: 0 24rpx 0 60rpx;
  border: 2rpx solid #e6e8eb;
  border-radius: 38rpx;
  font-size: 28rpx;
  background: #f5f6f8;
  box-sizing: border-box;
}

.search-input:focus {
  border-color: #1677ff;
  background: #fff;
}

.filter-box {
  flex: 1;
}

.picker-text {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e6e8eb;
  border-radius: 38rpx;
  font-size: 28rpx;
  text-align: center;
  background: #f5f6f8;
  color: #333;
}

.user-list {
  padding: 20rpx 30rpx;
}

.user-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  overflow: hidden;
  margin-right: 20rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 36rpx;
  color: #999;
  font-weight: bold;
}

.user-details {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.user-phone {
  display: block;
  font-size: 26rpx;
  color: #666;
}

.user-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-active {
  background: #d4edda;
  color: #155724;
}

.status-banned {
  background: #f8d7da;
  color: #721c24;
}

.user-details-row {
  margin-bottom: 20rpx;
}

.detail-item {
  display: flex;
  margin-bottom: 10rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
  width: 160rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.user-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  text-align: center;
  min-width: 120rpx;
}

.detail-btn {
  background: #e3f2fd;
  color: #1976d2;
}

.action-buttons {
  display: flex;
  gap: 15rpx;
}

.ban-btn {
  background: #f8d7da;
  color: #721c24;
}

.unban-btn {
  background: #d4edda;
  color: #155724;
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: #666;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

.load-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
