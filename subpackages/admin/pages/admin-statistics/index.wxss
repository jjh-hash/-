.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar { background: transparent; }

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
  position: relative;
}

.back-btn, .refresh-btn, .export-btn {
  color: var(--color-text);
  font-size: 32rpx;
  padding: 10rpx;
  flex-shrink: 0;
}

.title {
  color: var(--color-text);
  font-size: 36rpx;
  font-weight: bold;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.nav-right { width: 60rpx; flex-shrink: 0; }

.nav-actions { display: flex; align-items: center; gap: 20rpx; }

.export-btn {
  background: var(--color-primary);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-tag);
  font-size: 26rpx;
}

.tabs {
  display: flex;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  position: relative;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

.date-range {
  padding: 20rpx 30rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.picker-text {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-tag);
  font-size: 26rpx;
  color: var(--color-text);
}

/* 内容区域 */
.content {
  padding: 30rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}

.stat-icon { font-size: 48rpx; display: block; margin-bottom: 15rpx; }

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 10rpx;
}

.stat-number {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text);
}

.revenue-card {
  background: var(--color-primary);
  border-radius: var(--radius-card);
  padding: 40rpx;
  text-align: center;
  color: #fff;
  box-shadow: var(--shadow-card);
}

.revenue-label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 15rpx;
  opacity: 0.9;
}

.revenue-amount {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.chart-container {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 30rpx;
  text-align: center;
}

.chart-wrapper {
  width: 100%;
  overflow-x: auto;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  min-height: 250rpx;
  padding: 20rpx 0;
}

.chart-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.chart-bar-wrapper {
  width: 100%;
  height: 200rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 5rpx;
}

.chart-bar {
  width: 100%;
  max-width: 60rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, rgba(255, 184, 0, 0.75) 100%);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: all 0.3s ease;
}

.chart-bar.revenue-bar {
  background: linear-gradient(180deg, var(--color-warning) 0%, rgba(221, 142, 9, 0.7) 100%);
}

.chart-bar.active-bar {
  background: linear-gradient(180deg, var(--color-secondary) 0%, rgba(59, 130, 246, 0.7) 100%);
}

.chart-bar.merchant-bar {
  background: linear-gradient(180deg, var(--color-success) 0%, rgba(7, 193, 96, 0.7) 100%);
}

.chart-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 10rpx;
  text-align: center;
  transform: rotate(0deg);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}

.chart-value {
  display: block;
  font-size: 20rpx;
  color: var(--color-text);
  margin-top: 5rpx;
  text-align: center;
  font-weight: bold;
}

.chart-bar.time-bar {
  background: linear-gradient(180deg, var(--color-primary-light) 0%, rgba(255, 184, 0, 0.5) 100%);
}

.stat-trend {
  display: block;
  font-size: 20rpx;
  margin-top: 5rpx;
}

.stat-trend.positive { color: var(--color-success); }

.stat-trend.negative { color: var(--color-danger); }

.ranking-container {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
}

.ranking-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 20rpx;
  text-align: center;
}

.ranking-list { display: flex; flex-direction: column; gap: 15rpx; }

.ranking-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  border-left: 4rpx solid var(--color-primary);
}

.ranking-rank {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.ranking-info { flex: 1; display: flex; flex-direction: column; gap: 5rpx; }

.ranking-name { font-size: 28rpx; font-weight: bold; color: var(--color-text); }

.ranking-desc { font-size: 24rpx; color: var(--color-text-secondary); line-height: 1.5; }