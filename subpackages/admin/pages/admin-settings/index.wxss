/* 管理端设置 - 设计系统 */
.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav-bar{height:44px;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;position:relative}
.title{font-size:18px;color:var(--color-text);font-weight:600}
.back-btn{position:absolute;left:12px;color:var(--color-text);font-size:18px;cursor:pointer}

.page-content{height:calc(100vh - 44px);padding:12px}

.section{background:var(--color-bg-card);border-radius:var(--radius-card);padding:16px;margin-bottom:12px;box-shadow:var(--shadow-card)}
.section-title{font-size:16px;color:var(--color-text);font-weight:600;margin-bottom:16px;display:block}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.add-btn{color:var(--color-primary);font-size:14px}

.config-item{display:flex;align-items:center;padding:12px 0;border-bottom:1px solid var(--color-border)}
.config-item:last-child{border-bottom:none}
.config-label{flex:1;display:flex;flex-direction:column;gap:4px}
.label-text{color:var(--color-text);font-size:15px;font-weight:500}
.label-desc{color:var(--color-text-placeholder);font-size:12px}
.config-value{display:flex;align-items:center;gap:12px}
.value-text{color:var(--color-text-secondary);font-size:14px}
.edit-btn{color:var(--color-primary);font-size:14px}

.invite-code-list{display:flex;flex-direction:column;gap:12px}
.invite-code-item{background:var(--color-bg-page);border-radius:var(--radius-btn);padding:12px;display:flex;align-items:center;justify-content:space-between}
.code-info{flex:1;display:flex;flex-direction:column;gap:4px}
.code-text{color:var(--color-text);font-size:15px;font-weight:600}
.code-desc{color:var(--color-text-secondary);font-size:13px}
.code-status{color:var(--color-text-placeholder);font-size:12px}
.code-actions{display:flex;gap:12px}
.copy-btn{color:var(--color-primary);font-size:14px}
.delete-btn{color:var(--color-danger);font-size:14px}

.switch-item{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--color-border)}
.switch-item:last-child{border-bottom:none}
.switch-label{flex:1;display:flex;flex-direction:column;gap:4px}
.switch-title{color:var(--color-text);font-size:15px}
.switch-desc{color:var(--color-text-placeholder);font-size:13px}

.announcement-list{display:flex;flex-direction:column;gap:12px}
.announcement-item{background:var(--color-bg-page);border-radius:var(--radius-btn);padding:12px;display:flex;flex-direction:column;gap:8px}
.announcement-text{color:var(--color-text);font-size:14px;line-height:1.6}
.announcement-time{color:var(--color-text-placeholder);font-size:12px}

.action-item{display:flex;align-items:center;padding:12px 0;border-bottom:1px solid var(--color-border)}
.action-item:last-child{border-bottom:none}
.action-icon{font-size:20px;margin-right:12px}
.action-text{flex:1;color:var(--color-text);font-size:15px}
.action-arrow{color:var(--color-text-placeholder);font-size:14px}

.empty-state{text-align:center;padding:40px 0}
.empty-text{color:var(--color-text-placeholder);font-size:14px}

.banner-list{display:flex;flex-direction:column;gap:12px}
.banner-item{background:var(--color-bg-page);border-radius:var(--radius-btn);padding:12px;display:flex;flex-direction:column;gap:8px}
.banner-preview{width:100%;height:120px;border-radius:var(--radius-btn);overflow:hidden;background:var(--color-border)}
.banner-image{width:100%;height:100%}
.banner-info{display:flex;align-items:center;justify-content:space-between}
.banner-index{color:var(--color-text-secondary);font-size:14px}
.banner-actions{display:flex;gap:12px;justify-content:flex-end}

.announcement-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.announcement-title-wrapper{flex:1;display:flex;flex-direction:column;gap:4px}
.announcement-title{color:var(--color-text);font-size:15px;font-weight:600}
.announcement-type{color:var(--color-text-placeholder);font-size:12px}
.announcement-actions{display:flex;align-items:center;gap:8px}
.announcement-status{color:var(--color-success);font-size:12px;background:var(--color-primary-light);padding:2px 8px;border-radius:var(--radius-tag)}
.announcement-status.inactive{color:var(--color-danger);background:rgba(244,67,54,0.1)}
.announcement-delete{color:var(--color-danger);font-size:13px;cursor:pointer}
.announcement-delete:active{opacity:0.7}

.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:1000;display:flex;align-items:center;justify-content:center}
.modal-content{background:var(--color-bg-card);border-radius:var(--radius-card);width:90%;max-width:500px;max-height:80vh;display:flex;flex-direction:column}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:16px;border-bottom:1px solid var(--color-border)}
.modal-title{font-size:18px;color:var(--color-text);font-weight:600}
.modal-close{font-size:24px;color:var(--color-text-placeholder);cursor:pointer}
.modal-body{flex:1;overflow-y:auto;padding:16px}
.modal-footer{display:flex;padding:16px;border-top:1px solid var(--color-border);gap:12px}
.modal-btn{flex:1;padding:12px;text-align:center;border-radius:var(--radius-btn);font-size:15px}
.modal-btn.cancel{background:var(--color-bg-page);color:var(--color-text-secondary)}
.modal-btn.primary{background:var(--color-primary);color:#fff}
