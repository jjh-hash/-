<!--pages/admin-settings/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  

  <!-- 页面内容 -->
  <scroll-view scroll-y class="page-content">
    <!-- 平台参数配置 -->
    <view class="section">
      <text class="section-title">平台参数配置</text>
      
      <view class="config-item">
        <view class="config-label">
          <text class="label-text">平台服务费比例</text>
          <text class="label-desc">按订单金额的百分比收取服务费</text>
        </view>
        <view class="config-value">
          <text class="value-text">{{platformConfig.platformFeeRate * 100}}%</text>
          <text class="edit-btn" bindtap="onEditConfig" data-type="platformFeeRate">编辑</text>
        </view>
      </view>
      
      <view class="config-item">
        <view class="config-label">
          <text class="label-text">配送费</text>
          <text class="label-desc">统一配送费，所有商家相同</text>
        </view>
        <view class="config-value">
          <text class="value-text">¥{{platformConfig.deliveryFee}}</text>
          <text class="edit-btn" bindtap="onEditConfig" data-type="deliveryFee">编辑</text>
        </view>
      </view>
      
      <view class="config-item">
        <view class="config-label">
          <text class="label-text">最低订单金额下限</text>
          <text class="label-desc">商家起送金额不能低于此值</text>
        </view>
        <view class="config-value">
          <text class="value-text">¥{{platformConfig.minOrderAmountLimit}}</text>
          <text class="edit-btn" bindtap="onEditConfig" data-type="minOrderAmountLimit">编辑</text>
        </view>
      </view>
      
      <view class="config-item">
        <view class="config-label">
          <text class="label-text">预计送达时间</text>
          <text class="label-desc">商家出餐后预计送达的分钟数</text>
        </view>
        <view class="config-value">
          <text class="value-text">{{platformConfig.estimatedDeliveryMinutes}}分钟</text>
          <text class="edit-btn" bindtap="onEditConfig" data-type="estimatedDeliveryMinutes">编辑</text>
        </view>
      </view>
      
      <view class="config-item">
        <view class="config-label">
          <text class="label-text">订单超时时间</text>
          <text class="label-desc">订单创建后未支付自动取消的时间</text>
        </view>
        <view class="config-value">
          <text class="value-text">{{platformConfig.orderTimeoutMinutes}}分钟</text>
          <text class="edit-btn" bindtap="onEditConfig" data-type="orderTimeoutMinutes">编辑</text>
        </view>
      </view>
    </view>

    <!-- 轮播图管理 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">首页轮播图</text>
        <text class="add-btn" bindtap="onAddBanner">+ 添加</text>
      </view>
      
      <view wx:if="{{banners.length > 0}}" class="banner-list">
        <view class="banner-item" wx:for="{{banners}}" wx:key="_id">
          <view class="banner-preview">
            <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill" />
          </view>
          <view class="banner-info">
            <text class="banner-index">第 {{index + 1}} 张</text>
          </view>
          <view class="banner-actions">
            <text class="edit-btn" bindtap="onEditBanner" data-id="{{item._id}}">编辑</text>
            <text class="delete-btn" bindtap="onDeleteBanner" data-id="{{item._id}}">删除</text>
          </view>
        </view>
      </view>
      
      <view wx:else class="empty-state">
        <text class="empty-text">暂无轮播图</text>
      </view>
    </view>

    <!-- 邀请码管理 -->
    <view class="section">
      <text class="section-title">邀请码管理</text>
      
      <view wx:if="{{inviteCodes.length > 0}}" class="invite-code-list">
        <view class="invite-code-item" wx:for="{{inviteCodes}}" wx:key="_id">
          <view class="code-info">
            <text class="code-text">{{item.code}}</text>
            <text class="code-desc">{{item.description}}</text>
            <text class="code-status">已使用: {{item.usedCount}}/{{item.maxUses}}</text>
          </view>
          <view class="code-actions">
            <text class="copy-btn" bindtap="onCopyCode" data-code="{{item.code}}">复制</text>
            <text class="delete-btn" bindtap="onDeleteCode" data-id="{{item._id}}">删除</text>
          </view>
        </view>
      </view>
      
      <view wx:else class="empty-state">
        <text class="empty-text">暂无邀请码</text>
      </view>
    </view>

    <!-- 功能开关 -->
    <view class="section">
      <text class="section-title">功能开关</text>
      
      <view class="switch-item">
        <view class="switch-label">
          <text class="switch-title">允许游客下单</text>
          <text class="switch-desc">允许未登录用户下单</text>
        </view>
        <switch checked="{{switches.allowGuestOrder}}" bindchange="onToggleSwitch" data-key="allowGuestOrder" />
      </view>
      
      <view class="switch-item">
        <view class="switch-label">
          <text class="switch-title">自动接单</text>
          <text class="switch-desc">新订单自动接单</text>
        </view>
        <switch checked="{{switches.autoAcceptOrder}}" bindchange="onToggleSwitch" data-key="autoAcceptOrder" />
      </view>
      
      <view class="switch-item">
        <view class="switch-label">
          <text class="switch-title">启用分账</text>
          <text class="switch-desc">启用微信支付分账功能</text>
        </view>
        <switch checked="{{switches.enableProfitSharing}}" bindchange="onToggleSwitch" data-key="enableProfitSharing" />
      </view>
      
      <view class="switch-item">
        <view class="switch-label">
          <text class="switch-title">启用通知</text>
          <text class="switch-desc">启用消息推送通知</text>
        </view>
        <switch checked="{{switches.enableNotification}}" bindchange="onToggleSwitch" data-key="enableNotification" />
      </view>
    </view>

    <!-- 公告管理 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">系统公告</text>
        <text class="add-btn" bindtap="onPublishAnnouncement">+ 发布</text>
      </view>
      
      <view wx:if="{{announcements.length > 0}}" class="announcement-list">
        <view class="announcement-item" wx:for="{{announcements}}" wx:key="_id">
          <view class="announcement-header">
            <view class="announcement-title-wrapper">
              <text class="announcement-title">{{item.title}}</text>
              <text class="announcement-type">{{item.targetType === 'client' ? '👤客户端' : item.targetType === 'merchant' ? '🏪商家端' : '🌐全部'}}</text>
            </view>
            <view class="announcement-actions">
              <text class="announcement-status" wx:if="{{item.status === 'active'}}">启用</text>
              <text class="announcement-status inactive" wx:else>禁用</text>
              <text class="announcement-delete" bindtap="onDeleteAnnouncement" data-id="{{item._id}}">删除</text>
            </view>
          </view>
          <text class="announcement-text">{{item.content}}</text>
          <text class="announcement-time">{{item.createdAt}}</text>
        </view>
      </view>
      
      <view wx:else class="empty-state">
        <text class="empty-text">暂无公告</text>
      </view>
    </view>

    <!-- 系统维护 -->
    <view class="section">
      <text class="section-title">系统维护</text>
      
      <view class="action-item" bindtap="onBackupData">
        <view class="action-icon">💾</view>
        <text class="action-text">数据备份</text>
        <text class="action-arrow">></text>
      </view>
      
      <view class="action-item" bindtap="onClearCache">
        <view class="action-icon">🗑️</view>
        <text class="action-text">清理缓存</text>
        <text class="action-arrow">></text>
      </view>
    </view>
  </scroll-view>

  <!-- 发布公告弹窗 -->
  <view wx:if="{{showAnnouncementModal}}" class="modal-overlay" bindtap="onCloseAnnouncementModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">发布公告</text>
        <text class="modal-close" bindtap="onCloseAnnouncementModal">✕</text>
      </view>
      
      <view class="modal-body">
        <!-- 输入公告内容 -->
        <view class="form-item">
          <text class="form-label">公告内容</text>
          <textarea 
            class="form-textarea" 
            placeholder="请输入公告内容" 
            value="{{announcementForm.content}}"
            bindinput="onAnnouncementContentInput"
            maxlength="500"
            auto-height
          ></textarea>
        </view>
        
        <!-- 选择发布范围 -->
        <view class="form-item">
          <text class="form-label">发布范围</text>
          <view class="target-type-selector">
            <view 
              class="target-type-item {{announcementForm.targetType === 'client' ? 'active' : ''}}"
              bindtap="onSelectTargetType"
              data-type="client"
            >
              <text class="target-type-icon">👤</text>
              <text class="target-type-text">客户端</text>
            </view>
            
            <view 
              class="target-type-item {{announcementForm.targetType === 'merchant' ? 'active' : ''}}"
              bindtap="onSelectTargetType"
              data-type="merchant"
            >
              <text class="target-type-icon">🏪</text>
              <text class="target-type-text">商家端</text>
            </view>
            
            <view 
              class="target-type-item {{announcementForm.targetType === 'all' ? 'active' : ''}}"
              bindtap="onSelectTargetType"
              data-type="all"
            >
              <text class="target-type-icon">🌐</text>
              <text class="target-type-text">全部</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="onCloseAnnouncementModal">取消</view>
        <view class="modal-btn confirm" bindtap="onConfirmPublishAnnouncement">发布</view>
      </view>
    </view>
  </view>
</view>

