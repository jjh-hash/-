<!--pages/admin-order-list/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBack">◀</view>
    <text class="title">管理系统</text>
    <view class="nav-actions">
      <text class="refresh-btn" bindtap="onRefresh">🔄</text>
    </view>
  </view>

  <!-- 分类筛选区域 -->
  <view class="category-section">
    <!-- 第一行：订单类型分类（大圆形图标） -->
    <view class="category-row">
      <view 
        class="category-item {{currentCategory === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="onCategoryChange"
        data-category="{{item.id}}"
      >
        <view class="category-icon">{{item.icon}}</view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
    
    <!-- 第二行：状态筛选（小药丸按钮） -->
    <view class="filter-row">
      <view 
        class="filter-pill {{currentFilter === item.id ? 'active' : ''}}"
        wx:for="{{filters}}"
        wx:key="id"
        bindtap="onFilterChange"
        data-filter="{{item.id}}"
      >
        <text class="filter-icon" wx:if="{{currentFilter === item.id}}">✓</text>
        <text class="filter-text">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-item" wx:for="{{orderList}}" wx:key="id" bindtap="onOrderDetail" data-order="{{item}}">
      <view class="order-header">
        <view class="order-info">
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-time">{{item.createdAt}}</text>
        </view>
        <view class="order-status {{item.payStatus}}">
          {{item.statusText}}
        </view>
      </view>
      
      <view class="order-content">
        <view class="store-info">
          <!-- 无店铺订单显示用户信息 -->
          <image class="store-logo" wx:if="{{item.isNonStoreOrder && item.userAvatar && item.userAvatar !== ''}}" src="{{item.userAvatar}}" mode="aspectFill"></image>
          <image class="store-logo" wx:elif="{{item.isNonStoreOrder}}" src="/pages/小标/wode.png" mode="aspectFill"></image>
          <image class="store-logo" wx:else src="{{item.storeLogo}}" mode="aspectFill"></image>
          <view class="store-details">
            <text class="store-name" wx:if="{{item.isNonStoreOrder}}">{{item.userNickname || '用户'}}</text>
            <text class="store-name" wx:else>{{item.storeName}}</text>
            <text class="store-address" wx:if="{{item.isNonStoreOrder}}">{{item.orderType === 'gaming' ? '游戏陪玩' : (item.orderType === 'reward' ? '悬赏' : '代拿快递')}}</text>
            <text class="store-address" wx:else>{{item.storeAddress}}</text>
          </view>
        </view>
        
        <view class="order-items">
          <view class="order-item-info" wx:for="{{item.items}}" wx:key="id" wx:for-item="orderItem">
            <text class="item-name">{{orderItem.name}}</text>
            <text class="item-spec" wx:if="{{orderItem.spec}}">{{orderItem.spec}}</text>
            <text class="item-price">¥{{orderItem.price}}</text>
            <text class="item-quantity">x{{orderItem.quantity}}</text>
          </view>
        </view>
        
        <view class="order-summary">
          <view class="summary-row">
            <text class="summary-label">商品金额</text>
            <text class="summary-value">¥{{item.amountGoods}}</text>
          </view>
          <view class="summary-row">
            <text class="summary-label">配送费</text>
            <text class="summary-value">¥{{item.amountDelivery}}</text>
          </view>
          <view class="summary-row">
            <text class="summary-label">平台服务费</text>
            <text class="summary-value">¥{{item.platformFee || '0.00'}}</text>
          </view>
          <view class="summary-row">
            <text class="summary-label">商家收入</text>
            <text class="summary-value">¥{{item.merchantIncome || '0.00'}}</text>
          </view>
          <view class="summary-row total">
            <text class="summary-label">实付金额</text>
            <text class="summary-value">¥{{item.amountPayable}}</text>
          </view>
        </view>
        
        <!-- 退款信息 -->
        <view class="refund-info" wx:if="{{item.refundInfo}}">
          <view class="refund-badge {{item.refundInfo.status}}">
            <text class="refund-label">退款状态：</text>
            <text class="refund-status">{{item.refundInfo.refundStatusText}}</text>
            <text class="refund-amount">¥{{item.refundInfo.refundAmount}}</text>
          </view>
        </view>
      </view>
      
      <view class="order-actions" wx:if="{{item.payStatus === 'paid'}}">
        <button class="action-btn secondary" bindtap="onOrderAction" data-action="cancel" data-order="{{item}}">
          取消订单
        </button>
        <button class="action-btn primary" bindtap="onOrderAction" data-action="complete" data-order="{{item}}">
          完成订单
        </button>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{orderList.length === 0}}">
      <image class="empty-icon" src="/pages/小标/dingdan.png" mode="aspectFit"></image>
      <text class="empty-text">暂无订单数据</text>
    </view>
  </view>

</view>
