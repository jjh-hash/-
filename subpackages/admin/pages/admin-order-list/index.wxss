/* 管理端订单列表 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 120rpx;
}

.status-bar {
  background: var(--color-primary);
}

.nav-bar {
  height: 88rpx;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  color: #fff;
}

.back-btn {
  font-size: 36rpx;
  padding: 10rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 500;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.refresh-btn {
  font-size: 32rpx;
  padding: 10rpx;
}

.category-section {
  background: var(--color-bg-card);
  padding: 24rpx 0;
  margin-bottom: 20rpx;
}

.category-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.category-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  transition: all 0.3s ease;
}

.category-item.active .category-icon {
  background: var(--color-primary);
  transform: scale(1.1);
}

.category-name {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  transition: color 0.3s ease;
}

.category-item.active .category-name {
  color: var(--color-primary);
  font-weight: 600;
}

/* 第二行：状态筛选（小药丸按钮） */
.filter-row {
  display: flex;
  padding: 0 20rpx;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  background: var(--color-bg-page);
  font-size: 24rpx;
  color: var(--color-text-secondary);
  white-space: nowrap;
  transition: all 0.3s ease;
}

.filter-pill.active {
  background: var(--color-primary);
  color: #fff;
}

.filter-icon {
  font-size: 20rpx;
  font-weight: 600;
}

.filter-text {
  font-size: 24rpx;
}

/* 订单列表 */
.order-list {
  padding: 0 20rpx;
}

.order-item {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: var(--shadow-card);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-no {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.order-time {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}

.order-status {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.order-status.unpaid {
  background: rgba(255, 152, 0, 0.15);
  color: var(--color-warning);
}

.order-status.paid {
  background: var(--color-primary-light);
  color: var(--color-success);
}

.order-status.completed {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.order-status.cancelled {
  background: rgba(244, 67, 54, 0.15);
  color: var(--color-danger);
}

.order-content {
  margin-bottom: 20rpx;
}

.store-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.store-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
}

.store-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.store-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.store-address {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.order-items {
  margin-bottom: 20rpx;
}

.order-item-info {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.order-item-info:last-child {
  border-bottom: none;
}

.item-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text);
}

.item-spec {
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  margin-left: 10rpx;
}

.item-price {
  font-size: 26rpx;
  color: var(--color-text);
  margin-left: 20rpx;
  min-width: 80rpx;
  text-align: right;
}

.item-quantity {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-left: 20rpx;
  min-width: 60rpx;
  text-align: right;
}

.order-summary {
  background: var(--color-bg-page);
  border-radius: 8rpx;
  padding: 20rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.summary-row.total {
  border-top: 1rpx solid var(--color-border);
  padding-top: 12rpx;
  margin-top: 12rpx;
}

.summary-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.summary-value {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 500;
}

.summary-row.total .summary-value {
  color: var(--color-danger);
  font-size: 28rpx;
  font-weight: 600;
}

/* 退款信息 */
.refund-info {
  background: var(--color-primary-light);
  border-radius: 8rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.refund-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.refund-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.refund-status {
  font-size: 24rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.refund-badge.pending .refund-status,
.refund-badge.processing .refund-status {
  color: var(--color-warning);
  background: var(--color-primary-light);
}

.refund-badge.approved .refund-status,
.refund-badge.completed .refund-status {
  color: var(--color-success);
  background: var(--color-primary-light);
}

.refund-badge.rejected .refund-status {
  color: var(--color-danger);
  background: rgba(239, 68, 68, 0.1);
}

.refund-amount {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
  margin-left: auto;
}

.order-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.action-btn {
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  border: none;
  min-width: 120rpx;
}

.action-btn.primary {
  background: var(--color-primary);
  color: white;
}

.action-btn.secondary {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-placeholder);
}
