/* pages/admin-order-list/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx; /* 为底部导航栏预留空间 */
}

/* 状态栏 */
.status-bar {
  background: #667eea;
}

/* 导航栏 */
.nav-bar {
  height: 88rpx;
  background: #667eea;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  color: white;
}

.back-btn {
  font-size: 36rpx;
  padding: 10rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 500;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.refresh-btn {
  font-size: 32rpx;
  padding: 10rpx;
}

/* 分类筛选区域 */
.category-section {
  background: white;
  padding: 24rpx 0;
  margin-bottom: 20rpx;
}

/* 第一行：订单类型分类（大圆形图标） */
.category-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.category-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  transition: all 0.3s ease;
}

.category-item.active .category-icon {
  background: #3cc51f;
  transform: scale(1.1);
}

.category-name {
  font-size: 24rpx;
  color: #666;
  transition: color 0.3s ease;
}

.category-item.active .category-name {
  color: #3cc51f;
  font-weight: 600;
}

/* 第二行：状态筛选（小药丸按钮） */
.filter-row {
  display: flex;
  padding: 0 20rpx;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  background: #f5f5f5;
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.filter-pill.active {
  background: #3cc51f;
  color: white;
}

.filter-icon {
  font-size: 20rpx;
  font-weight: 600;
}

.filter-text {
  font-size: 24rpx;
}

/* 订单列表 */
.order-list {
  padding: 0 20rpx;
}

.order-item {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-no {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.order-status.unpaid {
  background: #fff3cd;
  color: #856404;
}

.order-status.paid {
  background: #d4edda;
  color: #155724;
}

.order-status.completed {
  background: #d1ecf1;
  color: #0c5460;
}

.order-status.cancelled {
  background: #f8d7da;
  color: #721c24;
}

.order-content {
  margin-bottom: 20rpx;
}

.store-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.store-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
}

.store-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.store-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.store-address {
  font-size: 24rpx;
  color: #666;
}

.order-items {
  margin-bottom: 20rpx;
}

.order-item-info {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-item-info:last-child {
  border-bottom: none;
}

.item-name {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.item-spec {
  font-size: 22rpx;
  color: #999;
  margin-left: 10rpx;
}

.item-price {
  font-size: 26rpx;
  color: #333;
  margin-left: 20rpx;
  min-width: 80rpx;
  text-align: right;
}

.item-quantity {
  font-size: 24rpx;
  color: #666;
  margin-left: 20rpx;
  min-width: 60rpx;
  text-align: right;
}

.order-summary {
  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 20rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.summary-row.total {
  border-top: 1rpx solid #e9ecef;
  padding-top: 12rpx;
  margin-top: 12rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #666;
}

.summary-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.summary-row.total .summary-value {
  color: #e74c3c;
  font-size: 28rpx;
  font-weight: 600;
}

/* 退款信息 */
.refund-info {
  background: #fff3e0;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.refund-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.refund-label {
  font-size: 24rpx;
  color: #666;
}

.refund-status {
  font-size: 24rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.refund-badge.pending .refund-status,
.refund-badge.processing .refund-status {
  color: #ff9800;
  background: #fff3e0;
}

.refund-badge.approved .refund-status,
.refund-badge.completed .refund-status {
  color: #4caf50;
  background: #e8f5e9;
}

.refund-badge.rejected .refund-status {
  color: #f44336;
  background: #ffebee;
}

.refund-amount {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 600;
  margin-left: auto;
}

.order-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  border: none;
  min-width: 120rpx;
}

.action-btn.primary {
  background: #667eea;
  color: white;
}

.action-btn.secondary {
  background: #f8f9fa;
  color: #666;
  border: 1rpx solid #dee2e6;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
