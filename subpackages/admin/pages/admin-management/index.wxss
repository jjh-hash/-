/* pages/admin-management/index.wxss */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 100rpx;
}

.status-bar {
  background: var(--color-primary);
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--color-primary);
  color: #fff;
}

.back-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 10rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.nav-actions {
  display: flex;
  align-items: center;
}

.refresh-btn {
  font-size: 32rpx;
  color: #fff;
  padding: 10rpx;
}

.page-content {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 30rpx;
  display: block;
  padding-left: 10rpx;
}

/* 管理功能菜单 */
.management-section {
  margin-bottom: 40rpx;
}

.menu-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  box-shadow: var(--shadow-card);
  border-left: 6rpx solid var(--color-primary);
  transition: all 0.3s ease;
}

.menu-item:active {
  transform: scale(0.98);
  background: var(--color-bg-page);
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 24rpx;
}

.menu-icon image {
  width: 100%;
  height: 100%;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.menu-description { font-size: 24rpx; color: var(--color-text-secondary); }

.menu-arrow { font-size: 32rpx; color: var(--color-text-placeholder); }

/* 快捷操作 */
.quick-actions-section {
  margin-bottom: 40rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.quick-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx 20rpx;
  box-shadow: var(--shadow-card);
  transition: all 0.3s ease;
}

.quick-action-item:active {
  transform: scale(0.95);
  background: var(--color-bg-page);
}

.action-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.action-icon.approve { background: var(--color-success); color: #fff; }

.action-icon.export { background: var(--color-warning); color: #fff; }

.action-icon.notice { background: var(--color-primary); color: #fff; }

.action-icon.backup { background: var(--color-primary); color: #fff; }

.action-text { font-size: 24rpx; color: var(--color-text); text-align: center; }

/* 系统状态 */
.system-status-section {
  margin-bottom: 40rpx;
}

.status-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.status-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  box-shadow: var(--shadow-card);
}

.status-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.status-title { font-size: 28rpx; font-weight: bold; color: var(--color-text); }

.status-indicator { width: 16rpx; height: 16rpx; border-radius: 50%; }

.status-indicator.online { background: var(--color-success); }

.status-indicator.warning { background: var(--color-warning); }

.status-indicator.offline { background: var(--color-danger); }

.status-text { font-size: 24rpx; color: var(--color-text-secondary); }