/* pages/admin-management/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 100rpx; /* 为tabBar留出空间 */
}

.status-bar {
  background: transparent;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.back-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 10rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.nav-actions {
  display: flex;
  align-items: center;
}

.refresh-btn {
  font-size: 32rpx;
  color: #fff;
  padding: 10rpx;
}

.page-content {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
  display: block;
}

/* 管理功能菜单 */
.management-section {
  margin-bottom: 40rpx;
}

.menu-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.menu-item:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.8);
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 24rpx;
}

.menu-icon image {
  width: 100%;
  height: 100%;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.menu-description {
  font-size: 24rpx;
  color: #666;
}

.menu-arrow {
  font-size: 32rpx;
  color: #999;
}

/* 快捷操作 */
.quick-actions-section {
  margin-bottom: 40rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.quick-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.quick-action-item:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.8);
}

.action-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.action-icon.approve {
  background: #4CAF50;
  color: #fff;
}

.action-icon.export {
  background: #FF9800;
  color: #fff;
}

.action-icon.notice {
  background: #2196F3;
  color: #fff;
}

.action-icon.backup {
  background: #9C27B0;
  color: #fff;
}

.action-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 系统状态 */
.system-status-section {
  margin-bottom: 40rpx;
}

.status-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.status-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.status-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.status-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.status-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.status-indicator.online {
  background: #4CAF50;
}

.status-indicator.warning {
  background: #FF9800;
}

.status-indicator.offline {
  background: #F44336;
}

.status-text {
  font-size: 24rpx;
  color: #666;
}