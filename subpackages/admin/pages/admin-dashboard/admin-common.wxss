/* 管理后台全局样式 - 与 app.wxss 设计系统一致 */
/* 使用 page 上的变量：--color-primary, --color-bg-page, --color-bg-card, --color-text, --color-border 等 */

/* 通用布局类 */
.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-around {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.flex-1 {
  flex: 1;
}

/* 通用间距类 */
.m-0 { margin: 0; }
.m-1 { margin: 10rpx; }
.m-2 { margin: 20rpx; }
.m-3 { margin: 30rpx; }
.m-4 { margin: 40rpx; }

.mt-0 { margin-top: 0; }
.mt-1 { margin-top: 10rpx; }
.mt-2 { margin-top: 20rpx; }
.mt-3 { margin-top: 30rpx; }
.mt-4 { margin-top: 40rpx; }

.mb-0 { margin-bottom: 0; }
.mb-1 { margin-bottom: 10rpx; }
.mb-2 { margin-bottom: 20rpx; }
.mb-3 { margin-bottom: 30rpx; }
.mb-4 { margin-bottom: 40rpx; }

.p-0 { padding: 0; }
.p-1 { padding: 10rpx; }
.p-2 { padding: 20rpx; }
.p-3 { padding: 30rpx; }
.p-4 { padding: 40rpx; }

.pt-0 { padding-top: 0; }
.pt-1 { padding-top: 10rpx; }
.pt-2 { padding-top: 20rpx; }
.pt-3 { padding-top: 30rpx; }
.pt-4 { padding-top: 40rpx; }

.pb-0 { padding-bottom: 0; }
.pb-1 { padding-bottom: 10rpx; }
.pb-2 { padding-bottom: 20rpx; }
.pb-3 { padding-bottom: 30rpx; }
.pb-4 { padding-bottom: 40rpx; }

/* 通用文字类 */
.text-left { text-align: left; }
.text-center { text-align: center; }
.text-right { text-align: right; }

.text-primary { color: var(--color-text); }
.text-secondary { color: var(--color-text-secondary); }
.text-disabled { color: var(--color-text-placeholder); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-error { color: var(--color-danger); }

.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 40rpx; }

.font-normal { font-weight: 400; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

/* 通用背景类 */
.bg-white { background-color: var(--color-bg-card); }
.bg-gray { background-color: var(--color-bg-page); }
.bg-primary { background-color: var(--color-primary); }
.bg-success { background-color: var(--color-success); }
.bg-warning { background-color: var(--color-warning); }
.bg-error { background-color: var(--color-danger); }

/* 通用边框类 */
.border { border: 1rpx solid var(--color-border); }
.border-t { border-top: 1rpx solid var(--color-border); }
.border-b { border-bottom: 1rpx solid var(--color-border); }
.border-l { border-left: 1rpx solid var(--color-border); }
.border-r { border-right: 1rpx solid var(--color-border); }

.border-none { border: none; }

/* 通用圆角类 */
.rounded-none { border-radius: 0; }
.rounded-sm { border-radius: 4rpx; }
.rounded { border-radius: 8rpx; }
.rounded-md { border-radius: 12rpx; }
.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 20rpx; }
.rounded-full { border-radius: 50%; }

/* 通用阴影类 */
.shadow-none { box-shadow: none; }
.shadow-sm { box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1); }
.shadow { box-shadow: var(--shadow-card); }
.shadow-md { box-shadow: var(--shadow-card-hover); }
.shadow-lg { box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2); }

/* 通用按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
  min-width: 120rpx;
}

.btn:active {
  transform: scale(0.98);
}

.btn-primary {
  background-color: var(--color-primary);
  color: white;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-secondary {
  background-color: var(--color-bg-page);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
}

.btn-secondary:active {
  background-color: var(--color-border);
}

.btn-success {
  background-color: var(--color-success);
  color: white;
}

.btn-success:active {
  opacity: 0.9;
}

.btn-warning {
  background-color: var(--color-warning);
  color: white;
}

.btn-warning:active {
  opacity: 0.9;
}

.btn-error {
  background-color: var(--color-danger);
  color: white;
}

.btn-error:active {
  opacity: 0.9;
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  min-width: 80rpx;
}

.btn-lg {
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  min-width: 160rpx;
}

/* 通用卡片样式 */
.card {
  background-color: var(--color-bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.card-header {
  padding: 30rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.card-body {
  padding: 30rpx;
}

.card-footer {
  padding: 30rpx;
  border-top: 1rpx solid var(--color-border);
  background-color: var(--color-bg-page);
}

/* 通用列表样式 */
.list {
  background-color: var(--color-bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--color-border);
  transition: background-color 0.3s ease;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background-color: var(--color-bg-page);
}

.list-item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.list-item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.list-item-title {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.list-item-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.list-item-arrow {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}

/* 通用状态样式 */
.status {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-success {
  background-color: #d4edda;
  color: #155724;
}

.status-warning {
  background-color: #fff3cd;
  color: #856404;
}

.status-error {
  background-color: #f8d7da;
  color: #721c24;
}

.status-info {
  background-color: #d1ecf1;
  color: #0c5460;
}

.status-default {
  background-color: #e2e3e5;
  color: #383d41;
}

/* 通用加载样式 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: var(--color-text-placeholder);
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--color-border);
  border-top: 4rpx solid var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 通用空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: var(--color-text-placeholder);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-placeholder);
}

/* 通用分割线样式 */
.divider {
  height: 1rpx;
  background-color: var(--color-border);
  margin: 20rpx 0;
}

.divider-vertical {
  width: 1rpx;
  background-color: var(--color-border);
  margin: 0 20rpx;
}

/* 通用响应式类 */
.hidden { display: none; }
.visible { display: block; }

/* 通用动画类 */
.fade-in {
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.slide-up {
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* 通用安全区域适配 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

/* 通用滚动条样式 */
.scroll-view {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.scroll-view::-webkit-scrollbar {
  display: none;
}
