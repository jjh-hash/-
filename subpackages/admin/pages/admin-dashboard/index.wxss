/* pages/admin-dashboard/index.wxss */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 100rpx;
}

.status-bar { background: var(--color-primary); }

.nav-bar {
  height: 88rpx;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  color: #fff;
}

.back-btn {
  font-size: 36rpx;
  padding: 10rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 500;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.refresh-btn {
  font-size: 32rpx;
  padding: 10rpx;
}

/* 页面内容 */
.page-content {
  padding: 20rpx;
}

/* 核心数据概览 */
.stats-section {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-card);
  border-left: 6rpx solid var(--color-primary);
}

.stat-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.stat-icon image {
  width: 100%;
  height: 100%;
}

.stat-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-number {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.2;
}

.stat-label { font-size: 24rpx; color: var(--color-text-secondary); }

.stat-trend { font-size: 22rpx; font-weight: 500; }

.stat-trend.positive { color: var(--color-success); }

.stat-trend.negative { color: var(--color-danger); }

/* 用户活跃度分析 */
.analytics-section {
  margin-bottom: 30rpx;
}

.analytics-cards {
  display: flex;
  gap: 20rpx;
}

.analytics-card {
  flex: 1;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  box-shadow: var(--shadow-card);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title { font-size: 26rpx; color: var(--color-text-secondary); }

.card-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text);
}

.card-chart {
  background: var(--color-bg-page);
  border-radius: var(--radius-card);
  padding: 20rpx;
  text-align: center;
}

.chart-text { font-size: 24rpx; font-weight: 500; }

.chart-text.positive { color: var(--color-success); }

.chart-text.negative { color: var(--color-danger); }

/* 订单概况 */
.order-overview-section {
  margin-bottom: 30rpx;
}

.order-stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.order-stat-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  box-shadow: var(--shadow-card);
}

.order-stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.order-stat-title { font-size: 26rpx; color: var(--color-text-secondary); }

.order-stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.order-stat-trend {
  text-align: right;
}

.trend-text {
  font-size: 22rpx;
  font-weight: 500;
}

.trend-text.positive { color: var(--color-success); }

.trend-text.warning { color: var(--color-warning); }

.trend-text.success { color: var(--color-success); }

.trend-text.info { color: var(--color-primary); }

.trend-text.negative { color: var(--color-danger); }

.chart-text.negative { color: var(--color-danger); }

/* 收入趋势 */
.revenue-trend-section {
  margin-bottom: 30rpx;
}

.revenue-chart {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 40rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  position: relative;
}

.chart-title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 0;
  width: 60rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

.chart-legend { display: flex; gap: 20rpx; }

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--color-primary-light);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-tag);
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 0, 0.3);
}

.legend-color.primary { background: var(--color-primary); }

.legend-text { font-size: 24rpx; color: var(--color-primary); font-weight: 600; }

.chart-content {
  height: 200rpx;
  position: relative;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 150rpx;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.chart-bar {
  flex: 1;
  background: linear-gradient(to top, var(--color-primary), rgba(255, 184, 0, 0.85));
  border-radius: 8rpx 8rpx 0 0;
  margin: 0 6rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  min-height: 20rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 0, 0.25);
}

.chart-bar:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 0, 0.35);
}

.bar-value {
  position: absolute;
  top: -40rpx;
  font-size: 20rpx;
  color: var(--color-text);
  font-weight: 600;
  white-space: nowrap;
  background: rgba(255, 255, 255, 0.9);
  padding: 4rpx 8rpx;
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}

.chart-labels {
  display: flex;
  justify-content: space-between;
  padding: 0 10rpx;
}

.chart-label {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  margin: 0 6rpx;
  padding: 8rpx 4rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  transition: all 0.3s ease;
}

.chart-label:hover {
  background: var(--color-primary-light);
  color: var(--color-primary);
}
