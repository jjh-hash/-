/* pages/admin-dashboard/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 100rpx; /* 为原生tabBar留出空间 */
}

/* 状态栏 */
.status-bar {
  background: #667eea;
}

/* 导航栏 */
.nav-bar {
  height: 88rpx;
  background: #667eea;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  color: white;
}

.back-btn {
  font-size: 36rpx;
  padding: 10rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 500;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.refresh-btn {
  font-size: 32rpx;
  padding: 10rpx;
}

/* 页面内容 */
.page-content {
  padding: 20rpx;
}

/* 核心数据概览 */
.stats-section {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border-left: 6rpx solid #667eea;
}

.stat-card.success {
  border-left-color: #4CAF50;
}

.stat-card.warning {
  border-left-color: #FF9800;
}

.stat-card.info {
  border-left-color: #2196F3;
}

.stat-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.stat-icon image {
  width: 100%;
  height: 100%;
}

.stat-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.stat-trend {
  font-size: 22rpx;
  font-weight: 500;
}

.stat-trend.positive {
  color: #4CAF50;
}

.stat-trend.negative {
  color: #f44336;
}

/* 用户活跃度分析 */
.analytics-section {
  margin-bottom: 30rpx;
}

.analytics-cards {
  display: flex;
  gap: 20rpx;
}

.analytics-card {
  flex: 1;
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 26rpx;
  color: #666;
}

.card-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.card-chart {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.chart-text {
  font-size: 24rpx;
  font-weight: 500;
}

.chart-text.positive {
  color: #4CAF50;
}

.chart-text.negative {
  color: #f44336;
}

/* 订单概况 */
.order-overview-section {
  margin-bottom: 30rpx;
}

.order-stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.order-stat-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.order-stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.order-stat-title {
  font-size: 26rpx;
  color: #666;
}

.order-stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.order-stat-trend {
  text-align: right;
}

.trend-text {
  font-size: 22rpx;
  font-weight: 500;
}

.trend-text.positive {
  color: #4CAF50;
}

.trend-text.warning {
  color: #FF9800;
}

.trend-text.success {
  color: #4CAF50;
}

.trend-text.info {
  color: #2196F3;
}

.trend-text.negative {
  color: #f44336;
}

.chart-text.negative {
  color: #f44336;
}

/* 收入趋势 */
.revenue-trend-section {
  margin-bottom: 30rpx;
}

.revenue-chart {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  position: relative;
}

.chart-title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 0;
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 2rpx;
}

.chart-legend {
  display: flex;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(102, 126, 234, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.legend-color.primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.legend-text {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
}

.chart-content {
  height: 200rpx;
  position: relative;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 150rpx;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.chart-bar {
  flex: 1;
  background: linear-gradient(to top, #667eea, #764ba2);
  border-radius: 8rpx 8rpx 0 0;
  margin: 0 6rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  min-height: 20rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.chart-bar:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.4);
}

.bar-value {
  position: absolute;
  top: -40rpx;
  font-size: 20rpx;
  color: #333;
  font-weight: 600;
  white-space: nowrap;
  background: rgba(255, 255, 255, 0.9);
  padding: 4rpx 8rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.chart-labels {
  display: flex;
  justify-content: space-between;
  padding: 0 10rpx;
}

.chart-label {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  margin: 0 6rpx;
  padding: 8rpx 4rpx;
  background: rgba(102, 102, 102, 0.05);
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.chart-label:hover {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}
