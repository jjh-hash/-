/* pages/admin-batch-audit/index.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-page);
  overflow: hidden;
}

.status-bar {
  background-color: var(--color-bg-card);
  flex-shrink: 0;
}

.nav-bar {
  display: flex;
  align-items: center;
  height: 44px;
  background-color: var(--color-bg-card);
  padding: 0 15px;
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0;
}

.back-btn { font-size: 20px; color: var(--color-text); margin-right: 10px; }

.title { font-size: 18px; font-weight: 600; color: var(--color-text); }

.tabs {
  display: flex;
  background-color: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 15px 0;
  font-size: 16px;
  color: var(--color-text-secondary);
  position: relative;
}

.tab.active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30px;
  height: 3px;
  background-color: var(--color-primary);
  border-radius: 2px;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 0;
}

.filter-bar {
  padding: 10px 15px;
  background-color: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0;
}

.filter-picker {
  display: flex;
  align-items: center;
  padding: 8px 12px;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-btn);
}

.filter-label {
  font-size: 14px;
  color: var(--color-text-secondary);
  margin-right: 8px;
}

.filter-value {
  flex: 1;
  font-size: 14px;
  color: var(--color-text);
  font-weight: 500;
}

.filter-arrow { font-size: 12px; color: var(--color-text-placeholder); }

.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 15px;
  background-color: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0;
}

.checkbox-item {
  display: flex;
  align-items: center;
  font-size: 14px;
  color: var(--color-text);
}

.checkbox-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  border: 2px solid var(--color-border);
  border-radius: 4px;
  margin-right: 8px;
  font-size: 12px;
  color: transparent;
}

.checkbox-icon.checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  color: #fff;
}

.action-buttons { display: flex; gap: 10px; }

.btn-approve,
.btn-reject {
  padding: 6px 16px;
  font-size: 14px;
  border-radius: var(--radius-btn);
  border: none;
}

.btn-approve {
  background-color: var(--color-success);
  color: #fff;
}

.btn-reject {
  background-color: var(--color-danger);
  color: #fff;
}

.list-content {
  flex: 1;
  padding: 10px 15px;
  overflow-y: auto;
  min-height: 0;
}

.item {
  display: flex;
  align-items: center;
  padding: 12px;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-card);
  margin-bottom: 10px;
  box-shadow: var(--shadow-card);
}

.checkbox { margin-right: 12px; flex-shrink: 0; }

.item-image {
  width: 60px;
  height: 60px;
  border-radius: var(--radius-btn);
  margin-right: 12px;
  background-color: var(--color-border);
  flex-shrink: 0;
}

.item-info,
.item-info-full {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 0;
}

.item-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 16px;
  color: var(--color-danger);
  font-weight: 600;
}

.item-phone {
  font-size: 14px;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time { font-size: 12px; color: var(--color-text-placeholder); }

.item-status {
  padding: 4px 12px;
  border-radius: var(--radius-tag);
  font-size: 12px;
  flex-shrink: 0;
  white-space: nowrap;
}

.status-pending {
  background-color: rgba(250, 140, 22, 0.12);
  color: var(--color-warning);
}

.status-approved,
.status-active {
  background-color: var(--color-primary-light);
  color: var(--color-success);
}

.status-rejected {
  background-color: rgba(255, 77, 79, 0.12);
  color: var(--color-danger);
}

.status-suspended {
  background-color: var(--color-border);
  color: var(--color-text-placeholder);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon { font-size: 48px; margin-bottom: 12px; }

.empty-text { font-size: 14px; color: var(--color-text-placeholder); }
