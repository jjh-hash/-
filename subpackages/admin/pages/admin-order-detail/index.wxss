/* pages/admin-order-detail/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.status-bar {
  background: #667eea;
}

.nav-bar {
  height: 88rpx;
  background: #667eea;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  color: white;
}

.back-btn {
  font-size: 36rpx;
  padding: 10rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 500;
}

.nav-actions {
  width: 60rpx;
}

.content {
  padding: 20rpx;
}

/* 订单状态 */
.status-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.status-badge {
  display: inline-block;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.status-badge.paid {
  background: #e8f5e9;
  color: #4caf50;
}

.status-badge.unpaid {
  background: #fff3e0;
  color: #ff9800;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
}

.order-no {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 20rpx;
}

.order-time {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 店铺信息 */
.store-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.store-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.store-info {
  flex: 1;
}

.store-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.store-address {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 商品列表 */
.items-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.items-list {
  margin-top: 20rpx;
}

.item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-row:last-child {
  border-bottom: none;
}

.item-info {
  flex: 1;
}

.item-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.item-spec {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.item-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-quantity {
  font-size: 26rpx;
  color: #666;
}

.item-price {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 金额明细 */
.amount-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.amount-list {
  margin-top: 20rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.amount-row:last-child {
  border-bottom: none;
}

.amount-row.highlight {
  background: #f8f9fa;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
  margin: 10rpx 0;
}

.amount-row.total {
  border-top: 2rpx solid #f0f0f0;
  margin-top: 10rpx;
  padding-top: 20rpx;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
}

.amount-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.amount-row.total .amount-value {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: 600;
}

.amount-note {
  font-size: 22rpx;
  color: #999;
  margin-left: 10rpx;
}

/* 退款信息 */
.refund-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.refund-content {
  margin-top: 20rpx;
}

.refund-row {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.refund-row:last-child {
  border-bottom: none;
}

.refund-label {
  font-size: 26rpx;
  color: #666;
  min-width: 160rpx;
}

.refund-status {
  font-size: 26rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.refund-status.pending,
.refund-status.processing {
  color: #ff9800;
  background: #fff3e0;
}

.refund-status.approved,
.refund-status.completed {
  color: #4caf50;
  background: #e8f5e9;
}

.refund-status.rejected {
  color: #f44336;
  background: #ffebee;
}

.refund-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.refund-value.highlight {
  color: #ff6b35;
  font-weight: 600;
  font-size: 30rpx;
}

.refund-actions {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.refund-detail-btn {
  width: 100%;
  background: #667eea;
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 20rpx;
  border: none;
}

/* 配送信息 */
.delivery-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.delivery-content {
  margin-top: 20rpx;
}

.delivery-row {
  display: flex;
  align-items: flex-start;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.delivery-row:last-child {
  border-bottom: none;
}

.delivery-label {
  font-size: 26rpx;
  color: #666;
  min-width: 160rpx;
}

.delivery-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  line-height: 1.6;
}

.address-detail-line {
  margin-bottom: 10rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
}

.detail-value {
  font-size: 24rpx;
  color: #333;
}

.view-more {
  text-align: center;
  padding: 20rpx 0;
  color: #667eea;
  font-size: 26rpx;
}

/* 备注信息 */
.remark-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.remark-content {
  margin-top: 20rpx;
}

.remark-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 订单信息 */
.order-info-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-list {
  margin-top: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #666;
  min-width: 160rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.info-value-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.copy-btn {
  font-size: 24rpx;
  color: #667eea;
  padding: 4rpx 16rpx;
  border: 1rpx solid #667eea;
  border-radius: 4rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  font-size: 28rpx;
  color: #999;
}

/* 退款信息徽章 */
.refund-info {
  background: #fff3e0;
  border-radius: 8rpx;
  padding: 20rpx;
  margin: 20rpx 0;
}

.refund-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.refund-label {
  font-size: 24rpx;
  color: #666;
}

.refund-status {
  font-size: 24rpx;
  font-weight: 500;
}

.refund-amount {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 600;
  margin-left: auto;
}

