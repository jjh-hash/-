/* 管理端订单详情 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar {
  background: var(--color-primary);
}

.nav-bar {
  height: 88rpx;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  color: #fff;
}

.back-btn { font-size: 36rpx; padding: 10rpx; }
.title { font-size: 32rpx; font-weight: 500; }
.nav-actions { width: 60rpx; }
.content { padding: 20rpx; }

.status-section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}

.status-badge {
  display: inline-block;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.status-badge.paid {
  background: var(--color-primary-light);
  color: var(--color-success);
}

.status-badge.unpaid {
  background: rgba(255, 152, 0, 0.15);
  color: var(--color-warning);
}

.status-text { font-size: 32rpx; font-weight: 600; }
.order-no { display: block; font-size: 26rpx; color: var(--color-text-secondary); margin-top: 20rpx; }
.order-time { display: block; font-size: 24rpx; color: var(--color-text-placeholder); margin-top: 10rpx; }

.store-section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-card);
}

.store-logo { width: 100rpx; height: 100rpx; border-radius: 50%; margin-right: 20rpx; }
.store-info { flex: 1; }
.store-name { display: block; font-size: 30rpx; font-weight: 500; color: var(--color-text); margin-bottom: 10rpx; }
.store-address { display: block; font-size: 24rpx; color: var(--color-text-placeholder); }

.items-section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.items-list { margin-top: 20rpx; }
.item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.item-row:last-child { border-bottom: none; }
.item-info { flex: 1; }
.item-name { display: block; font-size: 28rpx; color: var(--color-text); margin-bottom: 8rpx; }
.item-spec { display: block; font-size: 24rpx; color: var(--color-text-placeholder); }
.item-right { display: flex; align-items: center; gap: 20rpx; }
.item-quantity { font-size: 26rpx; color: var(--color-text-secondary); }
.item-price { font-size: 28rpx; color: var(--color-text); font-weight: 500; }

.amount-section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}
.amount-list { margin-top: 20rpx; }
.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.amount-row:last-child { border-bottom: none; }
.amount-row.highlight {
  background: var(--color-bg-page);
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
  margin: 10rpx 0;
}
.amount-row.total {
  border-top: 2rpx solid var(--color-border);
  margin-top: 10rpx;
  padding-top: 20rpx;
}
.amount-label { font-size: 28rpx; color: var(--color-text-secondary); }
.amount-value { font-size: 28rpx; color: var(--color-text); font-weight: 500; }
.amount-row.total .amount-value { font-size: 32rpx; color: var(--color-warning); font-weight: 600; }
.amount-note { font-size: 22rpx; color: var(--color-text-placeholder); margin-left: 10rpx; }

.refund-section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}
.refund-content { margin-top: 20rpx; }
.refund-row {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.refund-row:last-child { border-bottom: none; }
.refund-label { font-size: 26rpx; color: var(--color-text-secondary); min-width: 160rpx; }
.refund-status { font-size: 26rpx; font-weight: 500; padding: 4rpx 16rpx; border-radius: 4rpx; }
.refund-status.pending, .refund-status.processing { color: var(--color-warning); background: rgba(255,152,0,0.12); }
.refund-status.approved, .refund-status.completed { color: var(--color-success); background: var(--color-primary-light); }
.refund-status.rejected { color: var(--color-danger); background: rgba(244,67,54,0.1); }
.refund-value { font-size: 26rpx; color: var(--color-text); flex: 1; }
.refund-value.highlight { color: var(--color-warning); font-weight: 600; font-size: 30rpx; }
.refund-actions { margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid var(--color-border); }

.refund-detail-btn {
  width: 100%;
  background: var(--color-primary);
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 20rpx;
  border: none;
}

/* 配送信息 */
.delivery-section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.delivery-content {
  margin-top: 20rpx;
}

.delivery-row {
  display: flex;
  align-items: flex-start;
  padding: 15rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.delivery-row:last-child {
  border-bottom: none;
}

.delivery-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  min-width: 160rpx;
}

.delivery-value {
  font-size: 26rpx;
  color: var(--color-text);
  flex: 1;
  line-height: 1.6;
}

.address-detail-line {
  margin-bottom: 10rpx;
}

.detail-label {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}

.detail-value {
  font-size: 24rpx;
  color: var(--color-text);
}

.view-more {
  text-align: center;
  padding: 20rpx 0;
  color: var(--color-primary);
  font-size: 26rpx;
}

/* 备注信息 */
.remark-section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.remark-content {
  margin-top: 20rpx;
}

.remark-text {
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.6;
}

/* 订单信息 */
.order-info-section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.info-list {
  margin-top: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  min-width: 160rpx;
}

.info-value {
  font-size: 26rpx;
  color: var(--color-text);
  flex: 1;
}

.info-value-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.copy-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  padding: 4rpx 16rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: 4rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  font-size: 28rpx;
  color: var(--color-text-placeholder);
}

/* 退款信息徽章 */
.refund-info {
  background: var(--color-primary-light);
  border-radius: 8rpx;
  padding: 20rpx;
  margin: 20rpx 0;
}

.refund-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.refund-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.refund-status {
  font-size: 24rpx;
  font-weight: 500;
}

.refund-amount {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
  margin-left: auto;
}

