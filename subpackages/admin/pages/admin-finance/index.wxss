.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar { background: transparent; }

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
  position: relative;
}

.back-btn, .refresh-btn {
  color: var(--color-text);
  font-size: 32rpx;
  padding: 10rpx;
  flex-shrink: 0;
}

.refresh-btn { font-size: 28rpx; color: var(--color-primary); }

.title {
  color: var(--color-text);
  font-size: 36rpx;
  font-weight: bold;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.date-range {
  padding: 20rpx 30rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.picker-text {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-tag);
  font-size: 26rpx;
  color: var(--color-text);
}

.content { padding: 30rpx; }

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}

.stat-card.platform {
  background: var(--color-primary);
  color: #fff;
}

.stat-card.merchant {
  background: var(--color-warning);
  color: #fff;
}

.stat-card.user {
  background: var(--color-secondary);
  color: #fff;
}

.stat-card.net {
  background: var(--color-success);
  color: #fff;
}

.stat-icon { font-size: 48rpx; display: block; margin-bottom: 15rpx; }

.stat-label { display: block; font-size: 24rpx; margin-bottom: 10rpx; opacity: 0.9; }

.stat-card:not(.platform):not(.merchant):not(.user):not(.net) .stat-label {
  color: var(--color-text-secondary);
}

.stat-number { display: block; font-size: 36rpx; font-weight: bold; margin-bottom: 8rpx; }

.stat-desc { display: block; font-size: 20rpx; opacity: 0.8; }

.stat-card:not(.platform):not(.merchant):not(.user):not(.net) .stat-desc {
  color: var(--color-text-placeholder);
}

.stat-card:not(.platform):not(.merchant):not(.user):not(.net) .stat-number {
  color: var(--color-text);
}

.chart-container {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 30rpx;
  text-align: center;
}

.chart-wrapper { width: 100%; overflow-x: auto; }

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  min-height: 250rpx;
  padding: 20rpx 0;
}

.chart-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.chart-bar-wrapper {
  width: 100%;
  height: 200rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 5rpx;
}

.chart-bar {
  width: 100%;
  max-width: 60rpx;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: all 0.3s ease;
}

.chart-bar.platform-bar {
  background: linear-gradient(180deg, var(--color-primary) 0%, rgba(255, 184, 0, 0.75) 100%);
}

.chart-bar.merchant-bar {
  background: linear-gradient(180deg, var(--color-warning) 0%, rgba(221, 142, 9, 0.7) 100%);
}

.chart-bar.user-bar {
  background: linear-gradient(180deg, var(--color-secondary) 0%, rgba(59, 130, 246, 0.7) 100%);
}

.chart-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 10rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}

.chart-value {
  display: block;
  font-size: 20rpx;
  color: var(--color-text);
  margin-top: 5rpx;
  text-align: center;
  font-weight: bold;
}

.ranking-container {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
}

.ranking-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 20rpx;
  text-align: center;
}

.ranking-list { display: flex; flex-direction: column; gap: 15rpx; }

.ranking-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  border-left: 4rpx solid var(--color-primary);
}

.ranking-rank {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.ranking-info { flex: 1; display: flex; flex-direction: column; gap: 5rpx; }

.ranking-name { font-size: 28rpx; font-weight: bold; color: var(--color-text); }

.ranking-desc { font-size: 24rpx; color: var(--color-text-secondary); line-height: 1.5; }

.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: var(--color-text-placeholder);
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}
