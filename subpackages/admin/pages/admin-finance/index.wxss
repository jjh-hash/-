.page {
  min-height: 100vh;
  background: #f5f6f8;
}

.status-bar {
  background: transparent;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
  position: relative;
}

.back-btn, .refresh-btn {
  color: #333;
  font-size: 32rpx;
  padding: 10rpx;
  flex-shrink: 0;
}

.refresh-btn {
  font-size: 28rpx;
  color: #667eea;
}

.title {
  color: #333;
  font-size: 36rpx;
  font-weight: bold;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

/* 日期范围选择 */
.date-range {
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.picker-text {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #f8f9fa;
  border: 1rpx solid #ddd;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #333;
}

/* 内容区域 */
.content {
  padding: 30rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-card.platform {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.stat-card.merchant {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.stat-card.user {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
}

.stat-card.net {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  color: white;
}

.stat-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 15rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  opacity: 0.9;
}

.stat-card:not(.platform):not(.merchant):not(.user):not(.net) .stat-label {
  color: #666;
}

.stat-number {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-desc {
  display: block;
  font-size: 20rpx;
  opacity: 0.8;
}

.stat-card:not(.platform):not(.merchant):not(.user):not(.net) .stat-desc {
  color: #999;
}

.stat-card:not(.platform):not(.merchant):not(.user):not(.net) .stat-number {
  color: #333;
}

/* 图表容器 */
.chart-container {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.chart-wrapper {
  width: 100%;
  overflow-x: auto;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  min-height: 250rpx;
  padding: 20rpx 0;
}

.chart-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.chart-bar-wrapper {
  width: 100%;
  height: 200rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 5rpx;
}

.chart-bar {
  width: 100%;
  max-width: 60rpx;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: all 0.3s ease;
}

.chart-bar.platform-bar {
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
}

.chart-bar.merchant-bar {
  background: linear-gradient(180deg, #f093fb 0%, #f5576c 100%);
}

.chart-bar.user-bar {
  background: linear-gradient(180deg, #4facfe 0%, #00f2fe 100%);
}

.chart-label {
  display: block;
  font-size: 20rpx;
  color: #666;
  margin-top: 10rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}

.chart-value {
  display: block;
  font-size: 20rpx;
  color: #333;
  margin-top: 5rpx;
  text-align: center;
  font-weight: bold;
}

/* 排行榜容器 */
.ranking-container {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.ranking-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 15rpx;
  border-left: 4rpx solid #667eea;
}

.ranking-rank {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.ranking-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.ranking-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.ranking-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 100rpx;
  color: #666;
  font-size: 28rpx;
}

