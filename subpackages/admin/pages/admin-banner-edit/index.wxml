<!--pages/admin-banner-edit/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  

  <!-- 页面内容 -->
  <scroll-view scroll-y class="page-content">
    <!-- 预览区域 -->
    <view class="preview-section">
      <text class="section-title">预览效果</text>
      <view class="banner-preview">
        <image wx:if="{{previewImage}}" class="preview-img" src="{{previewImage}}" mode="aspectFill" />
        <view wx:else class="upload-placeholder" bindtap="onChooseImage">
          <text class="upload-icon">📷</text>
          <text class="upload-text">点击上传图片</text>
        </view>
      </view>
    </view>

    <!-- 图片上传 -->
    <view class="section">
      <text class="section-title">图片设置</text>
      
      <view class="upload-btn" bindtap="onChooseImage">
        <text class="upload-btn-text">选择图片并上传</text>
      </view>
      
      <view wx:if="{{previewImage}}" class="image-info">
        <text class="image-info-text">已上传图片</text>
        <view class="delete-btn" bindtap="onDeleteImage">
          <text class="delete-btn-text">删除图片</text>
        </view>
      </view>
    </view>

    <!-- 链接设置 -->
    <view class="section">
      <text class="section-title">链接设置</text>
      
      <view class="form-item">
        <text class="form-label">跳转链接</text>
        <input class="form-input" placeholder="点击轮播图跳转的链接（可选）" value="{{formData.linkUrl}}" bindinput="onLinkUrlInput" />
      </view>
    </view>

    <!-- 状态设置 -->
    <view class="section">
      <text class="section-title">状态设置</text>
      
      <view class="switch-item">
        <view class="switch-label">
          <text class="switch-title">启用状态</text>
          <text class="switch-desc">禁用后不会在首页显示</text>
        </view>
        <switch checked="{{formData.status === 'active'}}" bindchange="onToggleStatus" />
      </view>
    </view>

    <!-- 保存按钮 -->
    <view class="save-btn" bindtap="onSave">
      <text class="save-btn-text">保存</text>
    </view>
  </scroll-view>
</view>

