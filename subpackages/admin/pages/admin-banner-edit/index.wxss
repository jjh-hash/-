.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav-bar{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center;position:relative}
.title{font-size:18px;color:#333;font-weight:600}
.back-btn{position:absolute;left:12px;color:#333;font-size:18px;cursor:pointer}

.page-content{height:calc(100vh - 44px);padding:12px}

.section{background:#fff;border-radius:12px;padding:16px;margin-bottom:12px}
.section-title{font-size:16px;color:#333;font-weight:600;margin-bottom:16px;display:block}

.preview-section{background:#fff;border-radius:12px;padding:16px;margin-bottom:12px}
.banner-preview{width:100%;height:180px;border-radius:8px;overflow:hidden;margin-top:12px;background:#f5f5f5}
.preview-img{width:100%;height:100%}
.upload-placeholder{width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;gap:8px;border:2px dashed #d9d9d9}
.upload-icon{font-size:48px}
.upload-text{color:#999;font-size:14px}

.form-item{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
.form-item:last-child{margin-bottom:0}
.form-label{color:#333;font-size:15px;font-weight:500}
.form-input{background:#f9f9f9;border-radius:8px;padding:12px;color:#333;font-size:15px}

.upload-btn{background:#1677ff;border-radius:8px;padding:12px;text-align:center;margin-bottom:12px}
.upload-btn-text{color:#fff;font-size:15px;font-weight:500}
.image-info{margin-top:8px;display:flex;justify-content:space-between;align-items:center}
.image-info-text{color:#52c41a;font-size:13px}
.delete-btn{background:#ff4d4f;border-radius:6px;padding:6px 12px}
.delete-btn-text{color:#fff;font-size:13px}

.switch-item{display:flex;align-items:center;justify-content:space-between;padding:12px 0}
.switch-label{flex:1;display:flex;flex-direction:column;gap:4px}
.switch-title{color:#333;font-size:15px}
.switch-desc{color:#999;font-size:13px}

.save-btn{background:#1677ff;border-radius:12px;padding:16px;text-align:center;margin-top:12px}
.save-btn-text{color:#fff;font-size:16px;font-weight:600}
