<!--pages/admin-announcement/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <text class="title">系统公告</text>
    <view class="back-btn" bindtap="onBack">◀</view>
    <view class="add-btn" bindtap="showTypeModal">
      <text class="add-btn-text">+ 发布</text>
    </view>
  </view>

  <!-- 页面内容 -->
  <scroll-view scroll-y class="page-content">
    <!-- 公告列表 -->
    <view wx:if="{{announcements.length > 0}}" class="announcement-list">
      <view class="announcement-item" wx:for="{{announcements}}" wx:key="_id">
        <view class="announcement-header">
          <text class="announcement-title">{{item.title}}</text>
          <view class="announcement-type">
            <text wx:if="{{item.targetType === 'client'}}">👤 客户端</text>
            <text wx:elif="{{item.targetType === 'merchant'}}">🏪 商家端</text>
            <text wx:else>🌐 全部</text>
          </view>
        </view>
        <view class="announcement-status-bar">
          <view class="announcement-badge {{item.status === 'active' ? 'active' : 'inactive'}}">
            {{item.status === 'active' ? '启用' : '禁用'}}
          </view>
        </view>
        <view class="announcement-content">{{item.content}}</view>
        <view class="announcement-footer">
          <text class="announcement-time">{{item.createdAt}}</text>
          <view class="announcement-actions">
            <text class="action-btn edit-btn" bindtap="onEdit" data-announcement="{{item}}">编辑</text>
            <text class="action-btn delete-btn" bindtap="onDelete" data-announcement="{{item}}">删除</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <text class="empty-text">暂无公告</text>
    </view>
  </scroll-view>

  <!-- 添加/编辑弹窗 -->
  <view wx:if="{{showAddModal}}" class="modal-overlay" bindtap="closeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{currentAnnouncement ? '编辑公告' : '发布公告'}}</text>
        <text class="modal-close" bindtap="closeModal">✕</text>
      </view>
      
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">公告类型</text>
          <view class="form-type-display">
            <text wx:if="{{formData.targetType === 'client'}}">👤 客户端公告</text>
            <text wx:elif="{{formData.targetType === 'merchant'}}">🏪 商家端公告</text>
            <text wx:else>🌐 全部公告</text>
          </view>
        </view>
        
        <view class="form-item">
          <text class="form-label">公告内容</text>
          <textarea class="form-textarea" placeholder="请输入公告内容" value="{{formData.content}}" bindinput="onContentInput" maxlength="500" auto-height />
        </view>
        
        <view class="form-item">
          <text class="form-label">状态</text>
          <switch checked="{{formData.status === 'active'}}" bindchange="onToggleStatus" />
        </view>
      </view>
      
      <view class="modal-footer">
        <view class="modal-btn cancel-btn" bindtap="closeModal">
          <text class="modal-btn-text">取消</text>
        </view>
        <view class="modal-btn confirm-btn" bindtap="onSave">
          <text class="modal-btn-text">保存</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 选择公告类型弹窗 -->
  <view wx:if="{{showTypeModal}}" class="modal-overlay" bindtap="closeTypeModal">
    <view class="modal-content type-select-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">选择公告类型</text>
        <text class="modal-close" bindtap="closeTypeModal">✕</text>
      </view>
      
      <view class="modal-body">
        <view class="type-select-list">
          <view class="type-select-item" bindtap="onSelectAnnouncementType" data-type="client">
            <view class="type-select-icon">👤</view>
            <view class="type-select-info">
              <text class="type-select-title">客户端公告</text>
              <text class="type-select-desc">仅客户端用户可见</text>
            </view>
            <text class="type-select-arrow">›</text>
          </view>
          
          <view class="type-select-item" bindtap="onSelectAnnouncementType" data-type="all">
            <view class="type-select-icon">🌐</view>
            <view class="type-select-info">
              <text class="type-select-title">全部公告</text>
              <text class="type-select-desc">客户端和商家端都可见</text>
            </view>
            <text class="type-select-arrow">›</text>
          </view>
          
          <view class="type-select-item" bindtap="onSelectAnnouncementType" data-type="merchant">
            <view class="type-select-icon">🏪</view>
            <view class="type-select-info">
              <text class="type-select-title">商家端公告</text>
              <text class="type-select-desc">仅商家端用户可见</text>
            </view>
            <text class="type-select-arrow">›</text>
          </view>
        </view>
      </view>
      
      <view class="modal-footer">
        <view class="modal-btn cancel-btn" bindtap="closeTypeModal">
          <text class="modal-btn-text">取消</text>
        </view>
      </view>
    </view>
  </view>
</view>

