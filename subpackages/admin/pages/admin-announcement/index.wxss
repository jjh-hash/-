/* 管理端公告 - 设计系统 */
.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav-bar{height:44px;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;position:relative}
.title{font-size:18px;color:var(--color-text);font-weight:600}
.back-btn{position:absolute;left:12px;color:var(--color-text);font-size:18px;cursor:pointer}
.add-btn{position:absolute;right:12px;background:var(--color-primary);border-radius:var(--radius-btn);padding:6px 12px}
.add-btn-text{color:#fff;font-size:14px;font-weight:500}

.page-content{height:calc(100vh - 44px);padding:12px}

.announcement-list{display:flex;flex-direction:column;gap:12px}
.announcement-item{background:var(--color-bg-card);border-radius:var(--radius-card);padding:16px;box-shadow:var(--shadow-card)}
.announcement-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.announcement-title{font-size:16px;font-weight:600;color:var(--color-text);flex:1}
.announcement-type{font-size:12px;color:var(--color-text-secondary);padding:4px 8px;background:var(--color-bg-page);border-radius:var(--radius-tag)}
.announcement-status-bar{margin-bottom:12px}
.announcement-badge{padding:4px 8px;border-radius:var(--radius-tag);font-size:12px;display:inline-block}
.announcement-badge.active{background:var(--color-primary-light);color:var(--color-primary)}
.announcement-badge.inactive{background:var(--color-bg-page);color:var(--color-text-placeholder)}
.announcement-content{color:var(--color-text-secondary);font-size:14px;line-height:1.6;margin-bottom:12px}
.announcement-footer{display:flex;justify-content:space-between;align-items:center;padding-top:12px;border-top:1px solid var(--color-border)}
.announcement-time{color:var(--color-text-placeholder);font-size:12px}
.announcement-actions{display:flex;gap:12px}
.action-btn{padding:4px 12px;border-radius:var(--radius-tag);font-size:13px;cursor:pointer}
.edit-btn{background:var(--color-primary-light);color:var(--color-primary)}
.delete-btn{background:rgba(244,67,54,0.1);color:var(--color-danger)}

.empty-state{display:flex;justify-content:center;align-items:center;height:400px}
.empty-text{color:var(--color-text-placeholder);font-size:14px}

.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:1000;display:flex;align-items:center;justify-content:center}
.modal-content{width:90%;max-width:500px;background:var(--color-bg-card);border-radius:var(--radius-card);overflow:hidden}
.modal-header{display:flex;justify-content:space-between;align-items:center;padding:16px;border-bottom:1px solid var(--color-border)}
.modal-title{font-size:16px;font-weight:600;color:var(--color-text)}
.modal-close{font-size:24px;color:var(--color-text-placeholder);cursor:pointer}
.modal-body{padding:16px;max-height:400px;overflow-y:auto}
.form-item{margin-bottom:16px}
.form-item:last-child{margin-bottom:0}
.form-label{display:block;color:var(--color-text);font-size:14px;font-weight:500;margin-bottom:8px}
.form-input{width:100%;background:var(--color-bg-page);border-radius:var(--radius-btn);padding:12px;color:var(--color-text);font-size:14px;box-sizing:border-box}
.form-textarea{width:100%;min-height:120px;background:var(--color-bg-page);border-radius:var(--radius-btn);padding:12px;color:var(--color-text);font-size:14px;box-sizing:border-box}
.form-type-display{background:var(--color-bg-page);border-radius:var(--radius-btn);padding:12px;color:var(--color-text);font-size:14px;font-weight:500}
.modal-footer{display:flex;gap:12px;padding:16px;border-top:1px solid var(--color-border)}
.modal-btn{flex:1;border-radius:var(--radius-btn);padding:12px;text-align:center}
.cancel-btn{background:var(--color-bg-page)}
.confirm-btn{background:var(--color-primary)}
.modal-btn-text{font-size:15px;font-weight:500}
.cancel-btn .modal-btn-text{color:var(--color-text)}
.confirm-btn .modal-btn-text{color:#fff}

.type-select-modal{max-width:400px}
.type-select-list{display:flex;flex-direction:column;gap:0}
.type-select-item{display:flex;align-items:center;padding:16px;border-bottom:1px solid var(--color-border);cursor:pointer;transition:background 0.2s}
.type-select-item:last-child{border-bottom:none}
.type-select-item:active{background:var(--color-bg-page)}
.type-select-icon{font-size:32px;margin-right:16px;width:40px;text-align:center}
.type-select-info{flex:1;display:flex;flex-direction:column;gap:4px}
.type-select-title{font-size:16px;font-weight:600;color:var(--color-text)}
.type-select-desc{font-size:12px;color:var(--color-text-placeholder)}
