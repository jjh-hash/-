.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar { width: 100%; }

.nav-bar {
  height: 44px;
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 12px;
  color: var(--color-text);
  font-size: 18px;
}

.title { font-size: 18px; color: var(--color-text); font-weight: 600; }

.filter-section {
  background: var(--color-bg-card);
  padding: 12px;
  border-bottom: 1px solid var(--color-border);
}

.search-box {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.search-input {
  flex: 1;
  height: 36px;
  padding: 0 12px;
  background: var(--color-bg-page);
  border-radius: 18px;
  font-size: 14px;
}

.search-btn {
  margin-left: 8px;
  padding: 8px 16px;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-btn);
  font-size: 14px;
}

.filter-item {
  display: flex;
  align-items: center;
  padding: 8px 0;
}

.filter-label { font-size: 14px; color: var(--color-text-secondary); }

.filter-value {
  flex: 1;
  font-size: 14px;
  color: var(--color-text);
  margin-left: 8px;
}

.filter-arrow { font-size: 12px; color: var(--color-text-placeholder); }

/* 内容区域 */
.content {
  height: calc(100vh - 44px - 100px);
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
  color: var(--color-text-placeholder);
  font-size: 14px;
}

/* 骑手列表 */
.rider-list {
  padding: 12px;
}

.rider-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-card);
}

.rider-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border);
}

.rider-info {
  flex: 1;
}

.rider-name {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 4px;
}

.rider-phone { display: block; font-size: 14px; color: var(--color-text-secondary); }

.rider-status {
  padding: 4px 12px;
  border-radius: var(--radius-tag);
  font-size: 12px;
}

.rider-status.status-pending {
  background: rgba(250, 140, 22, 0.12);
  color: var(--color-warning);
}

.rider-status.status-approved {
  background: var(--color-primary-light);
  color: var(--color-success);
}

.rider-status.status-rejected {
  background: rgba(255, 77, 79, 0.12);
  color: var(--color-danger);
}

.rider-details {
  margin-bottom: 12px;
}

.detail-item {
  display: flex;
  padding: 6px 0;
  font-size: 14px;
}

.detail-label {
  color: var(--color-text-secondary);
  width: 80px;
  flex-shrink: 0;
}

.detail-value { flex: 1; color: var(--color-text); word-break: break-all; }

.rider-actions {
  display: flex;
  gap: 8px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
}

.action-btn {
  flex: 1;
  height: 36px;
  line-height: 36px;
  border-radius: var(--radius-btn);
  font-size: 14px;
  border: none;
}

.approve-btn { background: var(--color-success); color: #fff; }

.reject-btn { background: var(--color-danger); color: #fff; }

.action-btn::after {
  border: none;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-text { color: var(--color-text-placeholder); font-size: 14px; }

