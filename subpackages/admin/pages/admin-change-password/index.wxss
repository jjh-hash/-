/* pages/admin-change-password/index.wxss */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar { background: var(--color-primary); }

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--color-primary);
  color: #fff;
}

.back-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 10rpx;
  cursor: pointer;
}

.title { font-size: 36rpx; font-weight: bold; color: #fff; }

.nav-placeholder { width: 56rpx; }

.page-content { padding: 40rpx 30rpx; }

.form-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
  border-left: 6rpx solid var(--color-primary);
}

.form-item { margin-bottom: 40rpx; }

.form-item:last-child { margin-bottom: 0; }

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  height: 88rpx;
  padding: 0 20rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  color: var(--color-text);
}

.eye-icon {
  position: absolute;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  cursor: pointer;
}

.tips-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-card);
}

.tips-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.tips-text:last-child { margin-bottom: 0; }

.submit-section { margin-top: 40rpx; }

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: var(--shadow-card);
}

.submit-btn.disabled {
  background: var(--color-text-placeholder);
  box-shadow: none;
}

.submit-btn::after { border: none; }
