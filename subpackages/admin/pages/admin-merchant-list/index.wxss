/* 管理端商家列表 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar {
  background: transparent;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
  position: relative;
}

.back-btn {
  position: absolute;
  left: 30rpx;
  color: var(--color-text);
  font-size: 28rpx;
  padding: 10rpx;
}

.title {
  color: var(--color-text);
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.invite-code-section {
  padding: 24rpx 30rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.invite-code-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.invite-code-btn::after {
  border: none;
}

.filter-section {
  display: flex;
  padding: 20rpx 30rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
  gap: 20rpx;
}

.search-box {
  flex: 1;
  position: relative;
}

.search-icon {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: var(--color-text-placeholder);
  z-index: 1;
}

.search-input {
  width: 100%;
  height: 76rpx;
  padding: 0 24rpx 0 60rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 38rpx;
  font-size: 28rpx;
  background: var(--color-bg-page);
  box-sizing: border-box;
}

.search-input:focus {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
}

.filter-box {
  width: 200rpx;
}

.picker-text {
  height: 70rpx;
  line-height: 70rpx;
  padding: 0 20rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 35rpx;
  font-size: 28rpx;
  text-align: center;
  background: var(--color-bg-page);
  color: var(--color-text);
}

.merchant-list {
  padding: 20rpx 30rpx;
}

.merchant-item {
  background: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.merchant-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.merchant-info {
  flex: 1;
}

.merchant-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.merchant-phone {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.merchant-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-pending {
  background: rgba(255, 152, 0, 0.15);
  color: var(--color-warning);
}

.status-active {
  background: var(--color-primary-light);
  color: var(--color-success);
}

.status-suspended, .status-rejected {
  background: rgba(244, 67, 54, 0.15);
  color: var(--color-danger);
}

.merchant-details {
  margin-bottom: 20rpx;
}

.detail-item {
  display: flex;
  margin-bottom: 10rpx;
}

.detail-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  width: 160rpx;
}

.detail-value {
  font-size: 26rpx;
  color: var(--color-text);
  flex: 1;
}

.merchant-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  text-align: center;
  min-width: 120rpx;
}

.detail-btn {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.action-buttons {
  display: flex;
  gap: 15rpx;
}

.approve-btn, .resume-btn {
  background: var(--color-primary-light);
  color: var(--color-success);
}

.reject-btn, .delete-btn {
  background: rgba(244, 67, 54, 0.15);
  color: var(--color-danger);
}

.delete-btn {
  border: 1rpx solid rgba(244, 67, 54, 0.3);
}

.suspend-btn {
  background: rgba(255, 152, 0, 0.15);
  color: var(--color-warning);
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx;
  color: var(--color-text-placeholder);
  font-size: 26rpx;
}

/* 邀请码弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background: var(--color-bg-card);
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.modal-close {
  font-size: 40rpx;
  color: var(--color-text-placeholder);
  line-height: 1;
}

.modal-body {
  padding: 40rpx 30rpx;
}

.invite-code-display {
  text-align: center;
  padding: 40rpx;
  background: var(--color-bg-page);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.invite-code-text {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-primary);
  letter-spacing: 4rpx;
}

.invite-code-tip {
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid var(--color-border);
}

.copy-btn, .close-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.copy-btn {
  background: var(--color-primary);
  color: white;
}

.close-btn {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
}
