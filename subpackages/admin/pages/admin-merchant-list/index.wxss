.page {
  min-height: 100vh;
  background: #f5f6f8;
}

.status-bar {
  background: transparent;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 30rpx;
  color: #333;
  font-size: 28rpx;
  padding: 10rpx;
}

.title {
  color: #333;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 邀请码按钮区域 */
.invite-code-section {
  padding: 24rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.invite-code-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #1677ff;
  color: white;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.invite-code-btn::after {
  border: none;
}

/* 搜索和筛选 */
.filter-section {
  display: flex;
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
  gap: 20rpx;
}

.search-box {
  flex: 1;
  position: relative;
}

.search-icon {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #999;
  z-index: 1;
}

.search-input {
  width: 100%;
  height: 76rpx;
  padding: 0 24rpx 0 60rpx;
  border: 2rpx solid #e6e8eb;
  border-radius: 38rpx;
  font-size: 28rpx;
  background: #f5f6f8;
  box-sizing: border-box;
}

.search-input:focus {
  border-color: #1677ff;
  background: #fff;
}

.filter-box {
  width: 200rpx;
}

.picker-text {
  height: 70rpx;
  line-height: 70rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 35rpx;
  font-size: 28rpx;
  text-align: center;
  background: #f8f9fa;
  color: #333;
}

/* 商家列表 */
.merchant-list {
  padding: 20rpx 30rpx;
}

.merchant-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.merchant-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.merchant-info {
  flex: 1;
}

.merchant-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.merchant-phone {
  display: block;
  font-size: 26rpx;
  color: #666;
}

.merchant-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-pending {
  background: #fff3cd;
  color: #856404;
}

.status-active {
  background: #d4edda;
  color: #155724;
}

.status-suspended {
  background: #f8d7da;
  color: #721c24;
}

.status-rejected {
  background: #f8d7da;
  color: #721c24;
}

.merchant-details {
  margin-bottom: 20rpx;
}

.detail-item {
  display: flex;
  margin-bottom: 10rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
  width: 160rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.merchant-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  text-align: center;
  min-width: 120rpx;
}

.detail-btn {
  background: #e3f2fd;
  color: #1976d2;
}

.action-buttons {
  display: flex;
  gap: 15rpx;
}

.approve-btn {
  background: #d4edda;
  color: #155724;
}

.reject-btn {
  background: #f8d7da;
  color: #721c24;
}

.suspend-btn {
  background: #fff3cd;
  color: #856404;
}

.resume-btn {
  background: #d4edda;
  color: #155724;
}

.delete-btn {
  background: #f8d7da;
  color: #721c24;
  border: 1rpx solid #f5c6cb;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #666;
  font-size: 28rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 邀请码弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 40rpx 30rpx;
}

.invite-code-display {
  text-align: center;
  padding: 40rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.invite-code-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #1989fa;
  letter-spacing: 4rpx;
}

.invite-code-tip {
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.copy-btn, .close-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.copy-btn {
  background: #1989fa;
  color: white;
}

.close-btn {
  background: #f5f5f5;
  color: #666;
}
