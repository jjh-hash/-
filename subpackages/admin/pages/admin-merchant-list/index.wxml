<view class="page">
  <!-- 状态栏 -->
  

  <!-- 搜索和筛选 -->
  <view class="filter-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索商家名称或手机号" 
        bindinput="onSearch"
        value="{{keyword}}"
      />
    </view>
    <view class="filter-box">
      <picker 
        bindchange="onStatusChange" 
        value="{{statusIndex}}" 
        range="{{statusOptions}}" 
        range-key="label"
      >
        <view class="picker-text">
          {{statusOptions[statusIndex].label}}
        </view>
      </picker>
    </view>
  </view>

  <!-- 邀请码按钮 -->
  <view class="invite-code-section">
    <button class="invite-code-btn" bindtap="onCreateInviteCode">生成邀请码</button>
  </view>

  <!-- 商家列表 -->
  <view class="merchant-list">
    <block wx:for="{{merchants}}" wx:key="_id">
      <view class="merchant-item">
        <view class="merchant-header">
          <view class="merchant-info">
            <text class="merchant-name">{{item.merchantName}}</text>
            <text class="merchant-phone">{{item.contactPhone}}</text>
          </view>
          <view class="merchant-status status-{{item.status}}">
            <text wx:if="{{item.status === 'pending'}}">待审核</text>
            <text wx:elif="{{item.status === 'active'}}">已通过</text>
            <text wx:elif="{{item.status === 'suspended'}}">已暂停</text>
            <text wx:elif="{{item.status === 'rejected'}}">已拒绝</text>
          </view>
        </view>
        
        <view class="merchant-details">
          <view class="detail-item">
            <text class="detail-label">店铺名称：</text>
            <text class="detail-value">{{item.storeInfo.name}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">资质状态：</text>
            <text class="detail-value status-{{item.qualificationStatus}}">
              <text wx:if="{{item.qualificationStatus === 'pending'}}">待审核</text>
              <text wx:elif="{{item.qualificationStatus === 'approved'}}">已通过</text>
              <text wx:elif="{{item.qualificationStatus === 'rejected'}}">已拒绝</text>
            </text>
          </view>
          <view class="detail-item">
            <text class="detail-label">申请时间：</text>
            <text class="detail-value">{{item.createdAt}}</text>
          </view>
        </view>

        <view class="merchant-actions">
          <view 
            class="action-btn detail-btn" 
            bindtap="onViewDetail" 
            data-id="{{item._id}}"
          >
            查看详情
          </view>
          
          <view wx:if="{{item.status === 'pending'}}" class="action-buttons">
            <view 
              class="action-btn approve-btn" 
              bindtap="onApprove" 
              data-id="{{item._id}}" 
              data-name="{{item.merchantName}}"
            >
              通过
            </view>
            <view 
              class="action-btn reject-btn" 
              bindtap="onReject" 
              data-id="{{item._id}}" 
              data-name="{{item.merchantName}}"
            >
              拒绝
            </view>
          </view>
          
          <view wx:elif="{{item.status === 'active'}}" class="action-buttons">
            <view 
              class="action-btn suspend-btn" 
              bindtap="onSuspend" 
              data-id="{{item._id}}" 
              data-name="{{item.merchantName}}"
            >
              暂停
            </view>
            <view 
              class="action-btn delete-btn" 
              bindtap="onDelete" 
              data-id="{{item._id}}" 
              data-name="{{item.merchantName}}"
            >
              删除该商家
            </view>
          </view>
          
          <view wx:elif="{{item.status === 'suspended'}}" class="action-buttons">
            <view 
              class="action-btn resume-btn" 
              bindtap="onResume" 
              data-id="{{item._id}}" 
              data-name="{{item.merchantName}}"
            >
              取消暂停
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{merchants.length === 0}}" class="empty">
    <text class="empty-icon">📝</text>
    <text class="empty-text">暂无商家数据</text>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{merchants.length < total && !loading}}" class="load-more">
    <text>上拉加载更多</text>
  </view>

  <!-- 邀请码生成弹窗 -->
  <view wx:if="{{showInviteCodeModal}}" class="modal-mask" bindtap="onCloseInviteCodeModal">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">邀请码生成成功</text>
        <text class="modal-close" bindtap="onCloseInviteCodeModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="invite-code-display">
          <text class="invite-code-text">{{newInviteCode}}</text>
        </view>
        <view class="invite-code-tip">
          <text>请将此邀请码分享给需要注册的商家</text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="copy-btn" bindtap="onCopyInviteCode">复制邀请码</button>
        <button class="close-btn" bindtap="onCloseInviteCodeModal">关闭</button>
      </view>
    </view>
  </view>
</view>
