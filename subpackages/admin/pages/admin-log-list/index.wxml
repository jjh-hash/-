<!--pages/admin-log-list/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBack">◀</view>
    <text class="title">全部操作日志</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 页面内容 -->
  <view class="page-content">
    <!-- 统计信息 -->
    <view class="stats-section">
      <view class="stats-card">
        <text class="stats-label">总操作数</text>
        <text class="stats-value">{{total}}</text>
      </view>
    </view>

    <!-- 操作日志列表 -->
    <view class="logs-section">
      <view class="logs-list">
        <!-- 加载状态 -->
        <view class="loading-state" wx:if="{{loading && logs.length === 0}}">
          <text class="loading-text">加载中...</text>
        </view>

        <!-- 日志列表 -->
        <view class="log-item" wx:for="{{logs}}" wx:key="id">
          <view class="log-content">
            <view class="log-header">
              <text class="log-action">{{item.action}}</text>
              <view class="log-result {{item.result === '成功' || item.result === '通过' || item.result === '完成' ? 'success' : 'warning'}}">
                {{item.result}}
              </view>
            </view>
            <text class="log-target" wx:if="{{item.target}}">{{item.target}}</text>
            <text class="log-type">类型：{{item.targetType}}</text>
            <text class="log-time">{{item.time}}</text>
          </view>
        </view>

        <!-- 加载更多 -->
        <view class="load-more" wx:if="{{hasMore && logs.length > 0 && !loading}}" bindtap="onLoadMore">
          <text class="load-more-text">加载更多</text>
        </view>

        <!-- 加载更多中 -->
        <view class="load-more" wx:if="{{hasMore && loading && logs.length > 0}}">
          <text class="load-more-text">加载中...</text>
        </view>

        <!-- 没有更多 -->
        <view class="no-more" wx:if="{{!hasMore && logs.length > 0 && !loading}}">
          <text class="no-more-text">已加载全部 {{total}} 条记录</text>
        </view>

        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{!loading && logs.length === 0}}">
          <text class="empty-text">暂无操作记录</text>
        </view>
      </view>
    </view>
  </view>
</view>

