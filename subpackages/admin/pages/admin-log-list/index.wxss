/* pages/admin-log-list/index.wxss */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 40rpx;
}

.status-bar { background: var(--color-primary); }

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--color-primary);
  color: #fff;
}

.back-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 10rpx;
  cursor: pointer;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
  text-align: center;
}

.nav-placeholder { width: 56rpx; }

.page-content { padding: 30rpx; }

.stats-section { margin-bottom: 30rpx; }

.stats-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-left: 6rpx solid var(--color-primary);
}

.stats-label { font-size: 28rpx; color: var(--color-text-secondary); }

.stats-value {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-primary);
}

.logs-section { margin-bottom: 40rpx; }

.logs-list {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  box-shadow: var(--shadow-card);
}

.log-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.log-item:last-child { border-bottom: none; }

.log-content { display: flex; flex-direction: column; }

.log-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.log-action {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  flex: 1;
}

.log-result {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-tag);
  font-weight: bold;
}

.log-result.success {
  background: var(--color-primary-light);
  color: var(--color-success);
}

.log-result.warning {
  background: rgba(250, 140, 22, 0.12);
  color: var(--color-warning);
}

.log-target {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.log-type {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
  margin-bottom: 8rpx;
}

.log-time { font-size: 22rpx; color: var(--color-text-placeholder); }

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  margin-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.load-more-text { font-size: 28rpx; color: var(--color-primary); }

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  margin-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.no-more-text { font-size: 24rpx; color: var(--color-text-placeholder); }

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text { font-size: 28rpx; color: var(--color-primary); }

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text { font-size: 28rpx; color: var(--color-text-placeholder); }
