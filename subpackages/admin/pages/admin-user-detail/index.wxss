.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar { width: 100%; }

.nav-bar {
  height: 44px;
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 12px;
  color: var(--color-text);
  font-size: 18px;
}

.title { font-size: 18px; color: var(--color-text); font-weight: 600; }

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
  color: var(--color-text-placeholder);
  font-size: 14px;
}

.content { height: calc(100vh - 44px); padding: 12px; }

.section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 16px;
  color: var(--color-text);
  font-weight: 600;
  margin-bottom: 16px;
  display: block;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--color-border);
}

.user-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  margin-right: 12px;
  overflow: hidden;
  background: var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar image { width: 100%; height: 100%; }

.avatar-placeholder { font-size: 24px; color: var(--color-text-placeholder); font-weight: 600; }

.user-info { flex: 1; display: flex; flex-direction: column; }

.user-name {
  font-size: 18px;
  color: var(--color-text);
  font-weight: 600;
  margin-bottom: 4px;
}

.user-status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 4px;
  display: inline-block;
  width: fit-content;
}

.user-status.status-active {
  background: var(--color-primary-light);
  color: var(--color-success);
}

.user-status.status-banned {
  background: rgba(255, 77, 79, 0.12);
  color: var(--color-danger);
}

.info-item {
  display: flex;
  padding: 8px 0;
  border-bottom: 1px solid var(--color-border);
}

.info-item:last-child { border-bottom: none; }

.label {
  color: var(--color-text-secondary);
  font-size: 14px;
  width: 100px;
  flex-shrink: 0;
}

.value { flex: 1; color: var(--color-text); font-size: 14px; word-break: break-all; }

.ban-section {
  background: rgba(255, 77, 79, 0.08);
  border: 1px solid rgba(255, 77, 79, 0.3);
}

.ban-reason { color: var(--color-danger); font-weight: 500; }

.rider-section {
  background: var(--color-primary-light);
  border: 1px solid var(--color-border);
}

.rider-status { color: var(--color-primary); font-weight: 600; }

.rider-status-pending { color: var(--color-warning); }

.rider-status-approved { color: var(--color-success); }

.rider-status-rejected { color: var(--color-danger); }

.rider-status-unknown { color: var(--color-text-placeholder); }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon { font-size: 48px; margin-bottom: 12px; }

.empty-text { color: var(--color-text-placeholder); font-size: 14px; }
