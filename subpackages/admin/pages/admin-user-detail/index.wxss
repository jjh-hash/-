.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav-bar{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center;position:relative}
.back-btn{position:absolute;left:12px;color:#333;font-size:18px}
.title{font-size:18px;color:#333;font-weight:600}

.loading{display:flex;align-items:center;justify-content:center;padding:60px 0;color:#999;font-size:14px}

.content{height:calc(100vh - 44px);padding:12px}

.section{background:#fff;border-radius:12px;padding:16px;margin-bottom:12px}
.section-title{font-size:16px;color:#333;font-weight:600;margin-bottom:16px;display:block}

.user-header{display:flex;align-items:center;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #f5f5f5}
.user-avatar{width:60px;height:60px;border-radius:50%;margin-right:12px;overflow:hidden;background:#e6e6e6;display:flex;align-items:center;justify-content:center}
.user-avatar image{width:100%;height:100%}
.avatar-placeholder{font-size:24px;color:#999;font-weight:600}
.user-info{flex:1;display:flex;flex-direction:column}
.user-name{font-size:18px;color:#333;font-weight:600;margin-bottom:4px}
.user-status{font-size:12px;padding:2px 8px;border-radius:4px;display:inline-block;width:fit-content}
.user-status.status-active{background:#f6ffed;color:#52c41a}
.user-status.status-banned{background:#fff1f0;color:#ff4d4f}

.info-item{display:flex;padding:8px 0;border-bottom:1px solid #f5f5f5}
.info-item:last-child{border-bottom:none}
.label{color:#666;font-size:14px;width:100px;flex-shrink:0}
.value{flex:1;color:#333;font-size:14px;word-break:break-all}

.ban-section{background:#fff1f0;border:1px solid #ffccc7}
.ban-reason{color:#ff4d4f;font-weight:500}

.empty{display:flex;flex-direction:column;align-items:center;padding:60px 0}
.empty-icon{font-size:48px;margin-bottom:12px}
.empty-text{color:#999;font-size:14px}




