.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav-bar{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center;position:relative}
.back-btn{position:absolute;left:12px;color:#333;font-size:18px}
.title{font-size:18px;color:#333;font-weight:600}

.loading{display:flex;align-items:center;justify-content:center;padding:60px 0;color:#999;font-size:14px}

.content{height:calc(100vh - 44px);padding:12px}

.section{background:#fff;border-radius:12px;padding:16px;margin-bottom:12px}
.section-title{font-size:16px;color:#333;font-weight:600;margin-bottom:16px;display:block}

.info-item{display:flex;padding:8px 0;border-bottom:1px solid #f5f5f5}
.info-item:last-child{border-bottom:none}
.label{color:#666;font-size:14px;width:80px;flex-shrink:0}
.value{flex:1;color:#333;font-size:14px}

.status-pending{color:#faad14}
.status-active{color:#52c41a}
.status-suspended{color:#ff4d4f}
.status-rejected{color:#999}

.store-header{display:flex;align-items:center;margin-bottom:12px}
.store-logo{width:60px;height:60px;border-radius:8px;margin-right:12px}
.store-info{flex:1;display:flex;flex-direction:column}
.store-name{font-size:16px;color:#333;font-weight:600;margin-bottom:4px}
.store-status{font-size:12px}

.announcement{background:#f9f9f9;border-radius:8px;padding:12px;margin-top:12px}
.announcement-text{color:#666;font-size:14px;line-height:1.6}

.photo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.photo-item{width:100%;height:100px;border-radius:8px}

.category-list{display:flex;flex-wrap:wrap;gap:8px}
.category-item{background:#f9f9f9;border-radius:20px;padding:8px 16px;display:flex;align-items:center}
.category-icon{margin-right:4px;font-size:16px}
.category-name{color:#333;font-size:14px}

.product-list{display:flex;flex-direction:column;gap:12px}
.product-item{display:flex;align-items:center;padding:12px;background:#f9f9f9;border-radius:8px}
.product-image{width:60px;height:60px;border-radius:8px;margin-right:12px}
.product-info{flex:1;display:flex;flex-direction:column}
.product-name{font-size:15px;color:#333;font-weight:500;margin-bottom:4px}
.product-price{font-size:14px;color:#ff4d4f}
.product-status{display:flex;flex-direction:column;gap:4px}
.status-badge{font-size:12px;padding:2px 8px;border-radius:4px;text-align:center}
.status-badge.status-on{background:#e6f7ff;color:#1890ff}
.status-badge.status-off{background:#fff7e6;color:#faad14}
.audit-badge{font-size:12px;padding:2px 8px;border-radius:4px;text-align:center}
.audit-badge.audit-approved{background:#f6ffed;color:#52c41a}
.audit-badge.audit-pending{background:#fff7e6;color:#faad14}
.audit-badge.audit-rejected{background:#fff1f0;color:#ff4d4f}

.empty{display:flex;flex-direction:column;align-items:center;padding:60px 0}
.empty-icon{font-size:48px;margin-bottom:12px}
.empty-text{color:#999;font-size:14px}

