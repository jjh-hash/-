/* 管理端商家详情 - 设计系统 */
.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav-bar{height:44px;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;position:relative}
.back-btn{position:absolute;left:12px;color:var(--color-text);font-size:18px}
.title{font-size:18px;color:var(--color-text);font-weight:600}

.loading{display:flex;align-items:center;justify-content:center;padding:60px 0;color:var(--color-text-secondary);font-size:14px}
.content{height:calc(100vh - 44px);padding:12px}

.section{background:var(--color-bg-card);border-radius:var(--radius-card);padding:16px;margin-bottom:12px;box-shadow:var(--shadow-card)}
.section-title{font-size:16px;color:var(--color-text);font-weight:600;margin-bottom:16px;display:block}

.info-item{display:flex;padding:8px 0;border-bottom:1px solid var(--color-border)}
.info-item:last-child{border-bottom:none}
.label{color:var(--color-text-secondary);font-size:14px;width:80px;flex-shrink:0}
.value{flex:1;color:var(--color-text);font-size:14px}

.status-pending{color:var(--color-warning)}
.status-active{color:var(--color-success)}
.status-suspended{color:var(--color-danger)}
.status-rejected{color:var(--color-text-placeholder)}

.store-header{display:flex;align-items:center;margin-bottom:12px}
.store-logo{width:60px;height:60px;border-radius:var(--radius-btn);margin-right:12px}
.store-info{flex:1;display:flex;flex-direction:column}
.store-name{font-size:16px;color:var(--color-text);font-weight:600;margin-bottom:4px}
.store-status{font-size:12px}

.announcement{background:var(--color-bg-page);border-radius:var(--radius-btn);padding:12px;margin-top:12px}
.announcement-text{color:var(--color-text-secondary);font-size:14px;line-height:1.6}

.photo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.photo-item{width:100%;height:100px;border-radius:var(--radius-btn)}

.category-list{display:flex;flex-wrap:wrap;gap:8px}
.category-item{background:var(--color-bg-page);border-radius:var(--radius-tag);padding:8px 16px;display:flex;align-items:center}
.category-icon{margin-right:4px;font-size:16px}
.category-name{color:var(--color-text);font-size:14px}

.product-list{display:flex;flex-direction:column;gap:12px}
.product-item{display:flex;align-items:center;padding:12px;background:var(--color-bg-page);border-radius:var(--radius-btn)}
.product-image{width:60px;height:60px;border-radius:var(--radius-btn);margin-right:12px}
.product-info{flex:1;display:flex;flex-direction:column}
.product-name{font-size:15px;color:var(--color-text);font-weight:500;margin-bottom:4px}
.product-price{font-size:14px;color:var(--color-danger)}
.product-status{display:flex;flex-direction:column;gap:4px}
.status-badge{font-size:12px;padding:2px 8px;border-radius:var(--radius-tag);text-align:center}
.status-badge.status-on{background:var(--color-primary-light);color:var(--color-primary)}
.status-badge.status-off{background:rgba(255,152,0,0.12);color:var(--color-warning)}
.audit-badge{font-size:12px;padding:2px 8px;border-radius:var(--radius-tag);text-align:center}
.audit-badge.audit-approved{background:var(--color-primary-light);color:var(--color-success)}
.audit-badge.audit-pending{background:rgba(255,152,0,0.12);color:var(--color-warning)}
.audit-badge.audit-rejected{background:rgba(244,67,54,0.1);color:var(--color-danger)}

.empty{display:flex;flex-direction:column;align-items:center;padding:60px 0}
.empty-icon{font-size:48px;margin-bottom:12px}
.empty-text{color:var(--color-text-placeholder);font-size:14px}
