<view class="page">
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <text class="back" bindtap="onBack">◀</text>
      <text class="title">店铺信息</text>
      <view class="icons">
        <text class="dot">•</text>
        <text class="battery">▮</text>
      </view>
    </view>
    
    <!-- 标签栏 -->
    <view class="tabs">
      <view class="tab {{activeTab === 0 ? 'active' : ''}}" data-index="0" bindtap="onTabTap">点餐</view>
      <view class="tab {{activeTab === 1 ? 'active' : ''}}" data-index="1" bindtap="onTabTap">评价</view>
      <view class="tab {{activeTab === 2 ? 'active' : ''}}" data-index="2" bindtap="onTabTap">商家</view>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-container">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载商家信息...</text>
    </view>

    <!-- 错误状态 -->
    <view wx:elif="{{error}}" class="error-container">
      <view class="error-icon">⚠️</view>
      <text class="error-text">加载失败</text>
      <text class="error-desc">{{storeInfo.location}}</text>
      <button class="retry-btn" bindtap="onRetry">重新加载</button>
    </view>

    <!-- 商家信息 -->
    <view wx:else class="merchant-section">
      <!-- 店铺卡片（带头像） -->
      <view class="store-card-header">
        <image class="store-avatar" src="{{storeInfo.avatar || '/pages/小标/商家.png'}}" mode="aspectFill" />
        <view class="store-header-info">
          <view class="store-name-row">
            <text class="store-name-text">{{storeInfo.name}}</text>
          </view>
          <view class="contact-info-row">
            <text class="contact-label">联系方式:</text>
            <text class="contact-value">{{storeInfo.phone}}</text>
          </view>
        </view>
      </view>
      
      <view class="section-title">商家信息</view>
      
      <!-- 店铺名称 -->
      <view class="info-item">
        <view class="info-icon">🏪</view>
        <view class="info-content">
          <text class="info-text">{{storeInfo.name}}</text>
        </view>
      </view>
      
      <!-- 月售 -->
      <view class="info-item">
        <view class="info-icon">📦</view>
        <view class="info-content">
          <text class="info-text">月售{{storeInfo.monthlySales}}份</text>
        </view>
      </view>
      
      <!-- 位置 -->
      <view class="info-item">
        <view class="info-icon">📍</view>
        <view class="info-content">
          <text class="info-text">{{storeInfo.location}}</text>
        </view>
      </view>
      
      <!-- 电话 -->
      <view class="info-item">
        <view class="info-icon">📞</view>
        <view class="info-content">
          <text class="info-text">{{storeInfo.phone}}</text>
          <text class="call-btn" bindtap="onCallPhone">呼叫</text>
        </view>
      </view>
      
      <!-- 营业时间 -->
      <view class="info-item">
        <view class="info-icon">🕐</view>
        <view class="info-content">
          <text class="info-text">{{storeInfo.businessHours}}</text>
        </view>
      </view>
      
      <!-- 配送服务 -->
      <view class="info-item">
        <view class="info-icon">🚚</view>
        <view class="info-content">
          <text class="info-text">{{storeInfo.deliveryService}}</text>
        </view>
      </view>
      
      <!-- 公告 -->
      <view class="info-item" wx:if="{{storeInfo.announcement && storeInfo.announcement !== '暂无公告'}}">
        <view class="info-icon">📢</view>
        <view class="info-content">
          <text class="info-text">{{storeInfo.announcement}}</text>
        </view>
      </view>
      
      <!-- 简介 -->
      <view class="info-item" wx:if="{{storeInfo.introduction && storeInfo.introduction !== '暂无简介'}}">
        <view class="info-icon">📄</view>
        <view class="info-content">
          <text class="info-text">{{storeInfo.introduction}}</text>
        </view>
      </view>

      <!-- 刷新按钮 -->
      <view class="refresh-section">
        <button class="refresh-btn" bindtap="onRefresh">刷新信息</button>
      </view>
    </view>
  </scroll-view>
</view>
