.page {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 导航栏 */
.nav {
  background: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  position: relative;
}

.back {
  font-size: 18px;
  color: #333;
  font-weight: 600;
}

.title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.icons {
  display: flex;
  align-items: center;
  gap: 4px;
}

.dot {
  font-size: 12px;
  color: #999;
}

.battery {
  font-size: 12px;
  color: #999;
}

/* 标签栏 */
.tabs {
  display: flex;
  height: 44px;
  border-bottom: 1px solid #f0f0f0;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #999;
  position: relative;
  transition: all 0.2s ease;
}

.tab.active {
  color: #333;
  font-weight: 600;
}

/* 内容区域 */
.content {
  margin-top: 132px;
  padding: 0 16px;
}

/* 商家信息区域 */
.merchant-section {
  background: #fff;
  border-radius: 8px;
  padding: 20px;
  margin-bottom: 20px;
}

/* 店铺卡片头部 */
.store-card-header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  background: #f8f9fa;
  border-radius: 8px;
  margin-bottom: 20px;
}

.store-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  flex-shrink: 0;
  background: #e9ecef;
}

.store-header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.store-name-row {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.store-name-text {
  font-size: 18px;
  font-weight: 700;
  color: #333;
}

.contact-info-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
}

.contact-label {
  color: #666;
}

.contact-value {
  color: #333;
  font-weight: 500;
}

.section-title {
  font-size: 18px;
  font-weight: 700;
  color: #333;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}

/* 信息项 */
.info-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px 0;
  border-bottom: 1px solid #f8f9fa;
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 20px;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}

.info-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 24px;
}

.info-text {
  font-size: 15px;
  color: #333;
  line-height: 1.4;
  flex: 1;
}

.call-btn {
  font-size: 14px;
  color: #1976d2;
  font-weight: 600;
  padding: 4px 8px;
  border-radius: 4px;
  background: rgba(25, 118, 210, 0.1);
  flex-shrink: 0;
  margin-left: 12px;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  background: #fff;
  border-radius: 8px;
  margin-bottom: 20px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid #f0f0f0;
  border-top: 3px solid #1976d2;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16px;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: #666;
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  background: #fff;
  border-radius: 8px;
  margin-bottom: 20px;
}

.error-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.error-text {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.error-desc {
  font-size: 14px;
  color: #666;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 24px;
}

.retry-btn {
  background: #1976d2;
  color: #fff;
  border: none;
  border-radius: 6px;
  padding: 12px 24px;
  font-size: 14px;
  font-weight: 600;
}

/* 刷新按钮 */
.refresh-section {
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid #f0f0f0;
  text-align: center;
}

.refresh-btn {
  background: #f8f9fa;
  color: #666;
  border: 1px solid #e9ecef;
  border-radius: 6px;
  padding: 8px 16px;
  font-size: 14px;
  font-weight: 500;
}