/* 商家信息（审核等） - 设计系统 */
.page {
  background: var(--color-bg-page);
  min-height: 100vh;
}

.nav {
  background: var(--color-bg-card);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: var(--shadow-card);
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-page);
  position: relative;
}

.back {
  font-size: 18px;
  color: var(--color-text);
  font-weight: 600;
}

.title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
}

.icons {
  display: flex;
  align-items: center;
  gap: 4px;
}

.dot, .battery {
  font-size: 12px;
  color: var(--color-text-placeholder);
}

.tabs {
  display: flex;
  height: 44px;
  border-bottom: 1px solid var(--color-border);
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: var(--color-text-placeholder);
  position: relative;
  transition: all 0.2s ease;
}

.tab.active {
  color: var(--color-text);
  font-weight: 600;
}

/* 内容区域 */
.content {
  margin-top: 132px;
  padding: 0 var(--space-page);
}

.merchant-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-btn);
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: var(--shadow-card);
}

/* 店铺卡片头部 */
.store-card-header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: var(--space-block);
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  margin-bottom: 20px;
}

.store-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--color-border);
}

.store-header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.store-name-row {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.store-name-text {
  font-size: 18px;
  font-weight: 700;
  color: var(--color-text);
}

.contact-info-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
}

.contact-label {
  color: var(--color-text-secondary);
}

.contact-value {
  color: var(--color-text);
  font-weight: 500;
}

.section-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border);
}

/* 信息项 */
.info-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px 0;
  border-bottom: 1px solid var(--color-border);
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 20px;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}

.info-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 24px;
}

.info-text {
  font-size: 15px;
  color: var(--color-text);
  line-height: 1.4;
  flex: 1;
}

.call-btn {
  font-size: 14px;
  color: var(--color-primary);
  font-weight: 600;
  padding: 4px 8px;
  border-radius: var(--radius-tag);
  background: var(--color-primary-light);
  flex-shrink: 0;
  margin-left: 12px;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  background: var(--color-bg-card);
  border-radius: var(--radius-btn);
  margin-bottom: 20px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid var(--color-border);
  border-top: 3px solid var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16px;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: var(--color-text-secondary);
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  background: var(--color-bg-card);
  border-radius: var(--radius-btn);
  margin-bottom: 20px;
}

.error-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.error-text {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8px;
}

.error-desc {
  font-size: 14px;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.4;
  margin-bottom: 24px;
}

.retry-btn {
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-btn);
  padding: 12px 24px;
  font-size: 14px;
  font-weight: 600;
}

.refresh-section {
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid var(--color-border);
  text-align: center;
}

.refresh-btn {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-btn);
  padding: 8px 16px;
  font-size: 14px;
  font-weight: 500;
}