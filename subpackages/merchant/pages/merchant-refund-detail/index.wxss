/* 商家退款详情 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 80rpx;
}

.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: var(--color-bg-card);
}

.status-bar {
  background: var(--color-bg-card);
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 30rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.nav-bar .back {
  font-size: 36rpx;
  color: var(--color-text);
}

.nav-bar .title {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--color-text);
}

.nav-bar .icons {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}

.content {
  margin-top: 88rpx;
  padding: 20rpx;
}

.section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  min-width: 140rpx;
}

.info-value {
  font-size: 28rpx;
  color: var(--color-text);
  flex: 1;
  word-break: break-all;
}

.info-value.refund-amount {
  color: var(--color-danger);
  font-size: 32rpx;
  font-weight: 600;
}

.refund-status-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.refund-status-badge.pending {
  background: rgba(255, 152, 0, 0.15);
  color: var(--color-warning);
}

.refund-status-badge.approved {
  background: rgba(76, 175, 80, 0.2);
  color: #2e7d32;
}

.refund-status-badge.rejected {
  background: rgba(244, 67, 54, 0.15);
  color: var(--color-danger);
}

.refund-status-badge.processing {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.refund-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.refund-item:last-child {
  border-bottom: none;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.item-spec {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
  margin-bottom: 4rpx;
}

.item-quantity {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}

.item-price {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.images-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.refund-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--color-border);
}

.reject-reason-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: var(--color-bg-page);
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.reject-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.reject-actions button {
  flex: 1;
  height: 72rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.reject-actions button::after {
  border: none;
}

.btn-cancel {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
}

.btn-confirm {
  background: var(--color-danger);
  color: #fff;
}

.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  z-index: 1000;
}

.footer-actions button {
  flex: 1;
  height: 88rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.footer-actions button::after {
  border: none;
}

.btn-reject {
  background: var(--color-bg-card);
  color: var(--color-danger);
  border: 2rpx solid var(--color-danger);
}

.btn-approve {
  background: #52c41a;
  color: #fff;
}







