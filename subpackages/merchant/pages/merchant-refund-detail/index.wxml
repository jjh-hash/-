<view class="page">
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <text class="back" bindtap="onBack">◀</text>
      <text class="title">退款申请详情</text>
      <view class="icons">
        <text class="dot">•</text>
        <text class="battery">▮</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 订单信息 -->
    <view class="section" wx:if="{{orderInfo}}">
      <view class="section-title">订单信息</view>
      <view class="info-row">
        <text class="info-label">订单号：</text>
        <text class="info-value">{{orderInfo.orderNo}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">订单时间：</text>
        <text class="info-value">{{orderInfo.createdAt}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">订单金额：</text>
        <text class="info-value">¥{{orderInfo.total}}</text>
      </view>
    </view>

    <!-- 退款申请信息 -->
    <view class="section" wx:if="{{refundInfo}}">
      <view class="section-title">退款申请</view>
      <view class="refund-status-badge {{refundInfo.status}}">
        {{refundInfo.status === 'pending' ? '待处理' : refundInfo.status === 'approved' ? '已同意' : refundInfo.status === 'rejected' ? '已拒绝' : '处理中'}}
      </view>
      
      <view class="info-row">
        <text class="info-label">退款单号：</text>
        <text class="info-value">{{refundInfo.refundNo}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">退款金额：</text>
        <text class="info-value refund-amount">¥{{refundInfo.refundAmount}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">退款原因：</text>
        <text class="info-value">{{refundInfo.refundReason}}</text>
      </view>
      <view class="info-row" wx:if="{{refundInfo.refundReasonText}}">
        <text class="info-label">原因描述：</text>
        <text class="info-value">{{refundInfo.refundReasonText}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">申请时间：</text>
        <text class="info-value">{{refundInfo.createdAt}}</text>
      </view>
    </view>

    <!-- 退款商品 -->
    <view class="section" wx:if="{{refundInfo && refundInfo.selectedItems && refundInfo.selectedItems.length > 0}}">
      <view class="section-title">退款商品</view>
      <block wx:for="{{refundInfo.selectedItems}}" wx:key="id">
        <view class="refund-item">
          <image class="item-image" src="{{item.image || '/pages/小标/商家.png'}}" mode="aspectFill" />
          <view class="item-info">
            <view class="item-name">{{item.productName}}</view>
            <view class="item-spec" wx:if="{{item.spec}}">{{item.spec}}</view>
            <view class="item-quantity">x{{item.quantity}}</view>
          </view>
          <view class="item-price">¥{{item.price}}</view>
        </view>
      </block>
    </view>

    <!-- 退款凭证（图片） -->
    <view class="section" wx:if="{{refundInfo && refundInfo.images && refundInfo.images.length > 0}}">
      <view class="section-title">退款凭证</view>
      <view class="images-container">
        <block wx:for="{{refundInfo.images}}" wx:key="index" wx:for-index="imgIdx">
          <image 
            class="refund-image" 
            src="{{item}}" 
            mode="aspectFill"
            bindtap="onPreviewImage"
            data-index="{{imgIdx}}" />
        </block>
      </view>
    </view>

    <!-- 拒绝理由输入（如果显示） -->
    <view class="section" wx:if="{{showRejectInput}}">
      <view class="section-title">拒绝理由</view>
      <textarea 
        class="reject-reason-input" 
        placeholder="请输入拒绝退款的理由，该理由将发送给用户"
        value="{{rejectReason}}"
        bindinput="onRejectReasonInput"
        maxlength="200"
        show-confirm-bar="{{false}}">
      </textarea>
      <view class="reject-actions">
        <button class="btn-cancel" bindtap="onCancelReject">取消</button>
        <button class="btn-confirm" bindtap="onConfirmReject">确认拒绝</button>
      </view>
    </view>
  </scroll-view>

  <!-- 底部操作按钮 -->
  <view class="footer-actions" wx:if="{{refundInfo && refundInfo.status === 'pending' && !showRejectInput}}">
    <button class="btn-reject" bindtap="onShowRejectInput">拒绝退款</button>
    <button class="btn-approve" bindtap="onApproveRefund">同意退款</button>
  </view>
</view>







