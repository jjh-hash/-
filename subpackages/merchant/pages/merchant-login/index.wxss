.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav{height:44px;display:flex;align-items:center;justify-content:center;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);position:relative}
.back-btn{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--color-text);font-size:16px;opacity:.9}
.title{font-size:18px;color:var(--color-text);font-weight:600}
.content{padding:16px}
.desc{font-size:12px;color:var(--color-text-secondary);margin:12px 0 16px}
.btn{height:44px;min-height:44px;border-radius:var(--radius-btn);background:var(--color-bg-page);border:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;color:var(--color-text);margin-top:16px;font-size:16px}
.btn.primary{background:var(--color-primary);border-color:var(--color-primary);color:#fff}
.btn.secondary{background:var(--color-bg-card);border-color:var(--color-primary);color:var(--color-primary)}

.login-section{background:var(--color-bg-card);border-radius:var(--radius-card);padding:20px;margin-bottom:20px;box-shadow:var(--shadow-card)}
.section-title{font-size:16px;font-weight:600;color:#333;margin-bottom:20px}
.form-item{display:flex;flex-direction:column;margin-bottom:16px}
.form-item:last-child{margin-bottom:0}
.label{font-size:14px;color:#333;margin-bottom:8px}
.input{height:44px;padding:0 12px;background:#f5f5f5;border-radius:8px;font-size:15px;color:#333;border:1px solid #e0e0e0}
.input::placeholder{color:#999}

/* 分隔线 */
.divider{display:flex;align-items:center;margin:24px 0}
.divider-line{flex:1;height:1px;background:#e0e0e0}
.divider-text{font-size:12px;color:#999;padding:0 12px}

.wx-login-section{background:var(--color-bg-card);border-radius:var(--radius-card);padding:20px;box-shadow:var(--shadow-card)}

