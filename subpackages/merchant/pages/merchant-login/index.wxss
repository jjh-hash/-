.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav{height:44px;display:flex;align-items:center;justify-content:center;background:#fff;border-bottom:1px solid #f0f0f0;position:relative}
.back-btn{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#333;font-size:16px;opacity:.9}
.title{font-size:18px;color:#333;font-weight:600}
.content{padding:16px}
.desc{font-size:12px;color:#666;margin:12px 0 16px}
.btn{height:40px;border-radius:8px;background:#f0f0f0;border:1px solid #e0e0e0;display:flex;align-items:center;justify-content:center;color:#333;margin-top:16px;font-size:16px}
.btn.primary{background:#0a86ff;border-color:#0a86ff;color:#fff}
.btn.secondary{background:#fff;border-color:#0a86ff;color:#0a86ff}

/* 账户密码登录区域 */
.login-section{background:#fff;border-radius:12px;padding:20px;margin-bottom:20px}
.section-title{font-size:16px;font-weight:600;color:#333;margin-bottom:20px}
.form-item{display:flex;flex-direction:column;margin-bottom:16px}
.form-item:last-child{margin-bottom:0}
.label{font-size:14px;color:#333;margin-bottom:8px}
.input{height:44px;padding:0 12px;background:#f5f5f5;border-radius:8px;font-size:15px;color:#333;border:1px solid #e0e0e0}
.input::placeholder{color:#999}

/* 分隔线 */
.divider{display:flex;align-items:center;margin:24px 0}
.divider-line{flex:1;height:1px;background:#e0e0e0}
.divider-text{font-size:12px;color:#999;padding:0 12px}

/* 微信登录区域 */
.wx-login-section{background:#fff;border-radius:12px;padding:20px}

