<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  <view class="nav">
    <view class="back-btn" bindtap="onBackTap">◀</view>
    <text class="title">登录商家端</text>
  </view>
  <view class="content">
    <!-- 账户密码登录 -->
    <view class="login-section">
      <view class="section-title">账户密码登录</view>
      <view class="form-item">
        <text class="label">账号</text>
        <input 
          class="input" 
          type="text" 
          placeholder="请输入账号" 
          value="{{account}}" 
          bindinput="onAccountInput"
        />
      </view>
      <view class="form-item">
        <text class="label">密码</text>
        <input 
          class="input" 
          type="password" 
          placeholder="请输入密码" 
          value="{{password}}" 
          bindinput="onPasswordInput"
        />
      </view>
      <view class="btn primary" bindtap="onAccountLogin">登录</view>
    </view>

    <!-- 分隔线 -->
    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">或</text>
      <view class="divider-line"></view>
    </view>

    <!-- 微信一键登录 -->
    <view class="wx-login-section">
      <view class="desc">当前将使用微信身份进行一键登录（演示）。</view>
      <view class="btn secondary" bindtap="onWxLogin">一键登录</view>
    </view>
  </view>
</view>


