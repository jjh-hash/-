<view class="page">

  <!-- 总体评分 -->
  <view class="rating-overview">
    <view class="rating-left">
      <view class="stars">
        <text class="star {{ratingStats.overallRating >= 1 ? 'filled' : 'empty'}}">★</text>
        <text class="star {{ratingStats.overallRating >= 2 ? 'filled' : 'empty'}}">★</text>
        <text class="star {{ratingStats.overallRating >= 3 ? 'filled' : 'empty'}}">★</text>
        <text class="star {{ratingStats.overallRating >= 4 ? 'filled' : 'empty'}}">★</text>
        <text class="star {{ratingStats.overallRating >= 5 ? 'filled' : 'empty'}}">★</text>
      </view>
      <text class="review-count">共{{ratingStats.totalReviews}}人评价</text>
    </view>
    <view class="rating-right">
      <text class="rating-score">{{ratingStats.overallRating ? ratingStats.overallRating.toFixed(1) : '0.0'}}</text>
      <text class="rating-label">商品质量</text>
    </view>
  </view>

  <!-- 评价筛选标签 -->
  <view class="filter-tabs">
    <view class="tab {{activeTab===0?'active':''}}" bindtap="onTabTap" data-index="0">未回复</view>
    <view class="tab {{activeTab===1?'active':''}}" bindtap="onTabTap" data-index="1">全部评价</view>
  </view>

  <!-- 评价列表 -->
  <scroll-view scroll-y class="review-list">
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-container">
      <text>加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view wx:if="{{!loading && reviews.length === 0}}" class="empty-container">
      <text>{{activeTab === 0 ? '暂无未回复评价' : '暂无评价'}}</text>
    </view>
    
    <!-- 评价列表 -->
    <block wx:if="{{!loading && reviews.length > 0}}">
      <view class="review-item" wx:for="{{reviews}}" wx:key="id" wx:for-index="idx" wx:for-item="reviewItem">
        <view class="user-info">
          <image class="avatar" src="{{reviewItem.avatar}}" mode="aspectFill" />
          <view class="user-details">
            <text class="username">{{reviewItem.username}}</text>
            <view class="user-rating">
              <text class="star {{reviewItem.rating && reviewItem.rating >= 1 ? 'filled' : 'empty'}}">★</text>
              <text class="star {{reviewItem.rating && reviewItem.rating >= 2 ? 'filled' : 'empty'}}">★</text>
              <text class="star {{reviewItem.rating && reviewItem.rating >= 3 ? 'filled' : 'empty'}}">★</text>
              <text class="star {{reviewItem.rating && reviewItem.rating >= 4 ? 'filled' : 'empty'}}">★</text>
              <text class="star {{reviewItem.rating && reviewItem.rating >= 5 ? 'filled' : 'empty'}}">★</text>
            </view>
          </view>
          <text class="review-date">{{reviewItem.date}}</text>
        </view>
        
        <view class="review-content">
          <text class="review-text">{{reviewItem.content}}</text>
          
          <view class="review-images" wx:if="{{reviewItem.images && reviewItem.images.length > 0}}">
            <image 
              class="review-img" 
              wx:for="{{reviewItem.images}}" 
              wx:for-item="img" 
              wx:for-index="imgIndex"
              wx:key="{{reviewItem.id}}_{{imgIndex}}" 
              src="{{img}}" 
              mode="aspectFill"
              data-images="{{reviewItem.images}}"
              data-index="{{imgIndex}}"
              bindtap="onPreviewImage" />
          </view>
          
          <view class="merchant-reply" wx:if="{{reviewItem.reply}}">
            <text class="reply-label">商家回复:</text>
            <text class="reply-content">{{reviewItem.reply}}</text>
          </view>
          
          <!-- 回复按钮 -->
          <view class="reply-actions" wx:if="{{!reviewItem.hasReply}}">
            <view class="reply-btn" bindtap="onOpenReply" data-id="{{reviewItem.id}}">
              <text class="reply-btn-text">回复</text>
            </view>
          </view>
          
          <!-- 编辑回复按钮 -->
          <view class="reply-actions" wx:if="{{reviewItem.hasReply}}">
            <view class="reply-btn edit" bindtap="onOpenReply" data-id="{{reviewItem.id}}">
              <text class="reply-btn-text">编辑回复</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- 回复弹窗 -->
  <view class="reply-modal-mask {{showReplyModal ? 'show' : ''}}" bindtap="onCloseReply" wx:if="{{showReplyModal}}">
    <view class="reply-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">商家回复</text>
        <text class="modal-close" bindtap="onCloseReply">×</text>
      </view>
      
      <view class="modal-body">
        <textarea 
          class="reply-input" 
          placeholder="请输入回复内容..." 
          value="{{replyContent}}"
          bindinput="onReplyInput"
          bindfocus="onTextareaFocus"
          bindblur="onTextareaBlur"
          maxlength="500"
          auto-height
        ></textarea>
        <view class="char-count">{{replyContent.length}}/500</view>
      </view>
      
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="onCloseReply">取消</view>
        <view class="modal-btn submit" bindtap="onSubmitReply">
          <text wx:if="{{!replying}}">提交</text>
          <text wx:else>提交中...</text>
        </view>
      </view>
    </view>
  </view>
</view>
