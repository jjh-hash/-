/* 商家设置 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar {
  width: 100%;
  background: var(--color-bg-card);
}

.nav-bar {
  height: 44px;
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
}

.nav-left {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 24px;
  color: var(--color-text);
  font-weight: 300;
}

.nav-title {
  font-size: 18px;
  color: var(--color-text);
  font-weight: 600;
}

.nav-right {
  width: 44px;
}

.content {
  padding: var(--space-page);
}

.section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  margin-bottom: var(--space-block);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 16px;
  color: var(--color-text);
  font-weight: 600;
  padding: var(--space-block) var(--space-block) 8px;
  background: var(--color-bg-page);
  border-bottom: 1px solid var(--color-border);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-block);
  border-bottom: 1px solid var(--color-border);
  transition: background-color 0.2s ease;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: var(--color-bg-page);
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.item-icon {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-right: 12px;
  flex-shrink: 0;
}

.item-icon.store { background: var(--color-primary-light); }
.item-icon.time { background: rgba(255, 152, 0, 0.12); }
.item-icon.delivery { background: rgba(76, 175, 80, 0.12); }
.item-icon.money { background: rgba(255, 87, 34, 0.12); }
.item-icon.order { background: var(--color-primary-light); }
.item-icon.bell { background: rgba(244, 67, 54, 0.1); }
.item-icon.print { background: rgba(156, 39, 176, 0.1); }
.item-icon.payment { background: rgba(0, 188, 212, 0.12); }
.item-icon.settlement { background: var(--color-primary-light); }
.item-icon.notification { background: var(--color-primary-light); }
.item-icon.sound { background: rgba(255, 152, 0, 0.12); }
.item-icon.security { background: rgba(244, 67, 54, 0.1); }
.item-icon.verify { background: rgba(76, 175, 80, 0.12); }
.item-icon.cache { background: var(--color-bg-page); }
.item-icon.about { background: var(--color-primary-light); }
.item-icon.logout { background: rgba(244, 67, 54, 0.1); }

.item-content {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  font-size: 16px;
  color: var(--color-text);
  font-weight: 500;
  margin-bottom: 4px;
}

.logout-text {
  color: var(--color-danger);
}

.item-desc {
  display: block;
  font-size: 14px;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.arrow {
  font-size: 16px;
  color: var(--color-text-placeholder);
  font-weight: 300;
  margin-left: 8px;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
