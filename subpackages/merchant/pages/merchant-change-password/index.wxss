/* 商家修改密码 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-primary);
}

.status-bar {
  background: transparent;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.back-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 10rpx;
  cursor: pointer;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.nav-placeholder {
  width: 56rpx;
}

.page-content {
  padding: 40rpx 30rpx;
}

/* 表单区域 */
.form-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  height: 88rpx;
  padding: 0 20rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  color: var(--color-text);
}

.eye-icon {
  position: absolute;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  cursor: pointer;
}

/* 提示信息 */
.tips-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-card);
}

.tips-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.tips-text:last-child {
  margin-bottom: 0;
}

/* 提交按钮 */
.submit-section {
  margin-top: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: var(--shadow-card);
}

.submit-btn.disabled {
  background: var(--color-text-placeholder);
  box-shadow: none;
}

.submit-btn::after {
  border: none;
}

