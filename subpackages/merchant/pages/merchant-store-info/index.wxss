.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center;position:relative}
.back{position:absolute;left:12px;color:#333}
.title{font-size:18px;color:#333;font-weight:600}

.section-title{margin:12px;color:#333;font-weight:600}
.list{background:#fff;margin:0 12px 12px;border-radius:12px;overflow:hidden}
.cell{display:flex;align-items:center;justify-content:space-between;padding:14px 12px;border-bottom:1px solid #f2f3f5;color:#333}
.cell:last-child{border-bottom:none}
.label{color:#333}
.input{flex:1;text-align:right;color:#333}
.placeholder{flex:1;text-align:right;color:#c0c4cc}
.time-display{flex:1;text-align:right;color:#333}
.arrow{color:#c0c4cc;margin-left:8px}
.picker-view{display:flex;align-items:center;flex:1;justify-content:flex-end}
.picker-text{color:#333;text-align:right}
.picker-placeholder{color:#c0c4cc;text-align:right}
.avatar .right{display:flex;align-items:center}
.avatar-img{width:28px;height:28px;border-radius:14px}
.price{display:flex;align-items:center}
.short{width:60px;text-align:right}
.unit{margin-left:6px;color:#333}
.save-wrap{padding:20px 12px}
.btn.primary{height:44px;border-radius:22px;background:#1677ff;color:#fff;display:flex;align-items:center;justify-content:center}

/* 时间选择弹窗样式 */
.time-picker-modal{
  position:fixed;
  top:0;
  left:0;
  right:0;
  bottom:0;
  background:rgba(0,0,0,0.5);
  display:flex;
  align-items:flex-end;
  z-index:1000;
  opacity:0;
  visibility:hidden;
  transition:all 0.3s ease;
}
.time-picker-modal.show{
  opacity:1;
  visibility:visible;
}
.modal-content{
  background:#fff;
  width:100%;
  border-radius:12px 12px 0 0;
  padding:0 0 env(safe-area-inset-bottom) 0;
  transform:translateY(100%);
  transition:transform 0.3s ease;
}
.time-picker-modal.show .modal-content{
  transform:translateY(0);
}
.modal-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:16px 20px;
  border-bottom:1px solid #f0f0f0;
}
.cancel-btn{color:#666;font-size:16px}
.confirm-btn{color:#1677ff;font-size:16px;font-weight:500}
.time-display-section{
  display:flex;
  align-items:center;
  justify-content:center;
  padding:20px;
  gap:12px;
}
.time-box{
  padding:12px 20px;
  border:1px solid #e0e0e0;
  border-radius:8px;
  background:#f8f9fa;
  transition:all 0.2s ease;
}
.time-box.active{
  border-color:#1677ff;
  background:#f0f7ff;
}
.time-text{font-size:16px;color:#333;font-weight:500}
.time-separator{font-size:16px;color:#666;margin:0 8px}
.time-picker-container{
  display:flex;
  align-items:center;
  justify-content:center;
  padding:20px;
  gap:8px;
}
.picker-column{
  display:flex;
  flex-direction:column;
  align-items:center;
  height:120px;
  overflow-y:auto;
  scroll-behavior:smooth;
  position:relative;
}
.picker-item{
  padding:8px 16px;
  font-size:18px;
  text-align:center;
  min-height:36px;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  transition:all 0.2s ease;
  border-radius:4px;
  margin:2px 0;
}
.picker-item:hover{
  background:#f0f7ff;
}
.picker-item:active{
  background:#e6f3ff;
}
.picker-label{
  font-size:14px;
  color:#666;
  margin:0 4px;
}

