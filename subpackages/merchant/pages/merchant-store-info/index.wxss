/* 商家店铺信息 - 设计系统 */
.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav{height:44px;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;position:relative}
.back{position:absolute;left:12px;color:var(--color-text)}
.title{font-size:18px;color:var(--color-text);font-weight:600}

.section-title{margin:12px;color:var(--color-text);font-weight:600}
.list{background:var(--color-bg-card);margin:0 12px 12px;border-radius:var(--radius-card);overflow:hidden;box-shadow:var(--shadow-card)}
.cell{display:flex;align-items:center;justify-content:space-between;padding:14px 12px;border-bottom:1px solid var(--color-border);color:var(--color-text)}
.cell:last-child{border-bottom:none}
.label{color:var(--color-text)}
.input{flex:1;text-align:right;color:var(--color-text)}
.placeholder{flex:1;text-align:right;color:var(--color-text-placeholder)}
.time-display{flex:1;text-align:right;color:var(--color-text)}
.arrow{color:var(--color-text-placeholder);margin-left:8px}
.picker-view{display:flex;align-items:center;flex:1;justify-content:flex-end}
.picker-text{color:var(--color-text);text-align:right}
.picker-placeholder{color:var(--color-text-placeholder);text-align:right}
.avatar .right{display:flex;align-items:center}
.avatar-img{width:28px;height:28px;border-radius:14px}
.price{display:flex;align-items:center}
.short{width:60px;text-align:right}
.unit{margin-left:6px;color:var(--color-text)}
.save-wrap{padding:20px 12px}
.btn.primary{height:44px;border-radius:22px;background:var(--color-primary);color:#fff;display:flex;align-items:center;justify-content:center}

/* 时间选择弹窗样式 */
.time-picker-modal{
  position:fixed;
  top:0;
  left:0;
  right:0;
  bottom:0;
  background:rgba(0,0,0,0.5);
  display:flex;
  align-items:flex-end;
  z-index:1000;
  opacity:0;
  visibility:hidden;
  transition:all 0.3s ease;
}
.time-picker-modal.show{
  opacity:1;
  visibility:visible;
}
.modal-content{
  background:var(--color-bg-card);
  width:100%;
  border-radius:var(--radius-card) var(--radius-card) 0 0;
  padding:0 0 env(safe-area-inset-bottom) 0;
  transform:translateY(100%);
  transition:transform 0.3s ease;
}
.time-picker-modal.show .modal-content{
  transform:translateY(0);
}
.modal-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:16px 20px;
  border-bottom:1px solid var(--color-border);
}
.cancel-btn{color:var(--color-text-secondary);font-size:16px}
.confirm-btn{color:var(--color-primary);font-size:16px;font-weight:500}
.time-display-section{
  display:flex;
  align-items:center;
  justify-content:center;
  padding:20px;
  gap:12px;
}
.time-box{
  padding:12px 20px;
  border:1px solid var(--color-border);
  border-radius:var(--radius-btn);
  background:var(--color-bg-page);
  transition:all 0.2s ease;
}
.time-box.active{
  border-color:var(--color-primary);
  background:var(--color-primary-light);
}
.time-text{font-size:16px;color:var(--color-text);font-weight:500}
.time-separator{font-size:16px;color:var(--color-text-secondary);margin:0 8px}
.time-picker-container{
  display:flex;
  align-items:center;
  justify-content:center;
  padding:20px;
  gap:8px;
}
.picker-column{
  display:flex;
  flex-direction:column;
  align-items:center;
  height:120px;
  overflow-y:auto;
  scroll-behavior:smooth;
  position:relative;
}
.picker-item{
  padding:8px 16px;
  font-size:18px;
  text-align:center;
  min-height:36px;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  transition:all 0.2s ease;
  border-radius:4px;
  margin:2px 0;
}
.picker-item:hover{
  background:var(--color-primary-light);
}
.picker-item:active{
  background:var(--color-primary-light);
}
.picker-label{
  font-size:14px;
  color:var(--color-text-secondary);
  margin:0 4px;
}

