/* 商家我的 - 设计系统 */
.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav{height:44px;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);display:flex;align-items:center;justify-content:center}
.title{font-size:18px;color:var(--color-text);font-weight:600}

.user-card{margin:12px;background:var(--color-primary-light);border-radius:var(--radius-card);display:flex;align-items:center;padding:12px}
.avatar{width:48px;height:48px;border-radius:24px;margin-right:10px}
.u-meta{flex:1}
.row{display:flex;align-items:center;gap:6px}
.name{font-weight:600;color:var(--color-text)}
.tag{font-size:12px;color:var(--color-primary);background:var(--color-primary-light);border:1px solid var(--color-primary);border-radius:var(--radius-tag);padding:2px 8px}
.info{display:block;color:var(--color-text-secondary);font-size:12px;margin-top:4px}

.income{margin:12px;background:var(--color-bg-card);border-radius:var(--radius-card);padding:12px;display:flex;justify-content:space-between;align-items:center;box-shadow:var(--shadow-card)}
.strong{display:block;color:var(--color-text);font-weight:600}
.sub{display:block;color:var(--color-text-placeholder);font-size:12px;margin-top:4px}
.right{width:72px;height:48px;background:var(--color-bg-page);border-radius:var(--radius-btn)}

.list{background:var(--color-bg-card);margin:12px;border-radius:var(--radius-card);overflow:hidden;box-shadow:var(--shadow-card)}
.cell{display:flex;align-items:center;justify-content:space-between;padding:14px 12px;border-bottom:1px solid var(--color-border);color:var(--color-text)}
.cell:last-child{border-bottom:none}
.arrow{color:var(--color-text-placeholder)}

.tabbar{position:fixed;left:0;right:0;bottom:0;background:var(--color-bg-card);border-top:1px solid var(--color-border);display:flex;justify-content:space-around;padding:6px 0}
.t-item{display:flex;flex-direction:column;align-items:center;color:var(--color-text-placeholder)}
.t-item.active{color:var(--color-primary)}
.t-img{width:22px;height:22px}
.t-txt{font-size:12px;margin-top:2px}
