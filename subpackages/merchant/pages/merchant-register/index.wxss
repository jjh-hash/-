/* 商家注册 - 设计系统 */
.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav{height:44px;display:flex;align-items:center;justify-content:center;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);position:relative}
.back-btn{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--color-text);font-size:16px;opacity:.9}
.title{font-size:18px;color:var(--color-text);font-weight:600}
.content{padding:var(--space-page)}
.campus-bar{font-size:13px;color:var(--color-text-secondary);background:var(--color-primary-light);border-radius:var(--radius-btn);padding:10px 12px;margin-bottom:12px;line-height:1.5}
.field{background:var(--color-bg-card);border-radius:var(--radius-btn);padding:12px;margin-bottom:12px}
.label{display:block;color:var(--color-text-secondary);font-size:12px;margin-bottom:6px}
.input{height:36px;background:var(--color-bg-page);border:1px solid var(--color-border);border-radius:var(--radius-btn);padding:0 10px}
.tip{font-size:12px;color:var(--color-text-placeholder);margin:8px 0 16px;line-height:1.6}
.tip-item{margin-bottom:4px}
.tip-item:last-child{margin-bottom:0}
.btn{height:40px;border-radius:var(--radius-btn);background:var(--color-bg-page);border:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;color:var(--color-text)}
.btn.primary{background:var(--color-primary);border-color:var(--color-primary);color:#fff}
