/* 商家商品 - 设计系统 */
.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav{height:44px;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;position:relative}
.back{position:absolute;left:12px}
.title{font-size:18px;color:var(--color-text);font-weight:600}
.tools{position:absolute;right:12px}

.tabs{display:flex;justify-content:center;gap:40px;background:var(--color-bg-card);border-bottom:1px solid var(--color-border)}
.tab{padding:10px 0;color:var(--color-text-secondary)}
.tab.active{color:var(--color-primary);font-weight:600;position:relative}
.tab.active::after{content:'';position:absolute;left:50%;bottom:0;transform:translateX(-50%);width:24px;height:2px;background:var(--color-primary);border-radius:1px}

.content{display:flex;height:calc(100vh - 44px - 44px)}
.cats{width:90px;background:var(--color-bg-card);border-right:1px solid var(--color-border)}
.cat{padding:12px 10px;color:var(--color-text)}
.cat.active{color:var(--color-primary);background:var(--color-primary-light);border-left:2px solid var(--color-primary)}
.goods{flex:1}
.swipe-item{position:relative;margin:10px;border-radius:var(--radius-btn);overflow:hidden;background:var(--color-bg-card)}
.swipe-content{display:flex;align-items:center;padding:10px;background:var(--color-bg-card);transition:transform 0.3s ease;position:relative;z-index:2}
.thumb{width:54px;height:54px;border-radius:var(--radius-btn);margin-right:10px}
.meta{flex:1}
.name{color:var(--color-text)}
.price{color:var(--color-danger);font-size:12px;margin-top:2px;display:block}
.swipe-actions{position:absolute;right:0;top:0;bottom:0;display:flex;z-index:1}
.action-btn{width:60px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px}
.action-btn.edit{background:var(--color-primary)}
.action-btn.delete{background:var(--color-danger)}
.add-wrap{padding:10px}
.add-btn{border:1px solid var(--color-primary);color:var(--color-primary);height:40px;border-radius:var(--radius-btn);display:flex;align-items:center;justify-content:center;background:var(--color-bg-card)}

.empty-state{padding:40px 20px;text-align:center}
.empty-text{display:block;color:var(--color-text-secondary);font-size:14px;margin-bottom:8px}
.empty-desc{display:block;color:var(--color-text-placeholder);font-size:12px}
