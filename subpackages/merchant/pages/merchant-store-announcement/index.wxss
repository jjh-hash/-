/* 商家公告 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar {
  width: 100%;
  background: var(--color-bg-card);
}

.nav-bar {
  height: 44px;
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-page);
}

.nav-left {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 24px;
  color: var(--color-text);
  font-weight: 300;
}

.nav-title {
  font-size: 18px;
  color: var(--color-text);
  font-weight: 600;
}

.nav-right {
  width: 44px;
}

.content {
  padding: var(--space-page);
  min-height: calc(100vh - 44px - env(safe-area-inset-bottom));
}

.announcement-section {
  margin-bottom: 20px;
}

.textarea-container {
  position: relative;
  background: var(--color-bg-card);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-btn);
  padding: var(--space-block);
  min-height: 200px;
}

.announcement-textarea {
  width: 100%;
  min-height: 180px;
  font-size: 16px;
  color: var(--color-text);
  line-height: 1.5;
  border: none;
  outline: none;
  resize: none;
  background: transparent;
}

.announcement-textarea::placeholder {
  color: var(--color-text-placeholder);
  font-size: 16px;
}

.char-counter {
  position: absolute;
  bottom: 8px;
  right: 12px;
  font-size: 12px;
  color: var(--color-text-placeholder);
  background: var(--color-bg-card);
  padding: 2px 4px;
  border-radius: var(--radius-tag);
}

.confirm-section {
  margin-top: 20px;
}

.confirm-btn {
  width: 100%;
  height: 48px;
  background: var(--color-border);
  color: var(--color-text-secondary);
  border-radius: var(--radius-btn);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 500;
  transition: all 0.3s ease;
  cursor: pointer;
}

.confirm-btn.active {
  background: var(--color-primary);
  color: #fff;
}

.confirm-btn.active:active {
  opacity: 0.9;
  transform: scale(0.98);
}
