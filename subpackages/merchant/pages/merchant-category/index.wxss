/* 商家类目 - 设计系统 */
.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav{height:44px;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;position:relative}
.back{position:absolute;left:12px;color:var(--color-text)}
.title{font-size:18px;color:var(--color-text);font-weight:600}

.list{background:var(--color-bg-card);margin:12px;border-radius:var(--radius-card);overflow:hidden;box-shadow:var(--shadow-card)}
.swipe-item{position:relative;overflow:hidden}
.swipe-content{display:flex;align-items:center;padding:16px 12px;border-bottom:1px solid var(--color-border);background:var(--color-bg-card);transition:transform 0.3s ease;position:relative;z-index:2}
.swipe-content:last-child{border-bottom:none}
.c-text{color:var(--color-text);flex:1}
.swipe-actions{position:absolute;right:0;top:0;bottom:0;display:flex;z-index:1}
.action-btn{width:60px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px}
.action-btn.edit{background:var(--color-primary)}
.action-btn.delete{background:var(--color-danger)}

.footer{position:fixed;left:0;right:0;bottom:0;background:var(--color-bg-card);border-top:1px solid var(--color-border);padding:10px}
.add-btn{height:44px;border-radius:22px;border:1px solid var(--color-primary);color:var(--color-primary);display:flex;align-items:center;justify-content:center;margin:0 12px;background:var(--color-primary-light)}
