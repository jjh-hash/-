.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center;position:relative}
.back{position:absolute;left:12px;color:#333}
.title{font-size:18px;color:#333;font-weight:600}

.list{background:#fff;margin:12px;border-radius:12px;overflow:hidden}
.swipe-item{position:relative;overflow:hidden}
.swipe-content{display:flex;align-items:center;padding:16px 12px;border-bottom:1px solid #f2f3f5;background:#fff;transition:transform 0.3s ease;position:relative;z-index:2}
.swipe-content:last-child{border-bottom:none}
.c-text{color:#333;flex:1}
.swipe-actions{position:absolute;right:0;top:0;bottom:0;display:flex;z-index:1}
.action-btn{width:60px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px}
.action-btn.edit{background:#1677ff}
.action-btn.delete{background:#ff5959}

.footer{position:fixed;left:0;right:0;bottom:0;background:#fff;border-top:1px solid #eee;padding:10px}
.add-btn{height:44px;border-radius:22px;border:1px solid #1677ff;color:#1677ff;display:flex;align-items:center;justify-content:center;margin:0 12px;background:#f7fbff}

