<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  <view class="nav">
    <view class="back" bindtap="onBack">◀</view>
    <text class="title">商品分类</text>
  </view>

  <view class="list" bindtap="onListAreaTap">
    <block wx:for="{{cats}}" wx:key="id">
      <view class="swipe-item" data-id="{{item.id}}">
        <view class="swipe-content" 
              style="transform: translateX({{item.swipeOffset || 0}}px)"
              bindtouchstart="onTouchStart" 
              bindtouchmove="onTouchMove" 
              bindtouchend="onTouchEnd"
              data-id="{{item.id}}">
          <text class="c-text">{{item.name}}</text>
        </view>
        <view class="swipe-actions">
          <view class="action-btn edit" bindtap="onEdit" data-id="{{item.id}}">编辑</view>
          <view class="action-btn delete" bindtap="onDelete" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </block>
  </view>

  <view class="footer">
    <view class="add-btn" bindtap="onAdd">+添加分类</view>
  </view>
</view>


