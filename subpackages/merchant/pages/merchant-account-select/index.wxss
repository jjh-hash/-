.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(24px + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.nav-row {
  display: flex;
  align-items: center;
  padding: 12px 16px 8px;
  color: #1677ff;
  font-size: 15px;
}

.nav-back {
  font-size: 22px;
  line-height: 1;
  margin-right: 4px;
  font-weight: 300;
}

.nav-text {
  font-size: 15px;
}

.header {
  padding: 8px 20px 20px;
}

.title {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 10px;
}

.subtitle {
  font-size: 14px;
  color: #666;
  line-height: 1.5;
}

.accent {
  color: #52c41a;
  font-weight: 600;
}

.section-label {
  font-size: 13px;
  color: #999;
  padding: 0 20px 8px;
}

.card-list {
  padding: 0 16px;
}

.account-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 12px;
  padding: 16px 14px;
  margin-bottom: 12px;
  border: 2px solid transparent;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
}

.account-card--active {
  border-color: #1677ff;
  background: #f0f7ff;
}

.card-main {
  flex: 1;
  min-width: 0;
}

.name {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 6px;
}

.account-line {
  display: block;
  font-size: 13px;
  color: #888;
  word-break: break-all;
}

.tag {
  flex-shrink: 0;
  margin-left: 10px;
  font-size: 12px;
  color: #1677ff;
  background: rgba(22, 119, 255, 0.12);
  padding: 4px 10px;
  border-radius: 4px;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent, #f5f7fa 30%);
}

.btn-continue {
  width: 100%;
  height: 48px;
  line-height: 48px;
  background: #1677ff;
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.btn-continue::after {
  border: none;
}

.btn-continue[disabled] {
  opacity: 0.45;
}

.arrow {
  font-size: 20px;
  font-weight: 300;
}
