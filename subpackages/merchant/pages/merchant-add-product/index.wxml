<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  <view class="nav">
    <view class="back" bindtap="onBack">◀</view>
    <text class="title">{{isEditMode ? '编辑商品' : '添加商品'}}</text>
  </view>

  <view class="form-container">
    <!-- 基本信息 -->
    <view class="section">
      <text class="section-title">基本信息</text>
      
      <view class="form-item">
        <text class="label">商品名称</text>
        <input class="input" placeholder="请输入商品名称" value="{{formData.name}}" bindinput="onInput" data-field="name" />
      </view>
      
      <view class="form-item" bindtap="onSelectCategory">
        <text class="label">商品分类</text>
        <view class="select-value">
          <text class="placeholder {{formData.categoryName ? 'selected' : ''}}">{{formData.categoryName || '请选择分类'}}</text>
          <text class="arrow">></text>
        </view>
      </view>
      
      <view class="form-item">
        <text class="label">备餐用时</text>
        <input class="input" placeholder="如15 分" value="{{formData.prepTime}}" bindinput="onInput" data-field="prepTime" />
      </view>
      
      <view class="form-item upload-item">
        <text class="label">上传图片</text>
        <text class="upload-hint">请保证图片的清晰度(400*400)</text>
        <view class="upload-area" bindtap="onUploadImage">
          <image wx:if="{{formData.image}}" class="uploaded-image" src="{{formData.image}}" mode="aspectFill" />
          <view wx:else class="upload-placeholder">
            <text class="camera-icon">📷</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 价格信息 -->
    <view class="section">
      <text class="section-title">价格信息</text>
      
      <view class="form-item">
        <text class="label">价格</text>
        <input class="input" placeholder="如17 元" value="{{formData.price}}" bindinput="onInput" data-field="price" />
      </view>
    </view>

    <!-- 规格信息 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">规格信息</text>
        <view class="add-spec-group-btn" bindtap="addSpecGroup">
          <text class="add-icon">+</text>
          <text class="add-text">添加规格组</text>
        </view>
      </view>
      
      <view wx:if="{{formData.specifications && formData.specifications.length > 0}}" class="spec-groups">
        <block wx:for="{{formData.specifications}}" wx:key="index" wx:for-item="group">
          <view class="spec-group">
            <view class="spec-group-header">
              <input 
                class="spec-group-name-input" 
                placeholder="规格组名称，如：份量" 
                value="{{group.name}}" 
                bindinput="updateSpecGroupName"
                data-index="{{index}}"
              />
              <view class="delete-group-btn" bindtap="removeSpecGroup" data-index="{{index}}">
                <text class="delete-icon">🗑️</text>
              </view>
            </view>
            
            <!-- 规格组类型选择 -->
            <view class="spec-group-type">
              <text class="spec-type-label">选择类型：</text>
              <view class="spec-type-options">
                <view 
                  class="spec-type-item {{(!group.type || group.type === 'single') ? 'active' : ''}}"
                  bindtap="updateSpecGroupType"
                  data-index="{{index}}"
                  data-type="single"
                >
                  <text>单选</text>
                </view>
                <view 
                  class="spec-type-item {{group.type === 'required' ? 'active' : ''}}"
                  bindtap="updateSpecGroupType"
                  data-index="{{index}}"
                  data-type="required"
                >
                  <text>必选</text>
                </view>
                <view 
                  class="spec-type-item {{group.type === 'multiple' ? 'active' : ''}}"
                  bindtap="updateSpecGroupType"
                  data-index="{{index}}"
                  data-type="multiple"
                >
                  <text>多选</text>
                </view>
              </view>
            </view>
            
            <view class="spec-options">
              <block wx:for="{{group.options}}" wx:key="index" wx:for-item="option" wx:for-index="optionIndex">
                <view class="spec-option-item">
                  <input 
                    class="spec-option-name" 
                    placeholder="规格项名称" 
                    value="{{option.name}}" 
                    bindinput="updateSpecOption"
                    data-group-index="{{index}}"
                    data-option-index="{{optionIndex}}"
                    data-field="name"
                  />
                  <text class="spec-option-price-label">加价</text>
                  <input 
                    class="spec-option-price" 
                    type="digit" 
                    placeholder="0" 
                    value="{{option.price}}" 
                    bindinput="updateSpecOption"
                    data-group-index="{{index}}"
                    data-option-index="{{optionIndex}}"
                    data-field="price"
                  />
                  <text class="spec-option-price-unit">元</text>
                  <view class="delete-option-btn" bindtap="removeSpecOption" data-group-index="{{index}}" data-option-index="{{optionIndex}}">
                    <text class="delete-icon-small">×</text>
                  </view>
                </view>
              </block>
              <view class="add-option-btn" bindtap="addSpecOption" data-index="{{index}}">
                <text class="add-icon-small">+</text>
                <text class="add-option-text">添加规格项</text>
              </view>
            </view>
          </view>
        </block>
      </view>
      
      <view wx:else class="empty-specs">
        <text class="empty-text">暂无规格，点击上方"添加规格组"开始设置</text>
      </view>
    </view>
  </view>

  <!-- 上架中：显示保存按钮和下架按钮 -->
  <block wx:if="{{productStatus === 'on'}}">
    <view class="save-btn" bindtap="onSave">保存</view>
    <view wx:if="{{isEditMode}}" class="offline-btn" bindtap="onOffline">下架该商品</view>
  </block>
  
  <!-- 下架中：只显示上架按钮 -->
  <block wx:else>
    <view wx:if="{{isEditMode}}" class="save-btn" bindtap="onOnline">上架该商品</view>
  </block>

  <!-- 分类选择弹窗 -->
  <view class="category-modal-overlay {{showCategoryModal ? 'show' : ''}}" bindtap="onCloseCategoryModal">
    <view class="category-modal" catchtap="">
      <view class="category-modal-header">
        <text class="category-modal-title">选择分类</text>
        <text class="category-modal-close" bindtap="onCloseCategoryModal">✕</text>
      </view>
      <scroll-view class="category-modal-content" scroll-y>
        <view 
          class="category-modal-item {{formData.categoryId === item.id ? 'selected' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          bindtap="onCategoryItemTap"
          data-index="{{index}}"
        >
          <text class="category-modal-item-name">{{item.name}}</text>
          <text wx:if="{{formData.categoryId === item.id}}" class="category-modal-item-check">✓</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
