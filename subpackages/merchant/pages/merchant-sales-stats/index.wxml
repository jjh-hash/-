<view class="page">

  <!-- 销售概览 -->
  <view class="sales-overview">
    <view class="total-sales">
      <text class="amount">¥ {{totalSales}}</text>
      <!-- 上涨：红色向上箭头 -->
      <view wx:if="{{isGrowthPositive && dailyGrowthDisplay != '0.00'}}" class="growth growth-up">
        <text class="growth-arrow">↑</text>
        <text class="growth-amount">上涨 ¥{{dailyGrowthDisplay}}</text>
      </view>
      <!-- 下跌：绿色向下箭头 -->
      <view wx:elif="{{!isGrowthPositive && dailyGrowthDisplay != '0.00'}}" class="growth growth-down">
        <text class="growth-arrow">↓</text>
        <text class="growth-amount">下跌 ¥{{dailyGrowthDisplay}}</text>
      </view>
      <!-- 持平：灰色 -->
      <view wx:else class="growth growth-zero">
        <text class="growth-amount">持平</text>
      </view>
    </view>
  </view>

  <!-- 关键指标卡片 -->
  <view class="metrics-card">
    <view class="metric-left">
      <text class="metric-label">当前收益/元</text>
      <text class="metric-value">¥ {{currentRevenue}}</text>
    </view>
    <view class="metric-divider"></view>
    <view class="metric-right">
      <text class="metric-label">有效订单/单</text>
      <text class="metric-value">{{effectiveOrders}}</text>
    </view>
  </view>

  <!-- 销售数据图表 -->
  <view class="chart-section">
    <view class="chart-header">
      <text class="chart-title">销售数据</text>
      <view class="legend">
        <view class="legend-item">
          <view class="legend-dot orders"></view>
          <text class="legend-text">订单</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot revenue"></view>
          <text class="legend-text">收益</text>
        </view>
      </view>
      <text class="unit">单位:100</text>
    </view>
    
    <view class="bar-chart">
      <view class="chart-container">
        <view wx:if="{{chartData.length === 0}}" class="empty-chart">
          <text>暂无数据</text>
        </view>
        <view wx:else>
          <view class="bars">
            <view class="bar-group" wx:for="{{chartData}}" wx:key="date" bindtap="onBarClick" data-index="{{index}}">
              <view class="bar-wrapper">
                <view class="bar orders" style="height: {{item.orders > 0 ? (item.orders / maxOrders * 160) : 4}}px"></view>
                <view class="bar revenue" style="height: {{item.revenue > 0 ? (item.revenue / maxRevenue * 160) : 4}}px"></view>
              </view>
            </view>
          </view>
          <view class="x-axis">
            <text class="date-label" wx:for="{{chartData}}" wx:key="date">{{item.date}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 销售趋势图表 -->
  <view class="chart-section">
    <view class="chart-header">
      <text class="chart-title">销售趋势</text>
      <view class="time-selector" bindtap="onTimeSelect">
        <text class="time-text">{{selectedPeriod === 'week' ? '近一周' : selectedPeriod === 'month' ? '近一月' : '近三月'}}</text>
        <text class="arrow">▼</text>
      </view>
    </view>
    
    <view class="line-chart">
      <view class="chart-container">
        <canvas canvas-id="trendChart" class="trend-canvas" style="width: 300px; height: 160px;" disable-scroll="true"></canvas>
        <view class="x-axis" wx:if="{{trendDates.length > 0}}">
          <text class="date-label" wx:for="{{trendDates}}" wx:key="*this">{{item}}</text>
        </view>
        <view wx:if="{{trendData.length === 0}}" class="empty-chart-overlay">
          <text>暂无数据</text>
        </view>
      </view>
    </view>
  </view>
</view>

