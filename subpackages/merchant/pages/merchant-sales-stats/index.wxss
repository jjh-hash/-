.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center;position:relative}
.back{position:absolute;left:12px;color:#333;font-size:18px}
.title{font-size:18px;color:#333;font-weight:600}
.year-selector{position:absolute;right:12px;display:flex;align-items:center;padding:4px 8px;border:1px solid #ddd;border-radius:4px;background:#fff}
.calendar-icon{font-size:14px;margin-right:4px}
.year-text{font-size:14px;color:#333}
.arrow{font-size:10px;color:#999;margin-left:4px}

.sales-overview{padding:20px 12px;background:#fff;margin:12px;border-radius:12px}
.total-sales{display:flex;align-items:center;justify-content:space-between}
.amount{font-size:28px;color:#333;font-weight:bold}
.growth{font-size:16px;font-weight:500;display:flex;align-items:center;gap:4px}
.growth-up{color:#ff4d4f}
.growth-down{color:#52c41a}
.growth-zero{color:#999}
.growth-arrow{font-size:18px;font-weight:bold}
.growth-amount{font-size:14px}

.metrics-card{background:#1677ff;margin:0 12px 12px;border-radius:12px;padding:20px;display:flex;align-items:center}
.metric-left{flex:1;text-align:center}
.metric-right{flex:1;text-align:center}
.metric-divider{width:1px;height:40px;background:rgba(255,255,255,0.3);margin:0 20px}
.metric-label{color:#fff;font-size:14px;display:block;margin-bottom:8px}
.metric-value{color:#fff;font-size:24px;font-weight:bold;display:block}

.chart-section{background:#fff;margin:0 12px 12px;border-radius:12px;padding:16px}
.chart-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.chart-title{font-size:16px;color:#333;font-weight:600}
.legend{display:flex;gap:16px}
.legend-item{display:flex;align-items:center;gap:4px}
.legend-dot{width:8px;height:8px;border-radius:50%}
.legend-dot.orders{background:#ddd}
.legend-dot.revenue{background:#1677ff}
.legend-text{font-size:12px;color:#666}
.unit{font-size:12px;color:#999}
.time-selector{display:flex;align-items:center;gap:4px;padding:4px 8px;border:1px solid #ddd;border-radius:4px;background:#fff}
.time-text{font-size:14px;color:#333}

.bar-chart{margin-top:16px}
.chart-container{position:relative;height:200px}
.empty-chart{display:flex;align-items:center;justify-content:center;height:160px;color:#999;font-size:14px}
.bars{display:flex;align-items:end;justify-content:space-between;height:160px;padding:0 20px}
.bar-group{display:flex;flex-direction:column;justify-content:flex-end;height:100%;cursor:pointer;transition:opacity 0.2s}
.bar-group:hover{opacity:0.8}
.bar-wrapper{display:flex;align-items:flex-end;gap:4px;height:100%}
.bar{width:12px;border-radius:2px 2px 0 0;min-height:4px;transition:all 0.2s}
.bar.orders{background:#ddd}
.bar.revenue{background:#1677ff}
.x-axis{display:flex;justify-content:space-between;padding:0 20px;margin-top:8px}
.date-label{font-size:12px;color:#666;text-align:center;width:20px}

.line-chart{margin-top:16px}
.chart-container{position:relative;height:200px}
.empty-chart{display:flex;align-items:center;justify-content:center;height:160px;color:#999;font-size:14px}
.empty-chart-overlay{position:absolute;top:50%;left:50%;transform:translate(-50%, -50%);color:#999;font-size:14px;pointer-events:none}
.trend-canvas{width:100%;height:160px;margin:0 20px;display:block}
.x-axis{display:flex;justify-content:space-between;padding:0 20px;margin-top:8px}

