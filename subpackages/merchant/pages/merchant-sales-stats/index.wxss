/* 商家销量统计 - 设计系统 */
.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav{height:44px;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;position:relative}
.back{position:absolute;left:12px;color:var(--color-text);font-size:18px}
.title{font-size:18px;color:var(--color-text);font-weight:600}
.year-selector{position:absolute;right:12px;display:flex;align-items:center;padding:4px 8px;border:1px solid var(--color-border);border-radius:var(--radius-tag);background:var(--color-bg-card)}
.calendar-icon{font-size:14px;margin-right:4px}
.year-text{font-size:14px;color:var(--color-text)}
.arrow{font-size:10px;color:var(--color-text-placeholder);margin-left:4px}

.sales-overview{padding:20px 12px;background:var(--color-bg-card);margin:12px;border-radius:var(--radius-card);box-shadow:var(--shadow-card)}
.total-sales{display:flex;align-items:center;justify-content:space-between}
.amount{font-size:28px;color:var(--color-text);font-weight:bold}
.growth{font-size:16px;font-weight:500;display:flex;align-items:center;gap:4px}
.growth-up{color:var(--color-danger)}
.growth-down{color:#52c41a}
.growth-zero{color:var(--color-text-placeholder)}
.growth-arrow{font-size:18px;font-weight:bold}
.growth-amount{font-size:14px}

.metrics-card{background:var(--color-primary);margin:0 12px 12px;border-radius:var(--radius-card);padding:20px;display:flex;align-items:center}
.metric-left{flex:1;text-align:center}
.metric-right{flex:1;text-align:center}
.metric-divider{width:1px;height:40px;background:rgba(255,255,255,0.3);margin:0 20px}
.metric-label{color:#fff;font-size:14px;display:block;margin-bottom:8px}
.metric-value{color:#fff;font-size:24px;font-weight:bold;display:block}

.chart-section{background:var(--color-bg-card);margin:0 12px 12px;border-radius:var(--radius-card);padding:16px;box-shadow:var(--shadow-card)}
.chart-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.chart-title{font-size:16px;color:var(--color-text);font-weight:600}
.legend{display:flex;gap:16px}
.legend-item{display:flex;align-items:center;gap:4px}
.legend-dot{width:8px;height:8px;border-radius:50%}
.legend-dot.orders{background:var(--color-border)}
.legend-dot.revenue{background:var(--color-primary)}
.legend-text{font-size:12px;color:var(--color-text-secondary)}
.unit{font-size:12px;color:var(--color-text-placeholder)}
.time-selector{display:flex;align-items:center;gap:4px;padding:4px 8px;border:1px solid var(--color-border);border-radius:var(--radius-tag);background:var(--color-bg-card)}
.time-text{font-size:14px;color:var(--color-text)}

.bar-chart{margin-top:16px}
.chart-container{position:relative;height:200px}
.empty-chart{display:flex;align-items:center;justify-content:center;height:160px;color:var(--color-text-placeholder);font-size:14px}
.bars{display:flex;align-items:end;justify-content:space-between;height:160px;padding:0 20px}
.bar-group{display:flex;flex-direction:column;justify-content:flex-end;height:100%;cursor:pointer;transition:opacity 0.2s}
.bar-group:hover{opacity:0.8}
.bar-wrapper{display:flex;align-items:flex-end;gap:4px;height:100%}
.bar{width:12px;border-radius:2px 2px 0 0;min-height:4px;transition:all 0.2s}
.bar.orders{background:var(--color-border)}
.bar.revenue{background:var(--color-primary)}
.x-axis{display:flex;justify-content:space-between;padding:0 20px;margin-top:8px}
.date-label{font-size:12px;color:var(--color-text-secondary);text-align:center;width:20px}

.line-chart{margin-top:16px}
.chart-container{position:relative;height:200px}
.empty-chart{display:flex;align-items:center;justify-content:center;height:160px;color:var(--color-text-placeholder);font-size:14px}
.empty-chart-overlay{position:absolute;top:50%;left:50%;transform:translate(-50%, -50%);color:var(--color-text-placeholder);font-size:14px;pointer-events:none}
.trend-canvas{width:100%;height:160px;margin:0 20px;display:block}
.x-axis{display:flex;justify-content:space-between;padding:0 20px;margin-top:8px}
