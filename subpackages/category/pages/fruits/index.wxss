/* 页面基础样式 */
.page {
  background-color: #fff;
  min-height: 100vh;
}

/* 状态栏 */
.status-bar {
  background: #fff;
  padding: 0 12px;
}


/* 头部导航 */
.header {
  display: flex;
  align-items: center;
  padding: 8px 12px;
  border-bottom: 1px solid #f0f0f0;
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8px;
}

.back-icon {
  font-size: 18px;
  color: #333;
}

.search-container {
  flex: 1;
  height: 32px;
  background: #f5f5f5;
  border-radius: 16px;
  display: flex;
  align-items: center;
  padding: 0 12px;
  margin-right: 8px;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.search-placeholder {
  color: #999;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.search-btn {
  font-size: 14px;
  color: #333;
}

.more-btn {
  font-size: 16px;
  color: #333;
  transform: rotate(90deg);
}

/* 内容区域 */
.content {
  height: calc(100vh - 80px);
}

/* 主分类导航 */
.main-categories {
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 12px 0;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 16px;
  min-width: 60px;
}

.category-item.active .category-icon {
  background: #07c160;
  color: #fff;
}

.category-item.active .category-name {
  color: #07c160;
}

.category-icon {
  width: 40px;
  height: 40px;
  border-radius: 20px;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-bottom: 4px;
}

.category-name {
  font-size: 12px;
  color: #666;
}

/* 子分类导航 */
.sub-categories {
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.sub-category-scroll {
  white-space: nowrap;
}

.sub-category-list {
  display: flex;
  padding: 8px 0;
}

.sub-category-item {
  display: flex;
  align-items: center;
  padding: 6px 12px;
  margin: 0 4px;
  border-radius: 16px;
  background: #f5f5f5;
  white-space: nowrap;
}

.sub-category-item.active {
  background: #07c160;
  color: #fff;
}

.sub-category-icon {
  font-size: 14px;
  margin-right: 4px;
}

.sub-category-name {
  font-size: 12px;
}

/* 商家列表 */
.merchant-list {
  padding: 12px;
}

.merchant-card {
  background: #fff;
  border-radius: 8px;
  margin-bottom: 16px;
  padding: 12px;
  border: 1px solid #f0f0f0;
  position: relative;
}

/* 销量排行榜标签 */
.sales-rank {
  position: absolute;
  left: 0;
  top: 12px;
  background: #ff4757;
  color: #fff;
  padding: 4px 8px;
  border-radius: 0 12px 12px 0;
  font-size: 10px;
  z-index: 10;
}

/* 商家信息头部 */
.merchant-header {
  display: flex;
  margin-bottom: 8px;
}

.merchant-logo {
  width: 50px;
  height: 50px;
  border-radius: 8px;
  overflow: hidden;
  margin-right: 12px;
  flex-shrink: 0;
}

.logo-image {
  width: 100%;
  height: 100%;
}

.merchant-info {
  flex: 1;
}

.merchant-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.brand-tag {
  background: #07c160;
  color: #fff;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
  margin-right: 6px;
}

.merchant-name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-right: 8px;
}

.delivery-type {
  background: #f0f0f0;
  color: #666;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
}

.merchant-desc {
  font-size: 12px;
  color: #666;
  margin-bottom: 4px;
}

.merchant-stats {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.rating {
  display: flex;
  align-items: center;
  gap: 2px;
}

.rating-text {
  font-size: 12px;
  color: #07c160;
}

.star {
  font-size: 10px;
  color: #07c160;
}

.monthly-sales {
  font-size: 12px;
  color: #666;
}

.interested {
  font-size: 12px;
  color: #666;
}

.no-rating {
  font-size: 12px;
  color: #999;
}

.delivery-info {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: #666;
}

.min-order {
  color: #666;
}

.delivery-fee {
  color: #666;
}

.delivery-time {
  color: #666;
}

.distance {
  color: #666;
}

/* 保障和评价 */
.guarantee-section {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.guarantee {
  display: flex;
  align-items: center;
  gap: 4px;
}

.guarantee-icon {
  font-size: 12px;
  color: #07c160;
}

.guarantee-text {
  font-size: 12px;
  color: #07c160;
}

.quote {
  font-size: 12px;
  color: #666;
  font-style: italic;
}

/* 优惠券 */
.coupons {
  display: flex;
  gap: 6px;
  margin-bottom: 8px;
}

.coupon {
  background: #ff4757;
  color: #fff;
  font-size: 10px;
  padding: 4px 8px;
  border-radius: 4px;
}

/* 店铺位置 */
.store-location {
  margin-bottom: 8px;
}

.location-text {
  font-size: 12px;
  color: #666;
}

/* 商品列表 */
.products {
  margin-top: 8px;
}

.product-scroll {
  white-space: nowrap;
}

.product-list {
  display: flex;
  gap: 12px;
}

.product-item {
  width: 100px;
  flex-shrink: 0;
}

.product-image {
  width: 100px;
  height: 80px;
  border-radius: 8px;
  overflow: hidden;
  position: relative;
  margin-bottom: 6px;
}

.image {
  width: 100%;
  height: 100%;
}

.product-tag {
  position: absolute;
  top: 4px;
  left: 4px;
  background: #07c160;
  color: #fff;
  font-size: 8px;
  padding: 2px 4px;
  border-radius: 4px;
}

.product-info {
  text-align: center;
}

.product-name {
  font-size: 11px;
  color: #333;
  display: block;
  margin-bottom: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-subtitle {
  font-size: 10px;
  color: #666;
  display: block;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  font-size: 12px;
  color: #ff4757;
  font-weight: 600;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
