/* 页面基础样式 */
.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 自定义导航 */
.nav {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 12px;
  border-bottom: 1px solid #f0f0f0;
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8px;
}

.back-icon {
  font-size: 18px;
  color: #333;
}

.search-container {
  flex: 1;
  height: 32px;
  background: #f5f5f5;
  border-radius: 16px;
  display: flex;
  align-items: center;
  padding: 0 12px;
}

.search-icon {
  font-size: 14px;
  color: #999;
  margin-right: 6px;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.search-placeholder {
  color: #999;
}

/* 内容区域 */
.content {
  height: calc(100vh - 44px);
}

/* 分类标签 */
.category-tabs {
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 12px;
}

.category-item {
  padding: 12px 16px;
  font-size: 14px;
  color: #666;
  white-space: nowrap;
  position: relative;
}

.category-item.active {
  color: #ff6600;
  font-weight: 500;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 2px;
  background: #ff6600;
  border-radius: 1px;
}

/* 排序和筛选 */
.sort-filter {
  background: #fff;
  padding: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.sort-options {
  display: flex;
  margin-bottom: 12px;
}

.sort-item {
  display: flex;
  align-items: center;
  font-size: 14px;
  color: #666;
  margin-right: 20px;
}

.sort-item.active {
  color: #ff6600;
}

.sort-arrow {
  font-size: 10px;
  margin-left: 4px;
  color: #999;
}

.filter-buttons {
  display: flex;
  gap: 8px;
}

.filter-btn {
  padding: 6px 12px;
  background: #f5f5f5;
  border-radius: 12px;
  font-size: 12px;
  color: #666;
}

.filter-btn.active {
  background: #fff2e8;
  color: #ff6600;
}

/* 餐厅列表 */
.restaurant-list {
  padding: 12px;
}

.restaurant-card {
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
  display: flex;
}

.restaurant-image {
  width: 120px;
  height: 90px;
  position: relative;
  flex-shrink: 0;
}

.image {
  width: 100%;
  height: 100%;
}

.image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  padding: 8px;
}

.image-overlay.closed {
  background: linear-gradient(transparent, rgba(0,0,0,0.8));
}

.overlay-text {
  color: #fff;
  font-size: 12px;
  font-weight: bold;
}

.restaurant-info {
  flex: 1;
  padding: 12px;
  display: flex;
  flex-direction: column;
}

.tags {
  display: flex;
  gap: 4px;
  margin-bottom: 4px;
}

.tag {
  background: #e8f5e8;
  color: #52c41a;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
}

.restaurant-name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rating-sales {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.rating {
  color: #ff6600;
  font-size: 12px;
  font-weight: 500;
}

.sales {
  color: #999;
  font-size: 12px;
}

.avg-price {
  color: #999;
  font-size: 12px;
}

.rating-count {
  color: #999;
  font-size: 12px;
}

.delivery-info {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.delivery-type {
  background: #f0f0f0;
  color: #666;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
}

.min-order {
  color: #999;
  font-size: 12px;
}

.delivery-fee {
  color: #999;
  font-size: 12px;
}

.distance-time {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.delivery-time {
  color: #999;
  font-size: 12px;
}

.distance {
  color: #999;
  font-size: 12px;
}

.activities {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-bottom: 4px;
}

.activity {
  color: #ff6600;
  font-size: 10px;
}

.coupons {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.coupon {
  background: #fff2e8;
  color: #ff6600;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
  border: 1px solid #ffd4a3;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* 加载更多和空状态 */
.load-more {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 14px;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 14px;
  color: #999;
}

.loading-state {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 14px;
}
