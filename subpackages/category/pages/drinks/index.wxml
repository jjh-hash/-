<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px">
  </view>

  <!-- 头部导航 -->
  <view class="header">
    <view class="back-btn" bindtap="onBackTap">
      <text class="back-icon">←</text>
    </view>
    <text class="title">甜点饮品</text>
    <view class="search-container">
      <view class="search-icon">🔍</view>
      <input 
        class="search-input" 
        placeholder="请输入商家或商品名称" 
        placeholder-class="search-placeholder"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchSubmit"
      />
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 排序和筛选 -->
    <view class="sort-filter">
      <view class="sort-options">
        <block wx:for="{{sortOptions}}" wx:key="index">
          <view 
            class="sort-item {{index === activeSort ? 'active' : ''}}"
            bindtap="onSortTap"
            data-index="{{index}}"
          >
            {{item}}
            <text class="sort-arrow">▼</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 商家列表 -->
    <view class="store-list">
      <block wx:for="{{stores}}" wx:key="id">
        <view class="store-card" bindtap="onStoreTap" data-id="{{item.id}}">
          <!-- 商家信息 -->
          <view class="store-header">
            <view class="store-logo">
              <image class="logo-image" src="{{item.logo}}" mode="aspectFill" />
              <view class="logo-text">
                <text class="logo-title">CoComm</text>
                <text class="logo-subtitle">茶饮</text>
              </view>
            </view>
            <view class="store-info">
              <view class="store-name-row">
                <text class="store-name">{{item.fullName}}</text>
              </view>
              <view class="store-stats">
                <view class="rating">
                  <text class="star">⭐</text>
                  <text class="rating-text">{{item.rating}}</text>
                </view>
                <text class="monthly-sales">月售{{item.monthlySales}}</text>
                <text class="avg-price">人均¥{{item.avgPrice}}</text>
              </view>
              <view class="delivery-info">
                <text class="min-order">起送 ¥{{item.minOrder}}</text>
                <text class="delivery-fee">配送约¥{{item.deliveryFee}}</text>
              </view>
              <view class="distance-time">
                <text class="delivery-time">{{item.deliveryTime}}分钟</text>
              </view>
            </view>
          </view>

          <!-- 标签和优惠券 -->
          <view class="store-tags">
            <block wx:for="{{item.tags}}" wx:key="*this">
              <view class="tag">{{item}}</view>
            </block>
            <block wx:for="{{item.coupons}}" wx:key="*this">
              <view class="coupon">{{item}}</view>
            </block>
          </view>

          <!-- 商品展示 -->
          <view class="products">
            <scroll-view scroll-x class="product-scroll">
              <view class="product-list">
                <block wx:for="{{item.products}}" wx:key="id">
                  <view class="product-item" bindtap="onProductTap" data-product-id="{{item.id}}" data-store-id="{{item.storeId}}">
                    <view class="product-image">
                      <image class="image" src="{{item.image}}" mode="aspectFill" />
                      <view class="product-tag">{{item.tag}}</view>
                    </view>
                    <view class="product-info">
                      <text class="product-name">{{item.name}}</text>
                      <text class="product-price">¥{{item.price}}</text>
                    </view>
                  </view>
                </block>
              </view>
            </scroll-view>
          </view>
        </view>
      </block>
    </view>
    
    <view class="safe-area-bottom"></view>
  </scroll-view>
</view>
