<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px">
  </view>

  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBackTap">
      <text class="back-icon">←</text>
    </view>
    <text class="title">悬赏</text>
    <view class="nav-actions">
      <text class="more-btn">⋯</text>
      <text class="dot-btn">●</text>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 横幅 -->
    <view class="banner">
      <view class="banner-content">
        <view class="ribbon">
          <text class="ribbon-text">优质服务等你来!</text>
        </view>
        <view class="banner-decoration">
          <view class="ruler"></view>
        </view>
      </view>
    </view>

    <!-- 帮助地点 -->
    <view class="form-section">
      <view class="section-header">
        <view class="section-icon location-icon">起</view>
        <text class="section-title">去哪里帮忙</text>
        <view class="arrow" bindtap="onLocationTap">→</view>
      </view>
      <view class="location-input" bindtap="onLocationTap">
        <text class="location-placeholder" wx:if="{{!helpLocation}}">去哪里帮忙</text>
        <text class="location-value" wx:else>{{helpLocation}}</text>
      </view>
    </view>

    <!-- 帮助内容 -->
    <view class="form-section">
      <view class="section-header">
        <view class="section-icon content-icon">📄</view>
        <text class="section-title">帮助内容</text>
      </view>
      <textarea 
        class="content-input" 
        placeholder="请输入需要帮助的内容" 
        placeholder-class="content-placeholder"
        value="{{helpContent}}"
        bindinput="onContentInput"
        maxlength="500"
      ></textarea>
      
      <!-- 帮助类别 -->
      <view class="category-buttons">
        <block wx:for="{{categories}}" wx:key="id">
          <view 
            class="category-btn {{item.active ? 'active' : ''}}"
            bindtap="onCategoryTap"
            data-index="{{index}}"
          >
            {{item.name}}
          </view>
        </block>
      </view>
    </view>

    <!-- 图片上传 -->
    <view class="form-section">
      <view class="section-header">
        <view class="section-icon image-icon">🏞️</view>
        <text class="section-title">帮助图片上传({{uploadedImages.length}}/{{maxImages}})</text>
        <text class="optional">选填</text>
      </view>
      <view class="image-upload">
        <view class="upload-btn" bindtap="onUploadImage">
          <text class="plus-icon">+</text>
        </view>
        <block wx:for="{{uploadedImages}}" wx:key="index">
          <view class="uploaded-image">
            <image class="image" src="{{item}}" mode="aspectFill" />
            <view class="delete-btn" bindtap="onDeleteImage" data-index="{{index}}">
              <text class="delete-icon">×</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-section">
      <view class="section-header">
        <view class="section-icon remarks-icon">✏️</view>
        <text class="section-title">备注</text>
      </view>
      <input 
        class="remarks-input" 
        placeholder="输入内容" 
        placeholder-class="remarks-placeholder"
        value="{{remarks}}"
        bindinput="onRemarksInput"
      />
    </view>

    <!-- 赏金 -->
    <view class="form-section">
      <view class="section-header">
        <view class="section-icon bounty-icon">💰</view>
        <text class="section-title">赏金</text>
      </view>
      <view class="bounty-input-container">
        <input 
          class="bounty-input" 
          placeholder="请输入金额" 
          placeholder-class="bounty-placeholder"
          value="{{bounty}}"
          bindinput="onBountyInput"
          type="digit"
        />
        <text class="bounty-unit">元</text>
      </view>
    </view>

    <!-- 订单时间设置 -->
    <view class="form-section">
      <view class="section-header">
        <view class="section-icon timeout-icon">⏱️</view>
        <text class="section-title">订单截止时间</text>
      </view>
      <picker mode="multiSelector" range="{{dateTimeRange}}" value="{{dateTimeValue}}" bindchange="onOrderExpiredAtChange">
        <view class="timeout-input">
          <text class="timeout-value" wx:if="{{orderExpiredAtDisplay}}">{{orderExpiredAtDisplay}}</text>
          <text class="timeout-placeholder" wx:else>请选择截止时间</text>
          <text class="timeout-tip">超时未接单将自动取消</text>
        </view>
      </picker>
    </view>

    <!-- 联系信息 -->
    <view class="form-section">
      <view class="section-header" bindtap="onSelectAddress">
        <view class="section-icon address-icon">📍</view>
        <view class="section-content">
          <text class="section-title">联系信息</text>
          <view class="contact-info-display" wx:if="{{address}}">
            <view class="contact-name-row" wx:if="{{address.name}}">
              <image class="contact-avatar" src="{{address.avatar || '/pages/小标/默认头像.png'}}" mode="aspectFill"></image>
              <text class="contact-name">{{address.name}}</text>
            </view>
            <view class="contact-details">
              <text class="contact-item" wx:if="{{address.phone}}">电话：{{address.phone}}</text>
              <text class="contact-item" wx:if="{{address.wechat}}">微信：{{address.wechat}}</text>
              <text class="contact-item" wx:if="{{address.qq}}">QQ：{{address.qq}}</text>
            </view>
          </view>
          <text class="address-placeholder" wx:else>请选择联系信息</text>
        </view>
        <view class="arrow">></view>
      </view>
    </view>

    <!-- 总价显示 -->
    <view class="form-section" wx:if="{{hasBounty}}">
      <view class="price-summary">
        <view class="price-item">
          <text class="price-label">赏金</text>
          <text class="price-value">¥{{totalPrice}}</text>
        </view>
        <view class="price-divider"></view>
        <view class="price-item total">
          <text class="price-label">总计</text>
          <text class="price-value">¥{{totalPrice}}</text>
        </view>
      </view>
    </view>

    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 下单按钮 -->
  <view class="order-btn-container">
    <view class="order-btn" bindtap="onPlaceOrder">
      <text class="order-text">立即下单</text>
    </view>
  </view>
</view>
