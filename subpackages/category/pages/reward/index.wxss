/* 页面基础样式 */
.page {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 状态栏 */
.status-bar {
  background: #fff;
  padding: 0 12px;
}


/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 18px;
  color: #333;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.more-btn {
  font-size: 16px;
  color: #333;
  transform: rotate(90deg);
}

.dot-btn {
  font-size: 12px;
  color: #333;
}

/* 内容区域 */
.content {
  flex: 1;
  padding-bottom: 80px;
}

/* 横幅 */
.banner {
  background: linear-gradient(90deg, #4a90e2, #8b5cf6);
  margin: 12px;
  border-radius: 12px;
  height: 120px;
  position: relative;
  overflow: hidden;
}

.banner-content {
  position: relative;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ribbon {
  background: #ffd700;
  padding: 8px 16px;
  border-radius: 8px;
  position: relative;
  z-index: 2;
}

.ribbon::before {
  content: '';
  position: absolute;
  left: -8px;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border-top: 8px solid transparent;
  border-bottom: 8px solid transparent;
  border-right: 8px solid #ffd700;
}

.ribbon::after {
  content: '';
  position: absolute;
  right: -8px;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border-top: 8px solid transparent;
  border-bottom: 8px solid transparent;
  border-left: 8px solid #ffd700;
}

.ribbon-text {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.banner-decoration {
  position: absolute;
  right: 20px;
  top: 50%;
  transform: translateY(-50%);
}

.ruler {
  width: 40px;
  height: 8px;
  background: #ff8c00;
  border-radius: 4px;
  position: relative;
}

.ruler::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    90deg,
    #000 0px,
    #000 2px,
    transparent 2px,
    transparent 6px
  );
}

/* 表单区域 */
.form-section {
  background: #fff;
  margin: 12px;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.section-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  margin-right: 12px;
}

.location-icon {
  background: #8b5cf6;
}

.content-icon {
  background: #8b5cf6;
}

.image-icon {
  background: #8b5cf6;
}

.remarks-icon {
  background: #8b5cf6;
}

.bounty-icon {
  background: #8b5cf6;
}

.address-icon {
  background: #4a90e2;
}

.section-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.address-text {
  font-size: 12px;
  color: #666;
}

.address-placeholder {
  font-size: 12px;
  color: #999;
}

/* 价格汇总 */
.price-summary {
  padding: 12px 0;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.price-item.total {
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid #e0e0e0;
}

.price-label {
  font-size: 14px;
  color: #666;
}

.price-item.total .price-label {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.price-value {
  font-size: 14px;
  color: #333;
  font-weight: 600;
}

.price-item.total .price-value {
  font-size: 18px;
  color: #ff4757;
}

.price-divider {
  height: 1px;
  background: #e0e0e0;
  margin: 8px 0;
}

.section-title {
  flex: 1;
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.arrow {
  font-size: 16px;
  color: #999;
}

.optional {
  font-size: 12px;
  color: #999;
}

/* 地点输入 */
.location-input {
  padding: 12px;
  background: #f5f5f5;
  border-radius: 8px;
  min-height: 20px;
  display: flex;
  align-items: center;
}

.location-placeholder {
  color: #999;
  font-size: 14px;
}

.location-value {
  color: #333;
  font-size: 14px;
}

/* 内容输入 */
.content-input {
  width: 100%;
  min-height: 100px;
  padding: 12px;
  background: #f5f5f5;
  border-radius: 8px;
  border: 1px solid #e0e0e0;
  font-size: 14px;
  color: #333;
  margin-bottom: 12px;
}

.content-placeholder {
  color: #999;
}

/* 类别按钮 */
.category-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.category-btn {
  padding: 8px 16px;
  background: #f5f5f5;
  border-radius: 20px;
  font-size: 14px;
  color: #666;
  border: 1px solid #e0e0e0;
}

.category-btn.active {
  background: #8b5cf6;
  color: #fff;
  border-color: #8b5cf6;
}

/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.upload-btn {
  width: 80px;
  height: 80px;
  background: #f5f5f5;
  border: 2px dashed #ccc;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plus-icon {
  font-size: 24px;
  color: #999;
}

.uploaded-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  overflow: hidden;
  position: relative;
}

.image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 20px;
  height: 20px;
  background: #ff4757;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 12px;
  color: #fff;
  font-weight: 600;
}

/* 备注输入 */
.remarks-input {
  width: 100%;
  padding: 12px;
  background: #f5f5f5;
  border-radius: 8px;
  border: 1px solid #e0e0e0;
  font-size: 14px;
  color: #333;
}

.remarks-placeholder {
  color: #999;
}

/* 赏金输入 */
.bounty-input-container {
  display: flex;
  align-items: center;
  gap: 8px;
}

.bounty-input {
  flex: 1;
  padding: 12px;
  background: #f5f5f5;
  border-radius: 8px;
  border: 1px solid #e0e0e0;
  font-size: 16px;
  color: #333;
  font-weight: 600;
}

.bounty-placeholder {
  color: #999;
}

.bounty-unit {
  font-size: 14px;
  color: #666;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* 下单按钮 */
.order-btn-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12px;
  background: #fff;
  border-top: 1px solid #f0f0f0;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
}

.order-btn {
  width: 100%;
  height: 48px;
  background: #333;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-text {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}
