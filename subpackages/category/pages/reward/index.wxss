/* 页面基础样式 - 设计系统 */
.page {
  background-color: var(--color-bg-page);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 状态栏 */
.status-bar {
  background: var(--color-primary);
  padding: 0 12px;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  background: var(--color-primary);
  border-bottom: 1px solid rgba(255,255,255,0.2);
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 18px;
  color: #fff;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.more-btn {
  font-size: 16px;
  color: #fff;
  transform: rotate(90deg);
}

.dot-btn {
  font-size: 12px;
  color: #fff;
}

/* 内容区域 */
.content {
  flex: 1;
  padding-bottom: 80px;
}

/* 去任务大厅入口 */
.task-hall-entry {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  margin: 0 12px 12px;
  padding: 14px 16px;
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  border-left: 4px solid var(--color-primary);
}
.task-hall-entry .task-hall-label {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-primary);
  margin-right: 8px;
}
.task-hall-entry .task-hall-desc {
  flex: 1;
  font-size: 13px;
  color: var(--color-text-secondary);
}
.task-hall-entry .task-hall-arrow {
  font-size: 14px;
  color: var(--color-text-placeholder);
}

/* 横幅 */
.banner {
  background: linear-gradient(135deg, var(--color-primary) 0%, rgba(255, 184, 0, 0.85) 100%);
  margin: 12px;
  border-radius: var(--radius-card);
  height: 120px;
  position: relative;
  overflow: hidden;
}

.banner-content {
  position: relative;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ribbon {
  background: rgba(255, 255, 255, 0.95);
  padding: 8px 16px;
  border-radius: var(--radius-tag);
  position: relative;
  z-index: 2;
  box-shadow: var(--shadow-card);
}

.ribbon::before {
  content: '';
  position: absolute;
  left: -8px;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border-top: 8px solid transparent;
  border-bottom: 8px solid transparent;
  border-right: 8px solid rgba(255, 255, 255, 0.95);
}

.ribbon::after {
  content: '';
  position: absolute;
  right: -8px;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border-top: 8px solid transparent;
  border-bottom: 8px solid transparent;
  border-left: 8px solid rgba(255, 255, 255, 0.95);
}

.ribbon-text {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
}

.banner-decoration {
  position: absolute;
  right: 20px;
  top: 50%;
  transform: translateY(-50%);
}

.ruler {
  width: 40px;
  height: 8px;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 4px;
  position: relative;
}

.ruler::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    90deg,
    var(--color-text) 0px,
    var(--color-text) 2px,
    transparent 2px,
    transparent 6px
  );
}

/* 表单区域 */
.form-section {
  background: var(--color-bg-card);
  margin: 12px;
  border-radius: var(--radius-card);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-card);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.section-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  margin-right: 12px;
}

.location-icon {
  background: var(--color-primary);
}

.content-icon {
  background: var(--color-primary);
}

.image-icon {
  background: var(--color-primary);
}

.remarks-icon {
  background: var(--color-primary);
}

.bounty-icon {
  background: var(--color-primary);
}

.address-icon {
  background: var(--color-primary);
}

.section-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.address-text {
  font-size: 12px;
  color: var(--color-text-secondary);
}

.address-placeholder {
  font-size: 12px;
  color: var(--color-text-placeholder);
}

/* 联系信息显示 */
.contact-info-display {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.contact-name-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.contact-avatar {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 1px solid #e0e0e0;
}

.contact-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text);
}

.contact-details {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-left: 32px;
}

.contact-item {
  font-size: 12px;
  color: var(--color-text-secondary);
}

/* 价格汇总 */
.price-summary {
  padding: 12px 0;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.price-item.total {
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid var(--color-border);
}

.price-label {
  font-size: 14px;
  color: var(--color-text-secondary);
}

.price-item.total .price-label {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
}

.price-value {
  font-size: 14px;
  color: var(--color-text);
  font-weight: 600;
}

.price-item.total .price-value {
  font-size: 18px;
  color: var(--color-primary);
}

.price-divider {
  height: 1px;
  background: var(--color-border);
  margin: 8px 0;
}

.section-title {
  flex: 1;
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
}

.arrow {
  font-size: 16px;
  color: var(--color-text-placeholder);
}

.optional {
  font-size: 12px;
  color: var(--color-text-placeholder);
}

/* 地点输入 */
.location-input {
  padding: 12px 12px 12px 16px;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  min-height: 20px;
  display: flex;
  align-items: center;
  border: 1px solid var(--color-border);
}

.location-placeholder {
  color: var(--color-text-placeholder);
  font-size: 14px;
}

.location-value {
  color: var(--color-text);
  font-size: 14px;
}

/* 内容输入（左侧留足内边距，避免文字被裁剪） */
.content-input {
  width: 100%;
  min-height: 100px;
  padding: 12px 12px 12px 16px;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  border: 1px solid var(--color-border);
  font-size: 14px;
  color: var(--color-text);
  margin-bottom: 12px;
  box-sizing: border-box;
}

.content-placeholder {
  color: var(--color-text-placeholder);
}

/* 类别按钮 */
.category-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.category-btn {
  padding: 8px 16px;
  background: var(--color-bg-page);
  border-radius: var(--radius-tag);
  font-size: 14px;
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
}

.category-btn.active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}

/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.upload-btn {
  width: 80px;
  height: 80px;
  background: var(--color-bg-page);
  border: 2px dashed var(--color-border);
  border-radius: var(--radius-btn);
  display: flex;
  align-items: center;
  justify-content: center;
}

.plus-icon {
  font-size: 24px;
  color: var(--color-text-placeholder);
}

.uploaded-image {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-btn);
  overflow: hidden;
  position: relative;
}

.image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 20px;
  height: 20px;
  background: var(--color-danger);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 12px;
  color: #fff;
  font-weight: 600;
}

/* 备注输入（放大框高与内边距，避免占位符/文字上下被裁剪） */
.remarks-input {
  width: 100%;
  min-height: 48px;
  padding: 14px 14px 14px 18px;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  border: 1px solid var(--color-border);
  font-size: 15px;
  line-height: 1.5;
  color: var(--color-text);
  box-sizing: border-box;
}

.remarks-placeholder {
  color: var(--color-text-placeholder);
  font-size: 15px;
}

/* 赏金输入（放大框高与内边距，避免占位符/文字上下被裁剪） */
.bounty-input-container {
  display: flex;
  align-items: center;
  gap: 8px;
}

.bounty-input {
  flex: 1;
  min-width: 0;
  min-height: 48px;
  padding: 14px 14px 14px 18px;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  border: 1px solid var(--color-border);
  font-size: 16px;
  line-height: 1.5;
  color: var(--color-text);
  font-weight: 600;
  box-sizing: border-box;
}

.bounty-placeholder {
  color: var(--color-text-placeholder);
}

.bounty-unit {
  font-size: 14px;
  color: var(--color-text-secondary);
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* 订单时间设置 */
.timeout-input {
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.timeout-value {
  font-size: 16px;
  color: var(--color-text);
  font-weight: 500;
}
.timeout-tip {
  font-size: 12px;
  color: var(--color-text-placeholder);
}
.timeout-icon {
  background: var(--color-warning);
}

/* 下单按钮 */
.order-btn-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12px;
  background: var(--color-bg-card);
  border-top: 1px solid var(--color-border);
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
}

.order-btn {
  width: 100%;
  height: 48px;
  background: var(--color-primary);
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-btn:active {
  opacity: 0.9;
}

.order-text {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}
