/* 骑手统计 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar {
  width: 100%;
  background: #2C2C2C;
}

.nav-bar {
  background: #2C2C2C;
  color: #fff;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
}

.nav-left,
.nav-right {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 18px;
  color: #fff;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
}

/* 内容区域 */
.content {
  height: calc(100vh - 44px - env(safe-area-inset-top));
  padding-bottom: env(safe-area-inset-bottom);
}

/* 总统计卡片区域 */
.stats-header {
  display: flex;
  gap: 12px;
  padding: var(--space-page);
  margin-bottom: var(--space-block);
}

.stat-big-card {
  flex: 1;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-card);
  position: relative;
  overflow: hidden;
}

.stat-big-card::before {
  content: '';
  position: absolute;
  top: -30px;
  right: -30px;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  opacity: 0.1;
}

.orders-card::before {
  background: var(--color-primary);
}

.income-card::before {
  background: var(--color-danger);
}

.stat-icon-wrapper {
  margin-bottom: 12px;
}

.stat-icon {
  width: 64px;
  height: 64px;
  border-radius: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
}

.orders-icon {
  background: var(--color-primary);
}

.income-icon {
  background: var(--color-danger);
}

.stat-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.stat-label {
  font-size: 14px;
  color: var(--color-text-secondary);
  margin-bottom: 8px;
}

.stat-number {
  font-size: 28px;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.2;
}

.stat-unit {
  font-size: 16px;
  color: var(--color-text-placeholder);
  margin-left: 4px;
}

/* 时间统计区域 */
.time-stats-section {
  padding: 0 var(--space-page);
  margin-bottom: 20px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16px;
}

.time-stat-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: var(--space-block);
  margin-bottom: 12px;
  box-shadow: var(--shadow-card);
}

.time-stat-item:last-child {
  margin-bottom: 0;
}

.time-stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border);
}

.time-label {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
}

.time-date {
  font-size: 12px;
  color: var(--color-text-placeholder);
}

.time-stat-content {
  display: flex;
  gap: 16px;
}

.time-stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
}

.time-stat-label {
  font-size: 12px;
  color: var(--color-text-secondary);
  margin-bottom: 8px;
}

.time-stat-value {
  font-size: 18px;
  font-weight: 600;
  color: var(--color-primary);
}

