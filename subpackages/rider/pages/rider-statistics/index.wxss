.page {
  min-height: 100vh;
  background: #F5F6F8;
}

.status-bar {
  width: 100%;
  background: #2C2C2C;
}

.nav-bar {
  background: #2C2C2C;
  color: #fff;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
}

.nav-left,
.nav-right {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 18px;
  color: #fff;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
}

/* 内容区域 */
.content {
  height: calc(100vh - 44px - env(safe-area-inset-top));
  padding-bottom: env(safe-area-inset-bottom);
}

/* 总统计卡片区域 */
.stats-header {
  display: flex;
  gap: 12px;
  padding: 16px;
  margin-bottom: 16px;
}

.stat-big-card {
  flex: 1;
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.stat-big-card::before {
  content: '';
  position: absolute;
  top: -30px;
  right: -30px;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  opacity: 0.1;
}

.orders-card::before {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.income-card::before {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.stat-icon-wrapper {
  margin-bottom: 12px;
}

.stat-icon {
  width: 64px;
  height: 64px;
  border-radius: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
}

.orders-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.income-icon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.stat-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.stat-label {
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
}

.stat-number {
  font-size: 28px;
  font-weight: 700;
  color: #333;
  line-height: 1.2;
}

.stat-unit {
  font-size: 16px;
  color: #999;
  margin-left: 4px;
}

/* 时间统计区域 */
.time-stats-section {
  padding: 0 16px;
  margin-bottom: 20px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 16px;
}

.time-stat-item {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.time-stat-item:last-child {
  margin-bottom: 0;
}

.time-stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.time-label {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.time-date {
  font-size: 12px;
  color: #999;
}

.time-stat-content {
  display: flex;
  gap: 16px;
}

.time-stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px;
  background: #f8f9fa;
  border-radius: 8px;
}

.time-stat-label {
  font-size: 12px;
  color: #666;
  margin-bottom: 8px;
}

.time-stat-value {
  font-size: 18px;
  font-weight: 600;
  color: #1890ff;
}

