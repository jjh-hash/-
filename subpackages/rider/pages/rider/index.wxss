.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav{height:44px;display:flex;align-items:center;justify-content:center;background:#fff;border-bottom:1px solid #f0f0f0;position:relative}
.back-btn{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#333;font-size:16px;opacity:.9}
.title{font-size:18px;color:#333;font-weight:600}
.content{padding:16px}
.card{background:#fff;border-radius:12px;padding:16px;box-shadow:0 2px 8px rgba(0,0,0,0.06)}
.card-title{display:block;font-size:16px;color:#333;font-weight:600;margin-bottom:6px}
.card-sub{display:block;font-size:12px;color:#666;margin-bottom:14px}
.actions{display:flex;gap:12px}
.btn{flex:1;height:40px;border-radius:8px;background:#f5f5f5;color:#333;display:flex;align-items:center;justify-content:center;border:1px solid #e0e0e0}
.btn.primary{background:#0a86ff;color:#fff;border-color:#0a86ff}
.tips{margin-top:12px;font-size:12px;color:#999;line-height:1.6}


