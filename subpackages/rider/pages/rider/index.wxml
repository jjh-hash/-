<view class="page">
  <view class="content">
    <view class="card">
      <text class="card-title">欢迎加入骑手团队</text>
      <text class="card-sub">请选择要进行的操作</text>
      <view class="actions">
        <view class="btn primary" bindtap="onGoRegister">注册成为骑手</view>
        <view class="btn" bindtap="onGoLogin">登录骑手端</view>
      </view>
      <view class="tips">
        <text>提示：</text>
        <text>完成注册后可在接单端查看并接收订单。</text>
      </view>
    </view>
  </view>
</view>


