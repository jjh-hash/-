<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>

  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="onBack">
      <text class="back-icon">◀</text>
    </view>
    <view class="nav-title">跑单设置</view>
    <view class="nav-right"></view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 跑单设置 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">跑单设置</text>
        <text class="close-btn" bindtap="onBack">×</text>
      </view>

      <!-- 自动刷新抢单大厅 -->
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-label">自动刷新抢单大厅</text>
          <text class="setting-desc">{{autoRefresh ? '已开启,长时间未点击刷新将自动刷新抢单大厅' : '未开启,需要手动刷新抢单大厅'}}</text>
        </view>
        <view class="setting-right">
          <switch 
            checked="{{autoRefresh}}" 
            bindchange="onAutoRefreshChange"
            color="#ff9800" />
        </view>
      </view>

      <!-- 同时接单量 -->
      <view class="setting-item">
        <view class="setting-left" bindtap="onSetMaxOrders">
          <text class="setting-label">同时接单量</text>
          <text class="setting-value-inline">{{maxOrders}}单(最大)</text>
          <text class="setting-desc">当同时接单量达到上限时,将无法抢单和派单</text>
          <text class="setting-link" catchtap="onShowMaxOrdersHelp">同时接单量如何计算?</text>
        </view>
        <view class="setting-right" bindtap="onSetMaxOrders">
          <text class="arrow">></text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 同时接单量选择弹窗 -->
  <view class="modal" wx:if="{{showMaxOrdersModal}}" bindtap="onCloseMaxOrdersModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">设置同时接单量</text>
        <text class="modal-close" bindtap="onCloseMaxOrdersModal">×</text>
      </view>
      <view class="modal-body">
        <view class="picker-item" 
          wx:for="{{maxOrdersOptions}}" 
          wx:key="value"
          data-value="{{item.value}}"
          bindtap="onSelectMaxOrders">
          <text class="picker-label">{{item.label}}</text>
          <text class="picker-check" wx:if="{{maxOrders === item.value}}">✓</text>
        </view>
      </view>
    </view>
  </view>
</view>

