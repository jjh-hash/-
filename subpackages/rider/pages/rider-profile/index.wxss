.page {
  min-height: 100vh;
  background: #F5F6F8;
}

.status-bar {
  width: 100%;
  background: #2C2C2C;
}

.nav-bar {
  background: #2C2C2C;
  color: #fff;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
}

.nav-left,
.nav-right {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 18px;
  color: #fff;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
}

.setting-icon {
  width: 20px;
  height: 20px;
}

/* 内容区域 */
.content {
  height: calc(100vh - 44px - env(safe-area-inset-top));
  padding-bottom: env(safe-area-inset-bottom);
}

/* 用户信息卡片 */
.profile-card {
  background: linear-gradient(135deg, #1890FF 0%, #096DD9 100%);
  margin: 16px;
  border-radius: 16px;
  padding: 20px;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.profile-card::before {
  content: '';
  position: absolute;
  top: -50px;
  right: -50px;
  width: 200px;
  height: 200px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.profile-header {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar-wrapper {
  width: 60px;
  height: 60px;
  border-radius: 30px;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.3);
  margin-right: 16px;
  border: 2px solid rgba(255, 255, 255, 0.5);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.3);
}

.avatar-placeholder-text {
  font-size: 24px;
  color: #fff;
  font-weight: 600;
}

.profile-info {
  flex: 1;
}

.rider-name {
  display: block;
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 4px;
}

.rider-nickname {
  display: block;
  font-size: 14px;
  opacity: 0.8;
  margin-bottom: 8px;
}

.status-badge {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 500;
}

.status-badge.status-not_registered {
  background: rgba(255, 0, 0, 0.15);
  color: #ff0000;
}

.status-badge.status-pending {
  background: rgba(255, 193, 7, 0.2);
  color: #ffc107;
}

.status-badge.status-approved {
  background: rgba(0, 204, 0, 0.15);
  color: #00cc00;
}

.status-badge.status-rejected {
  background: rgba(255, 77, 79, 0.2);
  color: #ff4d4f;
}

/* 数据统计卡片 */
.stats-cards {
  padding: 0 16px;
  margin-bottom: 20px;
}

.stat-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.stat-card:last-child {
  margin-bottom: 0;
}

.stat-card-icon {
  width: 48px;
  height: 48px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  margin-right: 16px;
}

.order-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.income-icon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.feedback-icon {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.personal-icon {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.statistics-icon {
  background: linear-gradient(135deg, #30cfd0 0%, #330867 100%);
}

.stat-card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.stat-card-number {
  font-size: 24px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.stat-card-label {
  font-size: 14px;
  color: #666;
  font-weight: 500;
}

.stat-card-desc {
  font-size: 12px;
  color: #999;
  margin-top: 4px;
}

.stat-card-arrow {
  font-size: 16px;
  color: #ccc;
  margin-left: 8px;
}

/* 退出接单端按钮 */
.logout-section {
  padding: 0 16px;
  margin-top: 20px;
  margin-bottom: 20px;
}

.logout-btn {
  width: 100%;
  height: 48px;
  line-height: 48px;
  background: #fff;
  color: #ff4d4f;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 500;
  border: 1px solid #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn::after {
  border: none;
}

/* 信息展示区域 */
.info-section {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin: 0 16px 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 14px;
  color: #666;
  width: 100px;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 14px;
  color: #333;
  text-align: right;
  word-break: break-all;
}

.info-value.highlight {
  color: #1890ff;
  font-weight: 600;
  font-size: 15px;
}

.avatar-wrapper {
  cursor: pointer;
}

