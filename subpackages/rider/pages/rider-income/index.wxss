/* 骑手收入 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.status-bar {
  width: 100%;
  background: #2C2C2C;
}

.nav-bar {
  background: #2C2C2C;
  color: #fff;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
}

.nav-left,
.nav-right {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 18px;
  color: #fff;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
}

/* 总收入卡片 */
.income-header {
  padding: var(--space-page);
  background: var(--color-primary);
}

.income-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-card);
}

.income-label {
  font-size: 14px;
  color: var(--color-text-secondary);
  margin-bottom: 8px;
}

.income-amount {
  font-size: 36px;
  font-weight: 600;
  color: var(--color-danger);
  margin-bottom: 8px;
}

.income-desc {
  font-size: 12px;
  color: var(--color-text-placeholder);
}

/* 内容区域 */
.content-area {
  height: calc(100vh - 44px - 120px - env(safe-area-inset-bottom));
  padding: var(--space-page);
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px 0;
  color: var(--color-text-secondary);
  font-size: 14px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
}

.empty-illustration {
  margin-bottom: 20px;
}

.illustration-emoji {
  font-size: 64px;
}

.empty-title {
  font-size: 16px;
  color: var(--color-text);
  margin-bottom: 8px;
  font-weight: 500;
}

.empty-desc {
  font-size: 14px;
  color: var(--color-text-placeholder);
}

/* 收入明细区域 */
.income-section {
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
}

/* 收入明细项 */
.income-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: var(--space-block);
  margin-bottom: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: var(--shadow-card);
}

.income-item-left {
  flex: 1;
  display: flex;
  align-items: center;
}

.income-icon {
  width: 40px;
  height: 40px;
  border-radius: 20px;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-right: 12px;
  flex-shrink: 0;
}

.income-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.income-order-no {
  font-size: 13px;
  color: var(--color-text-secondary);
  margin-bottom: 4px;
}

.income-items {
  font-size: 14px;
  color: var(--color-text);
  font-weight: 500;
  margin-bottom: 4px;
}

.income-time {
  font-size: 12px;
  color: var(--color-text-placeholder);
}

.income-item-right {
  margin-left: 12px;
}

.income-value {
  font-size: 18px;
  font-weight: 600;
  color: #2e7d32;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20px 0;
  color: var(--color-text-placeholder);
  font-size: 14px;
}

