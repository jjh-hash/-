.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav{height:44px;display:flex;align-items:center;justify-content:center;background:#fff;border-bottom:1px solid #f0f0f0;position:relative}
.back-btn{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#333;font-size:16px;opacity:.9}
.title{font-size:18px;color:#333;font-weight:600}
.content{padding:16px}
.field{background:#fff;border-radius:8px;padding:12px;margin-bottom:12px}
.label{display:block;color:#666;font-size:12px;margin-bottom:6px}
.input{height:36px;background:#f7f7f7;border:1px solid #e0e0e0;border-radius:6px;padding:0 10px;flex:1}
.code-row{display:flex;align-items:center;gap:8px}
.send-btn{min-width:100px;height:36px;background:#0a86ff;color:#fff;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px;padding:0 8px}
.send-btn.disabled{background:#ccc;color:#666}
.tip{font-size:12px;color:#999;margin:8px 0 16px;line-height:1.6}
.tip-item{margin-bottom:4px}
.tip-item:last-child{margin-bottom:0}
.btn{height:40px;border-radius:8px;background:#0a86ff;color:#fff;display:flex;align-items:center;justify-content:center}


