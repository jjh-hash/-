/* 骑手首页 - 设计系统 */
.page {
  height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 顶部栏：仅标题 */
.top-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12px var(--space-page);
  background: var(--color-primary);
  color: #fff;
}
.top-title {
  font-size: 18px;
  font-weight: 600;
}

/* 底部固定：个人中心（副色蓝，与顶部黄区分、更清晰） */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 14px var(--space-page);
  padding-bottom: calc(14px + env(safe-area-inset-bottom));
  background: var(--color-secondary-light);
  border-top: 1px solid rgba(59, 130, 246, 0.2);
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.06);
}
.bottom-bar-text {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-secondary);
}
.bottom-bar-arrow {
  font-size: 18px;
  font-weight: 600;
  color: var(--color-secondary);
}
.bottom-bar:active {
  opacity: 0.88;
}

.tabs {
  display: flex;
  background: var(--color-primary);
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 14px 0;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.85);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.tab.active {
  color: #fff;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28px;
  height: 3px;
  background: #fff;
  border-radius: 2px;
}

.tab-arrow {
  font-size: 10px;
  opacity: 0.9;
  margin-left: 2px;
}

/* 审核状态提示横幅 */
.status-banner {
  background: var(--color-primary-light);
  padding: 12px var(--space-page);
  border-bottom: 1px solid var(--color-border);
}

.status-banner.status-not_registered {
  background: rgba(239, 68, 68, 0.08);
}

.status-banner.status-pending {
  background: var(--color-primary-light);
}

.status-banner.status-rejected {
  background: rgba(239, 68, 68, 0.08);
}

.status-content {
  display: flex;
  align-items: center;
  gap: 8px;
}

.status-icon {
  font-size: 18px;
  flex-shrink: 0;
}

.status-text {
  flex: 1;
  font-size: 13px;
  line-height: 1.4;
  color: var(--color-text);
}

.status-banner.status-not_registered .status-text {
  color: var(--color-danger);
}

.status-banner.status-pending .status-text {
  color: var(--color-warning);
}

.status-banner.status-rejected .status-text {
  color: var(--color-danger);
}

.status-action-btn {
  flex-shrink: 0;
  padding: 4px 12px;
  font-size: 12px;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-tag);
  border: none;
  line-height: 1.4;
}

.status-action-btn::after {
  border: none;
}

.content-area {
  flex: 1;
  height: 100%;
  padding: var(--space-page);
  padding-bottom: calc(56px + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow: hidden;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 48px 24px;
}

.empty-icon-wrap {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
}

.empty-icon {
  font-size: 44px;
  line-height: 1;
}

.empty-title {
  display: block;
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 10px;
}

.empty-desc {
  display: block;
  font-size: 14px;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.5;
}

.error-retry-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}
.error-icon { font-size: 48px; margin-bottom: 12px; }
.error-title { font-size: 16px; font-weight: 600; color: var(--color-text); margin-bottom: 8px; }
.error-desc { font-size: 13px; color: var(--color-text-secondary); margin-bottom: 16px; text-align: center; }
.retry-btn { padding: 10px 24px; background: var(--color-primary); color: #fff; border-radius: var(--radius-btn); font-size: 14px; border: none; }
.retry-btn::after { border: none; }

/* 订单列表 */
.order-list {
  width: 100%;
}

.order-skeleton-list .ds-skeleton-line { flex-shrink: 0; }

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  color: var(--color-text-secondary);
  font-size: 14px;
}

/* 订单卡片 */
.order-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: var(--space-block);
  margin-bottom: var(--space-item);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  border: 1px solid var(--color-border);
  transition: box-shadow var(--transition-fast);
}

.order-card:active {
  box-shadow: var(--shadow-card-hover);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border);
}

.delivery-time {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text);
}

.order-price {
  font-size: 18px;
  font-weight: 600;
  color: var(--color-primary);
}

/* 地址区域 */
.address-section {
  margin-bottom: 12px;
}

.address-section.pickup {
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border);
}

.address-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 0;
  width: 100%;
}

.distance {
  font-size: 13px;
  color: var(--color-text-secondary);
  margin-right: 8px;
  min-width: 50px;
  flex-shrink: 0;
  line-height: 1.5;
}

.store-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.store-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text);
  word-break: break-all;
  line-height: 1.4;
  margin-bottom: 4px;
}

.address-detail {
  font-size: 13px;
  color: var(--color-text-secondary);
  line-height: 1.5;
  word-break: break-all;
}

.delivery-address {
  font-size: 14px;
  color: var(--color-text);
  flex: 1;
  min-width: 0;
  word-break: break-all;
  line-height: 1.4;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 4px 10px;
  background: var(--color-bg-page);
  border-radius: var(--radius-tag);
  margin-bottom: 12px;
}

.status-tag text {
  font-size: 12px;
  color: var(--color-text-secondary);
}

/* 餐品信息 */
.items-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  margin-bottom: 12px;
}

.items-text {
  font-size: 13px;
  color: var(--color-text-secondary);
}

.items-arrow {
  font-size: 12px;
  color: var(--color-text-placeholder);
  transition: transform 0.3s;
}

.items-arrow.expanded {
  transform: rotate(180deg);
}

/* 餐品详情 */
.items-detail {
  padding: 8px 0;
  margin-bottom: 12px;
  border-top: 1px solid var(--color-border);
}

.food-item {
  display: flex;
  align-items: center;
  padding: 6px 0;
  font-size: 13px;
}

.food-name {
  color: var(--color-text);
  flex: 1;
}

.food-spec {
  color: var(--color-text-placeholder);
  margin-left: 8px;
  font-size: 12px;
}

.food-quantity {
  color: var(--color-text-secondary);
  margin-left: auto;
}

/* 抢单按钮 */
.grab-btn {
  width: 100%;
  height: 44px;
  background: var(--color-warning);
  color: #fff;
  border-radius: var(--radius-btn);
  font-size: 16px;
  font-weight: 600;
  border: none;
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: opacity var(--transition-fast);
}

.grab-btn::after {
  border: none;
}

.grab-btn:not(.disabled):active {
  opacity: 0.9;
}

.grab-btn.disabled {
  background: var(--color-text-placeholder);
  color: var(--color-text-secondary);
  opacity: 0.6;
}

/* 确认取餐按钮 */
.pickup-btn {
  width: 100%;
  height: 44px;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-btn);
  font-size: 16px;
  font-weight: 600;
  border: none;
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.pickup-btn::after {
  border: none;
}

.pickup-btn:active {
  opacity: 0.9;
}

/* 确认送达按钮 */
.deliver-btn {
  width: 100%;
  height: 44px;
  background: var(--color-success);
  color: #fff;
  border-radius: var(--radius-btn);
  font-size: 16px;
  font-weight: 600;
  border: none;
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: opacity var(--transition-fast);
}

.deliver-btn::after {
  border: none;
}

.deliver-btn:active {
  opacity: 0.9;
}


