.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.header{background:#111;color:#fff;padding:12px 16px;display:flex;justify-content:space-between;align-items:center}
.status-info{display:flex;align-items:center;gap:12px}
.status-pill{display:flex;align-items:center;gap:6px;padding:4px 10px;border-radius:16px;font-size:12px}
.status-pill .dot{width:6px;height:6px;border-radius:50%;display:inline-block}
.status-pill.online{background:rgba(0,255,106,0.15);color:#00ff6a}
.status-pill.online .dot{background:#00ff6a}
.status-pill.offline{background:rgba(255,255,255,0.1);color:#ffb3b3}
.status-pill.offline .dot{background:#ff6b6b}
.area-select{display:flex;align-items:center;font-size:12px;color:#fff;opacity:.8}
.area-select .arrow{margin-left:4px;font-size:10px}
.header-icons{display:flex;gap:10px;align-items:center}
.icon-btn{width:32px;height:32px;border-radius:16px;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;font-size:14px;position:relative}
.helper-avatar{width:100%;height:100%;border-radius:16px}
.badge{position:absolute;top:-4px;right:-4px;width:16px;height:16px;border-radius:8px;background:#ff4d4f;color:#fff;font-size:10px;display:flex;align-items:center;justify-content:center}

.tabs{display:flex;background:#fff}
.tab{flex:1;text-align:center;padding:12px 0;font-size:14px;color:#666}
.tab.active{color:#fe6723;font-weight:600;border-bottom:2px solid #fe6723}

.notice{display:flex;align-items:center;gap:6px;background:#fff7e6;color:#ad6800;padding:8px 12px;font-size:12px}
.notice .close{margin-left:auto;font-size:14px}

.empty-card{margin:16px;background:#fff;border-radius:16px;box-shadow:0 10px 30px rgba(0,0,0,0.05);padding:24px;text-align:center;color:#333}
.empty-img{width:160px;height:120px;margin:0 auto 16px;opacity:.9}
.empty-title{display:block;font-size:16px;font-weight:600;margin-bottom:6px}
.empty-desc{display:block;font-size:12px;color:#888;margin-bottom:16px}
.primary-btn{background:#ff7a1a;color:#fff;border-radius:24px;height:42px;line-height:42px}

.bottom-bar{margin:16px;padding:12px;background:#fff;border-radius:12px;display:flex;align-items:center;gap:12px}
.bottom-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#666;font-size:12px}
.bottom-icon{width:32px;height:32px;border-radius:16px;background:#f5f5f5;margin-bottom:4px}
.bottom-icon.gear{background-image:linear-gradient(135deg,#f093fb,#f5576c)}
.bottom-icon.center{background-image:linear-gradient(135deg,#5ee7df,#b490ca)}
.refresh-btn{flex:1;height:40px;border-radius:8px;background:#ff7a1a;color:#fff}


