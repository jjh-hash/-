<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>

  <view class="header">
    <view class="header-left">
      <view class="user-avatar" bindtap="onAvatarTap">
        <image class="avatar-img" src="/pages/小标/我的.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <view class="tabs">
    <block wx:for="{{tabs}}" wx:key="index">
      <view 
        class="tab {{activeTab === index ? 'active' : ''}}" 
        bindtap="onTabChange" 
        data-index="{{index}}"
      >
        {{item}}
        <view class="tab-arrow" wx:if="{{index === 0 && activeTab === index}}">▼</view>
      </view>
    </block>
  </view>

  <scroll-view class="content-area" scroll-y="{{true}}" enable-back-to-top="{{true}}">
    <!-- 待抢单订单列表 -->
    <view class="order-list" wx:if="{{activeTab === 0}}">
      <!-- 加载状态 -->
      <view class="loading-state" wx:if="{{loading}}">
        <text>加载中...</text>
      </view>
      
      <!-- 空状态 -->
      <view class="empty-state" wx:elif="{{!loading && orders.length === 0}}">
        <view class="empty-illustration">
          <text class="illustration-emoji">⏰</text>
        </view>
        <text class="empty-title">暂时没有订单</text>
        <text class="empty-desc">请保持在线状态，等待新订单</text>
      </view>
      
      <!-- 订单列表 -->
      <block wx:elif="{{!loading && orders.length > 0}}">
        <block wx:for="{{orders}}" wx:key="id">
          <view class="order-card">
            <!-- 顶部信息 -->
            <view class="order-header">
              <text class="delivery-time">{{item.deliveryTime}}</text>
              <text class="order-price">¥{{item.price}}</text>
            </view>
            
            <!-- 取货地址 -->
            <view class="address-section pickup">
              <view class="address-header">
                <!-- <text class="distance">{{item.pickupDistance}}</text> -->
                <view class="store-info">
                  <text class="store-name">{{item.pickupStore}}</text>
                  <text class="address-detail">{{item.pickupAddress}}</text>
                </view>
              </view>
            </view>
            
            <!-- 配送地址 -->
            <view class="address-section delivery">
              <view class="address-header">
                <!-- <text class="distance">{{item.deliveryDistance}}</text> -->
                <text class="delivery-address">{{item.deliveryAddress}}</text>
              </view>
            </view>
            
            <!-- 状态标签 -->
            <view class="status-tag" wx:if="{{item.status}}">
              <text>{{item.status}}</text>
            </view>
            
            <!-- 餐品信息 -->
            <view class="items-info" bindtap="onToggleItems" data-index="{{index}}">
              <text class="items-text">餐品: {{item.items}}</text>
              <text class="items-arrow {{item.showItems ? 'expanded' : ''}}">▼</text>
            </view>
            
            <!-- 餐品详情（可展开） -->
            <view class="items-detail" wx:if="{{item.showItems && item.itemsDetail && item.itemsDetail.length > 0}}">
              <block wx:for="{{item.itemsDetail}}" wx:key="index" wx:for-item="food">
                <view class="food-item">
                  <text class="food-name">{{food.name}}</text>
                  <text class="food-spec" wx:if="{{food.spec}}">{{food.spec}}</text>
                  <text class="food-quantity">x{{food.quantity}}</text>
                </view>
              </block>
            </view>
            
            <!-- 抢单按钮 -->
            <button class="grab-btn" bindtap="onGrabOrder" data-id="{{item.id}}">抢单</button>
          </view>
        </block>
      </block>
    </view>

    <!-- 待取货订单列表 -->
    <view class="order-list" wx:if="{{activeTab === 1}}">
      <!-- 加载状态 -->
      <view class="loading-state" wx:if="{{pickupLoading}}">
        <text>加载中...</text>
      </view>
      
      <!-- 空状态 -->
      <view class="empty-state" wx:elif="{{!pickupLoading && pickupOrders.length === 0}}">
        <view class="empty-illustration">
          <text class="illustration-emoji">📦</text>
          <text class="illustration-rider">🛵</text>
        </view>
        <text class="empty-title">暂时没有订单</text>
        <text class="empty-desc">建议您持续保持在线或去「待抢单」抢一个</text>
      </view>
      
      <!-- 订单列表 -->
      <block wx:elif="{{!pickupLoading && pickupOrders.length > 0}}">
        <block wx:for="{{pickupOrders}}" wx:key="id">
          <view class="order-card">
            <!-- 顶部信息 -->
            <view class="order-header">
              <text class="delivery-time">{{item.deliveryTime}}</text>
              <text class="order-price">¥{{item.price}}</text>
            </view>
            
            <!-- 取货地址 -->
            <view class="address-section pickup">
              <view class="address-header">
                <!-- <text class="distance">{{item.pickupDistance}}</text> -->
                <view class="store-info">
                  <text class="store-name">{{item.pickupStore}}</text>
                  <text class="address-detail">{{item.pickupAddress}}</text>
                </view>
              </view>
            </view>
            
            <!-- 配送地址 -->
            <view class="address-section delivery">
              <view class="address-header">
                <!-- <text class="distance">{{item.deliveryDistance}}</text> -->
                <text class="delivery-address">{{item.deliveryAddress}}</text>
              </view>
            </view>
            
            <!-- 状态标签 -->
            <view class="status-tag" wx:if="{{item.status}}">
              <text>{{item.status}}</text>
            </view>
            
            <!-- 餐品信息 -->
            <view class="items-info" bindtap="onTogglePickupItems" data-index="{{index}}">
              <text class="items-text">餐品: {{item.items}}</text>
              <text class="items-arrow {{item.showItems ? 'expanded' : ''}}">▼</text>
            </view>
            
            <!-- 餐品详情（可展开） -->
            <view class="items-detail" wx:if="{{item.showItems && item.itemsDetail && item.itemsDetail.length > 0}}">
              <block wx:for="{{item.itemsDetail}}" wx:key="index" wx:for-item="food">
                <view class="food-item">
                  <text class="food-name">{{food.name}}</text>
                  <text class="food-spec" wx:if="{{food.spec}}">{{food.spec}}</text>
                  <text class="food-quantity">x{{food.quantity}}</text>
                </view>
              </block>
            </view>
            
            <!-- 确认取餐按钮 -->
            <button class="pickup-btn" bindtap="onConfirmPickup" data-id="{{item.id}}">确认取餐</button>
          </view>
        </block>
      </block>
    </view>

    <!-- 待送达订单列表 -->
    <view class="order-list" wx:if="{{activeTab === 2}}">
      <!-- 加载状态 -->
      <view class="loading-state" wx:if="{{deliverLoading}}">
        <text>加载中...</text>
      </view>
      
      <!-- 空状态 -->
      <view class="empty-state" wx:elif="{{!deliverLoading && deliverOrders.length === 0}}">
        <view class="empty-illustration">
          <text class="illustration-emoji">🚚</text>
        </view>
        <text class="empty-title">暂时没有订单</text>
        <text class="empty-desc">暂无待送达订单</text>
      </view>
      
      <!-- 订单列表 -->
      <block wx:elif="{{!deliverLoading && deliverOrders.length > 0}}">
        <block wx:for="{{deliverOrders}}" wx:key="id">
          <view class="order-card">
            <!-- 顶部信息 -->
            <view class="order-header">
              <text class="delivery-time">{{item.deliveryTime}}</text>
              <text class="order-price">¥{{item.price}}</text>
            </view>
            
            <!-- 取货地址 -->
            <view class="address-section pickup">
              <view class="address-header">
                <!-- <text class="distance">{{item.pickupDistance}}</text> -->
                <view class="store-info">
                  <text class="store-name">{{item.pickupStore}}</text>
                  <text class="address-detail">{{item.pickupAddress}}</text>
                </view>
              </view>
            </view>
            
            <!-- 配送地址 -->
            <view class="address-section delivery">
              <view class="address-header">
                <!-- <text class="distance">{{item.deliveryDistance}}</text> -->
                <text class="delivery-address">{{item.deliveryAddress}}</text>
              </view>
            </view>
            
            <!-- 状态标签 -->
            <view class="status-tag" wx:if="{{item.status}}">
              <text>{{item.status}}</text>
            </view>
            
            <!-- 餐品信息 -->
            <view class="items-info" bindtap="onToggleDeliverItems" data-index="{{index}}">
              <text class="items-text">餐品: {{item.items}}</text>
              <text class="items-arrow {{item.showItems ? 'expanded' : ''}}">▼</text>
            </view>
            
            <!-- 餐品详情（可展开） -->
            <view class="items-detail" wx:if="{{item.showItems && item.itemsDetail && item.itemsDetail.length > 0}}">
              <block wx:for="{{item.itemsDetail}}" wx:key="index" wx:for-item="food">
                <view class="food-item">
                  <text class="food-name">{{food.name}}</text>
                  <text class="food-spec" wx:if="{{food.spec}}">{{food.spec}}</text>
                  <text class="food-quantity">x{{food.quantity}}</text>
                </view>
              </block>
            </view>
            
            <!-- 确认送达按钮 -->
            <button class="deliver-btn" bindtap="onConfirmDelivery" data-id="{{item.id}}">确认送达</button>
          </view>
        </block>
      </block>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="bottom-item" bindtap="onSettingTap">
      <view class="bottom-icon-wrapper">
        <image class="bottom-icon setting-icon" src="/pages/小标/设置.png" mode="aspectFit"></image>
        <text class="order-count" wx:if="{{orderCount > 0}}">{{orderCount}}单</text>
      </view>
      <text class="bottom-text">跑单设置</text>
    </view>
    <button class="refresh-btn" bindtap="onRefresh">刷新订单</button>
  </view>
</view>



