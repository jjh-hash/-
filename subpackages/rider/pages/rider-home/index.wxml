<view class="page">

  <!-- 顶部栏：仅标题 -->
  <view class="top-bar">
    <text class="top-title">骑手工作台</text>
  </view>

  <!-- 审核状态提示 -->
  <view class="status-banner status-{{riderStatus}}" wx:if="{{riderStatus !== 'approved'}}">
    <view class="status-content">
      <text class="status-icon">
        <text wx:if="{{riderStatus === 'not_registered'}}">⚠️</text>
        <text wx:elif="{{riderStatus === 'pending'}}">⏳</text>
        <text wx:elif="{{riderStatus === 'rejected'}}">❌</text>
      </text>
      <text class="status-text">
        <text wx:if="{{riderStatus === 'not_registered'}}">未审核 - 请先注册成为骑手</text>
        <text wx:elif="{{riderStatus === 'pending'}}">待审核 - 您的申请正在审核中，审核通过后才能接单</text>
        <text wx:elif="{{riderStatus === 'rejected'}}">审核未通过 - 请联系管理员</text>
      </text>
      <button 
        class="status-action-btn" 
        wx:if="{{riderStatus === 'not_registered'}}"
        bindtap="onGoRegister"
        size="mini"
      >
        注册骑手
      </button>
    </view>
  </view>

  <view class="tabs">
    <block wx:for="{{tabs}}" wx:key="index">
      <view 
        class="tab {{activeTab === index ? 'active' : ''}}" 
        bindtap="onTabChange" 
        data-index="{{index}}"
      >
        {{item}}
        <view class="tab-arrow" wx:if="{{index === 0 && activeTab === index}}">▼</view>
      </view>
    </block>
  </view>

  <scroll-view 
    class="content-area" 
    scroll-y="{{true}}" 
    enable-back-to-top="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscroll="onScroll"
    refresher-background="#FFF0E0">
    <!-- 待抢单订单列表 -->
    <view class="order-list" wx:if="{{activeTab === 0}}">
      <!-- 骨架屏 -->
      <view wx:if="{{loading && orders.length === 0}}" class="order-skeleton-list">
        <block wx:for="{{[1,2,3,4]}}" wx:key="*this">
          <view class="order-card">
            <view class="order-header">
              <view class="ds-skeleton-line" style="width:80px;height:18px;margin-bottom:8px;"></view>
              <view class="ds-skeleton-line" style="width:50px;height:20px;border-radius:4px;"></view>
            </view>
            <view class="address-section" style="margin-bottom:8px;">
              <view class="ds-skeleton-line" style="width:90%;height:14px;margin-bottom:4px;"></view>
              <view class="ds-skeleton-line" style="width:70%;height:14px;"></view>
            </view>
            <view class="ds-skeleton-line" style="width:60%;height:14px;margin-bottom:8px;"></view>
            <view class="ds-skeleton-line" style="width:100px;height:36px;border-radius:8px;"></view>
          </view>
        </block>
      </view>
      
      <!-- 错误重试 -->
      <view class="error-retry-state" wx:elif="{{loadError && !loading && orders.length === 0}}">
        <text class="error-icon">⚠️</text>
        <text class="error-title">加载失败</text>
        <text class="error-desc">{{errorMessage || '网络异常，请重试'}}</text>
        <button class="retry-btn" bindtap="onRetryLoad">点击重试</button>
      </view>
      
      <!-- 空状态 -->
      <view class="empty-state" wx:elif="{{!loading && orders.length === 0}}">
        <view class="empty-icon-wrap">
          <text class="empty-icon">⏰</text>
        </view>
        <text class="empty-title">暂时没有订单</text>
        <text class="empty-desc">请保持在线状态，等待新订单</text>
      </view>
      
      <!-- 订单列表 -->
      <block wx:elif="{{!loading && orders.length > 0}}">
        <block wx:for="{{orders}}" wx:key="id">
          <view class="order-card">
            <!-- 顶部信息 -->
            <view class="order-header">
              <text class="delivery-time">{{item.deliveryTime}}</text>
              <text class="order-price">¥{{item.price}}</text>
            </view>
            
            <!-- 取货地址 -->
            <view class="address-section pickup">
              <view class="address-header">
                <!-- <text class="distance">{{item.pickupDistance}}</text> -->
                <view class="store-info">
                  <text class="store-name">{{item.pickupStore}}</text>
                  <text class="address-detail">{{item.pickupAddress}}</text>
                </view>
              </view>
            </view>
            
            <!-- 配送地址 -->
            <view class="address-section delivery">
              <view class="address-header">
                <!-- <text class="distance">{{item.deliveryDistance}}</text> -->
                <text class="delivery-address">{{item.deliveryAddress}}</text>
              </view>
            </view>

            <!-- 顾客联系方式（待送达阶段可联系） -->
            <view class="contact-row" wx:if="{{item.customerPhone}}">
              <text class="contact-text">顾客：{{item.customerName || '用户'}} {{item.customerPhone}}</text>
              <button class="contact-btn" bindtap="onContactCustomer" data-phone="{{item.customerPhone}}" data-name="{{item.customerName || '用户'}}">联系顾客</button>
            </view>
            
            <!-- 状态标签 -->
            <view class="status-tag" wx:if="{{item.status}}">
              <text>{{item.status}}</text>
            </view>
            
            <!-- 餐品信息 -->
            <view class="items-info" bindtap="onToggleItems" data-index="{{index}}">
              <text class="items-text">餐品: {{item.items}}</text>
              <text class="items-arrow {{item.showItems ? 'expanded' : ''}}">▼</text>
            </view>
            
            <!-- 餐品详情（可展开） -->
            <view class="items-detail" wx:if="{{item.showItems && item.itemsDetail && item.itemsDetail.length > 0}}">
              <block wx:for="{{item.itemsDetail}}" wx:key="index" wx:for-item="food">
                <view class="food-item">
                  <text class="food-name">{{food.name}}</text>
                  <text class="food-spec" wx:if="{{food.spec}}">{{food.spec}}</text>
                  <text class="food-quantity">x{{food.quantity}}</text>
                </view>
              </block>
            </view>
            
            <!-- 抢单按钮 -->
            <button 
              class="grab-btn {{canGrabOrder && !grabbingOrderId ? '' : 'disabled'}}" 
              bindtap="onGrabOrder" 
              data-id="{{item.id}}"
              disabled="{{!canGrabOrder || grabbingOrderId === item.id}}"
            >
              {{grabbingOrderId === item.id ? '抢单中...' : (canGrabOrder ? '抢单' : '无法接单')}}
            </button>
          </view>
        </block>
      </block>
    </view>

    <!-- 待取货订单列表 -->
    <view class="order-list" wx:if="{{activeTab === 1}}">
      <!-- 骨架屏 -->
      <view wx:if="{{pickupLoading && pickupOrders.length === 0}}" class="order-skeleton-list">
        <block wx:for="{{[1,2,3,4]}}" wx:key="*this">
          <view class="order-card">
            <view class="order-header">
              <view class="ds-skeleton-line" style="width:80px;height:18px;margin-bottom:8px;"></view>
              <view class="ds-skeleton-line" style="width:50px;height:20px;border-radius:4px;"></view>
            </view>
            <view class="address-section" style="margin-bottom:8px;">
              <view class="ds-skeleton-line" style="width:90%;height:14px;margin-bottom:4px;"></view>
              <view class="ds-skeleton-line" style="width:70%;height:14px;"></view>
            </view>
            <view class="ds-skeleton-line" style="width:60%;height:14px;margin-bottom:8px;"></view>
            <view class="ds-skeleton-line" style="width:100px;height:36px;border-radius:8px;"></view>
          </view>
        </block>
      </view>
      
      <!-- 错误重试 -->
      <view class="error-retry-state" wx:elif="{{loadError && !pickupLoading && pickupOrders.length === 0}}">
        <text class="error-icon">⚠️</text>
        <text class="error-title">加载失败</text>
        <text class="error-desc">{{errorMessage || '网络异常，请重试'}}</text>
        <button class="retry-btn" bindtap="onRetryLoad">点击重试</button>
      </view>
      
      <!-- 空状态 -->
      <view class="empty-state" wx:elif="{{!pickupLoading && pickupOrders.length === 0}}">
        <view class="empty-icon-wrap">
          <text class="empty-icon">📦</text>
        </view>
        <text class="empty-title">暂时没有订单</text>
        <text class="empty-desc">建议您持续保持在线或去「待抢单」抢一个</text>
      </view>
      
      <!-- 订单列表 -->
      <block wx:elif="{{!pickupLoading && pickupOrders.length > 0}}">
        <block wx:for="{{pickupOrders}}" wx:key="id">
          <view class="order-card">
            <!-- 顶部信息 -->
            <view class="order-header">
              <text class="delivery-time">{{item.deliveryTime}}</text>
              <text class="order-price">¥{{item.price}}</text>
            </view>
            
            <!-- 取货地址 -->
            <view class="address-section pickup">
              <view class="address-header">
                <!-- <text class="distance">{{item.pickupDistance}}</text> -->
                <view class="store-info">
                  <text class="store-name">{{item.pickupStore}}</text>
                  <text class="address-detail">{{item.pickupAddress}}</text>
                </view>
              </view>
            </view>
            
            <!-- 配送地址 -->
            <view class="address-section delivery">
              <view class="address-header">
                <!-- <text class="distance">{{item.deliveryDistance}}</text> -->
                <text class="delivery-address">{{item.deliveryAddress}}</text>
              </view>
            </view>
            
            <!-- 状态标签 -->
            <view class="status-tag" wx:if="{{item.status}}">
              <text>{{item.status}}</text>
            </view>
            
            <!-- 餐品信息 -->
            <view class="items-info" bindtap="onTogglePickupItems" data-index="{{index}}">
              <text class="items-text">餐品: {{item.items}}</text>
              <text class="items-arrow {{item.showItems ? 'expanded' : ''}}">▼</text>
            </view>
            
            <!-- 餐品详情（可展开） -->
            <view class="items-detail" wx:if="{{item.showItems && item.itemsDetail && item.itemsDetail.length > 0}}">
              <block wx:for="{{item.itemsDetail}}" wx:key="index" wx:for-item="food">
                <view class="food-item">
                  <text class="food-name">{{food.name}}</text>
                  <text class="food-spec" wx:if="{{food.spec}}">{{food.spec}}</text>
                  <text class="food-quantity">x{{food.quantity}}</text>
                </view>
              </block>
            </view>
            
            <!-- 确认取餐按钮 -->
            <button class="pickup-btn" bindtap="onConfirmPickup" data-id="{{item.id}}" disabled="{{pickupOrderId === item.id}}">{{pickupOrderId === item.id ? '确认中...' : '确认取餐'}}</button>
          </view>
        </block>
      </block>
    </view>

    <!-- 待送达订单列表 -->
    <view class="order-list" wx:if="{{activeTab === 2}}">
      <!-- 骨架屏 -->
      <view wx:if="{{deliverLoading && deliverOrders.length === 0}}" class="order-skeleton-list">
        <block wx:for="{{[1,2,3,4]}}" wx:key="*this">
          <view class="order-card">
            <view class="order-header">
              <view class="ds-skeleton-line" style="width:80px;height:18px;margin-bottom:8px;"></view>
              <view class="ds-skeleton-line" style="width:50px;height:20px;border-radius:4px;"></view>
            </view>
            <view class="address-section" style="margin-bottom:8px;">
              <view class="ds-skeleton-line" style="width:90%;height:14px;margin-bottom:4px;"></view>
              <view class="ds-skeleton-line" style="width:70%;height:14px;"></view>
            </view>
            <view class="ds-skeleton-line" style="width:60%;height:14px;margin-bottom:8px;"></view>
            <view class="ds-skeleton-line" style="width:100px;height:36px;border-radius:8px;"></view>
          </view>
        </block>
      </view>
      
      <!-- 错误重试 -->
      <view class="error-retry-state" wx:elif="{{loadError && !deliverLoading && deliverOrders.length === 0}}">
        <text class="error-icon">⚠️</text>
        <text class="error-title">加载失败</text>
        <text class="error-desc">{{errorMessage || '网络异常，请重试'}}</text>
        <button class="retry-btn" bindtap="onRetryLoad">点击重试</button>
      </view>
      
      <!-- 空状态 -->
      <view class="empty-state" wx:elif="{{!deliverLoading && deliverOrders.length === 0}}">
        <view class="empty-icon-wrap">
          <text class="empty-icon">🚚</text>
        </view>
        <text class="empty-title">暂时没有订单</text>
        <text class="empty-desc">暂无待送达订单</text>
      </view>
      
      <!-- 订单列表 -->
      <block wx:elif="{{!deliverLoading && deliverOrders.length > 0}}">
        <block wx:for="{{deliverOrders}}" wx:key="id">
          <view class="order-card">
            <!-- 顶部信息 -->
            <view class="order-header">
              <text class="delivery-time">{{item.deliveryTime}}</text>
              <text class="order-price">¥{{item.price}}</text>
            </view>
            
            <!-- 取货地址 -->
            <view class="address-section pickup">
              <view class="address-header">
                <!-- <text class="distance">{{item.pickupDistance}}</text> -->
                <view class="store-info">
                  <text class="store-name">{{item.pickupStore}}</text>
                  <text class="address-detail">{{item.pickupAddress}}</text>
                </view>
              </view>
            </view>
            
            <!-- 配送地址 -->
            <view class="address-section delivery">
              <view class="address-header">
                <!-- <text class="distance">{{item.deliveryDistance}}</text> -->
                <text class="delivery-address">{{item.deliveryAddress}}</text>
              </view>
            </view>
            
            <!-- 状态标签 -->
            <view class="status-tag" wx:if="{{item.status}}">
              <text>{{item.status}}</text>
            </view>
            
            <!-- 餐品信息 -->
            <view class="items-info" bindtap="onToggleDeliverItems" data-index="{{index}}">
              <text class="items-text">餐品: {{item.items}}</text>
              <text class="items-arrow {{item.showItems ? 'expanded' : ''}}">▼</text>
            </view>
            
            <!-- 餐品详情（可展开） -->
            <view class="items-detail" wx:if="{{item.showItems && item.itemsDetail && item.itemsDetail.length > 0}}">
              <block wx:for="{{item.itemsDetail}}" wx:key="index" wx:for-item="food">
                <view class="food-item">
                  <text class="food-name">{{food.name}}</text>
                  <text class="food-spec" wx:if="{{food.spec}}">{{food.spec}}</text>
                  <text class="food-quantity">x{{food.quantity}}</text>
                </view>
              </block>
            </view>
            
            <!-- 确认送达按钮 -->
            <button class="deliver-btn" bindtap="onConfirmDelivery" data-id="{{item.id}}" disabled="{{deliveringOrderId === item.id}}">{{deliveringOrderId === item.id ? '确认中...' : '确认送达'}}</button>
          </view>
        </block>
      </block>
    </view>
  </scroll-view>

  <!-- 底部固定：个人中心 -->
  <view class="bottom-bar" bindtap="onAvatarTap">
    <text class="bottom-bar-text">个人中心</text>
    <text class="bottom-bar-arrow">›</text>
  </view>
</view>



