/* pages/secondhand-detail/index.wxss */
.page {
  background-color: var(--color-bg-page);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.status-bar { background-color: var(--color-bg-card); }

.nav-bar {
  display: flex;
  align-items: center;
  height: 44px;
  background-color: var(--color-bg-card);
  padding: 0 15px;
  border-bottom: 1px solid var(--color-border);
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10px;
}

.back-icon { font-size: 18px; color: var(--color-text); }

.title { flex: 1; font-size: 18px; font-weight: 600; color: var(--color-text); }

.share-btn { padding: 4px 12px; }

.share-icon { font-size: 14px; color: var(--color-text-secondary); }

.content {
  flex: 1;
  padding-bottom: 80px;
}

.image-section {
  position: relative;
  width: 100%;
  height: 375px;
  background-color: var(--color-bg-card);
}

.image-swiper {
  width: 100%;
  height: 100%;
}

.product-image {
  width: 100%;
  height: 100%;
}

.image-count {
  position: absolute;
  bottom: 15px;
  right: 15px;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
}

.info-section {
  background-color: var(--color-bg-card);
  padding: 15px;
  margin-bottom: 10px;
}

.price-row { display: flex; align-items: baseline; margin-bottom: 12px; }

.price {
  font-size: 28px;
  font-weight: 600;
  color: var(--color-primary);
  margin-right: 12px;
}

.original-price-info { display: flex; align-items: center; gap: 8px; }

.original-price {
  font-size: 14px;
  color: var(--color-text-placeholder);
  text-decoration: line-through;
}

.discount-badge {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
  padding: 2px 8px;
  border-radius: var(--radius-btn);
  font-size: 12px;
}

.product-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8px;
  line-height: 1.4;
}

.product-desc {
  font-size: 14px;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-bottom: 12px;
}

.tags-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }

.tag {
  padding: 4px 12px;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-tag);
  font-size: 12px;
  color: var(--color-text-secondary);
}

.meta-info { padding-top: 12px; border-top: 1px solid var(--color-border); }

.meta-item { display: flex; align-items: center; margin-bottom: 8px; font-size: 14px; }

.meta-item:last-child { margin-bottom: 0; }

.meta-label { color: var(--color-text-placeholder); margin-right: 8px; }

.meta-value { color: var(--color-text); }

.seller-section {
  background-color: var(--color-bg-card);
  padding: 15px;
  margin-bottom: 10px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12px;
}

.seller-card {
  display: flex;
  align-items: center;
  padding: 12px;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-btn);
}

.seller-avatar {
  width: 50px;
  height: 50px;
  border-radius: 25px;
  margin-right: 12px;
}

.seller-info { flex: 1; }

.seller-name {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 4px;
}

.seller-rating { display: flex; align-items: center; gap: 4px; }

.star { font-size: 12px; }

.rating { font-size: 12px; color: var(--color-text-secondary); }

.contact-btn {
  padding: 8px 20px;
  background-color: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-tag);
  font-size: 14px;
}

.contact-text { color: #fff; }

.detail-section {
  background-color: var(--color-bg-card);
  padding: 15px;
  margin-bottom: 10px;
}

.detail-content {
  padding: 12px;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-btn);
  min-height: 100px;
}

.detail-text {
  font-size: 14px;
  color: var(--color-text-secondary);
  line-height: 1.6;
  white-space: pre-wrap;
}

.detail-empty {
  font-size: 14px;
  color: var(--color-text-placeholder);
  text-align: center;
  padding: 20px 0;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* 加载状态 */
.loading-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 50px 0;
}

.loading-text { font-size: 14px; color: var(--color-text-placeholder); }

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--color-bg-card);
  padding: 12px 15px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  border-top: 1px solid var(--color-border);
  z-index: 100;
  display: flex;
  gap: 10px;
}

.action-btn {
  flex: 1;
  height: 44px;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
}

.contact-btn-bottom { background-color: var(--color-primary); color: #fff; }

.action-text { color: #fff; }

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-width: 400px;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-card);
  overflow: hidden;
  animation: modalShow 0.3s ease-out;
}

@keyframes modalShow {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(-20px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 20px 15px;
  border-bottom: 1px solid var(--color-border);
}

.modal-title { font-size: 18px; font-weight: 600; color: var(--color-text); }

.modal-close {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: var(--color-text-placeholder);
  line-height: 1;
}

.modal-body { padding: 20px; text-align: center; }

.contact-type-label {
  font-size: 14px;
  color: var(--color-text-placeholder);
  margin-bottom: 12px;
}

.contact-info-display {
  font-size: 20px;
  font-weight: 600;
  color: var(--color-primary);
  word-break: break-all;
  padding: 15px;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-btn);
  margin-bottom: 10px;
}

.modal-footer {
  display: flex;
  gap: 10px;
  padding: 15px 20px 20px;
  border-top: 1px solid var(--color-border);
}

.modal-btn {
  flex: 1;
  height: 44px;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 500;
}

.copy-btn { background-color: var(--color-bg-page); color: var(--color-text); }

.confirm-btn { background-color: var(--color-primary); color: #fff; }

.modal-btn-text {
  color: inherit;
}

