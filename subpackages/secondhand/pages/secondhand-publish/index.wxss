/* pages/secondhand-publish/index.wxss */
.page {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.status-bar {
  background-color: #fff;
}

.nav-bar {
  display: flex;
  align-items: center;
  height: 44px;
  background-color: #fff;
  padding: 0 15px;
  border-bottom: 1px solid #e5e5e5;
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10px;
}

.back-icon {
  font-size: 18px;
  color: #333;
}

.title {
  flex: 1;
  font-size: 18px;
  font-weight: 600;
  color: #333;
}

.content {
  flex: 1;
  padding-bottom: 80px;
}

.section {
  background-color: #fff;
  padding: 15px;
  margin-bottom: 10px;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.required {
  color: #ff4d4f;
}

/* 图片上传 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.image-item {
  position: relative;
  width: 80px;
  height: 80px;
  border-radius: 8px;
  overflow: hidden;
}

.image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: -5px;
  right: -5px;
  width: 20px;
  height: 20px;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
}

.add-image-btn {
  width: 80px;
  height: 80px;
  border: 1px dashed #ddd;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.add-icon {
  font-size: 24px;
  color: #999;
  margin-bottom: 4px;
}

.add-text {
  font-size: 12px;
  color: #999;
}

.tip {
  font-size: 12px;
  color: #999;
  margin-top: 8px;
}

/* 输入框 */
.input {
  width: 100%;
  padding: 12px;
  background-color: #f5f5f5;
  border-radius: 8px;
  font-size: 14px;
  color: #333;
}

.textarea {
  width: 100%;
  min-height: 100px;
  padding: 12px;
  background-color: #f5f5f5;
  border-radius: 8px;
  font-size: 14px;
  color: #333;
}

.price-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.price-input {
  flex: 1;
}

.unit {
  font-size: 14px;
  color: #666;
}

/* 选择器 */
.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px;
  background-color: #f5f5f5;
  border-radius: 8px;
}

.picker-text {
  font-size: 14px;
  color: #333;
}

.picker-text.placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 12px;
  color: #999;
}

/* 联系方式 */
.contact-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.contact-type-picker {
  flex-shrink: 0;
}

.contact-picker {
  width: 100px;
  min-width: 100px;
}

.contact-input {
  flex: 1;
}

/* 匿名发布开关 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
}

.switch-label {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-right: 15px;
}

.switch-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.switch-desc {
  font-size: 12px;
  color: #999;
  line-height: 1.4;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* 底部发布按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 12px 15px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  border-top: 1px solid #e5e5e5;
  z-index: 100;
}

.publish-btn {
  width: 100%;
  height: 44px;
  background-color: #ff6b35;
  color: #fff;
  border-radius: 22px;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(255, 107, 53, 0.3);
}

