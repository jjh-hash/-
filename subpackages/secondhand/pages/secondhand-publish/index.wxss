/* pages/secondhand-publish/index.wxss */
.page {
  background-color: var(--color-bg-page);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.status-bar { background-color: var(--color-bg-card); }

.nav-bar {
  display: flex;
  align-items: center;
  height: 44px;
  background-color: var(--color-bg-card);
  padding: 0 15px;
  border-bottom: 1px solid var(--color-border);
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10px;
}

.back-icon { font-size: 18px; color: var(--color-text); }

.title { flex: 1; font-size: 18px; font-weight: 600; color: var(--color-text); }

.content { flex: 1; padding-bottom: 80px; }

.section {
  background-color: var(--color-bg-card);
  padding: 15px;
  margin-bottom: 10px;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12px;
}

.required { color: var(--color-danger); }

/* 图片上传 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.image-item {
  position: relative;
  width: 80px;
  height: 80px;
  border-radius: 8px;
  overflow: hidden;
}

.image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: -5px;
  right: -5px;
  width: 20px;
  height: 20px;
  background-color: var(--color-danger);
  color: #fff;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
}

.add-image-btn {
  width: 80px;
  height: 80px;
  border: 1px dashed var(--color-border);
  border-radius: var(--radius-btn);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-page);
}

.add-icon { font-size: 24px; color: var(--color-text-placeholder); margin-bottom: 4px; }

.add-text { font-size: 12px; color: var(--color-text-placeholder); }

.tip { font-size: 12px; color: var(--color-text-placeholder); margin-top: 8px; }

.input {
  width: 100%;
  padding: 12px;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-btn);
  font-size: 14px;
  color: var(--color-text);
}

.textarea {
  width: 100%;
  min-height: 100px;
  padding: 12px;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-btn);
  font-size: 14px;
  color: var(--color-text);
}

.price-row { display: flex; align-items: center; gap: 8px; }

.price-input { flex: 1; }

.unit { font-size: 14px; color: var(--color-text-secondary); }

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-btn);
}

.picker-text { font-size: 14px; color: var(--color-text); }

.picker-text.placeholder { color: var(--color-text-placeholder); }

.picker-arrow { font-size: 12px; color: var(--color-text-placeholder); }

/* 联系方式 */
.contact-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.contact-type-picker {
  flex-shrink: 0;
}

.contact-picker {
  width: 100px;
  min-width: 100px;
}

.contact-input {
  flex: 1;
}

/* 匿名发布开关 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
}

.switch-label {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-right: 15px;
}

.switch-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 4px;
}

.switch-desc { font-size: 12px; color: var(--color-text-placeholder); line-height: 1.4; }

.safe-area-bottom { height: env(safe-area-inset-bottom); }

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--color-bg-card);
  padding: 12px 15px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  border-top: 1px solid var(--color-border);
  z-index: 100;
}

.publish-btn {
  width: 100%;
  height: 44px;
  background-color: var(--color-primary);
  color: #fff;
  border-radius: 22px;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(7, 193, 96, 0.3);
}

