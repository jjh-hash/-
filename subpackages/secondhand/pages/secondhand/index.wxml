<view class="page">
  <!-- 状态栏 -->

  <!-- 头部导航 -->

  <scroll-view scroll-y class="content">
    <!-- 分类标签 -->
    <view class="category-tabs">
      <scroll-view scroll-x class="category-scroll">
        <view class="category-list">
          <block wx:for="{{categories}}" wx:key="index">
            <view 
              class="category-item {{index === activeCategory ? 'active' : ''}}"
              bindtap="onCategoryTap"
              data-index="{{index}}"
            >
              {{item}}
            </view>
          </block>
        </view>
      </scroll-view>
    </view>

    <!-- 排序选项 -->
    <view class="sort-bar">
      <view class="sort-options">
        <block wx:for="{{sortOptions}}" wx:key="index">
          <view 
            class="sort-item {{index === activeSort ? 'active' : ''}}"
            bindtap="onSortTap"
            data-index="{{index}}"
          >
            {{item}}
            <text class="sort-arrow">▼</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="product-list">
      <block wx:for="{{products}}" wx:key="id">
        <view class="product-card" bindtap="onProductTap" data-id="{{item.id}}">
          <!-- 商品图片 -->
          <view class="product-image">
            <image class="image" src="{{item.images && item.images[0] ? item.images[0] : '/pages/小标/商家.png'}}" mode="aspectFill" lazy-load />
            <view class="price-tag">
              <text class="price">¥{{item.price}}</text>
            </view>
          </view>
          
          <!-- 商品信息 -->
          <view class="product-info">
            <view class="product-title">{{item.title}}</view>
            <view class="product-desc">{{item.description || '暂无描述'}}</view>
            
            <!-- 原价和折扣 -->
            <view class="price-info" wx:if="{{item.originalPrice}}">
              <text class="original-price">原价¥{{item.originalPrice}}</text>
              <text class="discount">{{item.discount || 0}}%</text>
            </view>
            
            <!-- 标签 -->
            <view class="product-tags" wx:if="{{item.tags && item.tags.length > 0}}">
              <block wx:for="{{item.tags}}" wx:key="*this">
                <view class="tag">{{item}}</view>
              </block>
            </view>
            
            <!-- 卖家信息 -->
            <view class="seller-info">
              <image class="seller-avatar" src="{{item.seller && item.seller.avatar ? item.seller.avatar : '/pages/小标/商家.png'}}" mode="aspectFill" />
              <view class="seller-details">
                <text class="seller-name">{{item.seller && item.seller.name ? item.seller.name : '匿名用户'}}</text>
                <view class="seller-rating">
                  <text class="star">⭐</text>
                  <text class="rating">{{item.seller && item.seller.rating ? item.seller.rating : '5.0'}}</text>
                </view>
              </view>
              <view class="location-time">
                <text class="location">{{item.location || '未填写'}}</text>
                <text class="time">{{item.publishTime || '刚刚'}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- 加载更多提示 -->
      <view wx:if="{{hasMore && products.length > 0}}" class="load-more">
        <text>上拉加载更多</text>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{products.length === 0 && !loading}}" class="empty">
        <text class="empty-icon">📦</text>
        <text class="empty-text">{{searchValue ? '未找到相关商品' : '暂无闲置商品'}}</text>
      </view>

      <!-- 加载状态 -->
      <view wx:if="{{loading && products.length === 0}}" class="loading-state">
        <text>加载中...</text>
      </view>
    </view>
    
    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 发布按钮 -->
  <view class="publish-btn" bindtap="onPublishTap">
    <text class="publish-icon">+</text>
    <text class="publish-text">发布</text>
  </view>
</view>
