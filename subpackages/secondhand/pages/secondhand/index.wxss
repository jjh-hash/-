.page {
  background-color: var(--color-bg-page);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.status-bar { background: var(--color-bg-card); padding: 0 12px; }

.header {
  display: flex;
  align-items: center;
  padding: 8px 16px;
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8px;
}

.back-icon { font-size: 18px; color: var(--color-text); }

.title { font-size: 18px; font-weight: 600; color: var(--color-text); margin-right: 12px; }

.search-container {
  flex: 1;
  height: 32px;
  background: var(--color-bg-page);
  border-radius: 16px;
  display: flex;
  align-items: center;
  padding: 0 12px;
}

.search-icon { font-size: 14px; color: var(--color-text-placeholder); margin-right: 6px; }

.search-input { flex: 1; font-size: 14px; color: var(--color-text); }

.search-placeholder { color: var(--color-text-placeholder); }

/* 内容区域 */
.content {
  flex: 1;
  padding-bottom: 80px;
}

.category-tabs {
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
}

.category-scroll { white-space: nowrap; }

.category-list { display: flex; padding: 0 12px; }

.category-item {
  padding: 12px 16px;
  font-size: 14px;
  color: var(--color-text-secondary);
  white-space: nowrap;
  position: relative;
}

.category-item.active {
  color: var(--color-primary);
  font-weight: 500;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 2px;
  background: var(--color-primary);
  border-radius: 1px;
}

.sort-bar {
  background: var(--color-bg-card);
  padding: 12px;
  border-bottom: 1px solid var(--color-border);
}

.sort-options {
  display: flex;
  flex-wrap: nowrap;
  gap: 16px;
  overflow-x: auto;
  padding-bottom: 2px;
}

.sort-item {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  font-size: 14px;
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.sort-item.active { color: var(--color-primary); }

.sort-arrow { font-size: 10px; margin-left: 4px; color: var(--color-text-placeholder); flex-shrink: 0; }

/* 商品列表 */
.product-list {
  padding: 12px;
}

.product-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  margin-bottom: 12px;
  overflow: hidden;
  display: flex;
  box-shadow: var(--shadow-card);
}

/* 商品图片 */
.product-image {
  width: 120px;
  height: 120px;
  position: relative;
  flex-shrink: 0;
}

.image {
  width: 100%;
  height: 100%;
}

.price-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  padding: 8px;
}

.price {
  color: #fff;
  font-size: 16px;
  font-weight: 600;
}

/* 商品信息 */
.product-info {
  flex: 1;
  padding: 12px;
  display: flex;
  flex-direction: column;
}

.product-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  font-size: 12px;
  color: var(--color-text-secondary);
  margin-bottom: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-info { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }

.original-price {
  font-size: 12px;
  color: var(--color-text-placeholder);
  text-decoration: line-through;
}

.discount {
  background: var(--color-primary);
  color: #fff;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: var(--radius-btn);
}

.product-tags { display: flex; gap: 4px; margin-bottom: 8px; }

.tag {
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-size: 10px;
  padding: 2px 6px;
  border-radius: var(--radius-btn);
}

/* 卖家信息 */
.seller-info {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: auto;
}

.seller-avatar {
  width: 24px;
  height: 24px;
  border-radius: 12px;
}

.seller-details {
  flex: 1;
}

.seller-name {
  font-size: 12px;
  color: var(--color-text);
  display: block;
  margin-bottom: 2px;
}

.seller-rating { display: flex; align-items: center; gap: 2px; }

.star { font-size: 10px; color: #ffd700; }

.rating { font-size: 10px; color: var(--color-text-secondary); }

.location-time { text-align: right; }

.location {
  font-size: 10px;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 2px;
}

.time { font-size: 10px; color: var(--color-text-placeholder); }

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

.load-more {
  text-align: center;
  padding: 20px;
  color: var(--color-text-placeholder);
  font-size: 14px;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon { font-size: 48px; margin-bottom: 12px; }

.empty-text { font-size: 14px; color: var(--color-text-placeholder); }

.loading-state {
  text-align: center;
  padding: 20px;
  color: var(--color-text-placeholder);
  font-size: 14px;
}

.publish-btn {
  position: fixed;
  right: 20px;
  bottom: 20px;
  width: 56px;
  height: 56px;
  background: var(--color-primary);
  border-radius: 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(7, 193, 96, 0.3);
  z-index: 100;
}

.publish-icon {
  font-size: 20px;
  color: #fff;
  font-weight: 600;
}

.publish-text {
  font-size: 10px;
  color: #fff;
  margin-top: 2px;
}
