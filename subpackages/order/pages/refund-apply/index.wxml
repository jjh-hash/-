<view class="page">
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <text class="back" bindtap="onBack">◀</text>
      <text class="title">申请退款</text>
      <view class="icons">
        <text class="dot">•</text>
        <text class="battery">▮</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 退款原因 -->
    <view class="section">
  
      <view class="form-item" bindtap="onSelectReason">
        <text class="form-value {{refundReason ? '' : 'placeholder'}}">
          {{refundReason || '请选择退款原因'}}
        </text>
        <text class="arrow">></text>
      </view>
      <view class="form-item">
        <textarea 
          class="textarea" 
          placeholder="请描述退款原因"
          value="{{refundReasonText}}"
          bindinput="onReasonTextInput"
          maxlength="200"
          show-confirm-bar="{{false}}">
        </textarea>
      </view>
      <view class="form-item">
        <view class="add-image-btn" bindtap="onChooseImage">
          <text class="camera-icon">📷</text>
          <text class="add-text">添加图片</text>
        </view>
      </view>
      <!-- 已上传的图片 -->
      <view class="image-container" wx:if="{{images.length > 0}}">
        <view 
          class="image-item"
          wx:for="{{images}}"
          wx:key="index">
          <image 
            class="image" 
            src="{{item}}" 
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="onPreviewImage" />
          <view 
            class="delete-btn"
            data-index="{{index}}"
            bindtap="onDeleteImage">
            ×
          </view>
        </view>
      </view>
    </view>

    <!-- 选择退款来源 -->
    <view class="section">
      <view class="section-label">选择退款来源</view>
      <view class="form-item">
        <text class="form-value">退款至您的支付账户</text>
        <view class="check-icon">✓</view>
      </view>
    </view>

    <!-- 已退款商品提示 -->
    <view class="section" wx:if="{{refundedItems.length > 0}}">
      <view class="section-label">已退款商品</view>
      <view class="refunded-tip">
        <text class="tip-text">已退款金额：¥{{totalRefundedAmount}}</text>
      </view>
      <block wx:for="{{refundedItems}}" wx:key="productId" wx:for-item="refundedItem">
        <view class="refund-item disabled">
          <view class="item-checkbox">
            <view class="checkbox disabled">✓</view>
          </view>
          <view class="item-info">
            <view class="item-name">{{refundedItem.productName || '商品'}}</view>
            <view class="item-spec" wx:if="{{refundedItem.spec}}">{{refundedItem.spec}}</view>
            <view class="item-quantity">已退款 x{{refundedItem.quantity}}</view>
          </view>
          <view class="item-price">¥{{refundedItem.amount}}</view>
        </view>
      </block>
    </view>

    <!-- 选择退款商品 -->
    <view class="section">
      <view class="section-label">选择退款商品</view>
      <view class="section-tip" wx:if="{{refundItems.length === 0}}">
        <text class="tip-text">该订单所有商品已退款</text>
      </view>
      <block wx:for="{{refundItems}}" wx:key="id" wx:for-index="idx">
        <view class="refund-item">
          <view class="item-checkbox" bindtap="onToggleItem" data-id="{{item.id}}">
            <view class="checkbox {{item.selected ? 'checked' : ''}}">
              <text wx:if="{{item.selected}}" class="check-mark">✓</text>
            </view>
          </view>
          <image class="item-image" src="{{item.image}}" mode="aspectFill" />
          <view class="item-info">
            <view class="item-name">{{item.productName}}</view>
            <view class="item-spec" wx:if="{{item.spec}}">{{item.spec}}</view>
            <view class="item-quantity">
              <text>订单数量：x{{item.quantity}}</text>
              <text wx:if="{{item.refundedQuantity > 0}}" class="refunded-quantity">（已退款：x{{item.refundedQuantity}}）</text>
              <text class="available-quantity">可退款：x{{item.availableQuantity}}</text>
            </view>
            <!-- 退款数量选择器 -->
            <view class="quantity-selector" wx:if="{{item.selected}}">
              <text class="quantity-label">退款数量：</text>
              <view class="quantity-controls">
                <view class="quantity-btn" bindtap="onAdjustQuantity" data-id="{{item.id}}" data-type="decrease">-</view>
                <input 
                  class="quantity-input" 
                  type="number" 
                  value="{{item.refundQuantity}}" 
                  data-id="{{item.id}}"
                  bindinput="onQuantityInput"
                  min="1"
                  max="{{item.availableQuantity}}" />
                <view class="quantity-btn" bindtap="onAdjustQuantity" data-id="{{item.id}}" data-type="increase">+</view>
              </view>
            </view>
          </view>
          <view class="item-price">
            <text wx:if="{{item.selected}}">¥{{item.subtotal}}</text>
            <text wx:else>¥{{item.priceText}}</text>
          </view>
        </view>
      </block>
      
      <!-- 其他费用（不退） -->
      <block wx:for="{{otherFees}}" wx:key="name">
        <view class="refund-item disabled">
          <view class="item-checkbox">
            <view class="checkbox disabled"></view>
          </view>
          <view class="item-info">
            <view class="item-name">{{item.name}}</view>
          </view>
          <view class="item-price">¥{{item.amount}}</view>
        </view>
      </block>
    </view>

    <!-- 全选和退款金额 -->
    <view class="summary-section">
      <view class="select-all" bindtap="onToggleSelectAll">
        <view class="checkbox {{selectAll ? 'checked' : ''}}">
          <text wx:if="{{selectAll}}" class="check-mark">✓</text>
        </view>
        <text class="select-all-text">全选</text>
      </view>
      <view class="refund-amount">
        <text class="amount-label">退款金额</text>
        <text class="amount-value">¥{{refundAmount}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部提交栏 -->
  <view class="footer-bar">
    <view class="footer-amount">
      <text class="footer-label">退款金额</text>
      <text class="footer-value">¥{{refundAmount}}</text>
    </view>
    <button 
      class="submit-btn {{isSubmitting ? 'disabled' : ''}}"
      bindtap="onSubmitRefund"
      disabled="{{isSubmitting}}">
      {{isSubmitting ? '提交中...' : '提交'}}
    </button>
  </view>
</view>

