.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 80rpx;
}

.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background-color: #fff;
}

.status-bar {
  background-color: #fff;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e5e5e5;
}

.nav-bar .back {
  font-size: 36rpx;
  color: #333;
}

.nav-bar .title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.nav-bar .icons {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.content {
  margin-top: 88rpx;
  padding: 20rpx 0;
}

.section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-value {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.form-value.placeholder {
  color: #999;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 20rpx;
}

.textarea {
  width: 100%;
  min-height: 150rpx;
  font-size: 32rpx;
  color: #333;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.add-image-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  background-color: #f9f9f9;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
}

.camera-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.add-text {
  font-size: 24rpx;
  color: #666;
}

.image-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.image-item .image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #ff4444;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
  background-color: #ffd700;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.refund-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.refund-item.disabled {
  opacity: 0.5;
}

.refund-item:last-child {
  border-bottom: none;
}

.item-checkbox {
  margin-right: 20rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background-color: #ffd700;
  border-color: #ffd700;
}

.checkbox.disabled {
  background-color: #f0f0f0;
  border-color: #e0e0e0;
}

.check-mark {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.item-spec {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 5rpx;
}

.item-quantity {
  font-size: 24rpx;
  color: #999;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.refunded-quantity {
  color: #ff9500;
  margin-left: 10rpx;
}

.available-quantity {
  color: #07c160;
  font-weight: 500;
}

.quantity-selector {
  display: flex;
  align-items: center;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.quantity-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 15rpx;
}

.quantity-controls {
  display: flex;
  align-items: center;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  overflow: hidden;
}

.quantity-btn {
  width: 60rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  border: none;
}

.quantity-btn:active {
  background-color: #e0e0e0;
}

.quantity-input {
  width: 80rpx;
  height: 50rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  border-left: 1rpx solid #ddd;
  border-right: 1rpx solid #ddd;
  background-color: #fff;
}

.item-price {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-right: 20rpx;
}

.item-feedback-btn {
  padding: 10rpx 20rpx;
  background-color: #666;
  color: #fff;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.summary-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all-text {
  font-size: 32rpx;
  color: #333;
  margin-left: 15rpx;
}

.refund-amount {
  display: flex;
  align-items: center;
}

.amount-label {
  font-size: 32rpx;
  color: #333;
  margin-right: 15rpx;
}

.amount-value {
  font-size: 36rpx;
  color: #ff4444;
  font-weight: bold;
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background-color: #333;
  z-index: 1000;
}

.footer-amount {
  display: flex;
  align-items: center;
}

.footer-label {
  font-size: 28rpx;
  color: #fff;
  margin-right: 15rpx;
}

.footer-value {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.submit-btn {
  padding: 20rpx 60rpx;
  background-color: #ffd700;
  color: #333;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.submit-btn.disabled {
  background-color: #ccc;
  color: #999;
}

.submit-btn::after {
  border: none;
}

.refunded-tip {
  padding: 15rpx 0;
  margin-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tip-text {
  font-size: 28rpx;
  color: #666;
}

.section-tip {
  padding: 30rpx 0;
  text-align: center;
}

.section-tip .tip-text {
  font-size: 28rpx;
  color: #999;
}


