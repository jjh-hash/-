<view class="page {{showDetail ? 'sheet-open' : ''}}">
  <!-- 搜索框 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="输入关键词搜索订单" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchSubmit"
      />
    </view>
  </view>

  <!-- 筛选选项 -->
  <view class="filter-section">
    <view class="filter-item" bindtap="onServiceFilterTap">
      <text class="filter-label">服务</text>
      <text class="filter-value" wx:if="{{selectedService}}">{{selectedService}}</text>
      <text class="filter-arrow">▼</text>
    </view>
    <view class="filter-item" bindtap="onStatusFilterTap">
      <text class="filter-label">状态</text>
      <text class="filter-value" wx:if="{{selectedStatus}}">{{selectedStatus}}</text>
      <text class="filter-arrow">▼</text>
    </view>
    <view class="filter-item" bindtap="onLocationFilterTap">
      <text class="filter-label">地点</text>
      <text class="filter-value" wx:if="{{selectedLocation}}">{{selectedLocation}}</text>
      <text class="filter-arrow">▼</text>
    </view>
    <view class="filter-item" bindtap="onGenderFilterTap">
      <text class="filter-label">性别</text>
      <text class="filter-value" wx:if="{{selectedGender}}">{{selectedGender}}</text>
      <text class="filter-arrow">▼</text>
    </view>
  </view>

  <!-- 地点筛选弹窗 -->
  <view class="filter-mask {{showLocationFilter ? 'show' : ''}}" catchtap="onCloseLocationFilter"></view>
  <view class="filter-popup {{showLocationFilter ? 'show' : ''}}">
    <view class="filter-popup-header">
      <text class="filter-popup-title">选择地点</text>
      <text class="filter-popup-close" bindtap="onCloseLocationFilter">×</text>
    </view>
    <scroll-view scroll-y class="filter-popup-content">
      <view 
        class="filter-popup-item {{selectedLocation === item || (!selectedLocation && item === '全部地点') ? 'active' : ''}}"
        wx:for="{{locationOptions}}" 
        wx:key="*this"
        bindtap="onSelectLocation"
        data-location="{{item}}"
      >
        <text class="filter-popup-item-text">{{item}}</text>
        <text class="filter-popup-item-check" wx:if="{{selectedLocation === item || (!selectedLocation && item === '全部地点')}}">✓</text>
      </view>
    </scroll-view>
    <view class="filter-popup-footer">
      <view class="filter-popup-btn reset" bindtap="onResetLocation">重置</view>
      <view class="filter-popup-btn confirm" bindtap="onCloseLocationFilter">确定</view>
    </view>
  </view>

  <!-- 服务筛选弹窗 -->
  <view class="filter-mask {{showServiceFilter ? 'show' : ''}}" catchtap="onCloseServiceFilter"></view>
  <view class="filter-popup {{showServiceFilter ? 'show' : ''}}">
    <view class="filter-popup-header">
      <text class="filter-popup-title">选择服务</text>
      <text class="filter-popup-close" bindtap="onCloseServiceFilter">×</text>
    </view>
    <scroll-view scroll-y class="filter-popup-content">
      <view 
        class="filter-popup-item {{selectedService === item || (!selectedService && item === '全部服务') ? 'active' : ''}}"
        wx:for="{{serviceOptions}}" 
        wx:key="*this"
        bindtap="onSelectService"
        data-service="{{item}}"
      >
        <text class="filter-popup-item-text">{{item}}</text>
        <text class="filter-popup-item-check" wx:if="{{selectedService === item || (!selectedService && item === '全部服务')}}">✓</text>
      </view>
    </scroll-view>
    <view class="filter-popup-footer">
      <view class="filter-popup-btn reset" bindtap="onResetService">重置</view>
      <view class="filter-popup-btn confirm" bindtap="onCloseServiceFilter">确定</view>
    </view>
  </view>

  <!-- 状态筛选弹窗 -->
  <view class="filter-mask {{showStatusFilter ? 'show' : ''}}" catchtap="onCloseStatusFilter"></view>
  <view class="filter-popup {{showStatusFilter ? 'show' : ''}}">
    <view class="filter-popup-header">
      <text class="filter-popup-title">选择状态</text>
      <text class="filter-popup-close" bindtap="onCloseStatusFilter">×</text>
    </view>
    <scroll-view scroll-y class="filter-popup-content">
      <view 
        class="filter-popup-item {{selectedStatus === item || (!selectedStatus && item === '全部') ? 'active' : ''}}"
        wx:for="{{statusOptions}}" 
        wx:key="*this"
        bindtap="onSelectStatus"
        data-status="{{item}}"
      >
        <text class="filter-popup-item-text">{{item}}</text>
        <text class="filter-popup-item-check" wx:if="{{selectedStatus === item || (!selectedStatus && item === '全部')}}">✓</text>
      </view>
    </scroll-view>
    <view class="filter-popup-footer">
      <view class="filter-popup-btn reset" bindtap="onResetStatus">重置</view>
      <view class="filter-popup-btn confirm" bindtap="onCloseStatusFilter">确定</view>
    </view>
  </view>

  <!-- 性别筛选弹窗 -->
  <view class="filter-mask {{showGenderFilter ? 'show' : ''}}" catchtap="onCloseGenderFilter"></view>
  <view class="filter-popup {{showGenderFilter ? 'show' : ''}}">
    <view class="filter-popup-header">
      <text class="filter-popup-title">选择性别</text>
      <text class="filter-popup-close" bindtap="onCloseGenderFilter">×</text>
    </view>
    <scroll-view scroll-y class="filter-popup-content">
      <view 
        class="filter-popup-item {{selectedGender === item || (!selectedGender && item === '全部性别') ? 'active' : ''}}"
        wx:for="{{genderOptions}}" 
        wx:key="*this"
        bindtap="onSelectGender"
        data-gender="{{item}}"
      >
        <text class="filter-popup-item-text">{{item}}</text>
        <text class="filter-popup-item-check" wx:if="{{selectedGender === item || (!selectedGender && item === '全部性别')}}">✓</text>
      </view>
    </scroll-view>
    <view class="filter-popup-footer">
      <view class="filter-popup-btn reset" bindtap="onResetGender">重置</view>
      <view class="filter-popup-btn confirm" bindtap="onCloseGenderFilter">确定</view>
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view scroll-y class="list">
    <!-- 首次加载骨架屏 -->
    <view wx:if="{{loading && orders.length === 0}}" class="order-skeleton-list">
      <block wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
        <view class="order-card">
          <view class="order-header">
            <view class="order-header-left">
              <view class="order-avatar ds-skeleton" style="width:40px;height:40px;border-radius:50%;"></view>
              <view class="ds-skeleton-line" style="width:72px;height:24px;border-radius:12px;"></view>
            </view>
            <view class="order-header-right">
              <view class="ds-skeleton-line" style="width:60px;height:14px;margin-bottom:6px;"></view>
              <view class="ds-skeleton-line" style="width:50px;height:20px;border-radius:12px;"></view>
            </view>
          </view>
          <view class="order-content" style="padding:8px 0;">
            <view class="ds-skeleton-line" style="width:100%;margin-bottom:6px;"></view>
            <view class="ds-skeleton-line" style="width:80%;margin-bottom:4px;"></view>
            <view class="ds-skeleton-line" style="width:60%;"></view>
          </view>
          <view class="order-footer" style="padding-top:8px;border-top:1px solid var(--color-border);">
            <view class="ds-skeleton-line" style="width:60px;height:14px;"></view>
          </view>
        </view>
      </block>
    </view>
    
    <!-- 空状态 -->
    <view wx:elif="{{orders.length === 0 && !loading}}" class="empty-wrap">
      <view class="empty-icon-wrap">
        <text class="empty-icon">📋</text>
      </view>
      <text class="empty-title">暂无任务</text>
      <text class="empty-desc">稍后再来看看，或去发布代拿/跑腿/陪玩</text>
    </view>
    
    <!-- 订单列表 -->
 <block wx:elif="{{orders.length > 0}}">
      <block wx:for="{{orders}}" wx:key="id">
        <view class="order-card" bindtap="onOpenDetail" data-id="{{item.id}}">
          <!-- 订单头部：头像、类型、截止时间、状态 -->
          <view class="order-header">
            <view class="order-header-left">
              <!-- 用户头像 -->
              <image class="order-avatar" src="{{item.userInfo && item.userInfo.avatarUrl ? item.userInfo.avatarUrl : (item.address && item.address.avatar ? item.address.avatar : '/pages/小标/默认头像.png')}}" mode="aspectFill" lazy-load></image>
              <!-- 订单类型标签 -->
              <view class="order-type-tag {{item.orderType}}">
                <text>{{item.orderTypeText}}</text>
              </view>
            </view>
            <view class="order-header-right">
              <!-- 截止时间 -->
              <view class="expired-time" wx:if="{{item.expiredAtDisplay}}">
                <text class="expired-time-icon">⏰</text>
                <text class="expired-time-text">{{item.expiredAtDisplay}}</text>
              </view>
              <!-- 订单状态标签 -->
              <view class="status-badge {{item.statusClass}}">
                <text>{{item.statusText}}</text>
              </view>
            </view>
          </view>
          
          <!-- 订单内容区域 -->
          <view class="order-content">
            <!-- 游戏陪玩订单特殊显示 -->
          <view wx:if="{{item.orderType === 'gaming'}}" class="special-order-info">
            <view class="special-info-item">
              <text class="special-label">游戏类型：</text>
              <text class="special-value">{{item.gameType}}</text>
            </view>
            <view class="special-info-item">
              <text class="special-label">时长：</text>
              <text class="special-value">{{item.taskDuration || item.sessionDuration}}{{item.taskDurationUnit === 'minute' ? '分钟' : '小时'}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.requirements || item.selectedRequirements}}">
              <text class="special-label">要求：</text>
              <text class="special-value">{{item.selectedRequirements && item.selectedRequirements.length > 0 ? item.selectedRequirements.join('、') : item.requirements}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.bounty}}">
              <text class="special-label">赏金：</text>
              <text class="special-value price">¥{{item.bounty.toFixed(2)}}</text>
            </view>
          </view>

          <!-- 悬赏订单特殊显示 -->
          <view wx:elif="{{item.orderType === 'reward'}}" class="special-order-info">
            <view class="special-info-item">
              <text class="special-label">类别：</text>
              <text class="special-value">{{item.category}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.helpLocation}}">
              <text class="special-label">帮助地点：</text>
              <text class="special-value">{{item.helpLocation}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.helpContent}}">
              <text class="special-label">内容：</text>
              <text class="special-value">{{item.helpContent}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.bounty}}">
              <text class="special-label">赏金：</text>
              <text class="special-value price">¥{{item.bounty.toFixed(2)}}</text>
            </view>
            <view class="special-images" wx:if="{{item.images && item.images.length > 0}}">
              <image wx:for="{{item.images}}" wx:key="*this" wx:for-item="img" class="special-image" src="{{img}}" mode="aspectFill" lazy-load />
            </view>
          </view>

          <!-- 代拿快递订单特殊显示 -->
          <view wx:elif="{{item.orderType === 'express'}}" class="special-order-info">
            <!-- 未接单前显示隐藏提示 -->
            <view wx:if="{{item.orderStatus === 'pending'}}" class="hidden-info-tip">
              <text class="hidden-tip-text">[相关信息已隐藏]</text>
            </view>
            <!-- 接单后显示详细信息 -->
            <block wx:else>
              <view class="special-info-item" wx:if="{{item.pickupLocation}}">
                <text class="special-label">取件位置：</text>
                <text class="special-value">{{item.pickupLocation}}</text>
              </view>
              <view class="special-info-item" wx:if="{{item.deliveryLocation}}">
                <text class="special-label">送达位置：</text>
                <text class="special-value">{{item.deliveryLocation}}</text>
              </view>
              <view class="special-info-item" wx:if="{{item.pickupCode}}">
                <text class="special-label">取件码：</text>
                <text class="special-value code">{{item.pickupCode}}</text>
              </view>
              <view class="special-info-item" wx:if="{{item.packageSizes && item.packageSizes.length > 0}}">
                <text class="special-label">包裹信息：</text>
                <text class="special-value">
                  <text wx:for="{{item.packageSizes}}" wx:key="id" wx:for-item="pkg" wx:for-index="pkgIndex">{{pkg.name}}{{pkg.description ? '(' + pkg.description + ')' : ''}} x{{pkg.quantity}}<text wx:if="{{pkgIndex < item.packageSizes.length - 1}}">、</text></text>
                </text>
              </view>
              <view class="special-images" wx:if="{{item.images && item.images.length > 0}}">
                <image wx:for="{{item.images}}" wx:key="*this" wx:for-item="img" class="special-image" src="{{img}}" mode="aspectFill" lazy-load />
              </view>
            </block>
          </view>

          <!-- 普通订单显示商品列表 -->
          <view class="items" wx:if="{{item.orderType !== 'gaming' && item.orderType !== 'reward' && item.orderType !== 'express'}}">
            <block wx:for="{{item.items}}" wx:key="productId" wx:for-item="product">
              <view class="item">
                <image class="thumb" src="{{product.image}}" mode="aspectFill" lazy-load wx:if="{{product.image}}" />
                <view class="meta">
                  <text class="name">{{product.productName}}</text>
                  <text class="spec" wx:if="{{product.spec}}">{{product.spec}}</text>
                  <text class="price">¥{{product.price}}</text>
                </view>
                <text class="qty">x{{product.quantity}}</text>
              </view>
            </block>
          </view>

          <view class="remark" wx:if="{{item.remark}}">备注：{{item.remark}}</view>
          
          <!-- 地址信息（游戏陪玩订单不显示地址，代拿快递订单未接单前不显示，且未接单前不显示联系人和电话） -->
          <view class="address-info" wx:if="{{item.address && item.orderType !== 'gaming' && !(item.orderType === 'express' && item.orderStatus === 'pending')}}">
            <view class="address-line">
              <text class="address-label">联系人：</text>
              <text>{{item.address.name}}</text>
            </view>
            <view class="address-line">
              <text class="address-label">电话：</text>
              <text>{{item.address.phone}}</text>
            </view>
            <view class="address-line">
              <text class="address-label">地址：</text>
              <text>{{item.address.buildingName}}{{item.address.houseNumber}}{{item.address.addressDetail}}</text>
            </view>
          </view>

          <!-- 游戏陪玩订单的联系信息（只有接单后才显示） -->
          <view class="address-info" wx:if="{{item.orderType === 'gaming' && item.orderStatus !== 'pending' && (item.address || item.userInfo)}}">
            <view class="address-line" wx:if="{{item.address && item.address.name}}">
              <text class="address-label">联系人：</text>
              <text>{{item.address.name}}</text>
            </view>
            <view class="address-line" wx:if="{{item.address && item.address.phone}}">
              <text class="address-label">电话：</text>
              <text>{{item.address.phone}}</text>
            </view>
            <view class="address-line" wx:if="{{item.userInfo && (item.userInfo.nickname || item.userInfo.userName)}}">
              <text class="address-label">联系人：</text>
              <text>{{item.userInfo.nickname || item.userInfo.userName || '用户'}}</text>
            </view>
            <view class="address-line" wx:if="{{item.userInfo && item.userInfo.phone}}">
              <text class="address-label">电话：</text>
              <text>{{item.userInfo.phone}}</text>
            </view>
          </view>

          <!-- 用户信息（无店铺订单，非游戏陪玩，代拿快递订单未接单前不显示） -->
          <view class="address-info" wx:if="{{!item.address && item.userInfo && item.orderType !== 'gaming' && !(item.orderType === 'express' && item.orderStatus === 'pending')}}">
            <view class="address-line">
              <text class="address-label">用户：</text>
              <text>{{item.userInfo.nickname || item.userInfo.userName || '用户'}}</text>
            </view>
            <view class="address-line" wx:if="{{item.userInfo.phone}}">
              <text class="address-label">电话：</text>
              <text>{{item.userInfo.phone}}</text>
            </view>
          </view>
          </view>
          
          <!-- 订单底部：赏金和接单按钮 -->
          <view class="order-footer">
            <view class="reward-box">
              <text class="reward-label">赏</text>
              <text class="reward-amount">¥{{item.bounty || item.amountTotal}}</text>
            </view>
            <view class="order-actions">
              <!-- 接单后才能联系用户 -->
              <view class="action-btn ghost" bindtap="onContactUser" data-id="{{item.id}}" wx:if="{{item.orderStatus !== 'pending' && item.orderStatus !== 'cancelled'}}" catchtap="stopPropagation">联系用户</view>
              <!-- 接单者完成订单按钮：接单后且订单进行中时显示 -->
              <view class="action-btn success" bindtap="onCompleteOrder" data-id="{{item.id}}" wx:if="{{(item.orderStatus === 'confirmed_by_receiver' || item.orderStatus === 'in_progress') && item.receiverOpenid === currentUserOpenid && currentUserOpenid}}" catchtap="stopPropagation">完成订单</view>
              <!-- 待接单：只有别人发的订单才显示接单按钮，不能接自己的订单 -->
              <view class="action-btn primary" bindtap="onConfirmOrder" data-id="{{item.id}}" wx:if="{{item.orderStatus === 'pending' && item.userOpenid && item.userOpenid !== currentUserOpenid && currentUserOpenid}}" catchtap="stopPropagation">
                <text>接单</text>
                <text class="btn-time" wx:if="{{currentTime}}">{{currentTime}}</text>
              </view>
              <!-- 等待用户确认：接单者看到“等待确认”，下单者看到“确认完成” -->
              <view class="action-btn waiting" wx:if="{{item.orderStatus === 'waiting_user_confirm' && item.userOpenid !== currentUserOpenid}}">等待确认</view>
              <view class="action-btn success" bindtap="onUserConfirmComplete" data-id="{{item.id}}" wx:if="{{item.orderStatus === 'waiting_user_confirm' && item.userOpenid === currentUserOpenid && currentUserOpenid}}" catchtap="stopPropagation">确认完成</view>
              <!-- 已完成 -->
              <view class="action-btn completed" wx:if="{{item.orderStatus === 'completed'}}">已完成</view>
              <!-- 已取消 -->
              <view class="action-btn cancelled" wx:if="{{item.orderStatus === 'cancelled'}}">订单已取消</view>
            </view>
          </view>
        </view>
      </block>
      <view class="load-more-footer" wx:if="{{orders.length > 0}}">
        <text wx:if="{{loading && hasMoreOrders}}">加载更多...</text>
        <text wx:elif="{{!hasMoreOrders}}">没有更多了</text>
      </view>
    </block>
    
    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 订单详情弹层 -->
  <view class="sheet-mask {{showDetail? 'show':''}}" catchtouchmove="preventTouchMove" bindtap="onCloseDetail"></view>
  <view class="sheet {{showDetail? 'show':''}}" catchtouchmove="preventTouchMove">
    <view class="sheet-header">
      <text class="sheet-desk">{{detail.deskNo}}#</text>
      <text class="sheet-status {{detail.orderStatus === 'cancelled' ? 'cancelled' : ''}}">{{detail.statusText}}</text>
    </view>
    <view class="sheet-items">
      <block wx:for="{{detail.items}}" wx:key="name">
        <view class="s-item">
          <image class="s-thumb" src="{{item.img}}" mode="aspectFill" lazy-load />
          <view class="s-meta">
            <text class="s-name">{{item.name}}</text>
            <text class="s-price">¥{{item.price}}</text>
          </view>
          <text class="s-qty">x{{item.qty}}</text>
        </view>
      </block>
    </view>
    <view class="sheet-remark" wx:if="{{detail.remark}}">备注：{{detail.remark}}</view>

    <view class="sheet-line"><text>商品金额</text><text>¥{{detail.amountGoods || '0.00'}}</text></view>
    <view class="sheet-line"><text>配送费</text><text>¥{{detail.amountDelivery || '0.00'}}</text></view>
    <view class="sheet-line"><text>平台服务费</text><text>¥{{detail.platformFee || '0.00'}}</text></view>
    <view class="sheet-line" wx:if="{{detail.amountDiscount > 0}}"><text>优惠</text><text>-¥{{detail.amountDiscount}}</text></view>
    <view class="sheet-line income"><text>合计</text><text class="red">¥{{detail.amountTotal || '0.00'}}</text></view>

    <view class="sheet-info">
      <!-- 接单者信息 -->
      <view class="i-row" wx:if="{{detail.receiverInfo}}">
        <text class="i-label">接单者</text>
        <view class="i-value">
          <image class="receiver-avatar" src="{{detail.receiverInfo.avatarUrl || '/pages/小标/默认头像.png'}}" mode="aspectFill"></image>
          <text class="receiver-name">{{detail.receiverInfo.nickname || '用户'}}</text>
        </view>
      </view>
      <!-- 配送信息（游戏陪玩订单不显示地址，代拿快递订单未接单前不显示，且未接单前不显示联系人和电话） -->
      <view class="i-row address-row" wx:if="{{(detail.address || detail.userInfo) && detail.orderType !== 'gaming' && !(detail.orderType === 'express' && detail.orderStatus === 'pending')}}" catchtap="onAddressTap">
        <text class="i-label">配送信息</text>
        <text class="i-value address-clickable" wx:if="{{detail.address}}">
          {{detail.address.name || '用户'}} {{detail.address.phone || ''}}\n{{detail.address.fullAddress || (detail.address.buildingName || '') + (detail.address.houseNumber || '') + (detail.address.addressDetail || detail.address.address || '未设置地址')}}
        </text>
        <text class="i-value address-clickable" wx:elif="{{detail.userInfo}}">
          {{detail.userInfo.nickname || detail.userInfo.userName || '用户'}} {{detail.userInfo.phone || ''}}\n未设置地址
        </text>
      </view>
      <!-- 游戏陪玩订单的联系信息（只有接单后才显示） -->
      <view class="i-row address-row" wx:if="{{detail.orderType === 'gaming' && detail.orderStatus !== 'pending' && (detail.address || detail.userInfo)}}" catchtap="onAddressTap">
        <text class="i-label">联系信息</text>
        <text class="i-value address-clickable" wx:if="{{detail.address}}">
          {{detail.address.name || '用户'}} {{detail.address.phone || ''}}
        </text>
        <text class="i-value address-clickable" wx:elif="{{detail.userInfo}}">
          {{detail.userInfo.nickname || detail.userInfo.userName || '用户'}} {{detail.userInfo.phone || ''}}
        </text>
      </view>
      <view class="i-row"><text class="i-label">订单号码</text><text class="i-value">{{detail.orderNo}}</text></view>
      <view class="i-row"><text class="i-label">下单时间</text><text class="i-value">{{detail.createdAt}}</text></view>
      <view class="i-row" wx:if="{{detail.readyAt}}">
        <text class="i-label">出餐时间</text>
        <text class="i-value">{{detail.readyAt}}</text>
      </view>
    </view>

    <view class="sheet-actions">
      <!-- 接单后才能联系用户 -->
      <view class="btn ghost" bindtap="onContactUser" data-id="{{detail.id}}" wx:if="{{detail.orderStatus !== 'pending' && detail.orderStatus !== 'cancelled'}}">联系用户</view>
      <!-- 接单者完成订单按钮：接单后且订单进行中时显示 -->
      <view class="btn success" bindtap="onCompleteOrder" data-id="{{detail.id}}" wx:if="{{(detail.orderStatus === 'confirmed_by_receiver' || detail.orderStatus === 'in_progress') && detail.receiverOpenid === currentUserOpenid && currentUserOpenid}}">完成订单</view>
      <!-- 待接单：只有别人发的订单才显示接单按钮，不能接自己的订单 -->
      <view class="btn primary" bindtap="onConfirmOrder" wx:if="{{detail.orderStatus === 'pending' && detail.userOpenid && detail.userOpenid !== currentUserOpenid && currentUserOpenid}}">接单</view>
      <!-- 等待用户确认：下单者可点击确认完成 -->
      <view class="btn waiting" wx:if="{{detail.orderStatus === 'waiting_user_confirm' && detail.userOpenid !== currentUserOpenid}}">等待确认</view>
      <view class="btn success" bindtap="onUserConfirmComplete" data-order-id="{{detail.id}}" wx:if="{{detail.orderStatus === 'waiting_user_confirm' && detail.userOpenid === currentUserOpenid && currentUserOpenid}}">确认完成</view>
      <!-- 已完成 -->
      <view class="btn completed" wx:if="{{detail.orderStatus === 'completed'}}">已完成</view>
      <!-- 已取消 -->
      <view class="btn cancelled" wx:if="{{detail.orderStatus === 'cancelled'}}">订单已取消</view>
    </view>
  </view>

  <!-- 我的订单浮动按钮 -->
  <view class="my-order-float-btn" bindtap="onMyOrderTap">
    <image class="my-order-icon" src="/pages/小标/dingdan.png" mode="aspectFit" />
  </view>

  <!-- 联系信息弹窗 -->
  <view class="contact-mask {{showContactInfo ? 'show' : ''}}" catchtouchmove="preventTouchMove" bindtap="onCloseContactInfo"></view>
  <view class="contact-popup {{showContactInfo ? 'show' : ''}}" catchtouchmove="preventTouchMove">
    <view class="contact-popup-header">
      <text class="contact-popup-title">联系用户</text>
      <text class="contact-popup-close" bindtap="onCloseContactInfo">×</text>
    </view>
    <view class="contact-popup-content">
      <view class="contact-user-name">
        <text>{{contactInfo.userName}}</text>
      </view>
      
      <!-- 微信号 -->
      <view class="contact-item" wx:if="{{contactInfo.wechat}}">
        <view class="contact-item-label">
          <text class="contact-icon">💬</text>
          <text>微信号</text>
        </view>
        <view class="contact-item-value">
          <text class="contact-value-text">{{contactInfo.wechat}}</text>
          <view class="contact-action-btn" bindtap="onCopyWechat">
            <text>复制</text>
          </view>
        </view>
      </view>

      <!-- 电话号 -->
      <view class="contact-item" wx:if="{{contactInfo.phone}}">
        <view class="contact-item-label">
          <text class="contact-icon">📞</text>
          <text>电话号</text>
        </view>
        <view class="contact-item-value">
          <text class="contact-value-text">{{contactInfo.phone}}</text>
          <view class="contact-action-btn-group">
            <view class="contact-action-btn" bindtap="onCopyPhone">
              <text>复制</text>
            </view>
            <view class="contact-action-btn primary" bindtap="onCallPhone">
              <text>拨打</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 无联系方式提示 -->
      <view class="contact-empty" wx:if="{{!contactInfo.wechat && !contactInfo.phone}}">
        <text>用户未设置联系方式</text>
      </view>
    </view>
  </view>

</view>
