<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  <view class="nav">
    <text class="title">接单</text>
    <view class="nav-icons"></view>
  </view>

  <!-- 顶部标签 -->
  <view class="tabs">
    <view class="tab {{activeTab===0?'active':''}}" data-index="0" bindtap="onTabTap">全部</view>
    <view class="tab {{activeTab===1?'active':''}}" data-index="1" bindtap="onTabTap">待确认</view>
    <view class="tab {{activeTab===2?'active':''}}" data-index="2" bindtap="onTabTap">已完成</view>
    <view class="tab {{activeTab===3?'active':''}}" data-index="3" bindtap="onTabTap">已取消</view>
  </view>

  <!-- 订单列表 -->
  <scroll-view scroll-y class="list">
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-container">
      <text>加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view wx:elif="{{orders.length === 0 && !loading}}" class="empty-container">
      <text>暂无订单</text>
    </view>
    
    <!-- 订单列表 -->
    <block wx:elif="{{!loading && orders.length > 0}}">
      <block wx:for="{{orders}}" wx:key="id">
        <view class="order-card" bindtap="onOpenDetail" data-id="{{item.id}}">
          <view class="order-top">
            <text class="order-no">订单号：{{item.orderNo}}</text>
            <text class="status {{item.statusClass}}">{{item.statusText}}</text>
          </view>
          <view class="items">
            <block wx:for="{{item.items}}" wx:key="productId" wx:for-item="product">
              <view class="item">
                <image class="thumb" src="{{product.image}}" mode="aspectFill" />
                <view class="meta">
                  <text class="name">{{product.productName}}</text>
                  <text class="spec" wx:if="{{product.spec}}">{{product.spec}}</text>
                  <text class="price">¥{{product.price}}</text>
                </view>
                <text class="qty">x{{product.quantity}}</text>
              </view>
            </block>
          </view>
          <view class="remark" wx:if="{{item.remark}}">备注：{{item.remark}}</view>
          <view class="address-info" wx:if="{{item.address}}">
            <view class="address-line">
              <text class="address-label">联系人：</text>
              <text>{{item.address.name}}</text>
            </view>
            <view class="address-line">
              <text class="address-label">电话：</text>
              <text>{{item.address.phone}}</text>
            </view>
            <view class="address-line">
              <text class="address-label">地址：</text>
              <text>{{item.address.buildingName}}{{item.address.houseNumber}}{{item.address.addressDetail}}</text>
            </view>
          </view>
          <view class="total-info">
            <text>合计：¥{{item.amountTotal}}</text>
          </view>
          <view class="actions">
            <view class="btn ghost" bindtap="onContactUser" data-id="{{item.id}}">联系用户</view>
            <view class="btn primary" bindtap="onConfirmOrder" data-id="{{item.id}}" wx:if="{{item.orderStatus === 'pending'}}">接单</view>
            <view class="btn success" bindtap="onCompleteOrder" data-id="{{item.id}}" wx:if="{{item.orderStatus === 'confirmed'}}">完成订单</view>
            <view class="btn cancelled" wx:if="{{item.orderStatus === 'cancelled'}}">订单已取消</view>
          </view>
        </view>
      </block>
    </block>
    
    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 订单详情弹层 -->
  <view class="sheet-mask {{showDetail? 'show':''}}" catchtouchmove="true" bindtap="onCloseDetail"></view>
  <view class="sheet {{showDetail? 'show':''}}" catchtouchmove="true">
    <view class="sheet-header">
      <text class="sheet-desk">{{detail.deskNo}}#</text>
      <text class="sheet-status {{detail.orderStatus === 'cancelled' ? 'cancelled' : ''}}">{{detail.statusText}}</text>
    </view>
    <view class="sheet-items">
      <block wx:for="{{detail.items}}" wx:key="name">
        <view class="s-item">
          <image class="s-thumb" src="{{item.img}}" mode="aspectFill" />
          <view class="s-meta">
            <text class="s-name">{{item.name}}</text>
            <text class="s-price">¥{{item.price}}</text>
          </view>
          <text class="s-qty">x{{item.qty}}</text>
        </view>
      </block>
    </view>
    <view class="sheet-remark" wx:if="{{detail.remark}}">备注：{{detail.remark}}</view>

    <view class="sheet-line"><text>商品金额</text><text>¥{{detail.amountGoods || '0.00'}}</text></view>
    <view class="sheet-line"><text>配送费</text><text>¥{{detail.amountDelivery || '0.00'}}</text></view>
    <view class="sheet-line"><text>平台服务费</text><text>¥{{detail.platformFee || '0.00'}}</text></view>
    <view class="sheet-line" wx:if="{{detail.amountDiscount > 0}}"><text>优惠</text><text>-¥{{detail.amountDiscount}}</text></view>
    <view class="sheet-line income"><text>合计</text><text class="red">¥{{detail.amountTotal || '0.00'}}</text></view>

    <view class="sheet-info">
      <view class="i-row" wx:if="{{detail.address}}">
        <text class="i-label">配送信息</text>
        <text class="i-value">{{detail.address.name}} {{detail.address.phone}}\n{{detail.address.fullAddress}}</text>
      </view>
      <view class="i-row"><text class="i-label">订单号码</text><text class="i-value">{{detail.orderNo}}</text></view>
      <view class="i-row"><text class="i-label">下单时间</text><text class="i-value">{{detail.createdAt}}</text></view>
      <view class="i-row" wx:if="{{detail.expiredAt && detail.orderStatus !== 'completed' && detail.orderStatus !== 'cancelled'}}">
        <text class="i-label">订单超时</text>
        <text class="i-value {{detail.expiredMinutes < 0 ? 'expired' : ''}}">
          <text wx:if="{{detail.expiredMinutes === null}}">{{detail.expiredAt}}</text>
          <text wx:elif="{{detail.expiredMinutes < 0}}">已超时</text>
          <text wx:else>剩余{{detail.expiredMinutes}}分钟</text>
        </text>
      </view>
      <view class="i-row" wx:if="{{detail.readyAt}}">
        <text class="i-label">出餐时间</text>
        <text class="i-value">{{detail.readyAt}}</text>
      </view>
    </view>

    <view class="sheet-actions">
      <view class="btn ghost" bindtap="onContactUser" data-id="{{detail.id}}">联系用户</view>
      <view class="btn cancelled" wx:if="{{detail.orderStatus === 'cancelled'}}">订单已取消</view>
      <view class="btn primary" bindtap="onConfirmOrder" wx:if="{{detail.orderStatus === 'pending'}}">接单</view>
      <view class="btn success" bindtap="onCompleteOrder" wx:if="{{detail.orderStatus === 'confirmed'}}">完成订单</view>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="tabbar">
    <view class="t-item {{bottomActive==='home'?'active':''}}" bindtap="onBottomTap" data-tab="home">
      <image class="t-img" src="{{bottomActive==='home'? '/pages/小标/shouye-copy.png' : '/pages/小标/shouye.png'}}" mode="aspectFit" />
      <text class="t-txt">首页</text>
    </view>
    <view class="t-item {{bottomActive==='order'?'active':''}}" bindtap="onBottomTap" data-tab="order">
      <image class="t-img" src="{{bottomActive==='order'? '/pages/小标/dingdan-copy.png' : '/pages/小标/dingdan.png'}}" mode="aspectFit" />
      <text class="t-txt">订单</text>
    </view>
    <!-- 接单功能正在开发中，已注释 -->
    <!-- <view class="t-item {{bottomActive==='receive'?'active':''}}" bindtap="onBottomTap" data-tab="receive">
      <image class="t-img" src="{{bottomActive==='receive'? '/pages/小标/接单 (1).png' : '/pages/小标/接单.png'}}" mode="aspectFit" />
      <text class="t-txt">接单</text>
    </view> -->
    <!-- 消息功能正在开发中，已注释 -->
    <!-- <view class="t-item {{bottomActive==='message'?'active':''}}" bindtap="onBottomTap" data-tab="message">
      <image class="t-img" src="{{bottomActive==='message'? '/pages/小标/消息 (1).png' : '/pages/小标/消息.png'}}" mode="aspectFit" />
      <text class="t-txt">消息</text>
    </view> -->
    <view class="t-item {{bottomActive==='profile'?'active':''}}" bindtap="onBottomTap" data-tab="profile">
      <image class="t-img" src="{{bottomActive==='profile'? '/pages/小标/wode-copy.png' : '/pages/小标/wode.png'}}" mode="aspectFit" />
      <text class="t-txt">我的</text>
    </view>
  </view>
</view>
