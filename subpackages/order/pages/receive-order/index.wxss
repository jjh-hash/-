/* 任务大厅 - 设计系统 */
.page{min-height:100vh;background:var(--color-bg-page)}
.status-bar{width:100%}
.nav{height:44px;background:var(--color-primary);border-bottom:1px solid rgba(0,0,0,.06);display:flex;align-items:center;justify-content:center;position:relative}
.title{font-size:18px;color:#fff;font-weight:600}
.nav-icons{position:absolute;right:12px;top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:8px}
.my-order-float-btn{position:fixed;right:16px;bottom:calc(24px + env(safe-area-inset-bottom));width:56px;height:56px;border-radius:50%;background:var(--color-primary);display:flex;align-items:center;justify-content:center;box-shadow:var(--shadow-float);z-index:999;transition:transform var(--transition-fast)}
.my-order-float-btn:active{transform:scale(0.95)}
.my-order-icon{width:24px;height:24px;filter:brightness(0) invert(1)}

.search-section{padding:var(--space-item) var(--space-page);background:var(--color-bg-card);border-bottom:1px solid var(--color-border)}
.search-box{display:flex;align-items:center;background:var(--color-bg-page);border-radius:var(--radius-tag);padding:10px 16px;border:1px solid var(--color-border)}
.search-icon{font-size:16px;margin-right:8px;color:var(--color-text-placeholder)}
.search-input{flex:1;font-size:14px;color:var(--color-text)}

.filter-section{display:flex;background:var(--color-bg-card);border-bottom:1px solid var(--color-border);padding:10px var(--space-page)}
.filter-item{flex:1;display:flex;align-items:center;justify-content:center;padding:8px 4px;position:relative;min-width:0}
.filter-item:not(:last-child)::after{content:'';position:absolute;right:0;top:50%;transform:translateY(-50%);width:1px;height:14px;background:var(--color-border)}
.filter-label{font-size:12px;color:var(--color-text-secondary);white-space:nowrap}
.filter-value{font-size:12px;color:var(--color-primary);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:64px;margin-left:4px}
.filter-arrow{font-size:10px;color:var(--color-text-placeholder);margin-left:4px}

.list{height:calc(100vh - 60px - 100px);padding-bottom:calc(80px + env(safe-area-inset-bottom));box-sizing:border-box}

.loading-container{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px;color:var(--color-text-secondary);font-size:14px}

.load-more-footer{text-align:center;padding:16px;color:var(--color-text-placeholder);font-size:12px}

/* 空状态 */
.empty-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 24px;text-align:center}
.empty-icon-wrap{width:72px;height:72px;border-radius:50%;background:var(--color-primary-light);display:flex;align-items:center;justify-content:center;margin:0 auto 20px}
.empty-icon{font-size:40px;line-height:1}
.empty-title{display:block;font-size:16px;font-weight:600;color:var(--color-text);margin-bottom:8px}
.empty-desc{display:block;font-size:14px;color:var(--color-text-secondary);line-height:1.4}

.order-skeleton-list .ds-skeleton-line{flex-shrink:0}

.order-card{background:var(--color-bg-card);margin:var(--space-item) var(--space-page);border-radius:var(--radius-card);box-shadow:var(--shadow-card);padding:var(--space-block);position:relative;overflow:hidden;border:1px solid var(--color-border);transition:box-shadow var(--transition-fast)}
.order-card:active{box-shadow:var(--shadow-card-hover)}
/* 订单头部 */
.order-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
.order-header-left{display:flex;align-items:center;gap:10px;flex:1}
.order-avatar{width:40px;height:40px;border-radius:50%;border:2px solid var(--color-border);flex-shrink:0}
.order-type-tag{padding:4px 12px;border-radius:var(--radius-tag);font-size:12px;font-weight:500;white-space:nowrap}
.order-type-tag.gaming{background:rgba(233,30,99,.12);color:#e91e63}
.order-type-tag.reward{background:var(--color-primary-light);color:var(--color-warning)}
.order-type-tag.express{background:var(--color-secondary-light);color:var(--color-secondary)}
.order-header-right{display:flex;flex-direction:column;align-items:flex-end;gap:6px}
.expired-time{display:flex;align-items:center;gap:4px;font-size:12px;color:var(--color-text-secondary)}
.expired-time-icon{font-size:14px}
.expired-time-text{font-size:12px;color:var(--color-text-secondary)}
.status-badge{padding:4px 10px;border-radius:var(--radius-tag);font-size:12px;font-weight:500;white-space:nowrap}
.status-badge.pending{background:rgba(221,142,9,.15);color:var(--color-warning)}
.status-badge.received{background:var(--color-secondary-light);color:var(--color-secondary)}
.status-badge.in-progress{background:var(--color-secondary-light);color:var(--color-secondary)}
.status-badge.waiting-confirm{background:rgba(7,193,96,.12);color:var(--color-success)}
.status-badge.completed{background:rgba(7,193,96,.12);color:var(--color-success)}
.status-badge.cancelled{background:rgba(239,68,68,.1);color:var(--color-danger)}
/* 订单内容区域 */
.order-content{margin-bottom:12px}
.address-info{margin-top:6px;background:var(--color-bg-page);border-radius:var(--radius-btn);padding:8px;font-size:12px}
.address-line{margin-bottom:4px;display:flex;align-items:flex-start}
.address-line:last-child{margin-bottom:0}
.address-label{color:var(--color-text-secondary);margin-right:4px;min-width:50px}
.hidden-info-tip{text-align:center;padding:16px;background:var(--color-bg-page);border-radius:var(--radius-btn);margin:8px 0}
.hidden-tip-text{font-size:13px;color:var(--color-text-placeholder);font-style:italic}
/* 订单底部 */
.order-footer{display:flex;justify-content:space-between;align-items:center;padding-top:12px;border-top:1px solid var(--color-border);margin-top:12px}
.reward-box{display:flex;align-items:center;gap:4px;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);border-radius:var(--radius-btn);padding:6px 12px}
.reward-label{font-size:14px;color:var(--color-danger);font-weight:600}
.reward-amount{font-size:16px;color:var(--color-danger);font-weight:700}
.order-actions{display:flex;gap:8px;align-items:center}
.action-btn{min-width:80px;height:36px;border-radius:var(--radius-tag);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:2px;padding:4px 16px;font-size:13px;font-weight:500}
.action-btn.ghost{background:var(--color-bg-card);border:1px solid var(--color-border);color:var(--color-text)}
.action-btn.primary{background:var(--color-text);color:#fff}
.action-btn.success{background:var(--color-primary);color:#fff}
.action-btn.waiting{background:var(--color-warning);color:#fff}
.action-btn.completed{background:var(--color-success);color:#fff}
.action-btn.cancelled{background:var(--color-bg-page);color:var(--color-text-placeholder);border:1px solid var(--color-border)}
.spec{display:block;color:var(--color-text-placeholder);font-size:12px;margin-top:2px}
.item{display:flex;align-items:center;padding:8px 0;border-bottom:1px solid var(--color-border)}
.item:last-child{border-bottom:none}
.thumb{width:48px;height:48px;border-radius:var(--radius-btn);margin-right:8px}
.meta{flex:1}
.name{display:block;color:var(--color-text)}
.price{display:block;color:var(--color-text-secondary);font-size:12px;margin-top:2px}
.qty{color:var(--color-text-secondary)}
.remark{background:var(--color-bg-page);color:var(--color-text-placeholder);font-size:12px;border-radius:var(--radius-btn);padding:8px;margin-top:6px}
.btn-time{font-size:10px;opacity:0.8;margin-top:2px}

.safe-area-bottom{height:env(safe-area-inset-bottom)}

/* 底部弹层 */
.sheet-mask{position:fixed;left:0;right:0;top:0;bottom:0;background:rgba(0,0,0,.35);opacity:0;visibility:hidden;transition:all .2s;z-index:998}
.sheet-mask.show{opacity:1;visibility:visible}
.sheet{position:fixed;left:0;right:0;bottom:-100%;background:var(--color-bg-card);border-radius:var(--radius-card) var(--radius-card) 0 0;box-shadow:0 -4px 16px rgba(0,0,0,.1);padding:var(--space-block);transition:bottom .25s;height:70%;z-index:999}
.sheet.show{bottom:0}
.sheet-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.sheet-desk{font-size:18px;font-weight:700;color:var(--color-text)}
.sheet-status{color:var(--color-primary)}
.sheet-status.cancelled{color:var(--color-danger)}
.sheet-items{max-height:160px;overflow:auto;margin-top:6px}
.s-item{display:flex;align-items:center;padding:8px 0;border-bottom:1px solid var(--color-border)}
.s-thumb{width:44px;height:44px;border-radius:var(--radius-btn);margin-right:8px}
.s-meta{flex:1}
.s-name{color:var(--color-text)}
.s-price{color:var(--color-text-secondary);font-size:12px;margin-top:2px;display:block}
.s-qty{color:var(--color-text-secondary)}
.sheet-remark{background:var(--color-bg-page);color:var(--color-text-placeholder);font-size:12px;border-radius:var(--radius-btn);padding:8px;margin:10px 0}
.sheet-line{display:flex;justify-content:space-between;color:var(--color-text);padding:6px 0}
.sheet-line.income{font-weight:700}
.red{color:var(--color-danger)}
.sheet-info{margin-top:6px}
.i-row{display:flex;justify-content:space-between;padding:6px 0;color:var(--color-text-secondary)}
.i-label{color:var(--color-text-placeholder)}
.i-value{color:var(--color-text);text-align:right;white-space:pre-line}
.i-value.expired{color:var(--color-danger)}
.i-value.address-clickable{color:var(--color-primary);text-decoration:underline;cursor:pointer}
.i-row.address-row{cursor:pointer}
.receiver-avatar{width:24px;height:24px;border-radius:50%;border:1px solid var(--color-border);margin-right:8px;vertical-align:middle}
.receiver-name{font-size:14px;color:var(--color-text);vertical-align:middle}
.btn.completed{background:var(--color-success);color:#fff}
.btn.waiting{background:var(--color-warning);color:#fff}
.sheet-actions{display:flex;gap:10px;margin-top:12px}

/* 特殊订单信息显示 */
.special-order-info{margin:8px 0;padding:10px;background:var(--color-primary-light);border-radius:var(--radius-btn);border-left:3px solid var(--color-primary)}
.special-info-item{display:flex;align-items:flex-start;margin-bottom:6px;line-height:1.5}
.special-info-item:last-child{margin-bottom:0}
.special-label{font-size:12px;color:var(--color-text-secondary);min-width:70px;flex-shrink:0}
.special-value{font-size:12px;color:var(--color-text);flex:1;word-break:break-all}
.special-value.price{color:var(--color-danger);font-weight:600}
.special-value.code{color:var(--color-primary);font-weight:600;font-size:14px}
.special-images{display:flex;gap:8px;margin-top:8px;flex-wrap:wrap}
.special-image{width:60px;height:60px;border-radius:var(--radius-btn);background:var(--color-border)}

/* 筛选弹窗 */
.filter-mask{position:fixed;left:0;right:0;top:0;bottom:0;background:rgba(0,0,0,.5);opacity:0;visibility:hidden;transition:all .3s;z-index:999}
.filter-mask.show{opacity:1;visibility:visible}
.filter-popup{position:fixed;left:0;right:0;bottom:-100%;background:var(--color-bg-card);border-radius:var(--radius-card) var(--radius-card) 0 0;transition:bottom .3s;z-index:1000;max-height:70vh;display:flex;flex-direction:column;box-shadow:0 -4px 16px rgba(0,0,0,.1)}
.filter-popup.show{bottom:0}
.filter-popup-header{display:flex;justify-content:space-between;align-items:center;padding:var(--space-block);border-bottom:1px solid var(--color-border)}
.filter-popup-title{font-size:16px;font-weight:600;color:var(--color-text)}
.filter-popup-close{font-size:24px;color:var(--color-text-placeholder);width:32px;height:32px;display:flex;align-items:center;justify-content:center}
.filter-popup-content{flex:1;overflow-y:auto;padding:8px 0;max-height:50vh}
.filter-popup-item{display:flex;justify-content:space-between;align-items:center;padding:12px var(--space-block);border-bottom:1px solid var(--color-border)}
.filter-popup-item.active{background:var(--color-primary-light)}
.filter-popup-item-text{font-size:14px;color:var(--color-text)}
.filter-popup-item.active .filter-popup-item-text{color:var(--color-primary);font-weight:500}
.filter-popup-item-check{color:var(--color-primary);font-size:16px;font-weight:600}
.filter-popup-footer{display:flex;gap:12px;padding:var(--space-item) var(--space-block);border-top:1px solid var(--color-border)}
.filter-popup-btn{flex:1;height:44px;border-radius:var(--radius-btn);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:500}
.filter-popup-btn.reset{background:var(--color-bg-page);color:var(--color-text-secondary)}
.filter-popup-btn.confirm{background:var(--color-primary);color:#fff}

/* 联系信息弹窗 */
.contact-mask{position:fixed;left:0;right:0;top:0;bottom:0;background:rgba(0,0,0,.5);opacity:0;visibility:hidden;transition:all .3s;z-index:1001}
.contact-mask.show{opacity:1;visibility:visible}
.contact-popup{position:fixed;left:50%;top:50%;transform:translate(-50%,-50%) scale(0.9);background:var(--color-bg-card);border-radius:var(--radius-card);width:85%;max-width:400px;opacity:0;visibility:hidden;transition:all .3s;z-index:1002;box-shadow:var(--shadow-float)}
.contact-popup.show{opacity:1;visibility:visible;transform:translate(-50%,-50%) scale(1)}
.contact-popup-header{display:flex;justify-content:space-between;align-items:center;padding:20px var(--space-block) 16px;border-bottom:1px solid var(--color-border)}
.contact-popup-title{font-size:18px;font-weight:600;color:var(--color-text)}
.contact-popup-close{font-size:28px;color:var(--color-text-placeholder);width:32px;height:32px;display:flex;align-items:center;justify-content:center;line-height:1}
.contact-popup-content{padding:var(--space-block)}
.contact-user-name{text-align:center;font-size:16px;font-weight:500;color:var(--color-text);margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid var(--color-border)}
.contact-item{margin-bottom:20px}
.contact-item:last-child{margin-bottom:0}
.contact-item-label{display:flex;align-items:center;margin-bottom:12px;font-size:14px;color:var(--color-text-secondary)}
.contact-icon{font-size:16px;margin-right:6px}
.contact-item-value{display:flex;flex-direction:column;gap:10px}
.contact-value-text{font-size:16px;color:var(--color-text);font-weight:500;word-break:break-all;padding:12px;background:var(--color-bg-page);border-radius:var(--radius-btn)}
.contact-action-btn-group{display:flex;gap:10px}
.contact-action-btn{flex:1;height:40px;border-radius:var(--radius-btn);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:500;background:var(--color-bg-page);color:var(--color-text);border:1px solid var(--color-border)}
.contact-action-btn.primary{background:var(--color-primary);color:#fff;border-color:var(--color-primary)}
.contact-action-btn:active{opacity:0.8}
.contact-empty{text-align:center;padding:40px 20px;color:var(--color-text-placeholder);font-size:14px}
