<view class="page">
  <scroll-view 
    scroll-y 
    class="content"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscroll="onScroll"
  >
    <!-- 分类标签 -->
    <view class="category-tabs">
      <block wx:for="{{categories}}" wx:key="id">
        <view 
          class="category-tab {{selectedCategory === item.id ? 'active' : ''}}" 
          bindtap="onCategoryTap" 
          data-id="{{item.id}}"
        >
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-text">{{item.name}}</text>
        </view>
      </block>
    </view>

    <!-- 首次加载骨架屏 -->
    <view wx:if="{{loading && filteredOrders.length === 0}}" class="order-list order-skeleton-list">
      <block wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
        <view class="order-card">
          <view class="order-header">
            <view class="food-img ds-skeleton" style="width:60px;height:60px;border-radius:var(--radius-btn);"></view>
            <view class="order-info" style="flex:1;">
              <view class="ds-skeleton-line" style="width:70%;margin-bottom:6px;"></view>
              <view class="ds-skeleton-line" style="width:40%;"></view>
            </view>
            <view class="ds-skeleton-line" style="width:50px;height:20px;border-radius:4px;"></view>
          </view>
          <view class="order-items" style="padding:0 0 8px;">
            <view class="ds-skeleton-line" style="width:90%;margin-bottom:4px;"></view>
            <view class="ds-skeleton-line" style="width:60%;"></view>
          </view>
          <view class="order-footer" style="border-top:1px solid var(--color-border);padding-top:8px;">
            <view class="ds-skeleton-line" style="width:80px;height:16px;"></view>
          </view>
        </view>
      </block>
    </view>
    
    <!-- 错误重试 -->
    <view wx:elif="{{loadError && filteredOrders.length === 0 && !loading}}" class="ds-empty ds-fade-in">
      <view class="ds-empty-icon-wrap"><text class="ds-empty-icon-char">⚠️</text></view>
      <text class="ds-empty-title">加载失败</text>
      <text class="ds-empty-desc">{{errorMessage || '网络异常，请重试'}}</text>
      <view class="ds-empty-btn ds-press" bindtap="onRetryLoad">点击重试</view>
    </view>
    
    <!-- 空状态 -->
    <view wx:elif="{{filteredOrders.length === 0 && !loading}}" class="ds-empty ds-fade-in">
      <view class="ds-empty-icon-wrap"><text class="ds-empty-icon-char">单</text></view>
      <text class="ds-empty-title">暂无订单</text>
      <text class="ds-empty-desc">去首页逛逛，发现好吃好玩的</text>
      <view class="ds-empty-btn ds-press" bindtap="onGoHome">去逛逛</view>
    </view>
    
    <!-- 订单列表（有数据时始终显示，加载更多时不整页替换为加载中） -->
    <view wx:elif="{{filteredOrders.length > 0}}" class="order-list">
      <block wx:for="{{filteredOrders}}" wx:key="id">
        <view class="order-card ds-press {{item.id === highlightOrderId ? 'highlight' : ''}}" id="order-{{item.id}}" bindtap="onOrderTap" data-id="{{item.id}}">
          <!-- 顶部信息 -->
          <view class="order-header">
            <image class="food-img" src="{{item.img}}" mode="aspectFill" lazy-load />
            <view class="order-info">
              <text class="store-name">{{item.storeName}}</text>
              <text class="order-date">{{item.date}}</text>
            </view>
            <view class="status-wrapper">
              <text class="order-status-badge cancelled" wx:if="{{item.orderStatus === 'cancelled'}}">已取消</text>
              <text class="refund-status-badge approved" wx:elif="{{item.refundInfo && (item.refundInfo.status === 'approved' || item.refundInfo.status === 'completed')}}">已退款</text>
              <text class="refund-status-badge rejected" wx:elif="{{item.refundInfo && item.refundInfo.status === 'rejected'}}">拒绝退款</text>
              <text class="pay-status-badge unpaid" wx:elif="{{item.payStatus === 'unpaid'}}">待支付</text>
              <text class="order-status-badge {{item.statusBadgeClass}}" wx:else>{{item.status}}</text>
            </view>
          </view>

          <!-- 订单商品（最多 2 行 + 等共x件） -->
          <view class="order-items">
            <block wx:for="{{item.displayItems || item.items}}" wx:key="index" wx:for-item="food">
              <text class="item-name">{{food.name}}</text>
            </block>
            <text class="item-name item-more" wx:if="{{item.itemsLength > 2}}">等共{{item.itemsLength}}件</text>
          </view>

          <!-- 退款状态显示 -->
          <view class="refund-status-info" wx:if="{{item.refundStatus}}">
            <text class="refund-status-text {{item.refundStatusClass}}">{{item.refundStatusText}}</text>
            <text class="refund-remark" wx:if="{{item.refundStatus === 'rejected' && item.refundInfo && item.refundInfo.remark}}">拒绝理由：{{item.refundInfo.remark}}</text>
            <text class="refund-amount" wx:if="{{item.refundInfo && item.refundInfo.refundAmount}}">退款金额：¥{{item.refundInfo.refundAmount}}</text>
          </view>

          <!-- 待支付倒计时 / 预计送达时间 -->
          <view class="order-time-info" wx:if="{{item.estimatedDeliveryTime || item.estimatedDeliveryTimeRange || (item.payStatus === 'unpaid' && item.expiredMinutes != null)}}">
            <text class="time-text expired" wx:if="{{item.payStatus === 'unpaid' && item.orderStatus !== 'cancelled' && item.expiredMinutes !== null && item.expiredMinutes < 0}}">订单已超时</text>
            <text class="time-text countdown" wx:elif="{{item.payStatus === 'unpaid' && item.orderStatus !== 'cancelled' && item.expiredMinutes !== null && item.expiredMinutes > 0}}">订单剩余{{item.expiredMinutes}}分钟</text>
            <text class="time-text delivery" wx:if="{{item.estimatedDeliveryTimeRange}}">预计到达时间：{{item.estimatedDeliveryTimeRange}}</text>
            <text class="time-text delivery" wx:elif="{{item.estimatedDeliveryTime}}">预计送达：{{item.estimatedDeliveryTime}}</text>
          </view>

          <!-- 底部价格和操作 -->
          <view class="order-footer">
            <view class="price-info">
              <text class="total-price">共 ¥{{item.total}}</text>
              <view class="price-detail" wx:if="{{item.amountGoods || item.amountDelivery}}">
                <text class="detail-text">商品¥{{item.amountGoods}} + 配送¥{{item.amountDelivery}}</text>
              </view>
            </view>
            <view class="action-buttons" catchtap="stopPropagation">
              <block wx:if="{{item.payStatus === 'unpaid' && item.orderStatus !== 'cancelled'}}">
                <button class="btn-pay" size="mini" bindtap="onPayOrder" data-id="{{item.id}}" disabled="{{payingOrderId === item.id}}">{{payingOrderId === item.id ? '支付中...' : '立即支付'}}</button>
                <button class="btn-cancel" size="mini" bindtap="onCancelOrder" data-id="{{item.id}}">取消订单</button>
              </block>
              <block wx:elif="{{item.orderStatus === 'pending' || item.orderStatus === 'confirmed' || item.orderStatus === 'preparing'}}">
                <button class="btn-cancel" size="mini" bindtap="onCancelOrder" data-id="{{item.id}}">取消订单</button>
                <button class="btn-contact" size="mini" bindtap="onContactMerchant" data-id="{{item.id}}" wx:if="{{item.storeId}}">联系商家</button>
                <button class="btn-again" size="mini" bindtap="onOrderAgain" data-id="{{item.id}}">再来一单</button>
              </block>
              <block wx:elif="{{item.orderStatus === 'cancelled'}}">
                <text class="cancelled-text">订单已取消</text>
              </block>
              <block wx:else>
                <button class="btn-refund" size="mini" catchtap="onRefund" data-id="{{item.id}}" wx:if="{{item.payStatus === 'paid' && item.canRefund && !item.refundStatus}}">申请退款</button>
                <button class="btn-contact" size="mini" bindtap="onContactMerchant" data-id="{{item.id}}" wx:if="{{item.storeId}}">联系商家</button>
                <button class="btn-again" size="mini" bindtap="onOrderAgain" data-id="{{item.id}}">再来一单</button>
              </block>
            </view>
          </view>
        </view>
      </block>
      <view class="load-more-footer" wx:if="{{filteredOrders.length > 0}}">
        <text wx:if="{{loading && hasMoreOrders}}">加载更多...</text>
        <text wx:elif="{{!hasMoreOrders}}">没有更多了</text>
      </view>
    </view>
    
    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 用户端底部栏（与首页/个人中心/任务大厅统一组件） -->
  <user-tab-bar active="order" variant="user" bindtabtap="onTabTap" />
</view>
