<view class="page">
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <text class="back" bindtap="onBack">◀</text>
      <text class="title">我的订单</text>
      <view class="icons"></view>
    </view>
  </view>

  <scroll-view 
    scroll-y 
    class="content"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
  >
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-container">
      <text>加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view wx:elif="{{orders.length === 0 && !loading}}" class="empty-container">
      <view class="empty-illustration">
        <text class="empty-icon">📋</text>
      </view>
      <text class="empty-text">暂无订单</text>
      <text class="empty-desc">您还没有发布过订单</text>
    </view>
    
    <!-- 订单列表 -->
    <view wx:elif="{{!loading && orders.length > 0}}" class="order-list">
      <block wx:for="{{orders}}" wx:key="id">
        <view class="order-card">
          <!-- 订单类型标签 -->
          <view class="order-type-tag {{item.orderType}}">
            <text>{{item.orderTypeText}}</text>
          </view>
          
          <view class="order-top">
            <text class="order-no">订单号：{{item.orderNo}}</text>
            <view class="order-top-right">
              <!-- 截止时间显示 -->
              <view class="expired-time" wx:if="{{item.expiredAtDisplay}}">
                <text class="expired-time-icon">🕐</text>
                <text class="expired-time-text">{{item.expiredAtDisplay}}</text>
              </view>
              <text class="status {{item.statusClass}}">{{item.statusText}}</text>
            </view>
          </view>

          <!-- 游戏陪玩订单特殊显示 -->
          <view wx:if="{{item.orderType === 'gaming'}}" class="special-order-info">
            <view class="special-info-item">
              <text class="special-label">游戏类型：</text>
              <text class="special-value">{{item.gameType}}</text>
            </view>
            <view class="special-info-item">
              <text class="special-label">时长：</text>
              <text class="special-value">{{item.sessionDuration}}小时</text>
            </view>
            <view class="special-info-item" wx:if="{{item.requirements || item.selectedRequirements}}">
              <text class="special-label">要求：</text>
              <text class="special-value">{{item.selectedRequirements && item.selectedRequirements.length > 0 ? item.selectedRequirements.join('、') : item.requirements}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.bounty}}">
              <text class="special-label">赏金：</text>
              <text class="special-value price">¥{{item.bounty}}</text>
            </view>
          </view>

          <!-- 悬赏订单特殊显示 -->
          <view wx:elif="{{item.orderType === 'reward'}}" class="special-order-info">
            <view class="special-info-item">
              <text class="special-label">类别：</text>
              <text class="special-value">{{item.category}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.helpLocation}}">
              <text class="special-label">帮助地点：</text>
              <text class="special-value">{{item.helpLocation}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.helpContent}}">
              <text class="special-label">内容：</text>
              <text class="special-value">{{item.helpContent}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.bounty}}">
              <text class="special-label">赏金：</text>
              <text class="special-value price">¥{{item.bounty}}</text>
            </view>
            <view class="special-images" wx:if="{{item.images && item.images.length > 0}}">
              <image wx:for="{{item.images}}" wx:key="*this" wx:for-item="img" class="special-image" src="{{img}}" mode="aspectFill" />
            </view>
          </view>

          <!-- 代拿快递订单特殊显示 -->
          <view wx:elif="{{item.orderType === 'express'}}" class="special-order-info">
            <view class="special-info-item" wx:if="{{item.pickupLocation}}">
              <text class="special-label">取件位置：</text>
              <text class="special-value">{{item.pickupLocation}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.deliveryLocation}}">
              <text class="special-label">送达位置：</text>
              <text class="special-value">{{item.deliveryLocation}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.pickupCode}}">
              <text class="special-label">取件码：</text>
              <text class="special-value code">{{item.pickupCode}}</text>
            </view>
            <view class="special-info-item" wx:if="{{item.packageSizes && item.packageSizes.length > 0}}">
              <text class="special-label">包裹信息：</text>
              <text class="special-value">
                <text wx:for="{{item.packageSizes}}" wx:key="id" wx:for-item="pkg" wx:for-index="pkgIndex">{{pkg.name}}{{pkg.description ? '(' + pkg.description + ')' : ''}} x{{pkg.quantity}}<text wx:if="{{pkgIndex < item.packageSizes.length - 1}}">、</text></text>
              </text>
            </view>
            <view class="special-images" wx:if="{{item.images && item.images.length > 0}}">
              <image wx:for="{{item.images}}" wx:key="*this" wx:for-item="img" class="special-image" src="{{img}}" mode="aspectFill" />
            </view>
          </view>

          <!-- 接单者信息 -->
          <view class="receiver-section" wx:if="{{item.receiverInfo}}">
            <view class="receiver-header">
              <text class="receiver-title">接单者信息</text>
            </view>
            <view class="receiver-info">
              <image class="receiver-avatar" src="{{item.receiverInfo.avatarUrl || '/pages/小标/默认头像.png'}}" mode="aspectFill"></image>
              <view class="receiver-details">
                <text class="receiver-name">{{item.receiverInfo.nickname || '用户'}}</text>
                <text class="receiver-status" wx:if="{{item.orderStatus === 'received'}}">已接单，等待确认</text>
                <text class="receiver-status" wx:elif="{{item.orderStatus === 'confirmed_by_receiver'}}">进行中</text>
                <text class="receiver-status" wx:elif="{{item.orderStatus === 'waiting_user_confirm'}}">等待您确认完成</text>
              </view>
            </view>
          </view>

          <!-- 未接单提示 -->
          <view class="no-receiver-tip" wx:if="{{!item.receiverInfo && item.orderStatus === 'pending'}}">
            <text class="tip-text">⏰ 等待接单中...</text>
          </view>

          <view class="total-info">
            <text>合计：¥{{item.amountTotal}}</text>
          </view>
          
          <view class="actions">
            <!-- 联系接单者 -->
            <view class="btn ghost" bindtap="onContactReceiver" data-id="{{item.id}}" wx:if="{{item.receiverInfo}}" catchtap="stopPropagation">联系接单者</view>
            <!-- 等待用户确认：下单者可以确认完成 -->
            <view class="btn success" bindtap="onUserConfirmComplete" data-id="{{item.id}}" wx:if="{{item.orderStatus === 'waiting_user_confirm'}}" catchtap="stopPropagation">确认完成</view>
            <!-- 已完成 -->
            <view class="btn completed" wx:if="{{item.orderStatus === 'completed'}}">已完成</view>
            <!-- 已取消 -->
            <view class="btn cancelled" wx:if="{{item.orderStatus === 'cancelled'}}">订单已取消</view>
          </view>
        </view>
      </block>
    </view>
    
    <view class="safe-area-bottom"></view>
  </scroll-view>
</view>


