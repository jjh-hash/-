.page {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: 120px;
}

.status-bar {
  width: 100%;
}

.content {
  height: calc(100vh - 120px);
}

.section {
  background: #fff;
  margin: 12px;
  border-radius: 12px;
  padding: 16px;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.address-section {
  position: relative;
  padding-right: 32px;
}

.address-row .name,
.address-row .phone {
  display: block;
  font-size: 14px;
  color: #333;
}

.address-row .detail {
  font-size: 13px;
  color: #666;
  margin-top: 4px;
}

.address-empty {
  font-size: 14px;
  color: #999;
}

.arrow {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  color: #999;
}

.store-block {
  border-top: 1px solid #f0f0f0;
  padding-top: 12px;
  margin-top: 12px;
}

.total-section {
  margin-bottom: 8px;
}

.total-in-content .total-value {
  font-size: 18px;
  font-weight: 600;
  color: #07c160;
}

.store-block:first-of-type {
  border-top: none;
  padding-top: 0;
  margin-top: 0;
}

.store-name {
  font-size: 14px;
  font-weight: 600;
  color: #333;
}

.item {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: #666;
  margin-top: 6px;
}

.item-name {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  color: #07c160;
  margin-left: 8px;
}

.store-footer {
  margin-top: 8px;
  font-size: 12px;
  color: #999;
}

.store-total {
  margin-right: 12px;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid #f0f0f0;
}

.total-row {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 14px;
  color: #666;
  margin-right: 8px;
}

.total-value {
  font-size: 18px;
  font-weight: 600;
  color: #07c160;
}

.btn-pay {
  background: #07c160;
  color: #fff;
  border: none;
  border-radius: 24px;
  padding: 10px 28px;
  font-size: 15px;
}

.btn-pay[disabled] {
  background: #ccc;
}
