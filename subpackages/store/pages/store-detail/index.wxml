<view class="page">
  <!-- 骨架屏：店铺详情加载中 -->
  <block wx:if="{{storeDetailLoading}}">
    <view class="skeleton-store-card">
      <view class="skeleton-logo"></view>
      <view class="skeleton-info">
        <view class="skeleton-line skeleton-title"></view>
        <view class="skeleton-line skeleton-stats"></view>
        <view class="skeleton-line skeleton-announce"></view>
      </view>
    </view>
    <view class="skeleton-tab-wrap">
      <view class="skeleton-tab"></view>
      <view class="skeleton-tab"></view>
      <view class="skeleton-tab"></view>
    </view>
    <view class="skeleton-tip"></view>
    <view class="skeleton-main">
      <view class="skeleton-sidebar">
        <view class="skeleton-cat" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this"></view>
      </view>
      <view class="skeleton-product-list">
        <view class="skeleton-product-item" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
          <view class="skeleton-product-img"></view>
          <view class="skeleton-product-info">
            <view class="skeleton-line skeleton-name"></view>
            <view class="skeleton-line skeleton-meta"></view>
            <view class="skeleton-line skeleton-price"></view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 真实内容：店铺信息卡片（美团式） -->
  <block wx:if="{{!storeDetailLoading}}">
  <view class="store-card">
    <view class="store-logo">
      <image 
        class="logo-image" 
        src="{{storeInfo.avatar || storeInfo.logo || storeInfo.logoUrl || '/pages/小标/商家.png'}}" 
        mode="aspectFill"
        binderror="onLogoError"
      />
    </view>
    <view class="store-info">
      <view class="store-header">
        <view class="store-name">{{storeInfo.name}}</view>
        <view class="store-stats">
          <text class="store-stat-item">评分 {{storeInfo.ratingAvg || storeInfo.overallRating || '0'}}</text>
          <text class="store-stat-item">月售{{storeInfo.monthlySales || storeInfo.sales || 0}}</text>
          <text class="store-stat-item">配送¥{{storeInfo.deliveryFee || 0}}</text>
          <text class="store-stat-item">起送¥{{storeInfo.minOrder || 0}}</text>
        </view>
      </view>
      <view class="announcement" wx:if="{{storeInfo.announcement}}">
        <text class="announcement-label">公告</text>
        <view class="announcement-wrapper">
          <view class="announcement-scroll {{announcementScroll ? 'scrolling' : ''}}" style="animation-duration: {{announcementDuration}}s;">
            <text class="announcement-text">公告: {{storeInfo.announcement}}</text>
            <text class="announcement-text" wx:if="{{announcementScroll}}">公告: {{storeInfo.announcement}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 标签页导航（美团式：点菜 评价 商家 + 温馨提示） -->
  <view class="tab-nav-wrap">
    <view class="tab-nav">
      <block wx:for="{{tabs}}" wx:key="index">
        <view 
          class="tab-item {{index === activeTab ? 'active' : ''}}"
          bindtap="onTabTap"
          data-index="{{index}}"
        >
          {{item}}
        </view>
      </block>
    </view>
    <view class="tab-warm-tip">温馨提示：请适量点餐</view>
  </view>

  <!-- 主内容区域 -->
  <!-- 点餐内容 -->
  <view class="main-content" wx:if="{{activeTab === 0}}">
    <!-- 左侧分类列表 -->
    <view class="category-sidebar">
      <block wx:for="{{categories}}" wx:key="id">
        <view 
          class="category-item {{index === activeCategory ? 'active' : ''}}"
          bindtap="onCategoryTap"
          data-index="{{index}}"
        >
          <text class="category-name">{{item.name}}</text>
        </view>
      </block>
    </view>

    <!-- 右侧商品列表（美团式：图左，名/月售/价格+选规格或加购同排） -->
    <view class="product-content">
      <block wx:for="{{displayProducts}}" wx:key="id">
        <view class="product-item">
          <image class="product-image" src="{{item.image || item.coverUrl}}" mode="aspectFill" lazy-load />
          <view class="product-info">
            <view class="product-name">{{item.name}}</view>
            <view class="product-meta">月售{{item.sales || 0}}</view>
            <view class="product-bottom-row">
              <view class="product-price-wrap">
                <text class="product-price">¥{{item.price}}</text>
              </view>
              <view class="product-actions">
                <!-- 有规格：选规格按钮（美团位） -->
                <view class="spec-btn" wx:if="{{item.hasSpec}}" bindtap="onSelectSpec" data-id="{{item.id}}">
                  <text class="spec-text">选规格</text>
                  <view class="spec-badge" wx:if="{{item.quantity > 0}}">{{item.quantity}}</view>
                </view>
                <!-- 无规格且已加购：加减 -->
                <view class="quantity-selector" wx:elif="{{item.quantity > 0}}">
                  <view class="quantity-btn" bindtap="onRemoveFromCart" data-id="{{item.id}}">
                    <text class="quantity-icon">-</text>
                  </view>
                  <view class="quantity-number">{{item.quantity}}</view>
                  <view class="quantity-btn" bindtap="onAddToCart" data-id="{{item.id}}">
                    <text class="quantity-icon">+</text>
                  </view>
                </view>
                <!-- 无规格未加购：加号 -->
                <view class="add-btn" wx:else bindtap="onAddToCart" data-id="{{item.id}}">
                  <text class="add-icon">+</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 评价内容 -->
  <scroll-view scroll-y class="reviews-content" wx:elif="{{activeTab === 1}}" style="padding-bottom: 80px;">
    <!-- 店铺评分 -->
    <view class="rating-section">
      <view class="rating-left">
        <view class="overall-rating">{{storeInfo.overallRating || 0}}</view>
        <view class="stars">
          <text class="star {{storeInfo.ratingStars[index] ? 'filled' : 'empty'}}" wx:for="{{5}}" wx:key="index">★</text>
        </view>
        <view class="rating-text">商品质量 共{{storeInfo.totalReviews || 0}}人点评</view>
      </view>
      <view class="rating-right">
        <view class="delivery-rating">{{storeInfo.deliveryRating || 0}}</view>
        <view class="delivery-text">配送服务</view>
      </view>
    </view>

    <!-- 评价列表 -->
    <view class="reviews-section">
      <block wx:for="{{reviews}}" wx:key="id">
        <view class="review-item">
          <!-- 用户信息 -->
          <view class="user-info">
            <image class="user-avatar" src="{{item.userAvatar}}" mode="aspectFill" lazy-load />
            <view class="user-details">
              <view class="user-name">{{item.userName}}</view>
              <view class="user-rating">
                <text class="star {{starItem ? 'filled' : 'empty'}}" wx:for="{{item.stars}}" wx:for-item="starItem" wx:key="index">★</text>
              </view>
            </view>
            <view class="review-date">{{item.date}}</view>
          </view>

          <!-- 评价内容 -->
          <view class="review-content">{{item.content}}</view>

          <!-- 评价图片 -->
          <view class="review-images" wx:if="{{item.images && item.images.length > 0}}">
            <image class="review-image" 
                   wx:for="{{item.images}}" 
                   wx:for-item="img"
                   wx:key="index"
                   src="{{img}}" 
                   mode="aspectFill"
                   lazy-load
                   data-images="{{item.images}}"
                   data-index="{{index}}"
                   bindtap="onPreviewReviewImage" />
          </view>

          <!-- 商家回复 -->
          <view class="merchant-reply" wx:if="{{item.hasMerchantReply && item.merchantReply}}">
            <view class="merchant-reply-label">商家回复：</view>
            <view class="merchant-reply-content">{{item.merchantReply}}</view>
          </view>
        </view>
      </block>
      
      <!-- 空状态 -->
      <view class="empty-reviews" wx:if="{{reviews.length === 0 && !reviewsLoading}}">
        <text class="empty-text">暂无评价</text>
      </view>
      
      <!-- 加载中 -->
      <view class="loading-reviews" wx:if="{{reviewsLoading}}">
        <text class="loading-text">加载中...</text>
      </view>
    </view>
    
    <!-- 底部编写评论按钮 -->
    <view class="submit-review-btn-container">
      <button class="submit-review-btn" bindtap="onSubmitReviewTap">
        <text class="btn-icon">✎</text>
        <text class="btn-text">编写评论</text>
      </button>
    </view>
  </scroll-view>

  <!-- 商家信息内容 -->
  <scroll-view scroll-y class="merchant-content" wx:elif="{{activeTab === 2}}">
    <view class="merchant-info-section">
      <!-- 月销量 -->
      <view class="info-item">
        <view class="info-label">月销量</view>
        <view class="info-value">{{merchantInfo.monthlySales || 0}}单</view>
      </view>

      <!-- 店铺地址 -->
      <view class="info-item">
        <view class="info-label">店铺地址</view>
        <view class="info-value">{{merchantInfo.location || '未设置地址'}}</view>
      </view>

      <!-- 联系电话 -->
      <view class="info-item">
        <view class="info-label">联系电话</view>
        <view class="info-value" bindtap="onCallPhone" wx:if="{{merchantInfo.phone && merchantInfo.phone !== '未设置电话'}}">
          {{merchantInfo.phone}}
          <text class="call-icon">📞</text>
        </view>
        <view class="info-value" wx:else>{{merchantInfo.phone || '未设置电话'}}</view>
      </view>

      <!-- 营业时间 -->
      <view class="info-item">
        <view class="info-label">营业时间</view>
        <view class="info-value">{{merchantInfo.businessHours || '未设置营业时间'}}</view>
      </view>

      <!-- 配送服务 -->
      <view class="info-item">
        <view class="info-label">配送服务</view>
        <view class="info-value">{{merchantInfo.deliveryService || '提供配送服务'}}</view>
      </view>

      <!-- 店铺简介 -->
      <view class="info-item info-item-full">
        <view class="info-label">店铺简介</view>
        <view class="info-value">{{merchantInfo.introduction || '暂无简介'}}</view>
      </view>
    </view>
    
    <!-- 加载中 -->
    <view class="loading-merchant" wx:if="{{merchantInfoLoading}}">
      <text class="loading-text">加载中...</text>
    </view>
  </scroll-view>
  </block>

  <!-- 底部购物车栏（未选菜品时，与结算栏同风格：左图标+文案，右起送） -->
  <view class="cart-bar" wx:if="{{!storeDetailLoading && activeTab === 0 && cartItems.length === 0}}">
    <view class="cart-bar-left">
      <view class="cart-bar-icon-wrap">
        <image class="cart-bar-delivery-icon" src="{{deliveryBoyIcon}}" mode="aspectFit" />
      </view>
      <view class="cart-bar-info">
        <view class="cart-bar-hint">去选菜品</view>
        <view class="cart-bar-fee">配送费{{storeInfo.deliveryFee}}元</view>
      </view>
    </view>
    <view class="cart-bar-right">¥{{storeInfo.minOrder}}起送</view>
  </view>

  <!-- 购物车结算栏 - 未达到起送金额（图二式：左图标+金额对齐，右按钮） -->
  <view class="checkout-bar checkout-bar-gray" wx:if="{{!storeDetailLoading && activeTab === 0 && cartItems.length > 0 && cartTotal < storeInfo.minOrder}}">
    <view class="cart-summary" bindtap="onToggleCartSummary">
      <view class="cart-icon-wrapper">
        <image class="cart-delivery-icon" src="{{deliveryBoyIcon}}" mode="aspectFit" />
        <view class="cart-badge">{{cartItems.length}}</view>
      </view>
      <view class="total-info">
        <view class="total-amount">共¥{{cartTotal}}元</view>
        <view class="delivery-fee">配送费{{storeInfo.deliveryFee}}元</view>
      </view>
    </view>
    <view class="checkout-section checkout-section-gray" bindtap="onToggleCartSummary">
      <text class="checkout-text" wx:if="{{minOrderGap}}">还差¥{{minOrderGap}}起送</text>
      <text class="checkout-text" wx:else>¥{{storeInfo.minOrder}}起送</text>
    </view>
  </view>

  <!-- 购物车结算栏 - 达到起送金额（图二式：左图标+金额对齐，右按钮） -->
  <view class="checkout-bar checkout-bar-blue" wx:if="{{!storeDetailLoading && activeTab === 0 && cartItems.length > 0 && cartTotal >= storeInfo.minOrder}}">
    <view class="cart-summary" bindtap="onToggleCartSummary">
      <view class="cart-icon-wrapper">
        <image class="cart-delivery-icon" src="{{deliveryBoyIcon}}" mode="aspectFit" />
        <view class="cart-badge">{{cartItems.length}}</view>
      </view>
      <view class="total-info">
        <view class="total-amount">共¥{{cartTotal}}元</view>
        <view class="delivery-fee">配送费{{storeInfo.deliveryFee}}元</view>
      </view>
    </view>
    <view class="checkout-section checkout-section-blue" bindtap="onCheckout">
      <text class="checkout-text">结算</text>
    </view>
  </view>

  <!-- 规格选择弹窗 -->
  <view class="spec-popup-mask" wx:if="{{showSpecPopup}}" bindtap="onCloseSpecPopup">
    <view class="spec-popup" catchtap="">
      <!-- 弹窗头部 -->
      <view class="popup-header">
        <view class="selected-info">
          <text class="selected-text">已选规格: {{selectedSpecsText}}</text>
        </view>
        <view class="close-btn" bindtap="onCloseSpecPopup">
          <text class="close-icon">×</text>
        </view>
      </view>

      <!-- 可滚动内容区域（内层限定宽度，避免右侧裁剪并居中） -->
      <scroll-view class="spec-popup-content" scroll-y>
        <view class="spec-popup-inner">
        <!-- 商品信息 -->
        <view class="product-section">
          <image class="product-image" src="{{currentProduct.image || currentProduct.coverUrl}}" mode="aspectFill" lazy-load />
          <view class="product-details">
            <view class="product-name">{{currentProduct.name}}</view>
            <view class="product-price">¥{{currentProduct.price}}</view>
          </view>
        </view>

        <!-- 动态规格组 -->
        <block wx:for="{{currentProduct.specifications}}" wx:key="index" wx:for-item="group">
          <view class="spec-section">
            <view class="section-label">
              {{group.name}}
              <text class="spec-type-hint" wx:if="{{group.type === 'required'}}">（必选）</text>
              <text class="spec-type-hint" wx:elif="{{group.type === 'multiple'}}">（可多选）</text>
            </view>
            <view class="option-buttons">
              <block wx:for="{{group.options}}" wx:key="optionIndex" wx:for-item="option" wx:for-index="optIdx">
                <view 
                  class="option-btn {{(group.type === 'multiple' ? (specSelectionMap[index] && specSelectionMap[index][optIdx]) : specSelectionMap[index] == optIdx) ? 'selected' : ''}}"
                  catchtap="onSelectSpecOption"
                  data-group-index="{{index}}"
                  data-option-index="{{optIdx}}"
                >
                  <text class="option-name">{{option.name}}</text>
                  <text class="option-price" wx:if="{{option.price && option.price > 0}}">+¥{{option.price}}</text>
                </view>
              </block>
            </view>
          </view>
        </block>
        </view>
      </scroll-view>

      <!-- 数量选择（固定在底部） -->
      <view class="quantity-section">
        <view class="section-label">数量</view>
        <view class="quantity-selector">
          <view class="quantity-btn" catchtap="onDecreaseQuantity">
            <text class="quantity-icon">-</text>
          </view>
          <view class="quantity-number">{{quantity}}</view>
          <view class="quantity-btn" catchtap="onIncreaseQuantity">
            <text class="quantity-icon">+</text>
          </view>
        </view>
      </view>

      <!-- 底部价格和确认按钮 -->
      <view class="popup-footer">
        <view class="price-info">
          <text class="total-price-label">总计</text>
          <text class="total-price">¥{{specTotalPrice}}</text>
        </view>
        <view class="confirm-btn" catchtap="onConfirmSpec">
          <text class="confirm-text">加入购物车</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 购物车订单确认弹窗 -->
  <view class="cart-popup-mask" wx:if="{{showCartSummary}}">
    <view class="cart-popup" catchtap="">
      <!-- 弹窗顶部：配送方式选择 -->
      <view class="cart-popup-header">
        <view class="delivery-type-selector">
          <view 
            class="delivery-type-item {{deliveryType === 'delivery' ? 'active' : ''}}"
            bindtap="onToggleDeliveryType"
            data-type="delivery"
          >
            <text>外送</text>
          </view>
          <view 
            class="delivery-type-item {{deliveryType === 'pickup' ? 'active' : ''}}"
            bindtap="onToggleDeliveryType"
            data-type="pickup"
          >
            <text>自取</text>
            <text class="pickup-time" wx:if="{{deliveryType === 'pickup'}}">15分钟后取餐</text>
          </view>
        </view>
        <view class="close-cart-btn" bindtap="onCloseCartSummary">
          <text class="close-icon">×</text>
        </view>
      </view>

      <!-- 已加购商品标题栏 -->
      <view class="cart-items-header">
        <view class="cart-items-title">
          <text>已加购商品</text>
        </view>
        <view class="clear-cart-btn" bindtap="onClearCart">
          <text class="trash-icon">🗑️</text>
          <text class="clear-text">清空</text>
        </view>
      </view>

      <!-- 温馨提示 -->
      <view class="warm-tip">
        <text>温馨提示:请适量点餐</text>
      </view>

      <!-- 商品列表 -->
      <scroll-view scroll-y class="cart-items-scroll">
        <block wx:for="{{cartItems}}" wx:key="cartItemId">
          <view class="cart-item-detailed">
            <image class="item-image" src="{{item.image || item.coverUrl}}" mode="aspectFill" lazy-load />
            <view class="item-info-detailed">
              <view class="item-name-detailed">{{item.name}}</view>
              <view class="item-spec-detailed" wx:if="{{item.selectedSpecs && item.selectedSpecs.length > 0}}">
                <block wx:for="{{item.selectedSpecs}}" wx:key="index" wx:for-item="spec">
                  <text>{{spec.optionName}}</text>
                  <text wx:if="{{index < item.selectedSpecs.length - 1}}">、</text>
                </block>
              </view>
              <view class="item-spec-detailed" wx:else>
                <text>1人份・微辣</text>
              </view>
              <view class="item-price-detailed">¥{{item.finalPrice || item.price}}</view>
            </view>
            <view class="item-quantity-detailed">
              <view class="quantity-selector-wrapper">
                <view class="quantity-btn-detailed" bindtap="onCartDecrease" data-id="{{item.cartItemId || item.id}}">
                  <text class="quantity-icon-detailed">-</text>
                </view>
                <view class="quantity-number-detailed">{{item.quantity}}</view>
                <view class="quantity-btn-detailed" bindtap="onCartIncrease" data-id="{{item.cartItemId || item.id}}">
                  <text class="quantity-icon-detailed">+</text>
                </view>
              </view>
            </view>
          </view>
        </block>
      </scroll-view>

      <!-- 底部结算栏 -->
      <view class="cart-checkout-footer">
        <view class="checkout-left">
          <view class="delivery-robot-icon">
            <text>🤖</text>
            <view class="robot-badge" wx:if="{{cartItems.length > 0}}">{{cartItems.length}}</view>
          </view>
        </view>
        <view class="checkout-center">
          <view class="final-price-info">
            <text class="final-price-label">到手约</text>
            <text class="final-price-amount" wx:if="{{priceInfo}}">¥{{priceInfo.finalPriceFormatted}}</text>
          </view>
          <view class="delivery-fee-info" wx:if="{{deliveryType === 'delivery' && storeInfo.deliveryFee === 0}}">
            <text>免配送费</text>
          </view>
        </view>
        <view class="checkout-right">
          <view class="checkout-btn" bindtap="onCheckoutFromCart">
            <text class="checkout-btn-text">去结算</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
