.page {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 导航栏 */
.nav {
  background: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  position: relative;
}

.back {
  font-size: 18px;
  color: #333;
  font-weight: 600;
}

.title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.icons {
  display: flex;
  align-items: center;
  gap: 4px;
}

.dot {
  font-size: 12px;
  color: #999;
}

.battery {
  font-size: 12px;
  color: #999;
}

/* 标签栏 */
.tabs {
  display: flex;
  height: 44px;
  border-bottom: 1px solid #f0f0f0;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #333;
  position: relative;
  transition: all 0.2s ease;
}

.tab.active {
  color: #1976d2;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30px;
  height: 2px;
  background: #1976d2;
  border-radius: 1px;
}

/* 内容区域 */
.content {
  margin-top: 132px;
  padding: 0 16px 80px 16px;
}

/* 店铺评分 */
.rating-section {
  background: #fff;
  padding: 20px;
  border-radius: 8px;
  margin-bottom: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rating-left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8px;
}

.overall-rating {
  font-size: 32px;
  font-weight: 700;
  color: #1976d2;
  line-height: 1;
}

.stars {
  display: flex;
  gap: 2px;
}

.star {
  font-size: 16px;
  color: #ddd; /* 默认灰色 */
}

.star.filled {
  color: #1976d2; /* 实心星星为蓝色 */
}

.star.empty {
  color: #ddd; /* 空心星星为灰色 */
  opacity: 0.5; /* 空心星星透明度 */
}

.rating-text {
  font-size: 12px;
  color: #999;
}

.rating-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.delivery-rating {
  font-size: 24px;
  font-weight: 700;
  color: #333;
  line-height: 1;
}

.delivery-text {
  font-size: 12px;
  color: #999;
}

/* 评价列表 */
.reviews-section {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
}

.review-item {
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.review-item:last-child {
  border-bottom: none;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
}

.user-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  flex-shrink: 0;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.user-name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.user-rating {
  display: flex;
  gap: 2px;
}

.user-rating .star {
  font-size: 14px;
  color: #ddd; /* 默认灰色 */
}

.user-rating .star.filled {
  color: #1976d2 !important; /* 实心星星为蓝色 */
}

.user-rating .star.empty {
  color: #ddd !important; /* 空心星星为灰色 */
  opacity: 0.5; /* 空心星星透明度 */
}

.review-date {
  font-size: 12px;
  color: #999;
  flex-shrink: 0;
}

/* 评价内容 */
.review-content {
  font-size: 14px;
  color: #333;
  line-height: 1.5;
  margin-bottom: 12px;
}

/* 评价图片 */
.review-images {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.review-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  flex-shrink: 0;
}

/* 商家回复 */
.merchant-reply {
  background: #f8f9fa;
  padding: 12px;
  border-radius: 8px;
  margin-top: 12px;
  border-left: 3px solid #1976d2;
}

.merchant-reply-label {
  font-size: 14px;
  color: #1976d2;
  font-weight: 600;
  margin-bottom: 4px;
}

.merchant-reply-content {
  font-size: 14px;
  color: #666;
  line-height: 1.5;
}

/* 底部发表评论按钮 */
.submit-review-btn-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  background: #fff;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.submit-review-btn {
  width: 100%;
  height: 48px;
  background: #1976d2;
  color: #fff;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 16px;
  font-weight: 600;
  border: none;
  box-shadow: 0 4px 12px rgba(25, 118, 210, 0.3);
}

.submit-review-btn::after {
  border: none;
}

.btn-icon {
  font-size: 18px;
}

.btn-text {
  font-size: 16px;
}
