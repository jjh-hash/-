<view class="page">
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <view class="back-btn" bindtap="onBackTap">
        <text class="back-icon">←</text>
      </view>
      <view class="search-container">
        <view class="search-icon">🔍</view>
        <input 
          class="search-input" 
          placeholder="请输入商家或商品名称" 
          placeholder-class="search-placeholder"
          value="{{searchValue}}"
          bindinput="onSearchInput"
          bindconfirm="onSearchSubmit"
        />
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 排序和筛选 -->
    <view class="sort-filter">
      <view class="sort-options">
        <block wx:for="{{sortOptions}}" wx:key="index">
          <view 
            class="sort-item {{index === activeSort ? 'active' : ''}}"
            bindtap="onSortTap"
            data-index="{{index}}"
          >
            {{item}}
            <text class="sort-arrow">▼</text>
          </view>
        </block>
      </view>
      
      <view class="filter-buttons">
        <block wx:for="{{filters}}" wx:key="index">
          <view 
            class="filter-btn {{item.active ? 'active' : ''}}"
            bindtap="onFilterTap"
            data-index="{{index}}"
          >
            {{item.text}}
          </view>
        </block>
      </view>
    </view>

    <!-- 商家列表 -->
    <view class="restaurant-list">
      <block wx:for="{{stores}}" wx:key="id">
        <view class="restaurant-card" bindtap="onStoreTap" data-id="{{item.id}}">
          <!-- 商家图片 -->
          <view class="restaurant-image">
            <image class="image" src="{{item.image || item.logoUrl || '/pages/小标/商家.png'}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}" />
            <view class="image-overlay" wx:if="{{item.businessStatus === 'open'}}">
              <text class="overlay-text">营业中</text>
            </view>
            <view class="image-overlay closed" wx:else>
              <text class="overlay-text">休息中</text>
            </view>
          </view>
          
          <!-- 商家信息 -->
          <view class="restaurant-info">
            <!-- 标签 -->
            <view class="tags" wx:if="{{item.tags}}">
              <block wx:for="{{item.tags}}" wx:key="*this">
                <view class="tag">{{item}}</view>
              </block>
            </view>
            
            <!-- 商家名称 -->
            <view class="restaurant-name">{{item.name}}</view>
            
            <!-- 评分和销量 -->
            <view class="rating-sales">
              <text class="rating">{{item.rating > 0 ? item.rating.toFixed(1) : '暂无'}}分</text>
              <text class="sales">月售{{item.monthlySales}}{{item.monthlySales >= 1000 ? '+' : ''}}</text>
              <text class="rating-count" wx:if="{{item.ratingCount > 0}}">({{item.ratingCount}}条评价)</text>
            </view>
            
            <!-- 配送信息 -->
            <view class="delivery-info">
              <text class="min-order">起送 ¥{{item.minOrder}}</text>
              <text class="delivery-fee">
                {{item.deliveryFee === 0 ? '免配送费' : '配送约¥' + item.deliveryFee}}
              </text>
            </view>
            
            <!-- 配送时间 -->
            <view class="distance-time">
              <text class="delivery-time">{{item.deliveryTime}}分钟</text>
            </view>
            
            <!-- 活动信息 -->
            <view class="activities" wx:if="{{item.activities}}">
              <block wx:for="{{item.activities}}" wx:key="*this">
                <text class="activity">{{item}}</text>
              </block>
            </view>
            
            <!-- 优惠券 -->
            <view class="coupons">
              <block wx:for="{{item.coupons}}" wx:key="*this">
                <view class="coupon">{{item}}</view>
              </block>
            </view>
          </view>
        </view>
      </block>

      <!-- 加载更多提示 -->
      <view wx:if="{{hasMore && stores.length > 0}}" class="load-more">
        <text>上拉加载更多</text>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{stores.length === 0 && !loading}}" class="empty">
        <text class="empty-icon">🏪</text>
        <text class="empty-text">{{searchValue ? '未找到相关商家' : '暂无商家'}}</text>
      </view>

      <!-- 加载状态 -->
      <view wx:if="{{loading && stores.length === 0}}" class="loading-state">
        <text>加载中...</text>
      </view>
    </view>
    
    <view class="safe-area-bottom"></view>
  </scroll-view>
</view>
