.page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120px;
  box-sizing: border-box;
}

/* 导航栏 */
.nav {
  background: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  position: relative;
}

.back {
  font-size: 20px;
  color: #333;
  font-weight: 600;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18px;
  font-weight: 700;
  color: #333;
}

.icons {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 40px;
  justify-content: flex-end;
}

.dot {
  font-size: 14px;
  color: #999;
}

.battery {
  font-size: 14px;
  color: #999;
}

/* 内容区域 */
.content {
  margin-top: 88px;
  padding: 0 20px;
  box-sizing: border-box;
}

/* 店铺信息 */
.store-info {
  background: #fff;
  padding: 20px;
  border-radius: 12px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.store-name {
  font-size: 18px;
  font-weight: 700;
  color: #333;
  margin-bottom: 12px;
  line-height: 1.3;
}

.store-announcement-wrapper {
  margin-top: 8px;
}

.store-announcement {
  font-size: 15px;
  color: #666;
  line-height: 1.5;
  word-break: break-all;
}

.store-announcement.collapsed {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.store-announcement.expanded {
  display: block;
}

.announcement-toggle {
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.toggle-text {
  font-size: 13px;
  color: #1976d2;
  padding: 4px 8px;
  border-radius: 4px;
  background: #f0f7ff;
}

/* 收货地址 */
.address-section {
  background: #fff;
  padding: 20px;
  border-radius: 12px;
  margin-bottom: 16px;
  display: flex;
  align-items: flex-start;
  gap: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.address-icon {
  font-size: 24px;
  color: #ff4757;
  margin-top: 2px;
  flex-shrink: 0;
}

.address-info {
  flex: 1;
  min-width: 0;
}

.address-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}

.user-name {
  font-size: 17px;
  font-weight: 700;
  color: #333;
}

.user-phone {
  font-size: 15px;
  color: #666;
}

.address-detail {
  font-size: 15px;
  color: #666;
  line-height: 1.5;
  word-break: break-all;
}

.no-address {
  padding: 8px 0;
}

.no-address-text {
  font-size: 15px;
  color: #999;
  font-style: italic;
}

.edit-icon {
  font-size: 18px;
  color: #999;
  margin-left: 8px;
  flex-shrink: 0;
}

/* 订单商品 */
.order-items {
  background: #fff;
  border-radius: 12px;
  margin-bottom: 16px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 18px;
  font-weight: 700;
  color: #333;
  padding: 20px 20px 16px;
  border-bottom: 1px solid #f0f0f0;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 20px;
  border-bottom: 1px solid #f8f9fa;
  gap: 16px;
}

.order-item:last-child {
  border-bottom: none;
}

.item-image {
  width: 80px;
  height: 80px;
  border-radius: 12px;
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-width: 0;
}

.item-name {
  font-size: 16px;
  font-weight: 700;
  color: #333;
  line-height: 1.3;
  word-break: break-all;
}

.item-spec {
  font-size: 13px;
  color: #666;
  background: #f5f5f5;
  padding: 4px 8px;
  border-radius: 8px;
  display: inline-block;
  width: fit-content;
  line-height: 1.4;
  margin-top: 4px;
}

.item-price {
  font-size: 16px;
  font-weight: 700;
  color: #ff4757;
}

.item-quantity {
  font-size: 16px;
  color: #666;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 8px;
}

/* 配送信息 */
.delivery-section {
  background: #fff;
  border-radius: 12px;
  margin-bottom: 16px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.delivery-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  border-bottom: 1px solid #f8f9fa;
}

.delivery-item:last-child {
  border-bottom: none;
}

.delivery-label {
  font-size: 16px;
  color: #333;
  font-weight: 500;
}

.delivery-value {
  font-size: 16px;
  color: #666;
  font-weight: 600;
}

/* 支付方式 */
.payment-section {
  background: #fff;
  border-radius: 12px;
  margin-bottom: 16px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  border-bottom: 1px solid #f8f9fa;
  transition: all 0.2s ease;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-item.active {
  background: #f8f9ff;
}

.payment-info {
  display: flex;
  align-items: center;
  gap: 16px;
}

.payment-icon {
  font-size: 20px;
}

.payment-name {
  font-size: 16px;
  color: #333;
  font-weight: 500;
}

.payment-radio {
  width: 22px;
  height: 22px;
  border: 2px solid #ddd;
  border-radius: 50%;
  position: relative;
  transition: all 0.2s ease;
}

.payment-radio.checked {
  border-color: #1976d2;
  background: #1976d2;
}

.payment-radio.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 10px;
  height: 10px;
  background: #fff;
  border-radius: 50%;
}

/* 餐具选择 */
.cutlery-section {
  background: #fff;
  border-radius: 12px;
  margin-bottom: 16px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.cutlery-options {
  display: flex;
  flex-direction: column;
  padding: 0 20px 16px;
  gap: 12px;
}

.cutlery-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  transition: all 0.2s ease;
}

.cutlery-option.active {
  background: #f8f9ff;
  margin: 0 -20px;
  padding: 12px 20px;
  border-radius: 8px;
}

.cutlery-label {
  font-size: 16px;
  color: #333;
  font-weight: 500;
}

.cutlery-radio {
  width: 22px;
  height: 22px;
  border: 2px solid #ddd;
  border-radius: 50%;
  position: relative;
  transition: all 0.2s ease;
}

.cutlery-radio.checked {
  border-color: #1976d2;
  background: #1976d2;
}

.cutlery-radio.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 10px;
  height: 10px;
  background: #fff;
  border-radius: 50%;
}

.cutlery-quantity {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 20px 16px;
}

.quantity-label {
  font-size: 15px;
  color: #666;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 4px 8px;
}

.quantity-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: #1976d2;
  font-weight: 600;
  cursor: pointer;
  user-select: none;
}

.quantity-btn:active {
  background: #f0f0f0;
  border-radius: 4px;
}

.quantity-value {
  font-size: 16px;
  color: #333;
  font-weight: 600;
  min-width: 24px;
  text-align: center;
}

.quantity-unit {
  font-size: 15px;
  color: #666;
}

/* 备注 */
.remark-section {
  background: #fff;
  border-radius: 12px;
  margin-bottom: 20px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.remark-input {
  width: 100%;
  min-height: 100px;
  padding: 20px;
  border: none;
  font-size: 15px;
  color: #333;
  background: transparent;
  line-height: 1.5;
  box-sizing: border-box;
}

.remark-input::placeholder {
  color: #999;
}

/* 底部结算栏 */
.checkout-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.1);
  z-index: 100;
  border-top: 1px solid #f0f0f0;
}

.total-info {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.total-label {
  font-size: 15px;
  color: #666;
  font-weight: 500;
}

.total-amount {
  font-size: 24px;
  font-weight: 700;
  color: #ff4757;
}

.submit-btn {
  background: #1976d2;
  padding: 16px 40px;
  border-radius: 30px;
  flex-shrink: 0;
  box-shadow: 0 4px 12px rgba(25, 118, 210, 0.3);
  transition: all 0.2s ease;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2px 8px rgba(25, 118, 210, 0.3);
}

.submit-text {
  color: #fff;
  font-size: 18px;
  font-weight: 700;
}
