/* 确认订单 - 依据配色设计文档全面优化 */
.page {
  background: var(--color-bg-page);
  min-height: 100vh;
  padding-bottom: 120px;
  box-sizing: border-box;
}

/* 顶栏：白底 + 主色点缀（与订单页一致） */
.nav {
  background: var(--color-bg-card);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: var(--shadow-card);
  border-bottom: 1px solid var(--color-border);
}

.status-bar { width: 100%; }

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  position: relative;
}

.back {
  font-size: 20px;
  color: var(--color-text);
  font-weight: 600;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18px;
  font-weight: 700;
  color: var(--color-text);
}

.icons {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 40px;
  justify-content: flex-end;
}

.dot, .battery {
  font-size: 14px;
  color: var(--color-text-placeholder);
}

.content {
  padding: 0 20px;
  box-sizing: border-box;
  min-height: 100vh;
}

/* ========== 店铺信息卡片 ========== */
.store-info {
  background: var(--color-bg-card);
  padding: 20px;
  border-radius: var(--radius-card);
  margin-bottom: 16px;
  box-shadow: var(--shadow-card);
  border: 1px solid var(--color-border);
}

.store-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12px;
  line-height: 1.3;
}

.store-announcement-wrapper { margin-top: 8px; }

.store-announcement {
  font-size: 15px;
  color: var(--color-text-secondary);
  line-height: 1.5;
  word-break: break-all;
}

.store-announcement.collapsed {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.store-announcement.expanded { display: block; }

.announcement-toggle {
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.toggle-text {
  font-size: 13px;
  color: var(--color-secondary);
  padding: 4px 8px;
  border-radius: var(--radius-btn);
  background: var(--color-secondary-light);
}

/* ========== 收货地址卡片 ========== */
.address-section {
  background: var(--color-bg-card);
  padding: 20px;
  border-radius: var(--radius-card);
  margin-bottom: 16px;
  display: flex;
  align-items: flex-start;
  gap: 16px;
  box-shadow: var(--shadow-card);
  border: 1px solid var(--color-border);
}

.address-icon {
  font-size: 24px;
  color: var(--color-primary);
  margin-top: 2px;
  flex-shrink: 0;
}

.address-info { flex: 1; min-width: 0; }

.address-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}

.user-name {
  font-size: 17px;
  font-weight: 700;
  color: var(--color-text);
}

.user-phone { font-size: 15px; color: var(--color-text-secondary); }

.address-detail {
  font-size: 15px;
  color: var(--color-text-secondary);
  line-height: 1.5;
  word-break: break-all;
}

.no-address { padding: 8px 0; }

.no-address-text {
  font-size: 15px;
  color: var(--color-text-placeholder);
  font-style: italic;
}

.edit-icon {
  font-size: 18px;
  color: var(--color-text-placeholder);
  margin-left: 8px;
  flex-shrink: 0;
}

/* ========== 订单详情卡片 ========== */
.order-items {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  margin-bottom: 16px;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1px solid var(--color-border);
}

.section-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--color-text);
  padding: 20px 20px 16px;
  border-bottom: 1px solid var(--color-border);
}

.order-item {
  display: flex;
  align-items: center;
  padding: 20px;
  border-bottom: 1px solid var(--color-border);
  gap: 16px;
}

.order-item:last-child { border-bottom: none; }

.item-image {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-card);
  flex-shrink: 0;
  box-shadow: var(--shadow-card);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-width: 0;
}

.item-name {
  font-size: 16px;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.3;
  word-break: break-all;
}

.item-spec {
  font-size: 13px;
  color: var(--color-text-secondary);
  background: var(--color-primary-light);
  padding: 4px 8px;
  border-radius: var(--radius-btn);
  display: inline-block;
  width: fit-content;
  line-height: 1.4;
  margin-top: 4px;
}

.item-price {
  font-size: 16px;
  font-weight: 700;
  color: var(--color-primary);
}

.item-quantity {
  font-size: 16px;
  color: var(--color-text-secondary);
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 8px;
}

/* ========== 配送信息卡片 ========== */
.delivery-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  margin-bottom: 16px;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1px solid var(--color-border);
}

.delivery-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  border-bottom: 1px solid var(--color-border);
}

.delivery-item:last-child { border-bottom: none; }

.delivery-label {
  font-size: 16px;
  color: var(--color-text);
  font-weight: 500;
}

.delivery-value {
  font-size: 16px;
  color: var(--color-text-secondary);
  font-weight: 600;
}

/* ========== 支付方式卡片 ========== */
.payment-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  margin-bottom: 16px;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1px solid var(--color-border);
}

.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  border-bottom: 1px solid var(--color-border);
  transition: all var(--transition-fast);
}

.payment-item:last-child { border-bottom: none; }

.payment-item.active {
  background: var(--color-primary-light);
}

.payment-info { display: flex; align-items: center; gap: 16px; }

.payment-icon { font-size: 20px; }

.payment-name {
  font-size: 16px;
  color: var(--color-text);
  font-weight: 500;
}

.payment-radio {
  width: 22px;
  height: 22px;
  border: 2px solid var(--color-border);
  border-radius: 50%;
  position: relative;
  transition: all var(--transition-fast);
}

.payment-radio.checked {
  border-color: var(--color-primary);
  background: var(--color-primary);
}

.payment-radio.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 10px;
  height: 10px;
  background: #fff;
  border-radius: 50%;
}

/* ========== 餐具选择卡片 ========== */
.cutlery-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  margin-bottom: 16px;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1px solid var(--color-border);
}

.cutlery-options {
  display: flex;
  flex-direction: column;
  padding: 0 20px 16px;
  gap: 12px;
}

.cutlery-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  transition: all var(--transition-fast);
}

.cutlery-option.active {
  background: var(--color-primary-light);
  margin: 0 -20px;
  padding: 12px 20px;
  border-radius: var(--radius-btn);
}

.cutlery-label {
  font-size: 16px;
  color: var(--color-text);
  font-weight: 500;
}

.cutlery-radio {
  width: 22px;
  height: 22px;
  border: 2px solid var(--color-border);
  border-radius: 50%;
  position: relative;
  transition: all var(--transition-fast);
}

.cutlery-radio.checked {
  border-color: var(--color-primary);
  background: var(--color-primary);
}

.cutlery-radio.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 10px;
  height: 10px;
  background: #fff;
  border-radius: 50%;
}

.cutlery-quantity {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 20px 16px;
}

.quantity-label {
  font-size: 15px;
  color: var(--color-text-secondary);
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-btn);
  padding: 4px 8px;
}

.quantity-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: var(--color-primary);
  font-weight: 600;
  cursor: pointer;
  user-select: none;
}

.quantity-btn:active {
  background: var(--color-primary-light);
  border-radius: 4px;
}

.quantity-value {
  font-size: 16px;
  color: var(--color-text);
  font-weight: 600;
  min-width: 24px;
  text-align: center;
}

.quantity-unit {
  font-size: 15px;
  color: var(--color-text-secondary);
}

/* ========== 备注卡片 ========== */
.remark-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  margin-bottom: 20px;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1px solid var(--color-border);
}

.remark-input {
  width: 100%;
  min-height: 100px;
  padding: 20px;
  border: none;
  font-size: 15px;
  color: var(--color-text);
  background: transparent;
  line-height: 1.5;
  box-sizing: border-box;
}

.remark-input::placeholder {
  color: var(--color-text-placeholder);
}

/* ========== 底部结算栏：白底 + 总价主色 + 结算主色按钮 ========== */
.checkout-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-card);
  padding: 20px;
  padding-bottom: calc(20px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.08);
  z-index: 100;
  border-top: 1px solid var(--color-border);
}

.total-info {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.total-label {
  font-size: 15px;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.total-amount {
  font-size: 24px;
  font-weight: 700;
  color: var(--color-primary);
}

.submit-btn {
  background: var(--color-primary);
  padding: 16px 40px;
  border-radius: 30px;
  flex-shrink: 0;
  box-shadow: 0 4px 12px rgba(255, 184, 0, 0.35);
  transition: all var(--transition-fast);
}

.submit-btn:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.submit-btn.disabled {
  opacity: 0.7;
  pointer-events: none;
}

.submit-text {
  color: #fff;
  font-size: 18px;
  font-weight: 700;
}
