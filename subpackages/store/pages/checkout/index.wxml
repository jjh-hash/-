<view class="page">
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <text class="back" bindtap="onBack">◀</text>
      <text class="title">确认订单</text>
      <view class="icons">
        <text class="dot">•</text>
        <text class="battery">▮</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 店铺信息 -->
    <view class="store-info">
      <view class="store-name">{{storeInfo.name}}</view>
      <view class="store-announcement-wrapper" wx:if="{{storeInfo.announcement}}">
        <view class="store-announcement {{announcementExpanded ? 'expanded' : 'collapsed'}}">
          {{storeInfo.announcement}}
        </view>
        <view class="announcement-toggle" bindtap="onToggleAnnouncement" wx:if="{{announcementNeedExpand}}">
          <text class="toggle-text">{{announcementExpanded ? '收起' : '查看详细'}}</text>
        </view>
      </view>
    </view>

    <!-- 收货地址 -->
    <view class="address-section" bindtap="onEditAddress">
      <view class="address-icon">📍</view>
      <view class="address-info">
        <view wx:if="{{hasAddress}}" class="address-header">
          <text class="user-name">{{userInfo.name}}</text>
          <text class="user-phone">{{userInfo.phone}}</text>
        </view>
        <text wx:if="{{hasAddress}}" class="address-detail">{{userInfo.address}}</text>
        <view wx:else class="no-address">
          <text class="no-address-text">点击新建地址</text>
        </view>
      </view>
      <text class="edit-icon">></text>
    </view>

    <!-- 商品列表 -->
    <view class="order-items">
      <view class="section-title">订单详情</view>
      <block wx:for="{{cartItems}}" wx:key="id">
        <view class="order-item">
          <image class="item-image" src="{{item.image}}" mode="aspectFill" />
          <view class="item-info">
            <view class="item-name">{{item.name}}</view>
            <!-- 优先显示新格式的规格信息 selectedSpecs -->
            <view class="item-spec" wx:if="{{item.selectedSpecs && item.selectedSpecs.length > 0}}">
              <block wx:for="{{item.selectedSpecs}}" wx:key="index" wx:for-item="spec">
                <text>{{spec.optionName}}</text>
                <text wx:if="{{index < item.selectedSpecs.length - 1}}">、</text>
              </block>
            </view>
            <!-- 兼容旧格式 selectedSpec -->
            <view class="item-spec" wx:elif="{{item.selectedSpec}}">
              {{item.selectedSpec.portion}}/{{item.selectedSpec.spiciness}}
            </view>
            <!-- 兼容字符串格式 spec -->
            <view class="item-spec" wx:elif="{{item.spec}}">
              {{item.spec}}
            </view>
            <view class="item-price">¥{{item.finalPrice || item.price}}</view>
          </view>
          <view class="item-quantity">x{{item.quantity}}</view>
        </view>
      </block>
    </view>

    <!-- 配送信息 -->
    <view class="delivery-section">
      <view class="section-title">配送信息</view>
      <view class="delivery-item">
        <text class="delivery-label">配送费</text>
        <text class="delivery-value">¥{{deliveryFee}}</text>
      </view>
      <view class="delivery-item">
        <text class="delivery-label">预计送达</text>
        <text class="delivery-value">{{estimatedDeliveryTimeRange}}</text>
      </view>
    </view>

    <!-- 支付方式 -->
    <view class="payment-section">
      <view class="section-title">支付方式</view>
      <view class="payment-item {{paymentMethod === 'wechat' ? 'active' : ''}}" 
            data-method="wechat" bindtap="onSelectPayment">
        <view class="payment-info">
          <text class="payment-icon">💳</text>
          <text class="payment-name">微信支付</text>
        </view>
        <view class="payment-radio {{paymentMethod === 'wechat' ? 'checked' : ''}}"></view>
      </view>
      <view class="payment-item {{paymentMethod === 'alipay' ? 'active' : ''}}" 
            data-method="alipay" bindtap="onSelectPayment">
        <view class="payment-info">
          <text class="payment-icon">💰</text>
          <text class="payment-name">支付宝</text>
        </view>
        <view class="payment-radio {{paymentMethod === 'alipay' ? 'checked' : ''}}"></view>
      </view>
    </view>

    <!-- 餐具选择 -->
    <view class="cutlery-section">
      <view class="section-title">餐具选择</view>
      <view class="cutlery-options">
        <view class="cutlery-option {{needCutlery ? 'active' : ''}}" bindtap="onToggleCutlery">
          <text class="cutlery-label">需要餐具</text>
          <view class="cutlery-radio {{needCutlery ? 'checked' : ''}}"></view>
        </view>
        <view class="cutlery-option {{!needCutlery ? 'active' : ''}}" bindtap="onToggleCutlery">
          <text class="cutlery-label">不需要餐具</text>
          <view class="cutlery-radio {{!needCutlery ? 'checked' : ''}}"></view>
        </view>
      </view>
      <view class="cutlery-quantity" wx:if="{{needCutlery}}">
        <text class="quantity-label">数量：</text>
        <view class="quantity-control">
          <view class="quantity-btn" bindtap="onDecreaseCutlery">-</view>
          <text class="quantity-value">{{cutleryQuantity}}</text>
          <view class="quantity-btn" bindtap="onIncreaseCutlery">+</view>
        </view>
        <text class="quantity-unit">份</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="remark-section">
      <view class="section-title">备注</view>
      <textarea class="remark-input" 
                placeholder="有什么特殊要求吗？" 
                value="{{remark}}" 
                bindinput="onRemarkInput"
                maxlength="100"></textarea>
    </view>
  </scroll-view>

  <!-- 底部结算栏 -->
  <view class="checkout-footer">
    <view class="total-info">
      <text class="total-label">合计</text>
      <text class="total-amount">¥{{totalAmount}}</text>
    </view>
    <view class="submit-btn" bindtap="onSubmitOrder">
      <text class="submit-text">结算</text>
    </view>
  </view>

</view>
