/* 我的评价 - 设计系统 */
.page {
  background: var(--color-bg-page);
  min-height: 100vh;
}

/* 内容区域 */
.content {
  padding: 16px;
}

/* 加载中 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px 0;
}

.loading-text {
  font-size: 14px;
  color: var(--color-text-secondary);
}

/* 空状态：整体居中 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
  padding: 48px 24px;
  text-align: center;
}

.empty-icon-wrap {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
}

.empty-icon {
  font-size: 40px;
  line-height: 1;
  display: block;
  text-align: center;
}

.empty-lines {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  width: 100%;
  box-sizing: border-box;
}

.empty-text,
.empty-tip {
  display: block;
  width: 100%;
  text-align: center;
  box-sizing: border-box;
}

.empty-text {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text);
}

.empty-tip {
  font-size: 14px;
  color: var(--color-text-secondary);
}

.reviews-container {
  display: flex;
  flex-direction: column;
  gap: var(--space-block);
}

.review-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: var(--space-block);
  box-shadow: var(--shadow-card);
  transition: box-shadow var(--transition-fast);
}

.review-card:active {
  box-shadow: var(--shadow-card-hover);
}

/* 店铺头部 */
.store-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-item);
  padding-bottom: var(--space-item);
  border-bottom: 1px solid var(--color-border);
}

.store-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.store-name {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text);
}

.review-date {
  font-size: 12px;
  color: var(--color-text-secondary);
}

.delete-btn {
  padding: 4px 8px;
}

.delete-icon {
  font-size: 18px;
}

/* 评分区域 */
.rating-section {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.rating-label {
  font-size: 14px;
  color: var(--color-text-secondary);
}

.stars {
  display: flex;
  gap: 2px;
}

.star {
  font-size: 14px;
  color: var(--color-border);
}

.star.filled {
  color: var(--color-primary);
}

.star.empty {
  color: var(--color-border);
  opacity: 0.5;
}

.review-content {
  font-size: 14px;
  color: var(--color-text);
  line-height: 1.6;
  margin-bottom: 12px;
}

/* 评价图片 */
.review-images {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.review-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  flex-shrink: 0;
}

.merchant-reply {
  background: var(--color-primary-light);
  padding: var(--space-item);
  border-radius: var(--radius-btn);
  margin-top: var(--space-item);
  border-left: 3px solid var(--color-primary);
}

.merchant-reply-label {
  font-size: 14px;
  color: var(--color-primary);
  font-weight: 600;
  margin-bottom: 4px;
}

.merchant-reply-content {
  font-size: 14px;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

