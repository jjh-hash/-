/* pages/chat/index.wxss */
.page {
  height: 100vh;
  background-color: #f5f6f8;
  display: flex;
  flex-direction: column;
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px;
  background: linear-gradient(180deg, #0a86ff, #2aa7ff);
  color: #fff;
  position: relative;
}

.back-btn {
  padding: 8px;
  font-size: 20px;
  color: #fff;
  flex-shrink: 0;
}

.title {
  font-size: 18px;
  font-weight: 600;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.nav-right {
  width: 40px;
  flex-shrink: 0;
}

.messages-container {
  flex: 1;
  height: calc(100vh - 44px - 60px);
  padding: 12px;
  padding-bottom: 80px;
}

.messages-list {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding-bottom: 20px;
}

.message-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 16px;
  padding: 0 8px;
}

.message-item.self {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 40px;
  height: 40px;
  flex-shrink: 0;
  margin: 0 8px;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #e5e7eb;
}

.message-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.message-item.self .message-wrapper {
  align-items: flex-end;
}

.message-item.other .message-wrapper {
  align-items: flex-start;
}

.message-content {
  max-width: 70%;
  padding: 10px 14px;
  border-radius: 12px;
  position: relative;
  word-wrap: break-word;
  word-break: break-all;
}

.message-content.other {
  background: #fff;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  border-top-left-radius: 4px;
}

.message-content.self {
  background: linear-gradient(180deg, #0a86ff, #2aa7ff);
  color: #fff;
  border-top-right-radius: 4px;
}

.message-text {
  font-size: 15px;
  line-height: 1.5;
  word-wrap: break-word;
  word-break: break-all;
}

.message-footer {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 4px;
  padding: 0 4px;
}

.message-time {
  font-size: 11px;
  color: #9ca3af;
}

.message-status {
  font-size: 11px;
}

.message-status .sending {
  color: #9ca3af;
}

.message-status .read {
  color: #1a73e8;
}

.message-status .unread {
  color: #9ca3af;
}

.input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 8px 12px;
  padding-bottom: calc(8px + env(safe-area-inset-bottom));
  border-top: 1px solid #eef0f3;
  display: flex;
  align-items: center;
  gap: 8px;
  z-index: 100;
}

.input {
  flex: 1;
  height: 36px;
  padding: 0 12px;
  background: #f3f4f6;
  border-radius: 18px;
  font-size: 14px;
}

.send-btn {
  padding: 8px 20px;
  background: #d1d5db;
  color: #6b7280;
  border-radius: 18px;
  font-size: 14px;
  transition: all 0.3s;
}

.send-btn.active {
  background: linear-gradient(180deg, #0a86ff, #2aa7ff);
  color: #fff;
}

.send-text {
  color: inherit;
}

