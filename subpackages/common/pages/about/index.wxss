/* 关于我们 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  overflow-y: auto;
}

.about-container {
  padding: var(--space-page);
}

.about-content {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 24px;
  box-shadow: var(--shadow-card);
}

.about-text {
  font-size: 15px;
  line-height: 1.8;
  color: var(--color-text);
  text-align: justify;
  display: block;
}

