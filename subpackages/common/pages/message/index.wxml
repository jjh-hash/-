<!--pages/message/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  

  <scroll-view 
    scroll-y 
    class="content" 
    refresher-enabled="{{true}}"
    refresher-triggered="{{loading && page === 1}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscrolltolower="onReachBottom"
  >
    <!-- 消息列表 -->
    <view class="message-list" wx:if="{{messages.length > 0}}">
      <view 
        class="message-item {{item.status === 'unread' ? 'unread' : ''}}" 
        wx:for="{{messages}}" 
        wx:key="_id"
        bindtap="onMessageTap"
        data-index="{{index}}"
      >
        <view class="message-header">
          <view class="type-badge" style="background-color: {{getMessageTypeInfo(item.messageType).color}}20; color: {{getMessageTypeInfo(item.messageType).color}}">
            <text class="type-icon">{{getMessageTypeInfo(item.messageType).icon}}</text>
            <text class="type-text">{{getMessageTypeInfo(item.messageType).text}}</text>
          </view>
          <text class="time">{{formatTime(item.createdAt)}}</text>
        </view>
        
        <view class="message-content">
          <view class="user-info">
            <text class="user-name">{{item.fromUserId === (userInfo && userInfo.openid) ? item.toUserName : item.fromUserName}}</text>
            <text class="user-label">{{item.fromUserId === (userInfo && userInfo.openid) ? '我' : '对方'}}</text>
          </view>
          <view class="related-info" wx:if="{{item.relatedTitle}}">
            <text class="related-title">{{item.relatedTitle}}</text>
          </view>
        </view>

        <view class="message-footer">
          <view class="contact-info">
            <text class="phone-label">联系方式：</text>
            <text class="phone-number">{{item.contactPhone || '未设置'}}</text>
          </view>
          <view class="contact-btn" catchtap="onContactTap" data-index="{{index}}">
            <text class="contact-text">联系</text>
          </view>
        </view>

        <view class="unread-dot" wx:if="{{item.status === 'unread' && userInfo && item.toUserId === userInfo.openid}}"></view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:else>
      <text class="empty-icon">💬</text>
      <text class="empty-text">暂无消息</text>
      <text class="empty-desc">联系记录将显示在这里</text>
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more" wx:if="{{hasMore && messages.length > 0}}">
      <text>上拉加载更多</text>
    </view>

    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 加载状态 -->
  <view wx:if="{{loading && messages.length === 0}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 自定义底部栏 -->
  <view class="tabbar">
    <view class="tab" bindtap="onTabTap" data-tab="home">
      <image class="t-icon" src="/pages/小标/shouye.png" mode="aspectFit" />
      <text class="t-text">首页</text>
    </view>
    <view class="tab" bindtap="onTabTap" data-tab="order">
      <image class="t-icon" src="/pages/小标/dingdan.png" mode="aspectFit" />
      <text class="t-text">订单</text>
    </view>
    <!-- 接单功能正在开发中，已注释 -->
    <!-- <view class="tab" bindtap="onTabTap" data-tab="receive">
      <image class="t-icon" src="/pages/小标/接单.png" mode="aspectFit" />
      <text class="t-text">接单</text>
    </view> -->
    <!-- 消息功能正在开发中，已注释 -->
    <!-- <view class="tab active">
      <image class="t-icon" src="/pages/小标/消息 (1).png" mode="aspectFit" />
      <text class="t-text">消息</text>
    </view> -->
    <view class="tab" bindtap="onTabTap" data-tab="profile">
      <image class="t-icon" src="/pages/小标/wode.png" mode="aspectFit" />
      <text class="t-text">我的</text>
    </view>
  </view>
</view>

