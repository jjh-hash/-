.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.status-bar {
  width: 100%;
}

.nav {
  background: #fff;
  border-bottom: 1px solid #eee;
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 12px;
}

.back {
  position: absolute;
  left: 12px;
  font-size: 18px;
  color: #333;
  padding: 8px;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}

.content {
  height: calc(100vh - 44px - 68px);
  padding: 16px;
  padding-bottom: 100px;
  box-sizing: border-box;
}

/* 用户信息展示 */
.user-info-section {
  background: #fff;
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-container {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 12px;
  border: 2px solid #f0f0f0;
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-name {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.user-tip {
  font-size: 12px;
  color: #999;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 12px;
  margin-bottom: 12px;
  padding: 0 16px;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 100px;
  font-size: 15px;
  color: #333;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 15px;
  color: #333;
  text-align: right;
}

.form-tip {
  padding: 12px 16px;
  margin-top: 8px;
}

.tip-text {
  font-size: 12px;
  color: #999;
  line-height: 1.5;
}

.safe-area-bottom {
  height: 80px;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  border-top: 1px solid #eee;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.05);
}

.btn-save {
  width: 100%;
  height: 44px;
  line-height: 44px;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #fff;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 600;
  border: none;
}

.btn-save::after {
  border: none;
}

