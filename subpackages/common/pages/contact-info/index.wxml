<view class="page">

  <scroll-view scroll-y class="content">
    <!-- 联系方式编辑（选填一个即可） -->
    <view class="form-section">
      <view class="form-item">
        <text class="form-label">电话号码</text>
        <input 
          class="form-input" 
          type="number"
          placeholder="选填" 
          value="{{contactInfo.phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="form-item">
        <text class="form-label">微信号</text>
        <input 
          class="form-input" 
          placeholder="选填" 
          value="{{contactInfo.wechat}}"
          bindinput="onWechatInput"
          maxlength="50"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="form-item">
        <text class="form-label">QQ号</text>
        <input 
          class="form-input" 
          type="number"
          placeholder="选填" 
          value="{{contactInfo.qq}}"
          bindinput="onQQInput"
          maxlength="15"
        />
      </view>
    </view>

    <view class="form-tip">
      <text class="tip-text">💡 至少填写一种联系方式即可</text>
    </view>

    <view class="safe-area-bottom"></view>
  </scroll-view>

  <view class="footer">
    <button class="btn-save" type="primary" bindtap="onSave">保存</button>
  </view>
</view>

