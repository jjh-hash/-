<view class="page">
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <text class="back" bindtap="onBack">◀</text>
      <text class="title">我的地址</text>
    </view>
  </view>

  <view class="content">
    <view class="empty" wx:if="{{addresses.length === 0}}">
      <text class="empty-title">暂无地址</text>
      <text class="empty-sub">点击下方按钮新增一个收货地址</text>
    </view>

    <view class="list" wx:if="{{addresses.length > 0}}">
      <scroll-view scroll-y class="scroll-view">
        <block wx:for="{{addresses}}" wx:key="_id">
          <view class="addr-item" bindtap="onSelectAddress" data-id="{{item._id}}">
            <view class="addr-header">
              <view class="addr-name-row">
                <text class="addr-name">{{item.name}}</text>
                <text class="addr-phone">{{item.phone}}</text>
              </view>
              <view class="addr-default" wx:if="{{item.isDefault}}">
                <text class="default-tag">默认</text>
              </view>
            </view>
            <view class="addr-body">
              <text class="addr-icon">📍</text>
              <text class="addr-detail">{{item.detail}}</text>
            </view>
            <view class="addr-footer">
              <text class="addr-set-default" wx:if="{{!item.isDefault}}" catchtap="onSetDefault" data-id="{{item._id}}">设为默认</text>
              <text class="addr-delete" catchtap="onDelete" data-id="{{item._id}}">删除</text>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>

  <view class="footer">
    <button class="btn-add" type="primary" size="default" bindtap="onAdd">新增地址</button>
  </view>
</view>

