/* 我的信息 - 设计系统 */
.page {
  box-sizing: border-box;
  max-width: 100%;
  overflow-x: hidden;
  background: var(--color-bg-page);
}

.content {
  height: 100vh;
  background: var(--color-bg-page);
  padding: var(--space-page);
  padding-top: calc(var(--space-page) + env(safe-area-inset-top, 0px));
  padding-bottom: 0;
  box-sizing: border-box;
  max-width: 100%;
}

.form-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: var(--space-block);
  margin-bottom: var(--space-item);
  box-sizing: border-box;
  max-width: 100%;
  box-shadow: var(--shadow-card);
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.form-label {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text);
}

/* 头像区域 */
.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.avatar-btn {
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  overflow: hidden;
  width: 160rpx;
  height: 160rpx;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--color-border);
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  border: 2px dashed var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-text {
  font-size: 28rpx;
  color: var(--color-text-placeholder);
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--color-text);
  background: var(--color-bg-page);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-btn);
  box-sizing: border-box;
  transition: border-color var(--transition-fast);
}

.form-input:focus {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
}

/* 选择器样式 */
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--color-bg-page);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-btn);
  box-sizing: border-box;
}

.form-picker-text {
  font-size: 30rpx;
  color: var(--color-text);
}

.form-picker-placeholder {
  font-size: 30rpx;
  color: var(--color-text-placeholder);
}

.form-picker-arrow {
  font-size: 28rpx;
  color: var(--color-text-placeholder);
}

/* 固定在底部的保存按钮：不透明背景 + 较高层级，避免表单透出 */
.save-section-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  isolation: isolate;
  padding: 16px 16px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom, 0px));
  background-color: #F0F1F3;
  background-color: var(--color-bg-page);
  box-sizing: border-box;
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.08);
}

.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: var(--color-primary);
  border: none;
  border-radius: var(--radius-btn);
  transition: opacity var(--transition-fast);
}

.save-btn:active {
  opacity: 0.9;
}

.save-btn::after {
  border: none;
}

/* 底部留白：为固定按钮预留空间，避免内容被遮挡 */
.scroll-bottom-spacer {
  height: calc(96rpx + 32px + env(safe-area-inset-bottom, 0px));
  flex-shrink: 0;
}

