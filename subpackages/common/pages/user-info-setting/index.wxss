/* 导航 */
.nav {
  background: #fff;
}
.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1px solid #f1f3f5;
  position: relative;
}
.back {
  position: absolute;
  left: 12px;
  color: #374151;
  font-size: 18px;
}
.title {
  font-size: 17px;
  font-weight: 600;
  color: #111827;
}

/* 内容区域 */
.content {
  height: calc(100vh - 120px);
  background: #f5f6f8;
  padding: 12px;
  padding-bottom: calc(12px + 88px + env(safe-area-inset-bottom));
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 12px;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-label {
  font-size: 16px;
  font-weight: 600;
  color: #1f2937;
}

/* 头像区域 */
.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}

.avatar-btn {
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  overflow: hidden;
  width: 160rpx;
  height: 160rpx;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.avatar-tips {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.avatar-tip-text {
  font-size: 26rpx;
  color: #6b7280;
}

.avatar-action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #f3f4f6;
  color: #374151;
  border: none;
  border-radius: 8px;
  font-size: 30rpx;
}

.avatar-action-btn::after {
  border: none;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  color: #1f2937;
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #1a73e8;
  background: #fff;
}

/* 选择器样式 */
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  padding: 0 20rpx;
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  box-sizing: border-box;
}

.form-picker-text {
  font-size: 32rpx;
  color: #1f2937;
}

.form-picker-placeholder {
  font-size: 32rpx;
  color: #9ca3af;
}

.form-picker-arrow {
  font-size: 32rpx;
  color: #9ca3af;
}

/* 底部按钮 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20px 40px;
  padding-bottom: calc(20px + env(safe-area-inset-bottom));
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.05);
}

.btn-save {
  width: 100%;
  background: #1a73e8;
  color: #fff;
  border: none;
  border-radius: 999px;
  height: 48px;
  font-size: 16px;
  font-weight: 600;
}

.btn-save::after {
  border: none;
}

