<view class="page">

  <scroll-view scroll-y class="content" enhanced="{{true}}" show-scrollbar="{{false}}">
    <!-- 头像设置 -->
    <view class="form-section">
      <view class="form-item">
        <text class="form-label">头像</text>
        <view class="avatar-wrapper">
          <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image class="avatar-img" src="{{tempAvatar}}" mode="aspectFill" wx:if="{{tempAvatar}}" />
            <view class="avatar-placeholder" wx:else>
              <text class="avatar-placeholder-text">点击选择</text>
            </view>
          </button>
        </view>
      </view>
    </view>

    <!-- 昵称设置 -->
    <view class="form-section">
      <view class="form-item">
        <text class="form-label">昵称</text>
        <input 
          class="form-input" 
          type="nickname"
          placeholder="请输入昵称" 
          value="{{tempNickname}}"
          bindinput="onNicknameInput"
          bindblur="onNicknameBlur"
          maxlength="20"
        />
      </view>
    </view>

    <!-- 校区选择 -->
    <view class="form-section">
      <view class="form-item">
        <text class="form-label">校区</text>
        <picker mode="selector" range="{{campusList}}" range-key="name" value="{{campusIndex}}" bindchange="onCampusChange">
          <view class="form-picker">
            <text class="form-picker-text" wx:if="{{tempCampus}}">{{tempCampus}}</text>
            <text class="form-picker-placeholder" wx:else>请选择校区</text>
            <text class="form-picker-arrow">></text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 学院设置 -->
    <view class="form-section">
      <view class="form-item">
        <text class="form-label">你的学院</text>
        <input 
          class="form-input" 
          placeholder="请输入你的学院" 
          value="{{tempCollege}}"
          bindinput="onCollegeInput"
          bindblur="onCollegeBlur"
          maxlength="50"
        />
      </view>
    </view>

    <!-- 专业设置 -->
    <view class="form-section">
      <view class="form-item">
        <text class="form-label">你的专业</text>
        <input 
          class="form-input" 
          placeholder="请输入你的专业" 
          value="{{tempMajor}}"
          bindinput="onMajorInput"
          bindblur="onMajorBlur"
          maxlength="50"
        />
      </view>
    </view>

    <!-- 常用联系电话 -->
    <view class="form-section">
      <view class="form-item">
        <text class="form-label">常用联系电话</text>
        <input 
          class="form-input" 
          type="number"
          placeholder="请输入常用联系电话" 
          value="{{tempPhone}}"
          bindinput="onPhoneInput"
          bindblur="onPhoneBlur"
          maxlength="11"
        />
      </view>
    </view>

    <!-- 底部留白（为固定按钮预留空间） -->
    <view class="scroll-bottom-spacer"></view>
  </scroll-view>

  <!-- 固定在底部的保存按钮 -->
  <view class="save-section save-section-fixed">
    <button class="save-btn" bindtap="saveUserInfo">保存</button>
  </view>
</view>

