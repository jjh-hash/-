/* 新增地址 - 设计系统 */
.page {
  background: var(--color-bg-page);
  min-height: 100vh;
}

.content {
  height: calc(100vh - 120px);
  background: var(--color-bg-page);
}

.form-section {
  background: var(--color-bg-card);
  margin: var(--space-page);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.form-item {
  display: flex;
  align-items: center;
  padding: var(--space-block);
  border-bottom: 1px solid var(--color-border);
  min-height: var(--min-tap);
}
.form-item:last-child {
  border-bottom: none;
}

.form-icon {
  width: 24px;
  height: 24px;
  margin-right: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.form-icon-img {
  width: 22px;
  height: 22px;
}

.form-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.form-label {
  font-size: 14px;
  color: var(--color-text-secondary);
  margin-bottom: 4px;
}
.form-value,
.form-input {
  font-size: 16px;
  color: var(--color-text);
  border: none;
  outline: none;
}

.form-arrow {
  color: var(--color-text-placeholder);
  font-size: 16px;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-card);
  padding: var(--space-page) 40px calc(var(--space-page) + env(safe-area-inset-bottom));
  box-shadow: 0 -2px 8px rgba(0,0,0,0.06);
}
.btn-confirm {
  width: 100%;
  height: 44px;
  min-height: var(--min-tap);
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-btn);
  font-size: 16px;
  font-weight: 600;
}
