/* 隐私政策 - 设计系统 */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}
.content {
  flex: 1;
  overflow-y: auto;
}
.policy-container {
  padding: 24rpx 30rpx 60rpx;
}
.policy-block {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}
.policy-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 24rpx;
  display: block;
}
.policy-section {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin: 24rpx 0 16rpx;
  display: block;
}
.policy-text {
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--color-text-secondary);
  text-align: justify;
  display: block;
  margin-bottom: 16rpx;
}
.policy-text:last-child {
  margin-bottom: 0;
}
.policy-update {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
  margin-top: 32rpx;
  display: block;
}
