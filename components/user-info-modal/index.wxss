/* components/user-info-modal/index.wxss */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.avatar-section,
.nickname-section {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.avatar-section {
  position: relative;
}

.section-label {
  font-size: 32rpx;
  color: #333;
  width: 120rpx;
}

.avatar-btn {
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 12rpx;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}

.avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-text {
  font-size: 24rpx;
  color: #999;
}

.avatar-action {
  margin-left: 20rpx;
}

.section-arrow {
  font-size: 32rpx;
  color: #999;
}

.nickname-input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  padding: 10rpx 0;
}

.suggestions {
  margin-top: 40rpx;
  margin-bottom: 20rpx;
}

.suggestion-item {
  padding: 20rpx 0;
  text-align: center;
}

.suggestion-text {
  font-size: 28rpx;
  color: #333;
}

.modal-footer {
  margin-top: 40rpx;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.confirm-btn::after {
  border: none;
}

