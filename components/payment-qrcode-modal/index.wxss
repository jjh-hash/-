/* components/payment-qrcode-modal/index.wxss */
.payment-qrcode-modal-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding-top: 60px;
  padding-bottom: 40px;
}

.payment-qrcode-modal-content {
  width: 80%;
  max-width: 360px;
  max-height: calc(100vh - 100px);
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.payment-qrcode-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px 10px 16px;
  border-bottom: 1px solid #f0f0f0;
  position: relative;
  flex-shrink: 0;
}

.payment-qrcode-modal-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.payment-qrcode-modal-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: #999;
  border-radius: 50%;
  background: #f5f5f5;
  position: relative;
  left: -8px;
  margin-right: -8px;
}

.payment-qrcode-modal-close:active {
  background: #e0e0e0;
}

.payment-qrcode-modal-body {
  padding: 16px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  overflow-y: auto;
}

.payment-tip {
  margin-bottom: 12px;
}

.tip-text {
  font-size: 12px;
  color: #fff;
  background: #07c160;
  padding: 4px 12px;
  border-radius: 16px;
  font-weight: 500;
}

.qrcode-container {
  width: 220px;
  height: 220px;
  background: #fff;
  border-radius: 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  border: 2px solid #f0f0f0;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  position: relative;
  cursor: pointer;
}

.qrcode-container:active {
  opacity: 0.8;
}

.qrcode-image {
  width: 100%;
  height: 100%;
  border-radius: 12px;
}

.preview-tip {
  position: absolute;
  bottom: 8px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 11px;
  white-space: nowrap;
}

.preview-tip-text {
  color: #fff;
  font-size: 11px;
}

.qrcode-loading {
  color: #999;
  font-size: 14px;
}

.merchant-info {
  margin-bottom: 12px;
}

.merchant-name {
  font-size: 16px;
  color: #333;
  font-weight: 500;
}

.order-info {
  width: 100%;
  background: #f8f9fa;
  border-radius: 6px;
  padding: 10px;
  margin-bottom: 12px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 14px;
  color: #666;
}

.info-value {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.info-value.amount {
  font-size: 18px;
  color: #ff4d4f;
  font-weight: 600;
}

.wechat-pay-logo {
  display: flex;
  align-items: center;
  gap: 8px;
}

.logo-text {
  font-size: 14px;
  color: #07c160;
  font-weight: 600;
}

.longpress-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  margin-top: 8px;
  margin-bottom: 12px;
  padding: 8px 12px;
  background: #e6f7ff;
  border-radius: 6px;
  border: 1px solid #91d5ff;
}

.tip-icon {
  font-size: 16px;
}

.longpress-tip .tip-text {
  font-size: 11px;
  color: #0958d9;
  background: transparent;
  padding: 0;
  border-radius: 0;
  font-weight: 500;
  text-align: left;
  line-height: 1.6;
  word-wrap: break-word;
  word-break: break-all;
}

.payment-qrcode-modal-footer {
  display: flex;
  gap: 10px;
  padding: 12px 16px;
  border-top: 1px solid #f0f0f0;
  flex-shrink: 0;
}

.action-btn {
  flex: 1;
  height: 40px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 500;
}

.scan-btn {
  background: #1677ff;
  color: #fff;
}

.scan-btn:active {
  background: #0958d9;
}

@media (max-width: 400px) {
  .action-btn {
    min-width: calc(50% - 6px);
    font-size: 13px;
  }
}

.confirm-btn {
  background: #07c160;
  color: #fff;
}

.confirm-btn:active {
  background: #06ad56;
}

.save-btn {
  background: #fff;
  color: #1677ff;
  border: 1px solid #1677ff;
}

.save-btn:active {
  background: #f0f7ff;
}

.btn-text {
  color: inherit;
}

