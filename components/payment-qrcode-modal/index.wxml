<!--components/payment-qrcode-modal/index.wxml-->
<view wx:if="{{showModal}}" class="payment-qrcode-modal-overlay" bindtap="onClose">
  <view class="payment-qrcode-modal-content" catchtap="stopPropagation">
    <view class="payment-qrcode-modal-header">
      <text class="payment-qrcode-modal-title">收款码</text>
      <text class="payment-qrcode-modal-close" bindtap="onClose">✕</text>
    </view>
    
    <view class="payment-qrcode-modal-body">
      <view class="payment-tip">
        <text class="tip-text">推荐使用微信支付</text>
      </view>
      
      <view class="qrcode-container" bindtap="onPreviewQRCode">
        <image 
          wx:if="{{qrcodeImage}}" 
          class="qrcode-image" 
          src="{{qrcodeImage}}" 
          mode="aspectFit"
          binderror="onImageError"
          bindload="onImageLoad"
          lazy-load="{{false}}"
        />
        <view wx:else class="qrcode-loading">
          <text>生成中...</text>
        </view>
        <!-- 添加点击提示 -->
        <view class="preview-tip">
          <text class="preview-tip-text">点击查看大图</text>
        </view>
      </view>

      <!-- 添加长按提示 -->
      <view class="longpress-tip">
        <text class="tip-icon">💡</text>
        <text class="tip-text">使用说明：点击二维码图片 → 在预览界面长按 → 选择"识别图中二维码"进行支付</text>
      </view>

      <view class="merchant-info" wx:if="{{orderInfo}}">
        <text class="merchant-name">{{orderInfo.merchantName || '商家'}}</text>
      </view>

      <view class="order-info" wx:if="{{orderInfo}}">
        <view class="info-row">
          <text class="info-label">订单号：</text>
          <text class="info-value">{{orderInfo.orderNo || ''}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">收款金额：</text>
          <text class="info-value amount">¥{{orderInfo.amountTotal || '0.00'}}</text>
        </view>
      </view>

      <view class="wechat-pay-logo">
        <text class="logo-text">微信支付</text>
      </view>
    </view>
    
    <view class="payment-qrcode-modal-footer">
      <view class="action-btn confirm-btn" bindtap="onConfirmPayment">
        <text class="btn-text">确认支付</text>
      </view>
      <view class="action-btn save-btn" bindtap="onSaveQRCode">
        <text class="btn-text">保存收款码</text>
      </view>
    </view>
  </view>
</view>

