/* 页面基础样式 */
.page {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 状态栏 */
.status-bar {
  background: #fff;
  padding: 0 12px;
}

/* 头部导航 */
.header {
  display: flex;
  align-items: center;
  padding: 8px 16px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8px;
}

.back-icon {
  font-size: 18px;
  color: #333;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-right: 12px;
}

.search-container {
  flex: 1;
  height: 32px;
  background: #f5f5f5;
  border-radius: 16px;
  display: flex;
  align-items: center;
  padding: 0 12px;
}

.search-icon {
  font-size: 14px;
  color: #999;
  margin-right: 6px;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.search-placeholder {
  color: #999;
}

/* 内容区域 */
.content {
  flex: 1;
  padding-bottom: 80px;
}

/* 分类标签 */
.category-tabs {
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 12px;
}

.category-item {
  padding: 12px 16px;
  font-size: 14px;
  color: #666;
  white-space: nowrap;
  position: relative;
}

.category-item.active {
  color: #ff6b35;
  font-weight: 500;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 2px;
  background: #ff6b35;
  border-radius: 1px;
}

/* 排序栏 */
.sort-bar {
  background: #fff;
  padding: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.sort-options {
  display: flex;
  gap: 20px;
}

.sort-item {
  display: flex;
  align-items: center;
  font-size: 14px;
  color: #666;
}

.sort-item.active {
  color: #ff6b35;
}

.sort-arrow {
  font-size: 10px;
  margin-left: 4px;
  color: #999;
}

/* 商品列表 */
.product-list {
  padding: 12px;
}

.product-card {
  background: #fff;
  border-radius: 12px;
  margin-bottom: 12px;
  overflow: hidden;
  display: flex;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

/* 商品图片 */
.product-image {
  width: 120px;
  height: 120px;
  position: relative;
  flex-shrink: 0;
}

.image {
  width: 100%;
  height: 100%;
}

.price-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  padding: 8px;
}

.price {
  color: #fff;
  font-size: 16px;
  font-weight: 600;
}

/* 商品信息 */
.product-info {
  flex: 1;
  padding: 12px;
  display: flex;
  flex-direction: column;
}

.product-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  font-size: 12px;
  color: #666;
  margin-bottom: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 价格信息 */
.price-info {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.original-price {
  font-size: 12px;
  color: #999;
  text-decoration: line-through;
}

.discount {
  background: #ff6b35;
  color: #fff;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
}

/* 商品标签 */
.product-tags {
  display: flex;
  gap: 4px;
  margin-bottom: 8px;
}

.tag {
  background: #fff3e0;
  color: #ff6b35;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
}

/* 卖家信息 */
.seller-info {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: auto;
}

.seller-avatar {
  width: 24px;
  height: 24px;
  border-radius: 12px;
}

.seller-details {
  flex: 1;
}

.seller-name {
  font-size: 12px;
  color: #333;
  display: block;
  margin-bottom: 2px;
}

.seller-rating {
  display: flex;
  align-items: center;
  gap: 2px;
}

.star {
  font-size: 10px;
  color: #ffd700;
}

.rating {
  font-size: 10px;
  color: #666;
}

.location-time {
  text-align: right;
}

.location {
  font-size: 10px;
  color: #666;
  display: block;
  margin-bottom: 2px;
}

.time {
  font-size: 10px;
  color: #999;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* 加载更多和空状态 */
.load-more {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 14px;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 14px;
  color: #999;
}

.loading-state {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 14px;
}

/* 发布按钮 */
.publish-btn {
  position: fixed;
  right: 20px;
  bottom: 20px;
  width: 56px;
  height: 56px;
  background: #ff6b35;
  border-radius: 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
  z-index: 100;
}

.publish-icon {
  font-size: 20px;
  color: #fff;
  font-weight: 600;
}

.publish-text {
  font-size: 10px;
  color: #fff;
  margin-top: 2px;
}
