.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center;position:relative}
.back{position:absolute;left:12px}
.title{font-size:18px;color:#333;font-weight:600}
.tools{position:absolute;right:12px}

.tabs{display:flex;justify-content:center;gap:40px;background:#fff;border-bottom:1px solid #eee}
.tab{padding:10px 0;color:#666}
.tab.active{color:#1677ff;font-weight:600;position:relative}
.tab.active::after{content:'';position:absolute;left:50%;bottom:0;transform:translateX(-50%);width:24px;height:2px;background:#1677ff;border-radius:1px}

.content{display:flex;height:calc(100vh - 44px - 44px)}
.cats{width:90px;background:#fff;border-right:1px solid #eee}
.cat{padding:12px 10px;color:#333}
.cat.active{color:#1677ff;background:#f6f9ff;border-left:2px solid #1677ff}
.goods{flex:1}
.swipe-item{position:relative;margin:10px;border-radius:8px;overflow:hidden;background:#fff}
.swipe-content{display:flex;align-items:center;padding:10px;background:#fff;transition:transform 0.3s ease;position:relative;z-index:2}
.thumb{width:54px;height:54px;border-radius:6px;margin-right:10px}
.meta{flex:1}
.name{color:#333}
.price{color:#ff4d4f;font-size:12px;margin-top:2px;display:block}
.swipe-actions{position:absolute;right:0;top:0;bottom:0;display:flex;z-index:1}
.action-btn{width:60px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px}
.action-btn.edit{background:#1677ff}
.action-btn.delete{background:#ff5959}
.add-wrap{padding:10px}
.add-btn{border:1px solid #1677ff;color:#1677ff;height:40px;border-radius:8px;display:flex;align-items:center;justify-content:center;background:#fff}

.empty-state{padding:40px 20px;text-align:center}
.empty-text{display:block;color:#666;font-size:14px;margin-bottom:8px}
.empty-desc{display:block;color:#999;font-size:12px}

