<!--pages/admin-order-detail/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBack">◀</view>
    <text class="title">订单详情</text>
    <view class="nav-actions"></view>
  </view>

  <scroll-view scroll-y class="content" wx:if="{{!loading}}">
    <!-- 订单状态 -->
    <view class="status-section">
      <view class="status-badge {{orderInfo.payStatus}}">
        <text class="status-text">{{orderInfo.statusText}}</text>
      </view>
      <text class="order-no">订单号：{{orderInfo.orderNo}}</text>
      <text class="order-time">下单时间：{{orderInfo.createdAt}}</text>
    </view>

    <!-- 店铺/用户信息 -->
    <view class="store-section">
      <image class="store-logo" 
             wx:if="{{orderInfo.isNonStoreOrder && orderInfo.userAvatar}}" 
             src="{{orderInfo.userAvatar}}" 
             mode="aspectFill"></image>
      <image class="store-logo" 
             wx:elif="{{orderInfo.isNonStoreOrder}}" 
             src="/pages/小标/wode.png" 
             mode="aspectFill"></image>
      <image class="store-logo" 
             wx:else 
             src="{{orderInfo.storeLogo}}" 
             mode="aspectFill"></image>
      <view class="store-info">
        <text class="store-name" wx:if="{{orderInfo.isNonStoreOrder}}">{{orderInfo.userNickname || '用户'}}</text>
        <text class="store-name" wx:else>{{orderInfo.storeName}}</text>
        <text class="store-address" wx:if="{{orderInfo.isNonStoreOrder}}">
          {{orderInfo.orderType === 'gaming' ? '游戏陪玩' : (orderInfo.orderType === 'reward' ? '悬赏' : '代拿快递')}}
        </text>
        <text class="store-address" wx:else>{{orderInfo.storeAddress}}</text>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="items-section">
      <view class="section-title">商品信息</view>
      <view class="items-list">
        <view class="item-row" wx:for="{{orderInfo.items}}" wx:key="id" wx:for-item="item">
          <view class="item-info">
            <text class="item-name">{{item.name || item.productName}}</text>
            <text class="item-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
          </view>
          <view class="item-right">
            <text class="item-quantity">x{{item.quantity || item.qty || 1}}</text>
            <text class="item-price">¥{{item.price}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 金额明细 -->
    <view class="amount-section">
      <view class="section-title">金额明细</view>
      <view class="amount-list">
        <view class="amount-row">
          <text class="amount-label">商品金额</text>
          <text class="amount-value">¥{{orderInfo.amountGoods}}</text>
        </view>
        <view class="amount-row">
          <text class="amount-label">配送费</text>
          <text class="amount-value">¥{{orderInfo.amountDelivery}}</text>
        </view>
        <view class="amount-row highlight">
          <text class="amount-label">平台服务费</text>
          <text class="amount-value">¥{{orderInfo.platformFee || '0.00'}}</text>
          <text class="amount-note">({{orderInfo.platformFeeRatePercent || 8}}%)</text>
        </view>
        <view class="amount-row highlight">
          <text class="amount-label">商家收入</text>
          <text class="amount-value">¥{{orderInfo.merchantIncome || '0.00'}}</text>
        </view>
        <view class="amount-row total">
          <text class="amount-label">实付金额</text>
          <text class="amount-value">¥{{orderInfo.amountPayable}}</text>
        </view>
      </view>
    </view>

    <!-- 退款信息 -->
    <view class="refund-section" wx:if="{{orderInfo.refundInfo}}">
      <view class="section-title">退款信息</view>
      <view class="refund-content">
        <view class="refund-row">
          <text class="refund-label">退款状态：</text>
          <text class="refund-status {{orderInfo.refundInfo.status}}">{{orderInfo.refundInfo.refundStatusText}}</text>
        </view>
        <view class="refund-row" wx:if="{{orderInfo.refundInfo.refundNo}}">
          <text class="refund-label">退款单号：</text>
          <text class="refund-value">{{orderInfo.refundInfo.refundNo}}</text>
        </view>
        <view class="refund-row">
          <text class="refund-label">退款金额：</text>
          <text class="refund-value highlight">¥{{orderInfo.refundInfo.refundAmount}}</text>
        </view>
        <view class="refund-row" wx:if="{{orderInfo.refundInfo.createdAt}}">
          <text class="refund-label">申请时间：</text>
          <text class="refund-value">{{orderInfo.refundInfo.createdAt}}</text>
        </view>
        <view class="refund-row" wx:if="{{orderInfo.refundInfo.completedAt}}">
          <text class="refund-label">完成时间：</text>
          <text class="refund-value">{{orderInfo.refundInfo.completedAt}}</text>
        </view>
        <view class="refund-actions" wx:if="{{orderInfo.refundInfo.refundId}}">
          <button class="refund-detail-btn" bindtap="onViewRefundDetail">查看退款详情</button>
        </view>
      </view>
    </view>

    <!-- 配送信息 -->
    <view class="delivery-section" wx:if="{{orderInfo.address}}">
      <view class="section-title">配送信息</view>
      <view class="delivery-content">
        <view class="delivery-row" wx:if="{{orderInfo.address.name}}">
          <text class="delivery-label">联系人：</text>
          <text class="delivery-value">{{orderInfo.address.name}}</text>
        </view>
        <view class="delivery-row" wx:if="{{orderInfo.address.phone}}">
          <text class="delivery-label">联系电话：</text>
          <text class="delivery-value">{{orderInfo.address.phone}}</text>
        </view>
        <view class="delivery-row">
          <text class="delivery-label">配送地址：</text>
          <text class="delivery-value" wx:if="{{!showAddressDetails}}">
            {{orderInfo.addressText || (orderInfo.address.buildingName || '') + (orderInfo.address.houseNumber || '') + (orderInfo.address.addressDetail || orderInfo.address.address || '')}}
          </text>
          <view class="delivery-value" wx:else>
            <view class="address-detail-line" wx:if="{{orderInfo.address.buildingName}}">
              <text class="detail-label">楼栋名：</text>
              <text class="detail-value">{{orderInfo.address.buildingName}}</text>
            </view>
            <view class="address-detail-line" wx:if="{{orderInfo.address.houseNumber}}">
              <text class="detail-label">门牌号：</text>
              <text class="detail-value">{{orderInfo.address.houseNumber}}</text>
            </view>
            <view class="address-detail-line" wx:if="{{orderInfo.address.addressDetail || orderInfo.address.address}}">
              <text class="detail-label">详细地址：</text>
              <text class="detail-value">{{orderInfo.address.addressDetail || orderInfo.address.address}}</text>
            </view>
          </view>
        </view>
        <view class="view-more" bindtap="onToggleAddressDetails" wx:if="{{orderInfo.address}}">
          <text>{{showAddressDetails ? '收起^' : '查看更多 ∨'}}</text>
        </view>
      </view>
    </view>

    <!-- 备注信息 -->
    <view class="remark-section" wx:if="{{orderInfo.remark}}">
      <view class="section-title">备注信息</view>
      <view class="remark-content">
        <text class="remark-text">{{orderInfo.remark}}</text>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="order-info-section">
      <view class="section-title">订单信息</view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">订单号</text>
          <view class="info-value-wrapper">
            <text class="info-value">{{orderInfo.orderNo}}</text>
            <text class="copy-btn" catchtap="onCopyOrderNo">复制</text>
          </view>
        </view>
        <view class="info-row">
          <text class="info-label">订单类型</text>
          <text class="info-value">
            {{orderInfo.orderType === 'gaming' ? '游戏陪玩' : (orderInfo.orderType === 'reward' ? '悬赏' : (orderInfo.orderType === 'express' ? '代拿快递' : '普通订单'))}}
          </text>
        </view>
        <view class="info-row">
          <text class="info-label">支付状态</text>
          <text class="info-value">{{orderInfo.payStatus === 'paid' ? '已支付' : '未支付'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">订单状态</text>
          <text class="info-value">{{orderInfo.statusText}}</text>
        </view>
        <view class="info-row" wx:if="{{orderInfo.refundStatus}}">
          <text class="info-label">退款状态</text>
          <text class="info-value">{{orderInfo.refundStatus === 'refunding' ? '退款中' : (orderInfo.refundStatus === 'refunded' ? '已退款' : '无退款')}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>

