.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.status-bar {
  width: 100%;
  background: #fff;
}

.nav-bar {
  height: 44px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
}

.nav-left {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 24px;
  color: #333;
  font-weight: 300;
}

.nav-title {
  font-size: 18px;
  color: #333;
  font-weight: 600;
}

.nav-right {
  width: 44px;
}

.content {
  padding: 16px;
  min-height: calc(100vh - 44px - env(safe-area-inset-bottom));
}

.announcement-section {
  margin-bottom: 20px;
}

.textarea-container {
  position: relative;
  background: #fff;
  border: 1px solid #1677ff;
  border-radius: 8px;
  padding: 16px;
  min-height: 200px;
}

.announcement-textarea {
  width: 100%;
  min-height: 180px;
  font-size: 16px;
  color: #333;
  line-height: 1.5;
  border: none;
  outline: none;
  resize: none;
  background: transparent;
}

.announcement-textarea::placeholder {
  color: #c0c4cc;
  font-size: 16px;
}

.char-counter {
  position: absolute;
  bottom: 8px;
  right: 12px;
  font-size: 12px;
  color: #c0c4cc;
  background: #fff;
  padding: 2px 4px;
  border-radius: 4px;
}

.confirm-section {
  margin-top: 20px;
}

.confirm-btn {
  width: 100%;
  height: 48px;
  background: #dcdcdc;
  color: #666;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 500;
  transition: all 0.3s ease;
  cursor: pointer;
}

.confirm-btn.active {
  background: #1677ff;
  color: #fff;
}

.confirm-btn.active:active {
  background: #0d5fcc;
  transform: scale(0.98);
}
