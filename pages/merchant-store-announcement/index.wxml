<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="nav-title">店铺公告</view>
    <view class="nav-right"></view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 公告输入区域 -->
    <view class="announcement-section">
      <view class="textarea-container">
        <textarea 
          class="announcement-textarea"
          placeholder="请输入公告"
          value="{{announcementText}}"
          bindinput="onTextInput"
          maxlength="200"
          auto-height
          show-confirm-bar="{{false}}"
        ></textarea>
        <view class="char-counter">{{announcementText.length}}/200</view>
      </view>
    </view>

    <!-- 确定按钮 -->
    <view class="confirm-section">
      <view class="confirm-btn {{announcementText.length > 0 ? 'active' : ''}}" bindtap="saveAnnouncement">
        确定
      </view>
    </view>
  </view>
</view>
