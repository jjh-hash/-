.user-login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffb800 0%, #f5f6f8 42%);
  box-sizing: border-box;
  padding: 0 32rpx 48rpx;
}

.status-bar-spacer {
  width: 100%;
}

.hero {
  padding: 72rpx 0 56rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.sub {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.5;
}

.actions {
  margin-top: 48rpx;
}

.btn-primary {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: #fff !important;
  color: #b37400 !important;
  font-size: 32rpx;
  font-weight: 600;
  border: none !important;
}

.btn-primary::after {
  border: none;
}

.btn-text {
  margin-top: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 16rpx;
}
