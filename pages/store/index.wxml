<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px">
  </view>

  <!-- 返回按钮 -->
  <view class="back-header">
    <view class="back-btn" bindtap="onBackTap">
      <text class="back-icon">←</text>
    </view>
  </view>

  <!-- 店铺信息头部 -->
  <view class="store-header">
    <view class="store-info">
      <view class="store-name">{{storeInfo.name}}</view>
      <view class="delivery-info">
        {{storeInfo.deliveryTime}}·起送¥{{storeInfo.minOrder}}·配送¥{{storeInfo.deliveryFee}}
      </view>
      <view class="announcement">公告: {{storeInfo.announcement}}</view>
    </view>
    <view class="store-logo">
      <view class="logo-content">
        <text class="brand-text">品牌</text>
        <text class="store-text">河工零食</text>
      </view>
    </view>
  </view>

  <!-- 配送时间条 -->
  <view class="delivery-bar">
    <text class="delivery-text">现在预订, 10:30开始配送</text>
  </view>

  <!-- 导航标签 -->
  <view class="nav-tabs">
    <block wx:for="{{tabs}}" wx:key="index">
      <view 
        class="tab-item {{index === activeTab ? 'active' : ''}}"
        bindtap="onTabTap"
        data-index="{{index}}"
      >
        {{item}}
      </view>
    </block>
    <view class="sort-option" bindtap="onSortTap">
      <text class="sort-text">销量 | 价格</text>
      <text class="sort-arrow">▼</text>
    </view>
  </view>

  <view class="main-content">
    <!-- 左侧分类 -->
    <view class="category-sidebar">
      <block wx:for="{{categories}}" wx:key="id">
        <view 
          class="category-item {{index === activeCategory ? 'active' : ''}}"
          bindtap="onCategoryTap"
          data-index="{{index}}"
        >
          {{item.name}}
        </view>
      </block>
    </view>

    <!-- 右侧商品列表 -->
    <view class="product-content">
      <view class="category-title">{{categories[activeCategory].name}}</view>
      <view class="product-list">
        <block wx:for="{{products}}" wx:key="id" wx:if="{{item.category === activeCategory}}">
          <view class="product-item">
            <image class="product-image" src="{{item.image}}" mode="aspectFill" />
            <view class="product-info">
              <view class="product-name">{{item.name}}</view>
              <view class="product-desc" wx:if="{{item.description}}">{{item.description}}</view>
              <view class="product-tags" wx:if="{{item.tags.length > 0}}">
                <block wx:for="{{item.tags}}" wx:key="*this">
                  <view class="tag {{index === 0 && item === '8.67折' ? 'discount' : ''}} {{item === '超级会员专享' ? 'member' : ''}} {{item === '特价商品' ? 'special' : ''}}">{{item}}</view>
                </block>
              </view>
              <view class="product-stats">
                <text class="sales">已售{{item.sales}}</text>
                <text class="likes">赞{{item.likes}}</text>
              </view>
              <view class="product-price">
                <text class="current-price">¥{{item.price}}</text>
                <text class="original-price" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
                <text class="unit" wx:if="{{item.name.includes('24瓶')}}">/件</text>
              </view>
            </view>
            <view class="add-btn" bindtap="onAddToCart" data-id="{{item.id}}">
              <text class="add-icon">+</text>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- 底部购物车 -->
  <view class="cart-bar">
    <view class="cart-info">
      <view class="cart-icon">🛒</view>
      <text class="cart-text" wx:if="{{cartItems.length === 0}}">购物车空空如也~~</text>
      <text class="cart-text" wx:else>共{{cartItems.length}}件商品</text>
    </view>
    <view class="min-order">¥{{storeInfo.minOrder}}起送</view>
  </view>
</view>
