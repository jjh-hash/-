/* 页面基础样式 */
.page {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 状态栏 */
.status-bar {
  background: #fff;
  padding: 0 12px;
}

/* 返回按钮 */
.back-header {
  background: #fff;
  padding: 8px 16px;
  border-bottom: 1px solid #f0f0f0;
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 18px;
  color: #333;
}

/* 店铺信息头部 */
.store-header {
  background: #fff;
  padding: 16px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.store-info {
  flex: 1;
}

.store-name {
  font-size: 20px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.delivery-info {
  font-size: 12px;
  color: #666;
  margin-bottom: 4px;
}

.announcement {
  font-size: 12px;
  color: #999;
}

.store-logo {
  width: 60px;
  height: 60px;
  background: #ff4757;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.logo-content {
  text-align: center;
}

.brand-text {
  font-size: 10px;
  color: #fff;
  display: block;
  margin-bottom: 4px;
}

.store-text {
  font-size: 12px;
  color: #fff;
  font-weight: 600;
  writing-mode: vertical-rl;
  text-orientation: mixed;
}

/* 配送时间条 */
.delivery-bar {
  background: #ff8c00;
  padding: 8px 16px;
  text-align: center;
}

.delivery-text {
  color: #fff;
  font-size: 14px;
}

/* 导航标签 */
.nav-tabs {
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 16px;
  border-bottom: 1px solid #f0f0f0;
}

.tab-item {
  padding: 12px 16px;
  font-size: 14px;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #ff4757;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 2px;
  background: #ff4757;
  border-radius: 1px;
}

.sort-option {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 12px 0;
}

.sort-text {
  font-size: 12px;
  color: #666;
}

.sort-arrow {
  font-size: 10px;
  color: #999;
}

/* 主内容区域 */
.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类 */
.category-sidebar {
  width: 80px;
  background: #fff;
  border-right: 1px solid #f0f0f0;
  overflow-y: auto;
}

.category-item {
  padding: 16px 8px;
  font-size: 12px;
  color: #666;
  text-align: center;
  border-bottom: 1px solid #f8f9fa;
  position: relative;
}

.category-item.active {
  color: #ff4757;
  background: #fff5f5;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: #ff4757;
}

/* 右侧商品内容 */
.product-content {
  flex: 1;
  background: #fff;
  overflow-y: auto;
}

.category-title {
  padding: 12px 16px;
  font-size: 14px;
  font-weight: 600;
  color: #333;
  border-bottom: 1px solid #f0f0f0;
}

.product-list {
  padding: 8px;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 12px;
  border-bottom: 1px solid #f8f9fa;
}

.product-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  margin-right: 12px;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.product-name {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.product-desc {
  font-size: 12px;
  color: #666;
}

.product-tags {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
}

.tag {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
  background: #f0f0f0;
  color: #666;
}

.tag.discount {
  background: #8b5cf6;
  color: #fff;
}

.tag.member {
  background: #ffd700;
  color: #333;
}

.tag.special {
  background: #ff4757;
  color: #fff;
}

.product-stats {
  display: flex;
  gap: 8px;
  font-size: 10px;
  color: #999;
}

.sales {
  color: #999;
}

.likes {
  color: #999;
}

.product-price {
  display: flex;
  align-items: center;
  gap: 4px;
}

.current-price {
  font-size: 16px;
  font-weight: 600;
  color: #ff4757;
}

.original-price {
  font-size: 12px;
  color: #999;
  text-decoration: line-through;
}

.unit {
  font-size: 12px;
  color: #666;
}

.add-btn {
  width: 32px;
  height: 32px;
  background: #ff4757;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.add-icon {
  color: #fff;
  font-size: 18px;
  font-weight: 600;
}

/* 底部购物车 */
.cart-bar {
  background: #333;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #fff;
}

.cart-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.cart-icon {
  font-size: 20px;
}

.cart-text {
  font-size: 14px;
  color: #fff;
}

.min-order {
  font-size: 14px;
  color: #fff;
}
