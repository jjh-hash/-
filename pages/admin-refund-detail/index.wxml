<!--pages/admin-refund-detail/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBack">◀</view>
    <text class="title">退款详情</text>
    <view class="nav-actions"></view>
  </view>

  <scroll-view scroll-y class="content" wx:if="{{!loading && refundInfo}}">
    <!-- 退款状态 -->
    <view class="status-section">
      <view class="status-badge {{refundInfo.status}}">
        <text class="status-text">{{refundInfo.statusText}}</text>
      </view>
    </view>

    <!-- 退款基本信息 -->
    <view class="section">
      <view class="section-title">退款信息</view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">退款单号</text>
          <text class="info-value">{{refundInfo.refundNo}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">退款金额</text>
          <text class="info-value highlight">¥{{refundInfo.refundAmount}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">退款原因</text>
          <text class="info-value">{{refundInfo.refundReason || '未填写'}}</text>
        </view>
        <view class="info-row" wx:if="{{refundInfo.refundReasonText}}">
          <text class="info-label">原因描述</text>
          <text class="info-value">{{refundInfo.refundReasonText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">申请时间</text>
          <text class="info-value">{{refundInfo.createdAt}}</text>
        </view>
        <view class="info-row" wx:if="{{refundInfo.approvedAt}}">
          <text class="info-label">同意时间</text>
          <text class="info-value">{{refundInfo.approvedAt}}</text>
        </view>
        <view class="info-row" wx:if="{{refundInfo.rejectedAt}}">
          <text class="info-label">拒绝时间</text>
          <text class="info-value">{{refundInfo.rejectedAt}}</text>
        </view>
        <view class="info-row" wx:if="{{refundInfo.completedAt}}">
          <text class="info-label">完成时间</text>
          <text class="info-value">{{refundInfo.completedAt}}</text>
        </view>
        <view class="info-row" wx:if="{{refundInfo.remark}}">
          <text class="info-label">备注</text>
          <text class="info-value">{{refundInfo.remark}}</text>
        </view>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="section" wx:if="{{orderInfo}}">
      <view class="section-title">关联订单</view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">订单号</text>
          <text class="info-value">{{orderInfo.orderNo}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">订单金额</text>
          <text class="info-value">¥{{orderInfo.amountPayable}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">下单时间</text>
          <text class="info-value">{{orderInfo.createdAt}}</text>
        </view>
      </view>
    </view>

    <!-- 退款商品 -->
    <view class="section" wx:if="{{refundInfo.selectedItems && refundInfo.selectedItems.length > 0}}">
      <view class="section-title">退款商品</view>
      <view class="items-list">
        <view class="item-row" wx:for="{{refundInfo.selectedItems}}" wx:key="id" wx:for-item="item">
          <image class="item-image" src="{{item.image || '/pages/小标/商家.png'}}" mode="aspectFill" />
          <view class="item-info">
            <text class="item-name">{{item.productName}}</text>
            <text class="item-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
          </view>
          <view class="item-right">
            <text class="item-quantity">x{{item.quantity}}</text>
            <text class="item-price">¥{{item.price}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 退款凭证 -->
    <view class="section" wx:if="{{refundInfo.images && refundInfo.images.length > 0}}">
      <view class="section-title">退款凭证</view>
      <view class="images-container">
        <image 
          class="refund-image" 
          wx:for="{{refundInfo.images}}" 
          wx:key="index"
          wx:for-item="img"
          src="{{img}}" 
          mode="aspectFill"
          bindtap="onPreviewImage"
          data-index="{{index}}" />
      </view>
    </view>
  </scroll-view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>

