<view class="page">

  <scroll-view scroll-y class="content">
    <!-- 店铺评分 -->
    <view class="rating-section">
      <view class="rating-left">
        <view class="overall-rating">{{storeInfo.overallRating}}</view>
        <view class="stars">
          <text class="star {{storeInfo.ratingStars[index] ? 'filled' : 'empty'}}" wx:for="{{5}}" wx:key="index">★</text>
        </view>
        <view class="rating-text">商品质量 共{{storeInfo.totalReviews}}人点评</view>
      </view>
      <view class="rating-right">
        <view class="delivery-rating">{{storeInfo.deliveryRating}}</view>
        <view class="delivery-text">配送服务</view>
      </view>
    </view>

    <!-- 评价列表 -->
    <view class="reviews-section">
      <block wx:for="{{reviews}}" wx:key="id">
        <view class="review-item">
          <!-- 用户信息 -->
          <view class="user-info">
            <image class="user-avatar" src="{{item.userAvatar}}" mode="aspectFill" />
            <view class="user-details">
              <view class="user-name">{{item.userName}}</view>
              <view class="user-rating">
                <text class="star {{starItem ? 'filled' : 'empty'}}" wx:for="{{item.stars}}" wx:for-item="starItem" wx:key="index">★</text>
              </view>
            </view>
            <view class="review-date">{{item.date}}</view>
          </view>

          <!-- 评价内容 -->
          <view class="review-content">{{item.content}}</view>

          <!-- 评价图片 -->
          <view class="review-images" wx:if="{{item.images && item.images.length > 0}}">
            <image class="review-image" 
                   wx:for="{{item.images}}" 
                   wx:for-item="img"
                   wx:key="index"
                   src="{{img}}" 
                   mode="aspectFill"
                   data-images="{{item.images}}"
                   data-index="{{index}}"
                   bindtap="onImageTap" />
          </view>

          <!-- 商家回复 -->
          <view class="merchant-reply" wx:if="{{item.hasMerchantReply && item.merchantReply}}">
            <view class="merchant-reply-label">商家回复：</view>
            <view class="merchant-reply-content">{{item.merchantReply}}</view>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- 底部发表评论按钮 -->
  <view class="submit-review-btn-container">
    <button class="submit-review-btn" bindtap="onSubmitReviewTap">
      <text class="btn-icon">✎</text>
      <text class="btn-text">发表评论</text>
    </button>
  </view>
</view>
