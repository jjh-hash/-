<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px">
  </view>

  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBackTap">
      <text class="back-icon">←</text>
    </view>
    <text class="title">取快递</text>
    <view class="nav-actions">
      <text class="more-btn">⋯</text>
      <text class="target-btn">🎯</text>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 横幅 -->
    <view class="banner">
      <view class="banner-content">
        <view class="banner-text">
          <text class="banner-subtitle">QUKUAIDI</text>
          <text class="banner-title">取快递</text>
        </view>
        <view class="ribbon">
          <text class="ribbon-text">优质服务等你来!</text>
        </view>
        <view class="package-icon">
          <view class="package-body">
            <view class="package-top"></view>
            <view class="package-lines">
              <view class="line"></view>
              <view class="line"></view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 取件位置 -->
    <view class="form-section">
      <view class="section-header">
        <view class="section-icon location-icon">📍</view>
        <text class="section-title">{{pickupLocation || '请选择一个位置'}}</text>
        <view class="arrow" bindtap="onPickupLocationTap">></view>
      </view>
    </view>

    <!-- 送达位置 -->
    <view class="form-section">
      <view class="section-header">
        <view class="section-icon delivery-icon">终</view>
        <text class="section-title">{{deliveryLocation || '送到哪里'}}</text>
        <view class="arrow" bindtap="onDeliveryLocationTap">></view>
      </view>
    </view>

    <!-- 收货地址 -->
    <view class="form-section">
      <view class="section-header" bindtap="onSelectAddress">
        <view class="section-icon address-icon">📍</view>
        <view class="section-content">
          <text class="section-title">收货地址</text>
          <text class="address-text" wx:if="{{address}}">{{address.buildingName || ''}}{{address.houseNumber || ''}}{{address.addressDetail || ''}}</text>
          <text class="address-placeholder" wx:else>请选择收货地址</text>
        </view>
        <view class="arrow">></view>
      </view>
    </view>

    <!-- 包裹类型选择 -->
    <view class="form-section">
      <view class="package-list">
        <block wx:for="{{packageSizes}}" wx:key="id">
          <view class="package-item">
            <view class="package-info">
              <view class="package-icon-item">📦</view>
              <view class="package-details">
                <text class="package-name">{{item.name}}</text>
                <text class="package-description">{{item.description}}</text>
                <text class="package-price">¥{{item.price}}</text>
              </view>
            </view>
            <view class="package-actions">
              <view class="quantity-control" wx:if="{{item.selected}}">
                <view class="quantity-btn" bindtap="onRemovePackage" data-id="{{item.id}}">-</view>
                <text class="quantity-text">{{item.quantity}}</text>
                <view class="quantity-btn" bindtap="onAddPackage" data-id="{{item.id}}">+</view>
              </view>
              <view class="add-btn" wx:else bindtap="onAddPackage" data-id="{{item.id}}">
                <text class="add-icon">+</text>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 图片上传 -->
    <view class="form-section">
      <view class="section-header">
        <view class="section-icon image-icon">🏞️</view>
        <text class="section-title">图片上传({{uploadedImages.length}}/{{maxImages}})</text>
        <text class="optional">最多上传3张图片</text>
      </view>
      <view class="image-upload">
        <view class="upload-btn" bindtap="onUploadImage">
          <text class="plus-icon">+</text>
        </view>
        <block wx:for="{{uploadedImages}}" wx:key="index">
          <view class="uploaded-image">
            <image class="image" src="{{item}}" mode="aspectFill" />
            <view class="delete-btn" bindtap="onDeleteImage" data-index="{{index}}">
              <text class="delete-icon">×</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 取件码 -->
    <view class="form-section">
      <view class="section-header">
        <view class="section-icon code-icon">🔍</view>
        <text class="section-title">取件码</text>
      </view>
      <input 
        class="pickup-code-input" 
        placeholder="输入取件码或粘贴取件短信" 
        placeholder-class="code-placeholder"
        value="{{pickupCode}}"
        bindinput="onPickupCodeInput"
      />
    </view>

    <!-- 总价显示 -->
    <view class="total-price" wx:if="{{totalPrice > 0}}">
      <text class="total-text">总计: ¥{{totalPrice}}</text>
    </view>

    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 下单按钮 -->
  <view class="order-btn-container">
    <view class="order-btn" bindtap="onPlaceOrder">
      <text class="order-text">立即下单</text>
    </view>
  </view>
</view>
