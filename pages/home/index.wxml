<view class="page">
  <announcement-modal
    id="announcementModal"
    announcement="{{announcement}}"
    show="{{showAnnouncement}}"
    bind:close="onCloseAnnouncement"
  ></announcement-modal>
  
  <scroll-view scroll-y class="content" style="height: {{scrollViewHeight}}px;" lower-threshold="120" bindscrolltolower="onHomeScrollToLower">
    <!-- 沉浸式顶部：轮播图延伸至状态栏 -->
    <view class="header-area header-immersive">
      <!-- 轮播图 -->
      <view class="carousel-wrap" wx:if="{{banners.length > 0}}">
        <swiper class="banner-swiper" indicator-dots="{{true}}" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff" autoplay="{{true}}" interval="{{3500}}" duration="{{400}}" circular="{{true}}">
          <block wx:for="{{banners}}" wx:key="index">
            <swiper-item>
              <view class="banner-item" bindtap="onBannerTap" data-link="{{item.linkUrl}}" style="{{item.imageUrl || item.img ? '' : 'background:' + (item.bg || 'linear-gradient(135deg,#FFB800,#F59E0B)')}}">
                <image wx:if="{{item.imageUrl || item.img}}" class="banner-image" src="{{item.imageUrl || item.img}}" mode="aspectFill" lazy-load />
                <view wx:else class="banner-placeholder">
                  <text class="banner-title">{{item.title || '精彩活动'}}</text>
                  <text class="banner-subtitle">{{item.subtitle || ''}}</text>
                </view>
              </view>
            </swiper-item>
          </block>
        </swiper>
      </view>
      <view class="carousel-placeholder" wx:else>
        <text class="carousel-placeholder-text">精彩活动即将上线</text>
      </view>

      <!-- 悬浮问候语（随时段变色，避开状态栏） -->
      <view class="hero-float" style="top: {{statusBarHeight + 12}}px;">
        <text class="hero-greeting" style="color: {{greetingColor}}">{{greeting}}</text>
        <text class="hero-slogan" style="color: {{greetingSloganColor}}">校园生活，触手可及</text>
      </view>

      <!-- 悬浮搜索栏 -->
      <view class="search-float">
        <view class="search ds-press">
          <view class="search-icon-wrap">
            <text class="search-icon">搜</text>
          </view>
          <input 
            class="input" 
            placeholder="搜店铺名…" 
            placeholder-class="ph" 
            value="{{searchKeyword}}"
            bindinput="onSearchInput"
            bindconfirm="onSearchSubmit"
            bindfocus="onSearchFocus"
            confirm-type="search"
          />
          <view class="clear-btn" wx:if="{{searchKeyword}}" bindtap="onClearSearch">
            <text class="clear-icon">×</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 常用服务：标题与校区切换同一行，校区在右侧横向排列 -->
    <view class="section service-section">
      <view class="service-section-header">
        <view class="section-title service-section-title">
          <text class="section-dot section-dot-red"></text>
          <text>常用服务</text>
        </view>
        <view class="campus-switch-inline">
          <text class="campus-switch-inline-label">校区</text>
          <view class="campus-switch-inline-btns">
            <view
              class="campus-switch-inline-btn {{currentCampus === '白沙校区' ? 'active' : ''}}"
              hover-class="campus-switch-inline-btn-hover"
              hover-stay-time="80"
              bindtap="onCampusChange"
              data-campus="白沙校区"
            >白沙</view>
            <view
              class="campus-switch-inline-btn {{currentCampus === '金水校区' ? 'active' : ''}}"
              hover-class="campus-switch-inline-btn-hover"
              hover-stay-time="80"
              bindtap="onCampusChange"
              data-campus="金水校区"
            >金水</view>
          </view>
        </view>
      </view>
      <view class="service-cards">
        <view class="service-row">
          <view class="service-main service-main-bg ds-press" bindtap="onServiceTap" data-key="reward">
            <image class="service-main-bg-img" src="{{cloudImages.serviceFlashBg}}" mode="aspectFill" lazy-load />
            <view class="service-main-content">
              <view class="service-main-icon">⚡</view>
              <text class="service-main-label">极速跑腿</text>
              <text class="service-main-desc">平均12min 送达</text>
            </view>
          </view>
          <view class="service-col">
            <view class="service-small service-small-with-img service-bg-express ds-press" bindtap="onServiceTap" data-key="express">
              <view class="service-small-text">
                <text class="service-small-title">代拿快递</text>
                <text class="service-small-desc">20+待接单</text>
              </view>
              <image class="service-small-img" src="{{cloudImages.expressIcon}}" mode="aspectFit" lazy-load />
            </view>
            <view class="service-small service-small-with-img service-bg-secondhand ds-press" bindtap="onServiceTap" data-key="secondhand">
              <view class="service-small-text">
                <text class="service-small-title">跳蚤市场</text>
                <text class="service-small-desc">发现好物</text>
              </view>
              <image class="service-small-img" src="{{cloudImages.secondhandIcon}}" mode="aspectFit" lazy-load />
            </view>
          </view>
        </view>
        <!-- 审核期先隐藏游戏搭子入口，后续按需恢复
        <view class="service-bottom service-bg-gaming ds-press" bindtap="onServiceTap" data-key="gaming">
          <view class="service-bottom-left">
            <image class="service-bottom-icon-img" src="{{cloudImages.gamingIcon}}" mode="aspectFit" lazy-load />
            <view class="service-bottom-text">
              <text class="service-bottom-title">游戏陪玩</text>
              <text class="service-bottom-desc">找搭子组队开黑，不再孤单</text>
            </view>
          </view>
          <view class="service-bottom-link-wrap">
            <text class="service-bottom-link">去看看</text>
            <text class="service-bottom-arrow">›</text>
          </view>
        </view>
        -->
      </view>
    </view>

    <!-- 筛选栏：当前校区胶囊在上；下一行「今日推荐」单行 + 排序；再下为分类 -->
    <view class="filters-wrap">
      <text class="filters-campus-pill filters-campus-pill-above">{{currentCampus}}</text>
      <view class="filters-header-row">
        <view class="filters-title-block">
          <view class="section-title-inline filters-title-one-line">
            <text class="section-dot"></text>
            <text>推荐店铺</text>
          </view>
        </view>
        <view class="filters-capsule">
          <block wx:for="{{filters}}" wx:key="*this">
            <view 
              class="f-item {{index===activeFilter? 'active':''}}" 
              bindtap="onFilterTap" 
              data-index="{{index}}"
            >{{item}}</view>
          </block>
        </view>
      </view>
      <!-- 分类横向滚动，右侧箭头提示可滑动 -->
      <scroll-view scroll-x class="category-bar" scroll-with-animation>
        <view class="category-scroll">
          <block wx:for="{{categoryOptions}}" wx:key="key">
            <view 
              class="category-item {{item.key === activeCategoryKey ? 'active' : ''}} {{item.key === '其他' ? 'category-item-with-arrow' : ''}}" 
              bindtap="onCategoryTap" 
              data-key="{{item.key}}"
            >{{item.label}}</view>
          </block>
        </view>
      </scroll-view>
    </view>

    <!-- 搜索无结果 -->
    <view class="empty-state ds-fade-in" wx:if="{{!productListLoading && searchKeyword && originalProducts.length === 0}}">
      <view class="ds-empty-icon-wrap"><text class="ds-empty-icon-char">搜</text></view>
      <text class="empty-text">未找到相关店铺</text>
      <text class="empty-tip">换个词或分类试试</text>
      <view class="empty-btn ds-press" bindtap="onClearSearch">
        <text>清空搜索</text>
      </view>
    </view>

    <view wx:else>
      <!-- 骨架屏 -->
      <view class="shop-list-section" wx:if="{{productListLoading}}">
        <view class="shop-list shop-skeleton-list shop-skeleton-overlay">
          <block wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
            <view class="shop shop-skeleton">
              <view class="cover ds-skeleton" style="width:88px;height:66px;border-radius:var(--radius-btn);"></view>
              <view class="meta">
                <view class="ds-skeleton-line" style="width:80%;margin-bottom:8px;"></view>
                <view class="ds-skeleton-line" style="width:50%;margin-bottom:6px;"></view>
                <view class="ds-skeleton-line" style="width:60%;"></view>
              </view>
            </view>
          </block>
        </view>
      </view>
      
      <!-- 瀑布流布局 -->
      <view class="shop-list-section" wx:elif="{{originalProducts.length > 0}}">
        <view class="shop-waterfall-wrap ds-fade-in">
          <view class="shop-waterfall-row">
            <!-- 左列 -->
            <view class="shop-waterfall-col">
              <block wx:for="{{displayProductsLeft}}" wx:key="listKey">
                <view class="shop-card shop-card-store ds-fade-in" bindtap="onStoreTap" data-store-id="{{item.storeId}}">
                  <view class="shop-card-cover">
                    <image class="shop-card-img" src="{{item.logo}}" mode="aspectFill" lazy-load binderror="onImageError" data-id="{{item._id}}" />
                    <view class="shop-card-store-tag">店铺</view>
                  </view>
                  <view class="shop-card-meta">
                    <text class="product-card-name ellipsis">{{item.name}}</text>
                    <text class="product-store-name product-store-name-top" wx:if="{{item.productCount > 0}}">在售 {{item.productCount}} 款</text>
                    <view class="product-card-row2">
                      <text class="product-store-name">起送¥{{item.minOrderAmount}} · 配送¥{{item.deliveryFee}}</text>
                      <text class="shop-card-store-entry">进店 ›</text>
                    </view>
                  </view>
                </view>
              </block>
            </view>
            
            <!-- 右列 -->
            <view class="shop-waterfall-col">
              <block wx:for="{{displayProductsRight}}" wx:key="listKey">
                <view class="shop-card shop-card-store ds-fade-in" bindtap="onStoreTap" data-store-id="{{item.storeId}}">
                  <view class="shop-card-cover">
                    <image class="shop-card-img" src="{{item.logo}}" mode="aspectFill" lazy-load binderror="onImageError" data-id="{{item._id}}" />
                    <view class="shop-card-store-tag">店铺</view>
                  </view>
                  <view class="shop-card-meta">
                    <text class="product-card-name ellipsis">{{item.name}}</text>
                    <text class="product-store-name product-store-name-top" wx:if="{{item.productCount > 0}}">在售 {{item.productCount}} 款</text>
                    <view class="product-card-row2">
                      <text class="product-store-name">起送¥{{item.minOrderAmount}} · 配送¥{{item.deliveryFee}}</text>
                      <text class="shop-card-store-entry">进店 ›</text>
                    </view>
                  </view>
                </view>
              </block>
            </view>
          </view>
          <view class="load-more-footer">
            <text wx:if="{{hasMoreProducts}}">上拉加载更多</text>
            <text wx:else>— 没有更多了 —</text>
          </view>
        </view>
      </view>
      
      <!-- 空状态 -->
      <view class="shop-list-section" wx:else>
        <view class="empty-state ds-fade-in">
          <view class="ds-empty-icon-wrap"><text class="ds-empty-icon-char">菜</text></view>
          <text class="empty-text">暂无店铺</text>
        </view>
      </view>
    </view>
    <view class="safe-area-bottom"></view>
  </scroll-view>
</view>
