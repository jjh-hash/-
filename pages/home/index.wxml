<view class="page">
  <!-- 公告弹窗组件 -->
  <announcement-modal id="announcementModal" announcement="{{announcement}}" show="{{showAnnouncement}}" bind:close="onCloseAnnouncement" />
  
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <text class="title">外卖</text>
      <view class="icons">
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 搜索框 -->
    <view class="search">
      <text class="icon">🔍</text>
      <input 
        class="input" 
        placeholder="输入你想要的东西" 
        placeholder-class="ph" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchSubmit"
        bindfocus="onSearchFocus"
        confirm-type="search"
      />
      <view class="clear-btn" wx:if="{{searchKeyword}}" bindtap="onClearSearch">
        <text class="clear-icon">×</text>
      </view>
    </view>

    <!-- 快捷分类 -->
    <view class="quick">
      <block wx:for="{{quickCats}}" wx:key="index">
        <view class="q-item" bindtap="onQuickCatTap" data-index="{{index}}">
          <view class="q-icon" style="background: {{item.bg}}">
            <text class="q-emoji">{{item.emoji}}</text>
          </view>
          <text class="q-text">{{item.text}}</text>
        </view>
      </block>
    </view>

    <!-- 轮播图 -->
    <swiper class="banner-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="{{3000}}" duration="{{500}}">
      <block wx:for="{{banners}}" wx:key="_id">
        <swiper-item>
          <view class="banner-item" bindtap="onBannerTap" data-link="{{item.linkUrl}}">
            <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill" />
          </view>
        </swiper-item>
      </block>
    </swiper>

    <!-- 筛选栏 -->
    <view class="filters">
      <block wx:for="{{filters}}" wx:key="text">
        <text class="f-item {{index===activeFilter? 'active':''}}" bindtap="onFilterTap" data-index="{{index}}">{{item}}</text>
      </block>
    </view>

    <!-- 店铺列表 -->
    <view class="shop-list" wx:if="{{shops.length > 0}}">
      <block wx:for="{{shops}}" wx:key="_id">
        <view class="shop" bindtap="onShopTap" data-id="{{item._id}}">
          <image 
            class="cover" 
            src="{{item.logoUrl || item.img || '/pages/小标/商家.png'}}" 
            mode="aspectFill"
            binderror="onImageError"
            data-index="{{index}}"
          />
          <view class="meta">
            <text class="name ellipsis">{{item.name}}</text>
            <view class="rate-line">
              <view class="rating-group">
                <text class="score">{{item.rating || item.score || item.ratingAvg || 0}}</text>
                <view class="stars" wx:if="{{item.stars && item.stars.length > 0}}">
                  <text class="star {{starItem === 'full' ? 'full' : starItem === 'half' ? 'half' : 'empty'}}" wx:for="{{item.stars}}" wx:for-item="starItem" wx:key="index">★</text>
                </view>
                <view class="stars" wx:else>
                  <text class="star empty" wx:for="{{5}}" wx:key="index">★</text>
                </view>
              </view>
              <text class="month">月售{{item.month || item.sales}}</text>
            </view>
            <view class="fee-line">
              <text>起送¥{{item.start || item.minOrderAmount}}</text>
              <text>配送¥{{item.delivery || item.deliveryFee}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
    
    <!-- 搜索无结果提示 -->
    <view class="empty-state" wx:if="{{searchKeyword && shops.length === 0}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">未找到相关店铺</text>
      <text class="empty-tip">试试其他关键词吧</text>
      <view class="empty-btn" bindtap="onClearSearch">
        <text>清空搜索</text>
      </view>
    </view>
    
    <!-- 空列表提示 -->
    <view class="empty-state" wx:if="{{!searchKeyword && shops.length === 0}}">
      <text class="empty-icon">🏪</text>
      <text class="empty-text">暂无店铺</text>
    </view>
    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 自定义底部栏 -->
  <view class="tabbar">
    <view class="tab active">
      <image class="t-icon" src="/pages/小标/shouye-copy.png" mode="aspectFit" />
      <text class="t-text">首页</text>
    </view>
    <view class="tab" bindtap="onTabTap" data-tab="order">
      <image class="t-icon" src="/pages/小标/dingdan.png" mode="aspectFit" />
      <text class="t-text">订单</text>
    </view>
    <!-- 接单功能正在开发中，已注释 -->
    <!-- <view class="tab" bindtap="onTabTap" data-tab="receive">
      <image class="t-icon" src="/pages/小标/接单.png" mode="aspectFit" />
      <text class="t-text">接单</text>
    </view> -->
    <!-- 消息功能正在开发中，已注释 -->
    <!-- <view class="tab" bindtap="onTabTap" data-tab="message">
      <image class="t-icon" src="/pages/小标/消息.png" mode="aspectFit" />
      <text class="t-text">消息</text>
    </view> -->
    <view class="tab" bindtap="onTabTap" data-tab="profile">
      <image class="t-icon" src="/pages/小标/wode.png" mode="aspectFit" />
      <text class="t-text">我的</text>
    </view>
  </view>
</view>

