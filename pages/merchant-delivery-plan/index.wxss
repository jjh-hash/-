.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.status-bar {
  width: 100%;
  background: #fff;
}

.nav-bar {
  height: 44px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
}

.nav-left {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 24px;
  color: #333;
  font-weight: 300;
}

.nav-title {
  font-size: 18px;
  color: #333;
  font-weight: 600;
}

.nav-right {
  width: 44px;
}

.content {
  padding: 16px;
}

.section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
}

.section-title {
  font-size: 16px;
  color: #333;
  font-weight: 600;
  margin-bottom: 20px;
  display: block;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
}

.setting-row:last-child {
  margin-bottom: 0;
}

.setting-label {
  font-size: 16px;
  color: #333;
}

.delivery-method {
  display: flex;
  background: #f5f5f5;
  border-radius: 20px;
  padding: 2px;
}

.method-btn {
  padding: 8px 16px;
  border-radius: 18px;
  font-size: 14px;
  color: #666;
  background: transparent;
  transition: all 0.3s ease;
  text-align: center;
  min-width: 60px;
}

.method-btn.active {
  background: #1677ff;
  color: #fff;
  font-weight: 500;
}

.delivery-fee {
  display: flex;
  align-items: baseline;
}

.fee-amount {
  font-size: 16px;
  color: #333;
  font-weight: 500;
}

.fee-unit {
  font-size: 14px;
  color: #666;
  margin-left: 2px;
}

.confirm-btn {
  position: fixed;
  left: 16px;
  right: 16px;
  bottom: 20px;
  height: 48px;
  background: #1677ff;
  color: #fff;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 500;
  box-shadow: 0 2px 8px rgba(22, 119, 255, 0.3);
}
