.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center}
.title{font-size:18px;color:#333;font-weight:600}

.overview{margin:12px;background:linear-gradient(135deg,#3f8cff,#8bb5ff);border-radius:12px;color:#fff;padding:14px}
.row{display:flex;justify-content:space-between;align-items:center}
.col.main .label{font-size:12px;opacity:.9}
.amount{display:block;font-size:28px;font-weight:700;margin-top:6px}
.btn.primary{background:#fff;color:#3f8cff;border-radius:8px;padding:8px 14px}
.row.bottom{margin-top:14px;gap:12px}
.kpi{background:rgba(255,255,255,.2);border-radius:8px;flex:1;padding:10px;text-align:center}
.k-amount{display:block;font-size:16px;font-weight:700}
.k-label{display:block;font-size:12px;opacity:.95}

.section{margin:12px;background:#fff;border-radius:12px;padding:12px}
.sec-title{display:block;color:#333;font-weight:600;margin-bottom:10px}
.grid{display:flex;flex-wrap:wrap}
.g-item{width:33.33%;display:flex;flex-direction:column;align-items:center;margin-bottom:14px}
.ico{width:36px;height:36px;border-radius:18px;background:#f5f7ff;color:#3f8cff;display:flex;align-items:center;justify-content:center}
.g-text{margin-top:6px;color:#333;font-size:12px}

.switch-row{display:flex;align-items:center;justify-content:space-between;padding:6px 0}
.s-label{color:#333;flex:1}
.s-status{color:#666;font-size:14px;margin-right:8px}

.tabbar{position:fixed;left:0;right:0;bottom:0;background:#fff;border-top:1px solid #eee;display:flex;justify-content:space-around;padding:6px 0}
.t-item{display:flex;flex-direction:column;align-items:center;color:#999}
.t-item.active{color:#1677ff}
.t-img{width:22px;height:22px}
.t-txt{font-size:12px;margin-top:2px}
.safe-area-bottom{height:env(safe-area-inset-bottom)}

