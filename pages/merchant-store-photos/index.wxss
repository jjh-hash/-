.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.status-bar {
  width: 100%;
  background: #fff;
}

.nav-bar {
  height: 44px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
}

.nav-left {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 24px;
  color: #333;
  font-weight: 300;
}

.nav-title {
  font-size: 18px;
  color: #333;
  font-weight: 600;
}

.nav-right {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 20px;
  color: #1677ff;
  font-weight: 300;
}

.content {
  padding: 16px;
}

.category-tabs {
  display: flex;
  background: #fff;
  border-radius: 8px;
  margin-bottom: 16px;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  padding: 12px 8px;
  text-align: center;
  font-size: 14px;
  color: #666;
  background: #fff;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #1677ff;
  background: #f0f5ff;
  font-weight: 500;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.photo-item {
  position: relative;
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  aspect-ratio: 1;
}

.photo-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.photo-item:active .photo-overlay {
  opacity: 1;
}

.photo-actions {
  display: flex;
  gap: 12px;
}

.action-btn {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.delete {
  background: rgba(255, 77, 79, 0.9);
}

.action-icon {
  font-size: 16px;
}

.photo-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 20px 12px 12px;
  color: #fff;
}

.photo-name {
  display: block;
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 4px;
}

.photo-category {
  display: block;
  font-size: 12px;
  opacity: 0.8;
}

.add-photo {
  border: 2px dashed #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.add-content {
  text-align: center;
}

.add-photo .add-icon {
  font-size: 32px;
  color: #999;
  margin-bottom: 8px;
}

.add-text {
  font-size: 14px;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 60px 20px;
}

.empty-icon {
  width: 120px;
  height: 120px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 16px;
  color: #666;
  margin-bottom: 8px;
}

.empty-desc {
  display: block;
  font-size: 14px;
  color: #999;
}

.photo-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.photo-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 90%;
  max-width: 400px;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 300px;
  object-fit: cover;
}

.preview-info {
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.preview-name {
  display: block;
  font-size: 16px;
  color: #333;
  font-weight: 500;
  margin-bottom: 4px;
}

.preview-category {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 4px;
}

.preview-time {
  display: block;
  font-size: 12px;
  color: #999;
}

.preview-actions {
  display: flex;
  padding: 16px;
  gap: 12px;
}

.preview-actions .action-btn {
  flex: 1;
  height: 40px;
  border-radius: 6px;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.preview-actions .action-btn:active {
  background: #e6e6e6;
}

.preview-actions .action-btn.delete {
  background: #fff2f0;
  color: #ff4d4f;
}

.preview-actions .action-btn.delete:active {
  background: #ffebe6;
}

.action-text {
  font-size: 14px;
  font-weight: 500;
}

.add-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.add-modal.show {
  opacity: 1;
  visibility: visible;
}

.add-modal-content {
  width: 90%;
  max-width: 400px;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
}

.add-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.add-title {
  font-size: 18px;
  color: #333;
  font-weight: 600;
}

.close-btn {
  font-size: 24px;
  color: #999;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-form {
  padding: 16px;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 40px;
  padding: 0 12px;
  border: 1px solid #d9d9d9;
  border-radius: 6px;
  font-size: 14px;
  background: #fff;
}

.form-input:focus {
  border-color: #1677ff;
}

.picker-text {
  height: 40px;
  line-height: 40px;
  padding: 0 12px;
  border: 1px solid #d9d9d9;
  border-radius: 6px;
  font-size: 14px;
  background: #fff;
}

.photo-upload {
  width: 100%;
  height: 120px;
  border: 2px dashed #d9d9d9;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  transition: all 0.2s ease;
}

.photo-upload:active {
  border-color: #1677ff;
  background: #f0f5ff;
}

.upload-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 4px;
}

.upload-placeholder {
  text-align: center;
}

.upload-icon {
  font-size: 32px;
  color: #999;
  margin-bottom: 8px;
}

.upload-text {
  font-size: 14px;
  color: #999;
}

.add-actions {
  display: flex;
  padding: 16px;
  gap: 12px;
  border-top: 1px solid #f0f0f0;
}

.btn {
  flex: 1;
  height: 40px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.2s ease;
}

.btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.btn.cancel:active {
  background: #e6e6e6;
}

.btn.confirm {
  background: #1677ff;
  color: #fff;
}

.btn.confirm:active {
  background: #0958d9;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
