/* pages/secondhand-detail/index.wxss */
.page {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.status-bar {
  background-color: #fff;
}

.nav-bar {
  display: flex;
  align-items: center;
  height: 44px;
  background-color: #fff;
  padding: 0 15px;
  border-bottom: 1px solid #e5e5e5;
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10px;
}

.back-icon {
  font-size: 18px;
  color: #333;
}

.title {
  flex: 1;
  font-size: 18px;
  font-weight: 600;
  color: #333;
}

.share-btn {
  padding: 4px 12px;
}

.share-icon {
  font-size: 14px;
  color: #666;
}

.content {
  flex: 1;
  padding-bottom: 80px;
}

/* 图片轮播 */
.image-section {
  position: relative;
  width: 100%;
  height: 375px;
  background-color: #fff;
}

.image-swiper {
  width: 100%;
  height: 100%;
}

.product-image {
  width: 100%;
  height: 100%;
}

.image-count {
  position: absolute;
  bottom: 15px;
  right: 15px;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
}

/* 商品信息 */
.info-section {
  background-color: #fff;
  padding: 15px;
  margin-bottom: 10px;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12px;
}

.price {
  font-size: 28px;
  font-weight: 600;
  color: #ff6b35;
  margin-right: 12px;
}

.original-price-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.original-price {
  font-size: 14px;
  color: #999;
  text-decoration: line-through;
}

.discount-badge {
  background-color: #fff3e0;
  color: #ff6b35;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
}

.product-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
  line-height: 1.4;
}

.product-desc {
  font-size: 14px;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12px;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 12px;
}

.tag {
  padding: 4px 12px;
  background-color: #f5f5f5;
  border-radius: 12px;
  font-size: 12px;
  color: #666;
}

.meta-info {
  padding-top: 12px;
  border-top: 1px solid #f0f0f0;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
  font-size: 14px;
}

.meta-item:last-child {
  margin-bottom: 0;
}

.meta-label {
  color: #999;
  margin-right: 8px;
}

.meta-value {
  color: #333;
}

/* 卖家信息 */
.seller-section {
  background-color: #fff;
  padding: 15px;
  margin-bottom: 10px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.seller-card {
  display: flex;
  align-items: center;
  padding: 12px;
  background-color: #fafafa;
  border-radius: 8px;
}

.seller-avatar {
  width: 50px;
  height: 50px;
  border-radius: 25px;
  margin-right: 12px;
}

.seller-info {
  flex: 1;
}

.seller-name {
  font-size: 16px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.seller-rating {
  display: flex;
  align-items: center;
  gap: 4px;
}

.star {
  font-size: 12px;
}

.rating {
  font-size: 12px;
  color: #666;
}

.contact-btn {
  padding: 8px 20px;
  background-color: #ff6b35;
  color: #fff;
  border-radius: 20px;
  font-size: 14px;
}

.contact-text {
  color: #fff;
}

/* 商品详情 */
.detail-section {
  background-color: #fff;
  padding: 15px;
  margin-bottom: 10px;
}

.detail-content {
  padding: 12px;
  background-color: #fafafa;
  border-radius: 8px;
  min-height: 100px;
}

.detail-text {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
  white-space: pre-wrap;
}

.detail-empty {
  font-size: 14px;
  color: #999;
  text-align: center;
  padding: 20px 0;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* 加载状态 */
.loading-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 50px 0;
}

.loading-text {
  font-size: 14px;
  color: #999;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 12px 15px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  border-top: 1px solid #e5e5e5;
  z-index: 100;
  display: flex;
  gap: 10px;
}

.action-btn {
  flex: 1;
  height: 44px;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
}

.contact-btn-bottom {
  background-color: #ff6b35;
  color: #fff;
}

.action-text {
  color: #fff;
}

