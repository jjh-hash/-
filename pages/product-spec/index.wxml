<view class="page">
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <text class="back" bindtap="onBack">←</text>
      <text class="title">商品规格</text>
    </view>
  </view>

  <view class="content">
    <view class="product-info">
      <image class="product-image" src="{{productInfo.image}}" mode="aspectFill"></image>
      <view class="product-details">
        <text class="product-name">{{productInfo.name}}</text>
        <text class="product-price">¥{{productInfo.price}}</text>
      </view>
    </view>

    <view class="spec-section">
      <text class="section-title">选择规格</text>
      <view class="spec-options">
        <view 
          wx:for="{{specOptions}}" 
          wx:key="id"
          class="spec-item {{selectedSpec.id === item.id ? 'selected' : ''}}"
          bindtap="selectSpec"
          data-spec="{{item}}"
        >
          <text class="spec-name">{{item.name}}</text>
          <text class="spec-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>

    <view class="quantity-section">
      <text class="section-title">数量</text>
      <view class="quantity-control">
        <button class="quantity-btn" bindtap="decreaseQuantity" disabled="{{quantity <= 1}}">-</button>
        <text class="quantity-text">{{quantity}}</text>
        <button class="quantity-btn" bindtap="increaseQuantity">+</button>
      </view>
    </view>

    <view class="remark-section">
      <text class="section-title">备注</text>
      <textarea 
        class="remark-input" 
        placeholder="请输入备注信息"
        bindinput="onRemarkInput"
        value="{{remark}}"
      ></textarea>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="total-price">
      <text class="total-label">合计：</text>
      <text class="total-amount">¥{{totalPrice}}</text>
    </view>
    <button class="add-to-cart-btn" bindtap="addToCart">加入购物车</button>
  </view>
</view>
