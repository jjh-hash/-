/* pages/admin-log-list/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

.status-bar {
  background: transparent;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.back-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 10rpx;
  cursor: pointer;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
  text-align: center;
}

.nav-placeholder {
  width: 56rpx;
}

.page-content {
  padding: 30rpx;
}

/* 统计信息 */
.stats-section {
  margin-bottom: 30rpx;
}

.stats-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stats-label {
  font-size: 28rpx;
  color: #666;
}

.stats-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
}

/* 日志列表 */
.logs-section {
  margin-bottom: 40rpx;
}

.logs-list {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.log-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.log-item:last-child {
  border-bottom: none;
}

.log-content {
  display: flex;
  flex-direction: column;
}

.log-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.log-action {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.log-result {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.log-result.success {
  background: #E8F5E8;
  color: #4CAF50;
}

.log-result.warning {
  background: #FFF3E0;
  color: #FF9800;
}

.log-target {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.log-type {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.log-time {
  font-size: 22rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  margin-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.load-more-text {
  font-size: 28rpx;
  color: #667eea;
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  margin-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.no-more-text {
  font-size: 24rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #667eea;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

