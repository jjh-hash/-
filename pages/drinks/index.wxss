/* 页面基础样式 */
.page {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 状态栏 */
.status-bar {
  background: #fff;
  padding: 0 12px;
}

/* 头部导航 */
.header {
  display: flex;
  align-items: center;
  padding: 8px 16px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.back-btn {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8px;
}

.back-icon {
  font-size: 18px;
  color: #333;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-right: 12px;
}

.search-container {
  flex: 1;
  height: 32px;
  background: #f5f5f5;
  border-radius: 16px;
  display: flex;
  align-items: center;
  padding: 0 12px;
}

.search-icon {
  font-size: 14px;
  color: #999;
  margin-right: 6px;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.search-placeholder {
  color: #999;
}

/* 内容区域 */
.content {
  flex: 1;
}

/* 分类标签 */
.category-tabs {
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 12px;
}

.category-item {
  padding: 12px 16px;
  font-size: 14px;
  color: #666;
  white-space: nowrap;
  position: relative;
}

.category-item.active {
  color: #ffd700;
  font-weight: 500;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 2px;
  background: #ffd700;
  border-radius: 1px;
}

/* 排序和筛选 */
.sort-filter {
  background: #fff;
  padding: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.sort-options {
  display: flex;
  gap: 20px;
}

.sort-item {
  display: flex;
  align-items: center;
  font-size: 14px;
  color: #666;
}

.sort-item.active {
  color: #ffd700;
}

.sort-arrow {
  font-size: 10px;
  margin-left: 4px;
  color: #999;
}

/* 商家列表 */
.store-list {
  padding: 12px;
}

.store-card {
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  padding: 12px;
  border: 1px solid #f0f0f0;
}

/* 商家信息头部 */
.store-header {
  display: flex;
  margin-bottom: 8px;
}

.store-logo {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  overflow: hidden;
  margin-right: 12px;
  flex-shrink: 0;
  position: relative;
}

.logo-image {
  width: 100%;
  height: 100%;
}

.logo-text {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  padding: 4px;
  text-align: center;
}

.logo-title {
  font-size: 10px;
  color: #ff8c00;
  font-weight: 600;
  display: block;
}

.logo-subtitle {
  font-size: 8px;
  color: #fff;
  display: block;
}

.store-info {
  flex: 1;
}

.store-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.store-name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-right: 8px;
  flex: 1;
}

.delivery-type {
  background: #f0f0f0;
  color: #ff8c00;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
}

.store-stats {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.rating {
  display: flex;
  align-items: center;
  gap: 2px;
}

.star {
  font-size: 12px;
  color: #ffd700;
}

.rating-text {
  font-size: 12px;
  color: #333;
}

.monthly-sales {
  font-size: 12px;
  color: #666;
}

.avg-price {
  font-size: 12px;
  color: #666;
}

.delivery-info {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.min-order {
  color: #666;
  font-size: 12px;
}

.delivery-fee {
  color: #666;
  font-size: 12px;
}

.distance-time {
  display: flex;
  align-items: center;
  gap: 8px;
}

.delivery-time {
  color: #666;
  font-size: 12px;
}

.distance {
  color: #666;
  font-size: 12px;
}

/* 标签和优惠券 */
.store-tags {
  display: flex;
  gap: 6px;
  margin-bottom: 8px;
}

.tag {
  background: #fff3e0;
  color: #ff8c00;
  font-size: 10px;
  padding: 4px 8px;
  border-radius: 4px;
}

.coupon {
  background: #f5f5f5;
  color: #666;
  font-size: 10px;
  padding: 4px 8px;
  border-radius: 4px;
}

/* 商品展示 */
.products {
  margin-top: 8px;
}

.product-scroll {
  white-space: nowrap;
}

.product-list {
  display: flex;
  gap: 12px;
}

.product-item {
  width: 80px;
  flex-shrink: 0;
}

.product-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  overflow: hidden;
  position: relative;
  margin-bottom: 6px;
  border: 2px solid #fff;
}

.image {
  width: 100%;
  height: 100%;
}

.product-tag {
  position: absolute;
  top: 4px;
  right: 4px;
  background: #fff;
  color: #666;
  font-size: 8px;
  padding: 2px 4px;
  border-radius: 4px;
}

.product-info {
  text-align: center;
}

.product-name {
  font-size: 11px;
  color: #333;
  display: block;
  margin-bottom: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  font-size: 12px;
  color: #ff4757;
  font-weight: 600;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
