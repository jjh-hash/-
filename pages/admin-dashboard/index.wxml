<!--pages/admin-dashboard/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBack">◀</view>
    <text class="title">数据概况</text>
    <view class="nav-actions">
      <text class="refresh-btn" bindtap="onRefresh">🔄</text>
    </view>
  </view>

  <!-- 页面内容 -->
  <view class="page-content">
    <!-- 核心数据概览 -->
    <view class="stats-section">
      <text class="section-title">核心数据概览</text>
      <view class="stats-grid">
        <view class="stat-card primary">
          <view class="stat-icon">
            <image src="/pages/小标/关于我们.png" mode="aspectFit"></image>
          </view>
          <view class="stat-content">
            <text class="stat-number">¥{{stats.totalRevenue}}</text>
            <text class="stat-label">总营收</text>
            <text class="stat-trend positive">+{{stats.revenueGrowth}}%</text>
          </view>
        </view>
        
        <view class="stat-card success">
          <view class="stat-icon">
            <image src="/pages/小标/商家.png" mode="aspectFit"></image>
          </view>
          <view class="stat-content">
            <text class="stat-number">{{stats.merchantCount}}</text>
            <text class="stat-label">商家总数</text>
            <text class="stat-trend positive">+{{stats.merchantGrowth}}%</text>
          </view>
        </view>
        
        <view class="stat-card warning">
          <view class="stat-icon">
            <image src="/pages/小标/dingdan.png" mode="aspectFit"></image>
          </view>
          <view class="stat-content">
            <text class="stat-number">{{stats.orderCount}}</text>
            <text class="stat-label">订单总数</text>
            <text class="stat-trend positive">+{{stats.orderGrowth}}%</text>
          </view>
        </view>
        
        <view class="stat-card info">
          <view class="stat-icon">
            <image src="/pages/小标/wode.png" mode="aspectFit"></image>
          </view>
          <view class="stat-content">
            <text class="stat-number">{{stats.userCount}}</text>
            <text class="stat-label">用户总数</text>
            <text class="stat-trend positive">+{{stats.userGrowth}}%</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 用户活跃度分析 -->
    <view class="analytics-section">
      <text class="section-title">用户活跃度分析</text>
      <view class="analytics-cards">
        <view class="analytics-card">
          <view class="card-header">
            <text class="card-title">日活跃用户</text>
            <text class="card-value">{{stats.dailyActiveUsers}}</text>
          </view>
          <view class="card-chart">
            <text class="chart-text">较昨日 +{{stats.dauGrowth}}%</text>
          </view>
        </view>
        
        <view class="analytics-card">
          <view class="card-header">
            <text class="card-title">月活跃用户</text>
            <text class="card-value">{{stats.monthlyActiveUsers}}</text>
          </view>
          <view class="card-chart">
            <text class="chart-text">较上月 +{{stats.mauGrowth}}%</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 订单概况 -->
    <view class="order-overview-section">
      <text class="section-title">订单概况</text>
      <view class="order-stats-grid">
        <view class="order-stat-card">
          <view class="order-stat-header">
            <text class="order-stat-title">今日订单</text>
            <text class="order-stat-value">{{orderStats.todayOrders}}</text>
          </view>
          <view class="order-stat-trend">
            <text class="trend-text positive">+{{orderStats.todayGrowth}}%</text>
          </view>
        </view>
        
        <view class="order-stat-card">
          <view class="order-stat-header">
            <text class="order-stat-title">待处理订单</text>
            <text class="order-stat-value">{{orderStats.pendingOrders}}</text>
          </view>
          <view class="order-stat-trend">
            <text class="trend-text warning">需处理</text>
          </view>
        </view>
        
        <view class="order-stat-card">
          <view class="order-stat-header">
            <text class="order-stat-title">已完成订单</text>
            <text class="order-stat-value">{{orderStats.completedOrders}}</text>
          </view>
          <view class="order-stat-trend">
            <text class="trend-text success">完成率 {{orderStats.completionRate}}%</text>
          </view>
        </view>
        
        <view class="order-stat-card">
          <view class="order-stat-header">
            <text class="order-stat-title">平均订单金额</text>
            <text class="order-stat-value">¥{{orderStats.avgOrderValue}}</text>
          </view>
          <view class="order-stat-trend">
            <text class="trend-text info">较昨日 +{{orderStats.avgOrderGrowth}}%</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 收入趋势 -->
    <view class="revenue-trend-section">
      <text class="section-title">收入趋势</text>
      <view class="revenue-chart">
        <view class="chart-header">
          <text class="chart-title">近7天收入趋势</text>
          <view class="chart-legend">
            <view class="legend-item">
              <view class="legend-color primary"></view>
              <text class="legend-text">收入</text>
            </view>
          </view>
        </view>
        <view class="chart-content">
          <view class="chart-bars">
            <view class="chart-bar" wx:for="{{revenueChart}}" wx:key="index" style="height: {{item.height}}%">
              <text class="bar-value">¥{{item.value}}</text>
            </view>
          </view>
          <view class="chart-labels">
            <text class="chart-label" wx:for="{{revenueChart}}" wx:key="index">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

  </view>

  <!-- 底部导航栏 -->
  <view class="admin-tabbar">
    <view class="tabbar-item {{currentTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-index="0">
      <view class="tabbar-icon">
        <image src="{{currentTab === 0 ? '/pages/小标/shouye-copy.png' : '/pages/小标/shouye.png'}}" mode="aspectFit"></image>
      </view>
      <text class="tabbar-text">数据概况</text>
    </view>
    
    <view class="tabbar-item {{currentTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-index="1">
      <view class="tabbar-icon">
        <image src="{{currentTab === 1 ? '/pages/小标/商家1.png' : '/pages/小标/商家.png'}}" mode="aspectFit"></image>
      </view>
      <text class="tabbar-text">管理系统</text>
    </view>
    
    <view class="tabbar-item {{currentTab === 2 ? 'active' : ''}}" bindtap="onTabChange" data-index="2">
      <view class="tabbar-icon">
        <image src="{{currentTab === 2 ? '/pages/小标/wode-copy.png' : '/pages/小标/wode.png'}}" mode="aspectFit"></image>
      </view>
      <text class="tabbar-text">管理员信息</text>
    </view>
  </view>
</view>