<!--pages/admin-batch-audit/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBack">◀</view>
    <text class="title">批量审核</text>
  </view>

  <!-- 标签页切换 -->
  <view class="tabs">
    <view 
      class="tab {{currentTab==='product'?'active':''}}" 
      bindtap="onTabChange" 
      data-tab="product"
    >
      商品审核
    </view>
    <view 
      class="tab {{currentTab==='merchant'?'active':''}}" 
      bindtap="onTabChange" 
      data-tab="merchant"
    >
      商家审核
    </view>
  </view>

  <!-- 商品审核 -->
  <view wx:if="{{currentTab === 'product'}}" class="content">
    <!-- 筛选栏 -->
    <view class="filter-bar">
      <picker 
        bindchange="onProductStatusChange" 
        value="{{productStatusIndex}}" 
        range="{{productStatusOptions}}" 
        range-key="label"
      >
        <view class="filter-picker">
          <text class="filter-label">状态：</text>
          <text class="filter-value">{{productStatusOptions[productStatusIndex].label}}</text>
          <text class="filter-arrow">▼</text>
        </view>
      </picker>
    </view>
    
    <!-- 操作栏 -->
    <view class="action-bar">
      <view class="checkbox-item" bindtap="onToggleAllProducts">
        <text class="checkbox-icon {{selectedProducts.length === products.length && products.length > 0 ? 'checked' : ''}}">✓</text>
        <text>全选</text>
      </view>
      <view class="action-buttons">
        <button class="btn-approve" bindtap="onBatchApproveProducts">批量通过</button>
        <button class="btn-reject" bindtap="onBatchRejectProducts">批量拒绝</button>
      </view>
    </view>

    <!-- 商品列表 -->
    <scroll-view scroll-y class="list-content" enable-back-to-top>
      <block wx:for="{{products}}" wx:key="id">
        <view class="item">
          <view class="checkbox" bindtap="onToggleProduct" data-id="{{item.id}}">
            <text class="checkbox-icon {{item._isSelected ? 'checked' : ''}}">✓</text>
          </view>
          <image class="item-image" src="{{item.coverUrl}}" mode="aspectFill" />
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-price">¥{{item.price}}</text>
            <text class="item-time">{{item.createTime}}</text>
          </view>
          <view class="item-status status-{{item.auditStatus}}">
            <text wx:if="{{item.auditStatus === 'pending'}}">待审核</text>
            <text wx:elif="{{item.auditStatus === 'approved'}}">已通过</text>
            <text wx:elif="{{item.auditStatus === 'rejected'}}">已拒绝</text>
          </view>
        </view>
      </block>

      <!-- 空状态 -->
      <view wx:if="{{products.length === 0}}" class="empty">
        <text class="empty-icon">📝</text>
        <text class="empty-text">暂无待审核商品</text>
      </view>
    </scroll-view>
  </view>

  <!-- 商家审核 -->
  <view wx:else class="content">
    <!-- 操作栏 -->
    <view class="action-bar">
      <view class="checkbox-item" bindtap="onToggleAllMerchants">
        <text class="checkbox-icon {{selectedMerchants.length === merchants.length && merchants.length > 0 ? 'checked' : ''}}">✓</text>
        <text>全选</text>
      </view>
      <view class="action-buttons">
        <button class="btn-approve" bindtap="onBatchApproveMerchants">批量通过</button>
        <button class="btn-reject" bindtap="onBatchRejectMerchants">批量拒绝</button>
      </view>
    </view>

    <!-- 商家列表 -->
    <scroll-view scroll-y class="list-content" enable-back-to-top>
      <block wx:for="{{merchants}}" wx:key="_id">
        <view class="item">
          <view class="checkbox" bindtap="onToggleMerchant" data-id="{{item._id}}">
            <text class="checkbox-icon {{item._isSelected ? 'checked' : ''}}">✓</text>
          </view>
          <view class="item-info-full">
            <text class="item-name">{{item.merchantName}}</text>
            <text class="item-phone">{{item.contactPhone}}</text>
            <text class="item-time">{{item.createdAt}}</text>
          </view>
          <view class="item-status status-{{item.status}}">
            <text wx:if="{{item.status === 'pending'}}">待审核</text>
            <text wx:elif="{{item.status === 'active'}}">已通过</text>
            <text wx:elif="{{item.status === 'suspended'}}">已暂停</text>
            <text wx:elif="{{item.status === 'rejected'}}">已拒绝</text>
          </view>
        </view>
      </block>

      <!-- 空状态 -->
      <view wx:if="{{merchants.length === 0}}" class="empty">
        <text class="empty-icon">🏪</text>
        <text class="empty-text">暂无待审核商家</text>
      </view>
    </scroll-view>
  </view>
</view>

