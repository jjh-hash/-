<view class="page">
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <text class="back" bindtap="onBack">◀</text>
      <text class="title">订单</text>
      <view class="icons">
        <text class="dot">•</text>
        <text class="battery">▮</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 订单列表 -->
    <view class="order-list">
      <block wx:for="{{orders}}" wx:key="id">
        <view class="order-card">
          <!-- 顶部信息 -->
          <view class="order-header">
            <image class="food-img" src="{{item.img}}" mode="aspectFill" />
            <view class="order-info">
              <text class="store-name">{{item.storeName}}</text>
              <text class="order-date">{{item.date}}</text>
            </view>
            <text class="order-status {{item.statusClass}}">{{item.status}}</text>
          </view>

          <!-- 订单商品 -->
          <view class="order-items">
            <block wx:for="{{item.items}}" wx:key="index" wx:for-item="food">
              <text class="item-name">{{food.name}}</text>
            </block>
          </view>

          <!-- 底部价格和操作 -->
          <view class="order-footer">
            <text class="total-price">共 ¥{{item.total}}</text>
            <view class="action-buttons">
              <block wx:if="{{item.status === '待支付'}}">
                <button class="btn-cancel" size="mini">取消订单</button>
                <button class="btn-pay" size="mini">进行支付</button>
              </block>
              <block wx:elif="{{item.status === '商家待接单'}}">
                <button class="btn-cancel" size="mini">取消订单</button>
                <button class="btn-again" size="mini">再来一单</button>
              </block>
              <block wx:else>
                <button class="btn-again" size="mini">再来一单</button>
              </block>
            </view>
          </view>
        </view>
      </block>
    </view>
    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 自定义底部栏 -->
  <view class="tabbar">
    <view class="tab" bindtap="onTabTap" data-tab="home">
      <image class="t-icon" src="/pages/小标/shouye.png" mode="aspectFit" />
      <text class="t-text">首页</text>
    </view>
    <view class="tab active">
      <image class="t-icon" src="/pages/小标/dingdan-copy.png" mode="aspectFit" />
      <text class="t-text">订单</text>
    </view>
    <view class="tab" bindtap="onTabTap" data-tab="profile">
      <image class="t-icon" src="/pages/小标/wode.png" mode="aspectFit" />
      <text class="t-text">我的</text>
    </view>
  </view>
</view>
