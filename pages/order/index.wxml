<view class="page">

  <scroll-view 
    scroll-y 
    class="content"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscroll="onScroll"
  >
    <!-- 分类标签 -->
    <view class="category-tabs">
      <block wx:for="{{categories}}" wx:key="id">
        <view 
          class="category-tab {{selectedCategory === item.id ? 'active' : ''}}" 
          bindtap="onCategoryTap" 
          data-id="{{item.id}}"
        >
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-text">{{item.name}}</text>
        </view>
      </block>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-container">
      <text>加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view wx:elif="{{filteredOrders.length === 0 && !loading}}" class="empty">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无订单</text>
      <text class="empty-desc">去首页逛逛，发现好吃好玩的</text>
      <navigator class="go-home" url="/pages/home/index" open-type="switchTab">去逛逛</navigator>
    </view>
    
    <!-- 订单列表 -->
    <view wx:elif="{{!loading && filteredOrders.length > 0}}" class="order-list">
      <block wx:for="{{filteredOrders}}" wx:key="id">
        <view class="order-card" bindtap="onOrderTap" data-id="{{item.id}}">
          <!-- 顶部信息 -->
          <view class="order-header">
            <image class="food-img" src="{{item.img}}" mode="aspectFill" />
            <view class="order-info">
              <text class="store-name">{{item.storeName}}</text>
              <text class="order-date">{{item.date}}</text>
            </view>
            <text class="order-status {{item.statusClass}}">{{item.status}}</text>
          </view>

          <!-- 订单商品 -->
          <view class="order-items">
            <block wx:for="{{item.items}}" wx:key="index" wx:for-item="food">
              <text class="item-name">{{food.name}}</text>
            </block>
          </view>

          <!-- 退款状态显示 -->
          <view class="refund-status-info" wx:if="{{item.refundStatus}}">
            <text class="refund-status-text {{item.refundStatusClass}}">{{item.refundStatusText}}</text>
            <text class="refund-remark" wx:if="{{item.refundStatus === 'rejected' && item.refundInfo && item.refundInfo.remark}}">拒绝理由：{{item.refundInfo.remark}}</text>
            <text class="refund-amount" wx:if="{{item.refundInfo && item.refundInfo.refundAmount}}">退款金额：¥{{item.refundInfo.refundAmount}}</text>
          </view>

          <!-- 订单超时和预计送达时间 -->
          <view class="order-time-info" wx:if="{{item.expiredAt || item.estimatedDeliveryTime || item.estimatedDeliveryTimeRange}}">
            <!-- 只有订单还在进行中（未完成/未取消）且超时时，才显示超时提示 -->
            <text class="time-text expired" wx:if="{{item.expiredMinutes !== null && item.expiredMinutes < 0 && item.orderStatus !== 'completed' && item.orderStatus !== 'cancelled'}}">订单已超时</text>
            <text class="time-text" wx:elif="{{item.expiredMinutes !== null && item.expiredMinutes > 0 && item.orderStatus !== 'completed' && item.orderStatus !== 'cancelled'}}">订单剩余{{item.expiredMinutes}}分钟</text>
            <text class="time-text delivery" wx:if="{{item.estimatedDeliveryTimeRange}}">预计到达时间：{{item.estimatedDeliveryTimeRange}}</text>
            <text class="time-text delivery" wx:elif="{{item.estimatedDeliveryTime}}">预计送达：{{item.estimatedDeliveryTime}}</text>
          </view>

          <!-- 底部价格和操作 -->
          <view class="order-footer">
            <view class="price-info">
              <text class="total-price">共 ¥{{item.total}}</text>
              <view class="price-detail" wx:if="{{item.amountGoods || item.amountDelivery}}">
                <text class="detail-text">商品¥{{item.amountGoods}} + 配送¥{{item.amountDelivery}}</text>
              </view>
            </view>
            <view class="action-buttons" catchtap="stopPropagation">
              <block wx:if="{{item.orderStatus === 'pending' || item.orderStatus === 'confirmed' || item.orderStatus === 'preparing'}}">
                <button class="btn-cancel" size="mini" bindtap="onCancelOrder" data-id="{{item.id}}">取消订单</button>
                <button class="btn-contact" size="mini" bindtap="onContactMerchant" data-id="{{item.id}}" wx:if="{{item.storeId}}">联系商家</button>
                <button class="btn-again" size="mini" bindtap="onOrderAgain" data-id="{{item.id}}">再来一单</button>
              </block>
              <block wx:elif="{{item.orderStatus === 'cancelled'}}">
                <text class="cancelled-text">订单已取消</text>
              </block>
              <block wx:else>
                <button class="btn-refund" size="mini" catchtap="onRefund" data-id="{{item.id}}" wx:if="{{item.payStatus === 'paid' && item.canRefund && !item.refundStatus}}">申请退款</button>
                <button class="btn-contact" size="mini" bindtap="onContactMerchant" data-id="{{item.id}}" wx:if="{{item.storeId}}">联系商家</button>
                <button class="btn-again" size="mini" bindtap="onOrderAgain" data-id="{{item.id}}">再来一单</button>
              </block>
            </view>
          </view>
        </view>
      </block>
    </view>
    
    <view class="safe-area-bottom"></view>
  </scroll-view>
</view>
