/* 订单列表 - 依据配色设计文档 */
.page { background: var(--color-bg-page); min-height: 100vh; }

/* 顶栏：白底 + 主色点缀 */
.nav { background: var(--color-bg-card); color: var(--color-text); }
.status-bar { width: 100%; }
.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12px;
  position: relative;
  border-bottom: 1px solid var(--color-border);
}
.back { position: absolute; left: 12px; color: var(--color-text); }
.title { font-size: 17px; font-weight: 600; color: var(--color-text); }
.icons { display: none; }

.content { height: calc(100vh - 88px); background: var(--color-bg-page); box-sizing: border-box; }

/* 分类标签：全部订单 / 代拿快递 / 游戏陪玩 - 选中用主色 */
.category-tabs {
  display: flex;
  padding: 12px;
  gap: 8px;
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
  overflow-x: auto;
  white-space: nowrap;
}
.category-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8px 16px;
  border-radius: var(--radius-tag);
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
  font-size: 14px;
  white-space: nowrap;
  transition: all 0.2s;
}
.category-tab.active {
  background: var(--color-primary);
  color: #fff;
}
.category-icon { margin-right: 4px; font-size: 14px; }
.category-text { font-size: 14px; font-weight: 500; }

/* 加载和空状态 */
.loading-container,
.empty-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  color: var(--color-text-placeholder);
  font-size: 14px;
}

/* 订单列表 */
.order-list { padding: 12px; }
.order-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 12px;
  margin-bottom: 16px;
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-card);
}

/* 订单头部 */
.order-header { display: flex; align-items: flex-start; margin-bottom: 12px; }
.food-img {
  width: 60px;
  height: 60px;
  border-radius: var(--radius-btn);
  background: var(--color-border);
  margin-right: 12px;
}
.order-info { flex: 1; }
.store-name { font-size: 16px; font-weight: 600; color: var(--color-text); display: block; margin-bottom: 4px; }
.order-date { font-size: 12px; color: var(--color-text-secondary); }
.order-status { font-size: 14px; font-weight: 500; margin-left: auto; }
.order-status.pending { color: var(--color-warning); }
.order-status.normal { color: var(--color-text); }
.order-status.cancelled { color: var(--color-danger); }

/* 订单商品 */
.order-items {
  margin: 8px 0 12px;
  background: var(--color-bg-page);
  border-radius: var(--radius-btn);
  padding: 12px;
}
.item-name { font-size: 14px; color: var(--color-text-secondary); display: block; margin-bottom: 4px; }

/* 退款状态 */
.refund-status-info {
  margin: 8px 0;
  padding: 10px 12px;
  background: var(--color-primary-light);
  border-radius: var(--radius-btn);
  border-left: 3px solid var(--color-primary);
}
.refund-status-text { font-size: 14px; font-weight: 500; display: block; margin-bottom: 6px; }
.refund-status-text.refund-pending { color: var(--color-warning); }
.refund-status-text.refund-success { color: var(--color-success); }
.refund-status-text.refund-rejected { color: var(--color-danger); }
.refund-remark { font-size: 12px; color: var(--color-text-secondary); display: block; margin-top: 4px; line-height: 1.5; }
.refund-amount { font-size: 12px; color: var(--color-primary); display: block; margin-top: 4px; }

/* 订单超时和预计送达：警告色条 + 超时用危险色 */
.order-time-info {
  margin: 8px 0;
  padding: 8px 12px;
  background: var(--color-primary-light);
  border-radius: var(--radius-btn);
  border-left: 3px solid var(--color-warning);
}
.order-time-info .time-text { font-size: 12px; color: var(--color-warning); display: block; margin-bottom: 4px; }
.order-time-info .time-text:last-child { margin-bottom: 0; }
.order-time-info .time-text.expired { color: var(--color-danger); }
.order-time-info .time-text.delivery { color: var(--color-success); }

/* 订单底部：总价 + 操作按钮 */
.order-footer { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; }
.price-info { flex: 1; }
.total-price { font-size: 16px; font-weight: 700; color: var(--color-text); display: block; }
.price-detail { margin-top: 4px; }
.detail-text { font-size: 12px; color: var(--color-text-placeholder); }
.action-buttons { display: flex; gap: 10px; flex-wrap: wrap; }
.action-buttons button { padding: 8px 14px; border-radius: var(--radius-btn); font-size: 13px; }
.btn-cancel { background: var(--color-bg-card); color: var(--color-text); border: 1px solid var(--color-border); }
.btn-pay { background: var(--color-primary); color: #fff; font-weight: 600; border: none; }
.btn-refund { background: var(--color-danger); color: #fff; font-weight: 500; border: none; }
.btn-contact { background: var(--color-primary); color: #fff; border: none; }
.btn-again { background: var(--color-bg-card); color: var(--color-text); border: 1px solid var(--color-border); }
.cancelled-text { font-size: 12px; color: var(--color-danger); }

/* 底部 Tab 栏：白底 + 选中主色（与顶栏一致） */
.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-card);
  display: flex;
  justify-content: space-around;
  padding: 8px 0 env(safe-area-inset-bottom);
  border-top: 1px solid var(--color-border);
}
.tab { display: flex; flex-direction: column; align-items: center; color: var(--color-text-placeholder); }
.tab.active { color: var(--color-primary); }
.t-icon { width: 20px; height: 20px; }
.t-text { font-size: 12px; margin-top: 2px; }
