<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  <view class="nav">
    <view class="back" bindtap="onBack">◀</view>
    <text class="title">销售统计</text>
    <view class="year-selector" bindtap="onYearSelect">
      <text class="calendar-icon">📅</text>
      <text class="year-text">2022</text>
      <text class="arrow">▼</text>
    </view>
  </view>

  <!-- 销售概览 -->
  <view class="sales-overview">
    <view class="total-sales">
      <text class="amount">¥ 5693.22</text>
      <text class="growth">↑ 36.33</text>
    </view>
  </view>

  <!-- 关键指标卡片 -->
  <view class="metrics-card">
    <view class="metric-left">
      <text class="metric-label">当前收益/元</text>
      <text class="metric-value">666.00</text>
    </view>
    <view class="metric-divider"></view>
    <view class="metric-right">
      <text class="metric-label">有效订单/单</text>
      <text class="metric-value">621</text>
    </view>
  </view>

  <!-- 销售数据图表 -->
  <view class="chart-section">
    <view class="chart-header">
      <text class="chart-title">销售数据</text>
      <view class="legend">
        <view class="legend-item">
          <view class="legend-dot orders"></view>
          <text class="legend-text">订单</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot revenue"></view>
          <text class="legend-text">收益</text>
        </view>
      </view>
      <text class="unit">单位:100</text>
    </view>
    
    <view class="bar-chart">
      <view class="chart-container">
        <view class="bars">
          <view class="bar-group" wx:for="{{chartData}}" wx:key="date" bindtap="onBarClick" data-index="{{index}}">
            <view class="bar-wrapper">
              <view class="bar orders" style="height: {{item.orders * 2}}px"></view>
              <view class="bar revenue" style="height: {{item.revenue / 10}}px"></view>
            </view>
          </view>
        </view>
        <view class="x-axis">
          <text class="date-label" wx:for="{{chartData}}" wx:key="date">{{item.date}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 销售趋势图表 -->
  <view class="chart-section">
    <view class="chart-header">
      <text class="chart-title">销售趋势</text>
      <view class="time-selector" bindtap="onTimeSelect">
        <text class="time-text">近一周</text>
        <text class="arrow">▼</text>
      </view>
    </view>
    
    <view class="line-chart">
      <view class="chart-container">
        <canvas canvas-id="trendChart" class="trend-canvas"></canvas>
        <view class="x-axis">
          <text class="date-label" wx:for="{{trendDates}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

