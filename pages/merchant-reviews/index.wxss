.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center;position:relative}
.back{position:absolute;left:12px;color:#333;font-size:18px}
.title{font-size:18px;color:#333;font-weight:600}

.rating-overview{background:#fff;margin:12px;border-radius:12px;padding:20px;display:flex;justify-content:space-between;align-items:center}
.rating-left{display:flex;flex-direction:column;align-items:flex-start}
.stars{display:flex;margin-bottom:8px}
.star{font-size:20px;margin-right:2px}
.star.filled{color:#1677ff}
.star.empty{color:#ddd}
.review-count{color:#999;font-size:14px}
.rating-right{display:flex;flex-direction:column;align-items:flex-end}
.rating-score{font-size:32px;color:#1677ff;font-weight:bold;line-height:1}
.rating-label{color:#999;font-size:14px;margin-top:4px}

.filter-tabs{background:#fff;margin:0 12px;border-radius:12px;display:flex;padding:0}
.tab{flex:1;padding:16px 0;text-align:center;color:#999;font-size:16px;position:relative}
.tab.active{color:#1677ff;font-weight:600}
.tab.active::after{content:'';position:absolute;left:50%;bottom:0;transform:translateX(-50%);width:24px;height:2px;background:#1677ff;border-radius:1px}

.review-list{flex:1;padding:12px}
.review-item{background:#fff;margin-bottom:12px;border-radius:12px;padding:16px}
.user-info{display:flex;align-items:center;margin-bottom:12px}
.avatar{width:40px;height:40px;border-radius:20px;margin-right:12px}
.user-details{flex:1}
.username{color:#333;font-size:16px;font-weight:500;display:block;margin-bottom:4px}
.user-rating{display:flex}
.user-rating .star{font-size:14px;margin-right:1px;color:#1677ff}
.review-date{color:#999;font-size:14px}
.review-content{color:#333;line-height:1.6}
.review-text{font-size:15px;margin-bottom:12px;display:block}
.review-images{display:flex;gap:8px;margin-bottom:12px}
.review-img{width:80px;height:80px;border-radius:8px}
.merchant-reply{background:#f8f9fa;padding:12px;border-radius:8px;margin-top:12px}
.reply-label{color:#666;font-size:14px;font-weight:500;display:block;margin-bottom:6px}
.reply-content{color:#333;font-size:14px;line-height:1.5}
