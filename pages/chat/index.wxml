<!--pages/chat/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBack">
      <text class="back-icon">←</text>
    </view>
    <text class="title">{{toUserName}}</text>
    <view class="nav-right"></view>
  </view>

  <!-- 消息列表 -->
  <scroll-view 
    scroll-y 
    class="messages-container"
    scroll-into-view="{{scrollIntoView}}"
    scroll-with-animation="{{true}}"
    enable-back-to-top="{{true}}"
    refresher-enabled="{{true}}"
    bindrefresherrefresh="onPullDownRefresh"
  >
    <view class="messages-list">
      <view 
        class="message-item {{item.fromUserId === (userInfo && userInfo.openid) ? 'self' : 'other'}}" 
        wx:for="{{messages}}" 
        wx:key="_id"
        id="msg-{{index}}"
      >
        <!-- 对方消息：头像在左侧 -->
        <view class="message-avatar" wx:if="{{item.fromUserId !== (userInfo && userInfo.openid)}}">
          <image 
            class="avatar-img" 
            src="{{item.fromUserAvatar || toUserAvatar || '/pages/小标/商家.png'}}" 
            mode="aspectFill"
            binderror="onAvatarError"
            data-type="other"
          />
        </view>
        
        <view class="message-wrapper">
          <view class="message-content {{item.fromUserId === (userInfo && userInfo.openid) ? 'self' : 'other'}}">
            <text class="message-text">{{item.content}}</text>
          </view>
          <view class="message-footer">
            <text class="message-time">{{formatTime(item.createdAt)}}</text>
            <view class="message-status" wx:if="{{item.fromUserId === (userInfo && userInfo.openid)}}">
              <text wx:if="{{item.status === 'sending'}}" class="sending">发送中</text>
              <text wx:elif="{{item.status === 'read'}}" class="read">✓</text>
              <text wx:else class="unread">✓</text>
            </view>
          </view>
        </view>
        
        <!-- 自己消息：头像在右侧 -->
        <view class="message-avatar" wx:if="{{item.fromUserId === (userInfo && userInfo.openid)}}">
          <image 
            class="avatar-img" 
            src="{{userInfo && userInfo.avatar ? userInfo.avatar : '/pages/小标/商家.png'}}" 
            mode="aspectFill"
            binderror="onAvatarError"
            data-type="self"
          />
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 输入框 -->
  <view class="input-bar">
    <input 
      class="input" 
      placeholder="输入消息..." 
      value="{{inputValue}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="onSend"
    />
    <view class="send-btn {{inputValue.trim() ? 'active' : ''}}" bindtap="onSend">
      <text class="send-text">发送</text>
    </view>
  </view>
</view>

