<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  <view class="nav">
    <text class="title">订单中心</text>
    <view class="nav-icons"></view>
  </view>

  <!-- 顶部标签 -->
  <view class="tabs">
    <view class="tab {{activeTab===0?'active':''}}" data-index="0" bindtap="onTabTap">全部</view>
    <view class="tab {{activeTab===1?'active':''}}" data-index="1" bindtap="onTabTap">待确认</view>
    <view class="tab {{activeTab===2?'active':''}}" data-index="2" bindtap="onTabTap">已完成</view>
    <view class="tab {{activeTab===3?'active':''}}" data-index="3" bindtap="onTabTap">已取消</view>
  </view>

  <!-- 订单列表 -->
  <scroll-view scroll-y class="list">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card" bindtap="onOpenDetail" data-id="{{item.id}}">
        <view class="order-top">
          <text class="desk">{{item.deskNo}}#</text>
          <text class="status">{{item.statusText}}</text>
        </view>
        <view class="items">
          <block wx:for="{{item.items}}" wx:key="name">
            <view class="item">
              <image class="thumb" src="{{item2.img}}" mode="aspectFill" />
              <view class="meta">
                <text class="name">{{item2.name}}</text>
                <text class="price">¥{{item2.price}}</text>
              </view>
              <text class="qty">x{{item2.qty}}</text>
            </view>
          </block>
        </view>
        <view class="remark" wx:if="{{item.remark}}">备注：{{item.remark}}</view>
        <view class="actions">
          <view class="btn ghost" bindtap="onContactUser" data-id="{{item.id}}">联系用户</view>
          <view class="btn primary" bindtap="onConfirmOrder" data-id="{{item.id}}">确认订单</view>
        </view>
      </view>
    </block>
    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 订单详情弹层 -->
  <view class="sheet-mask {{showDetail? 'show':''}}" catchtouchmove="true" bindtap="onCloseDetail"></view>
  <view class="sheet {{showDetail? 'show':''}}" catchtouchmove="true">
    <view class="sheet-header">
      <text class="sheet-desk">{{detail.deskNo}}#</text>
      <text class="sheet-status">{{detail.statusText}}</text>
    </view>
    <view class="sheet-items">
      <block wx:for="{{detail.items}}" wx:key="name">
        <view class="s-item">
          <image class="s-thumb" src="{{item.img}}" mode="aspectFill" />
          <view class="s-meta">
            <text class="s-name">{{item.name}}</text>
            <text class="s-price">¥{{item.price}}</text>
          </view>
          <text class="s-qty">x{{item.qty}}</text>
        </view>
      </block>
    </view>
    <view class="sheet-remark" wx:if="{{detail.remark}}">备注：{{detail.remark}}</view>

    <view class="sheet-line"><text>餐盒费</text><text>¥2</text></view>
    <view class="sheet-line"><text>配送费</text><text>¥4.5</text></view>
    <view class="sheet-line income"><text>预计收入</text><text class="red">¥24.5</text></view>

    <view class="sheet-info">
      <view class="i-row"><text class="i-label">配送信息</text><text class="i-value">呼啸声 17844110901\n井州学院五号楼402</text></view>
      <view class="i-row"><text class="i-label">订单号码</text><text class="i-value">202212458525125125</text></view>
      <view class="i-row"><text class="i-label">下单时间</text><text class="i-value">2022-10-10 15:15:44</text></view>
    </view>

    <view class="sheet-actions">
      <view class="btn ghost" bindtap="onCancelOrder">取消订单</view>
      <view class="btn primary" bindtap="onConfirmOrder">确认订单</view>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="tabbar">
    <view class="t-item {{bottomActive==='orders'?'active':''}}" bindtap="onBottomTap" data-tab="orders">
      <image class="t-img" src="{{bottomActive==='orders'? '/pages/小标/dingdan-copy.png' : '/pages/小标/dingdan.png'}}" mode="aspectFit" />
      <text class="t-txt">订单</text>
    </view>
    <view class="t-item {{bottomActive==='workbench'?'active':''}}" bindtap="onBottomTap" data-tab="workbench">
      <image class="t-img" src="{{bottomActive==='workbench'? '/pages/小标/商家1.png' : '/pages/小标/商家.png'}}" mode="aspectFit" />
      <text class="t-txt">工作台</text>
    </view>
    <view class="t-item {{bottomActive==='mine'?'active':''}}" bindtap="onBottomTap" data-tab="mine">
      <image class="t-img" src="{{bottomActive==='mine'? '/pages/小标/wode-copy.png' : '/pages/小标/wode.png'}}" mode="aspectFit" />
      <text class="t-txt">我的</text>
    </view>
  </view>
</view>


