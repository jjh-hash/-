<view class="page">

  <!-- 订单列表（仅展示已支付订单） -->
  <scroll-view 
    scroll-y 
    class="list"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscroll="onScroll"
  >
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-container">
      <text>加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view wx:elif="{{orders.length === 0 && !loading}}" class="empty-container">
      <text>暂无订单</text>
    </view>
    
    <!-- 订单列表 -->
    <block wx:elif="{{!loading && orders.length > 0}}">
      <block wx:for="{{orders}}" wx:key="id">
        <view class="order-card" bindtap="onOpenDetail" data-id="{{item.id}}">
          <view class="order-top">
            <text class="order-no">订单号：{{item.orderNo}}</text>
            <view class="status-wrapper">
              <text class="order-status-badge cancelled" wx:if="{{item.orderStatus === 'cancelled'}}">已取消</text>
              <text class="pay-status-badge paid" wx:elif="{{item.payStatus === 'paid'}}">已支付</text>
              <text class="refund-status-badge approved" wx:if="{{item.refundInfo && item.refundInfo.status === 'approved'}}">已退款</text>
              <text class="refund-status-badge rejected" wx:if="{{item.refundInfo && item.refundInfo.status === 'rejected'}}">拒绝退款</text>
            </view>
          </view>
          <view class="items">
            <block wx:for="{{item.items}}" wx:key="productId" wx:for-item="product">
              <view class="item">
                <image class="thumb" src="{{product.image}}" mode="aspectFill" />
                <view class="meta">
                  <text class="name">{{product.productName}}</text>
                  <text class="spec" wx:if="{{product.spec}}">{{product.spec}}</text>
                  <text class="price">¥{{product.price}}</text>
                </view>
                <text class="qty">x{{product.quantity}}</text>
              </view>
            </block>
          </view>
          <view class="remark" wx:if="{{item.remark}}">备注：{{item.remark}}</view>
          <view class="delivery-type-info">
            <text class="delivery-type-label">配送方式：</text>
            <text class="delivery-type-value {{item.deliveryType === 'pickup' ? 'pickup' : ''}}">{{item.deliveryType === 'pickup' ? '自取' : '外送'}}</text>
          </view>
          <view class="address-info" wx:if="{{item.address && item.deliveryType === 'delivery'}}">
            <view class="address-line">
              <text class="address-label">联系人：</text>
              <text>{{item.address.name}}</text>
            </view>
            <view class="address-line">
              <text class="address-label">电话：</text>
              <text>{{item.address.phone}}</text>
            </view>
            <view class="address-line">
              <text class="address-label">地址：</text>
              <text>{{item.address.buildingName}}{{item.address.houseNumber}}{{item.address.addressDetail}}</text>
            </view>
          </view>
          <view class="pickup-info" wx:if="{{item.deliveryType === 'pickup'}}">
            <text class="pickup-text">顾客将到店自取</text>
          </view>
          <view class="total-info">
            <text>商家收入：¥{{item.merchantIncome}}</text>
          </view>
          <view class="actions" catchtap="stopPropagation">
            <view class="btn ghost" bindtap="onContactUser" data-id="{{item.id}}">联系用户</view>
            <view class="btn refund" catchtap="onViewRefund" data-id="{{item.id}}" wx:if="{{item.refundInfo && (item.refundInfo.status === 'pending' || item.refundInfo.status === 'processing')}}">申请退款</view>
            <view class="btn cancelled" wx:if="{{item.orderStatus === 'cancelled'}}">订单已取消</view>
          </view>
        </view>
      </block>
    </block>
    
    <view class="safe-area-bottom"></view>
  </scroll-view>

  <!-- 订单详情弹层 -->
  <view class="sheet-mask {{showDetail? 'show':''}}" catchtouchmove="true" bindtap="onCloseDetail"></view>
  <view class="sheet {{showDetail? 'show':''}}" catchtouchmove="true">
    <view class="sheet-header">
      <text class="sheet-desk">{{detail.deskNo}}#</text>
      <view class="sheet-status-wrapper">
        <text class="order-status-badge cancelled" wx:if="{{detail.orderStatus === 'cancelled'}}">已取消</text>
        <text class="pay-status-badge paid" wx:elif="{{detail.payStatus === 'paid'}}">已支付</text>
      </view>
    </view>
    <scroll-view scroll-y class="sheet-items">
      <block wx:for="{{detail.items}}" wx:key="name">
        <view class="s-item">
          <image class="s-thumb" src="{{item.img}}" mode="aspectFill" />
          <view class="s-meta">
            <text class="s-name">{{item.name}}</text>
            <text class="s-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
            <text class="s-price">¥{{item.price}}</text>
          </view>
          <text class="s-qty">x{{item.qty}}</text>
        </view>
      </block>
    </scroll-view>
    <view class="sheet-remark" wx:if="{{detail.remark}}">备注：{{detail.remark}}</view>
    
    <view class="delivery-type-info" style="margin-top:6px;margin-bottom:6px">
      <text class="delivery-type-label">配送方式：</text>
      <text class="delivery-type-value {{detail.deliveryType === 'pickup' ? 'pickup' : ''}}">{{detail.deliveryType === 'pickup' ? '自取' : '外送'}}</text>
    </view>
    
    <view class="address-info" wx:if="{{detail.address && detail.deliveryType === 'delivery'}}" style="margin-bottom:6px">
      <view class="address-line">
        <text class="address-label">联系人：</text>
        <text>{{detail.address.name}}</text>
      </view>
      <view class="address-line">
        <text class="address-label">电话：</text>
        <text>{{detail.address.phone}}</text>
      </view>
      <view class="address-line">
        <text class="address-label">地址：</text>
        <text>{{detail.address.buildingName}}{{detail.address.houseNumber}}{{detail.address.addressDetail}}</text>
      </view>
    </view>
    <view class="pickup-info" wx:if="{{detail.deliveryType === 'pickup'}}" style="margin-bottom:6px">
      <text class="pickup-text">顾客将到店自取</text>
    </view>

    <view class="sheet-line"><text>商品金额</text><text>¥{{detail.amountGoods || '0.00'}}</text></view>
    <view class="sheet-line"><text>平台服务费</text><text>-¥{{detail.platformFee || '0.00'}}</text></view>
    <view class="sheet-line"><text>配送费</text><text>¥{{detail.amountDelivery || '0.00'}}</text></view>
    <view class="sheet-line" wx:if="{{detail.amountDiscount > 0}}"><text>优惠</text><text>-¥{{detail.amountDiscount}}</text></view>
    <view class="sheet-line income"><text>商家收入</text><text class="red">¥{{detail.merchantIncome}}</text></view>
    <view class="sheet-line"><text>顾客支付</text><text>¥{{detail.amountTotal || '0.00'}}</text></view>
    <view class="sheet-line"><text>餐具</text><text>{{detail.needCutlery ? (detail.cutleryQuantity > 0 ? detail.cutleryQuantity + '份' : '需要') : '不需要'}}</text></view>

    <view class="sheet-info">
      <view class="i-row" wx:if="{{detail.address && detail.deliveryType === 'delivery'}}">
        <text class="i-label">配送信息</text>
        <text class="i-value">{{detail.address.name}} {{detail.address.phone}}\n{{detail.address.fullAddress}}</text>
      </view>
      <view class="i-row" wx:if="{{detail.deliveryType === 'pickup'}}">
        <text class="i-label">配送方式</text>
        <text class="i-value" style="color:#ff9800;font-weight:600">自取（顾客到店自取）</text>
      </view>
      <view class="i-row"><text class="i-label">订单号码</text><text class="i-value">{{detail.orderNo}}</text></view>
      <view class="i-row"><text class="i-label">下单时间</text><text class="i-value">{{detail.createdAt}}</text></view>
      <view class="i-row" wx:if="{{detail.expiredAt && detail.orderStatus !== 'completed' && detail.orderStatus !== 'cancelled'}}">
        <text class="i-label">订单超时</text>
        <text class="i-value {{detail.expiredMinutes < 0 ? 'expired' : ''}}">
          <text wx:if="{{detail.expiredMinutes === null}}">{{detail.expiredAt}}</text>
          <text wx:elif="{{detail.expiredMinutes < 0}}">已超时</text>
          <text wx:else>剩余{{detail.expiredMinutes}}分钟</text>
        </text>
      </view>
      <view class="i-row" wx:if="{{detail.readyAt}}">
        <text class="i-label">出餐时间</text>
        <text class="i-value">{{detail.readyAt}}</text>
      </view>
    </view>

    <!-- 退款申请信息 -->
    <view class="refund-section" wx:if="{{detail.refundInfo}}">
      <view class="refund-header">
        <text class="refund-title">退款申请</text>
        <text class="refund-status {{detail.refundInfo.status}}">
          {{detail.refundInfo.status === 'pending' ? '待处理' : detail.refundInfo.status === 'approved' ? '已退款' : detail.refundInfo.status === 'rejected' ? '拒绝退款' : '处理中'}}
        </text>
      </view>
      <view class="refund-content">
        <view class="refund-row">
          <text class="refund-label">退款单号：</text>
          <text class="refund-value">{{detail.refundInfo.refundNo}}</text>
        </view>
        <view class="refund-row">
          <text class="refund-label">退款原因：</text>
          <text class="refund-value">{{detail.refundInfo.refundReason}}</text>
        </view>
        <view class="refund-row" wx:if="{{detail.refundInfo.refundReasonText}}">
          <text class="refund-label">原因描述：</text>
          <text class="refund-value">{{detail.refundInfo.refundReasonText}}</text>
        </view>
        <view class="refund-row">
          <text class="refund-label">退款金额：</text>
          <text class="refund-value refund-amount">¥{{detail.refundInfo.refundAmount}}</text>
        </view>
        <view class="refund-row">
          <text class="refund-label">申请时间：</text>
          <text class="refund-value">{{detail.refundInfo.createdAt}}</text>
        </view>
        <!-- 退款商品 -->
        <view class="refund-items" wx:if="{{detail.refundInfo.selectedItems && detail.refundInfo.selectedItems.length > 0}}">
          <text class="refund-label">退款商品：</text>
          <view class="refund-items-list">
            <block wx:for="{{detail.refundInfo.selectedItems}}" wx:key="id">
              <view class="refund-item-tag">
                {{item.productName}} x{{item.quantity}}
              </view>
            </block>
          </view>
        </view>
        <!-- 退款图片 -->
        <view class="refund-images" wx:if="{{detail.refundInfo.images && detail.refundInfo.images.length > 0}}">
          <text class="refund-label">退款凭证：</text>
          <view class="refund-images-list">
            <block wx:for="{{detail.refundInfo.images}}" wx:key="index" wx:for-index="imgIdx">
              <image class="refund-image" src="{{item}}" mode="aspectFill" bindtap="onPreviewRefundImage" data-index="{{imgIdx}}"></image>
            </block>
          </view>
        </view>
      </view>
    </view>

    <view class="sheet-actions">
      <view class="btn ghost" bindtap="onContactUser" data-id="{{detail.id}}">联系用户</view>
      <view class="btn cancelled" wx:if="{{detail.orderStatus === 'cancelled'}}">订单已取消</view>
      <!-- 退款申请操作按钮 -->
      <view class="refund-actions" wx:if="{{detail.refundInfo && detail.refundInfo.status === 'pending'}}">
        <view class="btn reject" bindtap="onRejectRefund">拒绝退款</view>
        <view class="btn approve" bindtap="onApproveRefund">同意退款</view>
      </view>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="tabbar">
    <view class="t-item {{bottomActive==='orders'?'active':''}}" bindtap="onBottomTap" data-tab="orders">
      <image class="t-img" src="{{bottomActive==='orders'? '/pages/小标/dingdan-copy.png' : '/pages/小标/dingdan.png'}}" mode="aspectFit" />
      <text class="t-txt">订单</text>
    </view>
    <view class="t-item {{bottomActive==='workbench'?'active':''}}" bindtap="onBottomTap" data-tab="workbench">
      <image class="t-img" src="{{bottomActive==='workbench'? '/pages/小标/商家1.png' : '/pages/小标/商家.png'}}" mode="aspectFit" />
      <text class="t-txt">工作台</text>
    </view>
    <view class="t-item {{bottomActive==='mine'?'active':''}}" bindtap="onBottomTap" data-tab="mine">
      <image class="t-img" src="{{bottomActive==='mine'? '/pages/小标/wode-copy.png' : '/pages/小标/wode.png'}}" mode="aspectFit" />
      <text class="t-txt">我的</text>
    </view>
  </view>
</view>


