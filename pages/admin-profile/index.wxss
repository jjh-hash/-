/* pages/admin-profile/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 100rpx;
}

.status-bar {
  background: transparent;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.back-btn {
  font-size: 36rpx;
  color: white;
  padding: 10rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.nav-actions {
  display: flex;
  align-items: center;
}

.logout-btn {
  font-size: 28rpx;
  color: white;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

.page-content {
  padding: 30rpx;
}

/* 管理员信息卡片 */
.admin-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
}

.admin-avatar {
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
}

.admin-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.admin-info {
  flex: 1;
}

.admin-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #495057;
  margin-bottom: 10rpx;
}

.admin-role {
  display: block;
  font-size: 28rpx;
  color: #6c757d;
  margin-bottom: 10rpx;
}

.admin-status {
  display: inline-block;
  font-size: 24rpx;
  color: #28a745;
  background: #d4edda;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 功能菜单 */
.menu-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f8f9fa;
  transition: background-color 0.3s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f8f9fa;
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.menu-icon image {
  width: 100%;
  height: 100%;
}

.menu-content {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #495057;
  margin-bottom: 8rpx;
}

.menu-desc {
  display: block;
  font-size: 24rpx;
  color: #6c757d;
}

.menu-arrow {
  font-size: 32rpx;
  color: #6c757d;
}

/* 系统信息 */
.system-info {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #495057;
  margin-bottom: 20rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.info-label {
  font-size: 24rpx;
  color: #6c757d;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #495057;
}

/* 底部导航栏 */
.admin-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-around;
  z-index: 1000;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 10rpx;
  transition: all 0.3s ease;
}

.tabbar-item.active {
  transform: scale(1.1);
}

.tabbar-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.tabbar-icon image {
  width: 100%;
  height: 100%;
}

.tabbar-text {
  font-size: 20rpx;
  color: #7A7E83;
  transition: color 0.3s ease;
}

.tabbar-item.active .tabbar-text {
  color: #3cc51f;
  font-weight: bold;
}