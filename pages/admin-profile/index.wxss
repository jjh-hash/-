/* pages/admin-profile/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx; /* 为底部导航栏预留空间 */
}

/* 底部导航栏样式 */
.admin-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  display: flex;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
  transition: all 0.3s ease;
}

.tabbar-item.active {
  color: #007aff;
}

.tabbar-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.tabbar-icon image {
  width: 100%;
  height: 100%;
}

.tabbar-text {
  font-size: 20rpx;
  color: #999999;
  transition: color 0.3s ease;
}

.tabbar-item.active .tabbar-text {
  color: #007aff;
  font-weight: 500;
}