<!--pages/admin-profile/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBack">◀</view>
    <text class="title">管理员信息</text>
    <view class="nav-actions">
      <text class="refresh-btn" bindtap="onRefresh">🔄</text>
    </view>
  </view>

  <!-- 页面内容 -->
  <view class="page-content">
    <!-- 管理员基本信息 -->
    <view class="admin-info-section">
      <text class="section-title">管理员信息</text>
      <view class="admin-card">
        <view class="admin-avatar">
          <image src="/pages/小标/wode.png" mode="aspectFit"></image>
        </view>
        <view class="admin-details">
          <text class="admin-name">超级管理员</text>
          <text class="admin-role">系统管理员</text>
          <text class="admin-id">ID: admin_001</text>
        </view>
      </view>
    </view>

    <!-- 登录信息 -->
    <view class="login-info-section">
      <text class="section-title">登录信息</text>
      <view class="info-cards">
        <view class="info-card">
          <text class="info-label">最后登录时间</text>
          <text class="info-value">{{loginInfo.lastLoginTime}}</text>
        </view>
        <view class="info-card">
          <text class="info-label">登录IP地址</text>
          <text class="info-value">{{loginInfo.lastLoginIP}}</text>
        </view>
        <view class="info-card">
          <text class="info-label">登录设备</text>
          <text class="info-value">{{loginInfo.loginDevice}}</text>
        </view>
        <view class="info-card">
          <text class="info-label">在线时长</text>
          <text class="info-value">{{loginInfo.onlineDuration}}</text>
        </view>
      </view>
    </view>

    <!-- 权限信息 -->
    <view class="permission-section">
      <text class="section-title">权限信息</text>
      <view class="permission-list">
        <view class="permission-item">
          <text class="permission-icon">👥</text>
          <text class="permission-name">用户管理</text>
          <text class="permission-status active">已授权</text>
        </view>
        <view class="permission-item">
          <text class="permission-icon">🏪</text>
          <text class="permission-name">商家管理</text>
          <text class="permission-status active">已授权</text>
        </view>
        <view class="permission-item">
          <text class="permission-icon">📦</text>
          <text class="permission-name">订单管理</text>
          <text class="permission-status active">已授权</text>
        </view>
        <view class="permission-item">
          <text class="permission-icon">💰</text>
          <text class="permission-name">财务管理</text>
          <text class="permission-status active">已授权</text>
        </view>
        <view class="permission-item">
          <text class="permission-icon">⚙️</text>
          <text class="permission-name">系统设置</text>
          <text class="permission-status active">已授权</text>
        </view>
      </view>
    </view>

    <!-- 操作记录 -->
    <view class="operation-section">
      <text class="section-title">最近操作记录</text>
      <view class="operation-list">
        <view class="operation-item" wx:for="{{operationLogs}}" wx:key="index">
          <view class="operation-icon">
            <text class="icon">{{item.icon}}</text>
          </view>
          <view class="operation-content">
            <text class="operation-title">{{item.title}}</text>
            <text class="operation-desc">{{item.description}}</text>
            <text class="operation-time">{{item.time}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 系统设置 -->
    <view class="settings-section">
      <text class="section-title">系统设置</text>
      <view class="settings-list">
        <view class="setting-item" bindtap="onSettingClick" data-setting="password">
          <text class="setting-icon">🔒</text>
          <text class="setting-name">修改密码</text>
          <text class="setting-arrow">></text>
        </view>
        <view class="setting-item" bindtap="onSettingClick" data-setting="notification">
          <text class="setting-icon">🔔</text>
          <text class="setting-name">通知设置</text>
          <text class="setting-arrow">></text>
        </view>
        <view class="setting-item" bindtap="onSettingClick" data-setting="security">
          <text class="setting-icon">🛡️</text>
          <text class="setting-name">安全设置</text>
          <text class="setting-arrow">></text>
        </view>
        <view class="setting-item" bindtap="onSettingClick" data-setting="logout">
          <text class="setting-icon">🚪</text>
          <text class="setting-name">退出登录</text>
          <text class="setting-arrow">></text>
        </view>
      </view>
    </view>
  </view>
</view>