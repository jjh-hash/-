/* pages/login-modal-demo/index.wxss */
.container {
  padding: 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.status-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.status-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label {
  font-size: 32rpx;
  color: #666;
  margin-right: 20rpx;
  min-width: 120rpx;
}

.value {
  font-size: 32rpx;
  color: #333;
  flex: 1;
}

.value.success {
  color: #52c41a;
  font-weight: bold;
}

.value.error {
  color: #ff4d4f;
  font-weight: bold;
}

.user-info {
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 2rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-item .label {
  font-size: 28rpx;
  color: #999;
  min-width: 140rpx;
}

.info-item .value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.button-section {
  margin-bottom: 40rpx;
}

.demo-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.demo-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.demo-btn.secondary {
  background-color: #1890ff;
  color: #fff;
}

.demo-btn.warning {
  background-color: #faad14;
  color: #fff;
}

.demo-btn.info {
  background-color: #13c2c2;
  color: #fff;
}

.demo-btn.danger {
  background-color: #ff4d4f;
  color: #fff;
}

.demo-btn.outline {
  background-color: transparent;
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

.settings-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.tips-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.tips-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
}

.tips-content text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.code-section {
  background-color: #f8f9fa;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.code-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.code-content {
  display: flex;
  flex-direction: column;
}

.code-content text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 8rpx;
  font-family: 'Courier New', monospace;
  background-color: #fff;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  border-left: 4rpx solid #1890ff;
}
