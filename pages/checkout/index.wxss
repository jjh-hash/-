.page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100px;
}

/* 导航栏 */
.nav {
  background: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.status-bar {
  width: 100%;
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  position: relative;
}

.back {
  font-size: 18px;
  color: #333;
  font-weight: 600;
}

.title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.icons {
  display: flex;
  align-items: center;
  gap: 4px;
}

.dot {
  font-size: 12px;
  color: #999;
}

.battery {
  font-size: 12px;
  color: #999;
}

/* 内容区域 */
.content {
  margin-top: 100px;
  padding: 0 16px;
}

/* 店铺信息 */
.store-info {
  background: #fff;
  padding: 16px;
  border-radius: 8px;
  margin-bottom: 12px;
}

.store-name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.store-announcement {
  font-size: 14px;
  color: #666;
  line-height: 1.4;
}

/* 收货地址 */
.address-section {
  background: #fff;
  padding: 16px;
  border-radius: 8px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.address-icon {
  font-size: 20px;
  color: #1976d2;
}

.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 4px;
}

.user-name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.user-phone {
  font-size: 14px;
  color: #666;
}

.address-detail {
  font-size: 14px;
  color: #666;
  line-height: 1.4;
}

.edit-icon {
  font-size: 16px;
  color: #999;
}

/* 订单商品 */
.order-items {
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  padding: 16px 16px 12px;
  border-bottom: 1px solid #f0f0f0;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f8f9fa;
}

.order-item:last-child {
  border-bottom: none;
}

.item-image {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  margin-right: 12px;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.item-name {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.item-spec {
  font-size: 12px;
  color: #666;
}

.item-price {
  font-size: 14px;
  font-weight: 600;
  color: #ff4757;
}

.item-quantity {
  font-size: 14px;
  color: #666;
  font-weight: 600;
}

/* 配送信息 */
.delivery-section {
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
}

.delivery-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f8f9fa;
}

.delivery-item:last-child {
  border-bottom: none;
}

.delivery-label {
  font-size: 14px;
  color: #333;
}

.delivery-value {
  font-size: 14px;
  color: #666;
}

/* 支付方式 */
.payment-section {
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
}

.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f8f9fa;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-item.active {
  background: #f8f9ff;
}

.payment-info {
  display: flex;
  align-items: center;
  gap: 12px;
}

.payment-icon {
  font-size: 18px;
}

.payment-name {
  font-size: 14px;
  color: #333;
}

.payment-radio {
  width: 20px;
  height: 20px;
  border: 2px solid #ddd;
  border-radius: 50%;
  position: relative;
}

.payment-radio.checked {
  border-color: #1976d2;
  background: #1976d2;
}

.payment-radio.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8px;
  height: 8px;
  background: #fff;
  border-radius: 50%;
}

/* 备注 */
.remark-section {
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
}

.remark-input {
  width: 100%;
  min-height: 80px;
  padding: 16px;
  border: none;
  font-size: 14px;
  color: #333;
  background: transparent;
}

.remark-input::placeholder {
  color: #999;
}

/* 底部结算栏 */
.checkout-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.total-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.total-label {
  font-size: 14px;
  color: #666;
}

.total-amount {
  font-size: 20px;
  font-weight: 600;
  color: #ff4757;
}

.submit-btn {
  background: #1976d2;
  padding: 12px 32px;
  border-radius: 25px;
  flex-shrink: 0;
}

.submit-text {
  color: #fff;
  font-size: 16px;
  font-weight: 600;
}
