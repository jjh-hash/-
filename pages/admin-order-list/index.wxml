<!--pages/admin-order-list/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBack">◀</view>
    <text class="title">管理系统</text>
    <view class="nav-actions">
      <text class="refresh-btn" bindtap="onRefresh">🔄</text>
    </view>
  </view>

  <!-- 筛选条件 -->
  <view class="filter-section">
    <view class="filter-tabs">
      <view class="filter-tab {{currentFilter === 'all' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="all">
        全部
      </view>
      <view class="filter-tab {{currentFilter === 'unpaid' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="unpaid">
        待支付
      </view>
      <view class="filter-tab {{currentFilter === 'paid' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="paid">
        已支付
      </view>
      <view class="filter-tab {{currentFilter === 'completed' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="completed">
        已完成
      </view>
      <view class="filter-tab {{currentFilter === 'cancelled' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="cancelled">
        已取消
      </view>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-item" wx:for="{{orderList}}" wx:key="id" bindtap="onOrderDetail" data-order="{{item}}">
      <view class="order-header">
        <view class="order-info">
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-time">{{item.createdAt}}</text>
        </view>
        <view class="order-status {{item.payStatus}}">
          {{item.statusText}}
        </view>
      </view>
      
      <view class="order-content">
        <view class="store-info">
          <image class="store-logo" src="{{item.storeLogo}}" mode="aspectFill"></image>
          <view class="store-details">
            <text class="store-name">{{item.storeName}}</text>
            <text class="store-address">{{item.storeAddress}}</text>
          </view>
        </view>
        
        <view class="order-items">
          <view class="order-item-info" wx:for="{{item.items}}" wx:key="id" wx:for-item="orderItem">
            <text class="item-name">{{orderItem.name}}</text>
            <text class="item-spec" wx:if="{{orderItem.spec}}">{{orderItem.spec}}</text>
            <text class="item-price">¥{{orderItem.price}}</text>
            <text class="item-quantity">x{{orderItem.quantity}}</text>
          </view>
        </view>
        
        <view class="order-summary">
          <view class="summary-row">
            <text class="summary-label">商品金额</text>
            <text class="summary-value">¥{{item.amountGoods}}</text>
          </view>
          <view class="summary-row">
            <text class="summary-label">配送费</text>
            <text class="summary-value">¥{{item.amountDelivery}}</text>
          </view>
          <view class="summary-row total">
            <text class="summary-label">实付金额</text>
            <text class="summary-value">¥{{item.amountPayable}}</text>
          </view>
        </view>
      </view>
      
      <view class="order-actions" wx:if="{{item.payStatus === 'paid'}}">
        <button class="action-btn secondary" bindtap="onOrderAction" data-action="cancel" data-order="{{item}}">
          取消订单
        </button>
        <button class="action-btn primary" bindtap="onOrderAction" data-action="complete" data-order="{{item}}">
          完成订单
        </button>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{orderList.length === 0}}">
      <image class="empty-icon" src="/pages/小标/dingdan.png" mode="aspectFit"></image>
      <text class="empty-text">暂无订单数据</text>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <admin-tabbar currentTab="{{currentTab}}" bind:tabchange="onTabChange"></admin-tabbar>
</view>
