/* pages/admin-order-list/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 100rpx;
}

.status-bar {
  background: transparent;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.back-btn {
  font-size: 36rpx;
  color: white;
  padding: 10rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.nav-actions {
  display: flex;
  align-items: center;
}

.refresh-btn {
  font-size: 32rpx;
  color: white;
  padding: 10rpx;
}

.page-content {
  padding: 30rpx;
}

/* 筛选栏 */
.filter-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.filter-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.picker-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
}

.picker-text {
  font-size: 28rpx;
  color: #495057;
}

.picker-arrow {
  font-size: 24rpx;
  color: #6c757d;
}

.search-bar {
  position: relative;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  padding: 20rpx 50rpx 20rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
  font-size: 28rpx;
}

.search-icon {
  position: absolute;
  right: 20rpx;
  font-size: 28rpx;
  color: #6c757d;
}

/* 订单列表 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.order-item:active {
  transform: scale(0.98);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f8f9fa;
}

.order-no {
  font-size: 32rpx;
  font-weight: bold;
  color: #495057;
}

.order-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.order-status.created {
  background: #fff3cd;
  color: #856404;
}

.order-status.accepted {
  background: #d1ecf1;
  color: #0c5460;
}

.order-status.making {
  background: #d4edda;
  color: #155724;
}

.order-status.delivering {
  background: #cce5ff;
  color: #004085;
}

.order-status.completed {
  background: #d1ecf1;
  color: #0c5460;
}

.order-status.cancelled {
  background: #f8d7da;
  color: #721c24;
}

.order-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.info-label {
  font-size: 28rpx;
  color: #6c757d;
  width: 160rpx;
}

.info-value {
  font-size: 28rpx;
  color: #495057;
  flex: 1;
}

.info-value.amount {
  font-weight: bold;
  color: #28a745;
}

.info-value.unpaid {
  color: #dc3545;
}

.info-value.paid {
  color: #28a745;
}

.info-value.refunding {
  color: #ffc107;
}

.info-value.refunded {
  color: #6c757d;
}

.order-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  transition: all 0.3s ease;
}

.action-btn.primary {
  background: linear-gradient(135deg, #007bff, #0056b3);
  color: white;
}

.action-btn.primary:active {
  background: linear-gradient(135deg, #0056b3, #004085);
}

.action-btn.danger {
  background: linear-gradient(135deg, #dc3545, #c82333);
  color: white;
}

.action-btn.danger:active {
  background: linear-gradient(135deg, #c82333, #bd2130);
}

/* 加载状态 */
.loading-section {
  text-align: center;
  padding: 60rpx;
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 空状态 */
.empty-section {
  text-align: center;
  padding: 100rpx 60rpx;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 底部导航栏 */
.admin-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-around;
  z-index: 1000;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 10rpx;
  transition: all 0.3s ease;
}

.tabbar-item.active {
  transform: scale(1.1);
}

.tabbar-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.tabbar-icon image {
  width: 100%;
  height: 100%;
}

.tabbar-text {
  font-size: 20rpx;
  color: #7A7E83;
  transition: color 0.3s ease;
}

.tabbar-item.active .tabbar-text {
  color: #3cc51f;
  font-weight: bold;
}