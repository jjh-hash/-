<view class="page profile-page">
  <!-- 状态栏占位，避免头像/昵称被遮挡 -->
  <view class="status-bar-spacer" style="height: {{statusBarHeight}}px;"></view>
  <!-- 用户信息区域 -->
  <view class="profile-section" bindtap="editUserInfo">
    <view class="avatar">
      <image class="avatar-img" src="{{userInfo.avatar}}" mode="aspectFill" wx:if="{{userInfo.avatar}}" />
      <view class="avatar-placeholder" wx:else>
        <text class="avatar-placeholder-text">{{userInfo.nickname ? userInfo.nickname.substring(0, 1) : '用'}}</text>
      </view>
    </view>
    <text class="nickname">{{userInfo.nickname || '微信用户'}}</text>
  </view>

  <user-info-modal
    id="userInfoModal"
    show="{{showUserInfoModal}}"
    userInfo="{{userInfo}}"
    bind:close="onCloseUserInfoModal"
    bind:update="onUpdateUserInfo"
  />

  <!-- 白色内容区：宫格入口 -->
  <view class="profile-content">
    <view class="menu-section" wx:for="{{menuSections}}" wx:key="title">
      <text class="section-title">{{item.title}}</text>
      <view class="menu-grid menu-grid-cols-{{item.cols || 2}}">
        <view
          class="menu-grid-item ds-press"
          wx:for="{{item.items}}"
          wx:for-item="entry"
          wx:key="type"
          bindtap="onMenuTap"
          data-type="{{entry.type}}"
        >
          <view class="grid-icon-wrap">
            <image class="grid-icon" src="{{entry.icon}}" mode="aspectFit" />
          </view>
          <text class="grid-text">{{entry.text}}</text>
          <text class="grid-extra" wx:if="{{entry.extra}}">{{entry.extra}}</text>
          <text class="grid-desc" wx:if="{{entry.desc}}">{{entry.desc}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
