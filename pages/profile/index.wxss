/* 个人中心 - 宫格布局，省空间 */
.profile-page {
  background: linear-gradient(180deg, var(--color-primary) 0%, #E5A500 100%);
  min-height: 100vh;
  /* 兼容刘海屏/手势条：先保底 100px，再叠加安全区（不支持 calc 的机型仍保留保底） */
  padding-bottom: 100px;
  padding-bottom: calc(100px + constant(safe-area-inset-bottom));
  padding-bottom: calc(100px + env(safe-area-inset-bottom, 0px));
  box-sizing: border-box;
  max-width: 100%;
  overflow-x: hidden;
}

.nav { background: transparent; color: #fff; }
.status-bar { width: 100%; }
.nav-bar { height: 44px; display: flex; align-items: center; justify-content: space-between; padding: 0 var(--space-page); }
.back { opacity: 0.9; }
.title { font-size: 18px; font-weight: 600; }
.icons { font-size: 16px; opacity: 0.9; }

.status-bar-spacer {
  width: 100%;
  flex-shrink: 0;
}
.profile-section {
  background: transparent;
  padding: 20px var(--space-page) 28px;
  padding-top: 24px;
  display: flex;
  align-items: flex-start;
}
.profile-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding-top: 4px;
}
.campus-tip {
  background: rgba(255, 255, 255, 0.22);
  border-radius: 10px;
  padding: 10px 12px;
}
.campus-tip-text {
  color: #fff;
  font-size: 13px;
  line-height: 1.45;
  word-break: break-word;
  overflow-wrap: anywhere;
}
.avatar { margin-right: 18px; flex-shrink: 0; }
.avatar-img {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: var(--color-bg-card);
  border: 3px solid rgba(255,255,255,0.4);
  box-sizing: border-box;
}
.avatar-placeholder {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  border: 3px solid rgba(255,255,255,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.avatar-empty {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  border: 3px solid rgba(255,255,255,0.45);
  box-sizing: border-box;
}
.avatar-placeholder-text { color: #fff; font-size: 26px; font-weight: 600; }
.nickname { color: #fff; font-size: 18px; font-weight: 600; letter-spacing: 0.5px; }

.profile-content {
  background: var(--color-bg-card);
  border-radius: 20px;
  padding: var(--space-page);
  min-height: 50vh;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
  box-sizing: border-box;
  max-width: 100%;
}

/* 分区标题 */
.menu-section {
  margin-bottom: 20px;
}
.menu-section:last-child {
  margin-bottom: 0;
}
.section-title {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12px;
  padding-left: 2px;
}

/* 宫格：固定每个入口尺寸，不使用弹性布局 */
.menu-grid {
  display: block;
  font-size: 0;
  letter-spacing: 0;
}
.menu-grid-item {
  display: inline-block;
  vertical-align: top;
  width: 100px;
  min-height: 88px;
  margin-right: 10px;
  margin-bottom: 12px;
  padding: 12px 8px;
  background: var(--color-bg-page);
  border-radius: var(--radius-card);
  border: 1px solid var(--color-border);
  box-sizing: border-box;
  text-align: center;
  font-size: 14px;
  transition: background var(--transition-fast);
}
.menu-grid-item:nth-child(2n) {
  margin-right: 0;
}
.menu-grid-cols-3 .menu-grid-item:nth-child(2n) {
  margin-right: 10px;
}
.menu-grid-cols-3 .menu-grid-item:nth-child(3n) {
  margin-right: 0;
}
.menu-grid-item:active {
  background: var(--color-primary-light);
}

.grid-icon-wrap {
  width: 40px;
  height: 40px;
  margin: 0 auto 8px;
  border-radius: 10px;
  background: var(--color-primary-light);
  text-align: center;
  line-height: 40px;
}
.grid-icon {
  width: 22px;
  height: 22px;
  vertical-align: middle;
}
.grid-text {
  font-size: 13px;
  font-weight: 500;
  color: var(--color-text);
  line-height: 1.3;
  display: block;
}
.grid-extra {
  font-size: 11px;
  color: var(--color-text-placeholder);
  margin-top: 2px;
}
.grid-desc {
  font-size: 11px;
  color: var(--color-text-secondary);
  margin-top: 4px;
  line-height: 1.3;
}
