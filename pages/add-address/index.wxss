/* 导航 */
.nav{ background:#fff; }
.nav-bar{ height:44px; display:flex; align-items:center; justify-content:center; border-bottom:1px solid #f1f3f5; }
.back{ position:absolute; left:12px; color:#374151; }
.title{ font-size:17px; font-weight:600; color:#111827; }

.content{ height: calc(100vh - 120px); background:#f5f6f8; }

/* 表单区域 */
.form-section{ background:#fff; margin:12px; border-radius:12px; overflow:hidden; }
.form-item{ 
  display:flex; 
  align-items:center; 
  padding:16px; 
  border-bottom:1px solid #f1f3f5; 
  min-height:60px;
}
.form-item:last-child{ border-bottom:none; }

.form-icon{ 
  width:24px; 
  height:24px; 
  margin-right:12px; 
  display:flex; 
  align-items:center; 
  justify-content:center; 
}

.form-icon-img{ width:22px; height:22px; }

.form-content{ flex:1; display:flex; flex-direction:column; }
.form-label{ font-size:14px; color:#6b7280; margin-bottom:4px; }
.form-value{ font-size:16px; color:#1f2937; }
.form-input{ font-size:16px; color:#1f2937; border:none; outline:none; }

.form-arrow{ color:#9ca3af; font-size:16px; }

/* 底部按钮 */
.footer{ position:fixed; left:0; right:0; bottom:0; background:#fff; padding:20px 40px env(safe-area-inset-bottom); }
.btn-confirm{ width:100%; background:#1a73e8; color:#fff; border:none; border-radius:999px; height:48px; font-size:16px; font-weight:600; text-transform:uppercase; }
