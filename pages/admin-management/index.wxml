<!--pages/admin-management/index.wxml-->
<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="onBack">◀</view>
    <text class="title">管理系统</text>
    <view class="nav-actions">
      <text class="refresh-btn" bindtap="onRefresh">🔄</text>
    </view>
  </view>

  <!-- 页面内容 -->
  <view class="page-content">
    <!-- 管理功能菜单 -->
    <view class="management-section">
      <text class="section-title">管理功能</text>
      <view class="menu-grid">
        <view 
          class="menu-item" 
          wx:for="{{managementMenus}}" 
          wx:key="id"
          bindtap="onMenuTap"
          data-id="{{item.id}}"
          style="border-left: 4px solid {{item.color}}"
        >
          <view class="menu-icon">
            <image src="{{item.icon}}" mode="aspectFit"></image>
          </view>
          <view class="menu-content">
            <text class="menu-title">{{item.title}}</text>
            <text class="menu-description">{{item.description}}</text>
          </view>
          <view class="menu-arrow">></view>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions-section">
      <text class="section-title">快捷操作</text>
      <view class="quick-actions">
        <view class="quick-action-item" bindtap="onQuickAction" data-action="approve">
          <view class="action-icon approve">✓</view>
          <text class="action-text">批量审核</text>
        </view>
        
        <view class="quick-action-item" bindtap="onQuickAction" data-action="export">
          <view class="action-icon export">📊</view>
          <text class="action-text">数据导出</text>
        </view>
        
        <view class="quick-action-item" bindtap="onQuickAction" data-action="notice">
          <view class="action-icon notice">📢</view>
          <text class="action-text">发布公告</text>
        </view>
        
        <view class="quick-action-item" bindtap="onQuickAction" data-action="backup">
          <view class="action-icon backup">💾</view>
          <text class="action-text">数据备份</text>
        </view>
      </view>
    </view>

    <!-- 系统状态 -->
    <view class="system-status-section">
      <text class="section-title">系统状态</text>
      <view class="status-cards">
        <view class="status-card">
          <view class="status-header">
            <text class="status-title">数据库</text>
            <view class="status-indicator online"></view>
          </view>
          <text class="status-text">运行正常</text>
        </view>
        
        <view class="status-card">
          <view class="status-header">
            <text class="status-title">支付系统</text>
            <view class="status-indicator online"></view>
          </view>
          <text class="status-text">连接正常</text>
        </view>
        
        <view class="status-card">
          <view class="status-header">
            <text class="status-title">存储服务</text>
            <view class="status-indicator online"></view>
          </view>
          <text class="status-text">可用</text>
        </view>
        
        <view class="status-card">
          <view class="status-header">
            <text class="status-title">消息推送</text>
            <view class="status-indicator warning"></view>
          </view>
          <text class="status-text">部分延迟</text>
        </view>
      </view>
    </view>
  </view>
</view>