.page{min-height:100vh;background:#f5f5f5}
.status-bar{width:100%}
.nav-bar{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center;position:relative}
.title{font-size:18px;color:#333;font-weight:600}
.back-btn{position:absolute;left:12px;color:#333;font-size:18px;cursor:pointer}

.page-content{height:calc(100vh - 44px);padding:12px}

.section{background:#fff;border-radius:12px;padding:16px;margin-bottom:12px}
.section-title{font-size:16px;color:#333;font-weight:600;margin-bottom:16px;display:block}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.add-btn{color:#1677ff;font-size:14px}

.config-item{display:flex;align-items:center;padding:12px 0;border-bottom:1px solid #f5f5f5}
.config-item:last-child{border-bottom:none}
.config-label{flex:1;display:flex;flex-direction:column;gap:4px}
.label-text{color:#333;font-size:15px;font-weight:500}
.label-desc{color:#999;font-size:12px}
.config-value{display:flex;align-items:center;gap:12px}
.value-text{color:#666;font-size:14px}
.edit-btn{color:#1677ff;font-size:14px}

.invite-code-list{display:flex;flex-direction:column;gap:12px}
.invite-code-item{background:#f9f9f9;border-radius:8px;padding:12px;display:flex;align-items:center;justify-content:space-between}
.code-info{flex:1;display:flex;flex-direction:column;gap:4px}
.code-text{color:#333;font-size:15px;font-weight:600}
.code-desc{color:#666;font-size:13px}
.code-status{color:#999;font-size:12px}
.code-actions{display:flex;gap:12px}
.copy-btn{color:#1677ff;font-size:14px}
.delete-btn{color:#ff4d4f;font-size:14px}

.switch-item{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid #f5f5f5}
.switch-item:last-child{border-bottom:none}
.switch-label{flex:1;display:flex;flex-direction:column;gap:4px}
.switch-title{color:#333;font-size:15px}
.switch-desc{color:#999;font-size:13px}

.announcement-list{display:flex;flex-direction:column;gap:12px}
.announcement-item{background:#f9f9f9;border-radius:8px;padding:12px;display:flex;flex-direction:column;gap:8px}
.announcement-text{color:#333;font-size:14px;line-height:1.6}
.announcement-time{color:#999;font-size:12px}

.action-item{display:flex;align-items:center;padding:12px 0;border-bottom:1px solid #f5f5f5}
.action-item:last-child{border-bottom:none}
.action-icon{font-size:20px;margin-right:12px}
.action-text{flex:1;color:#333;font-size:15px}
.action-arrow{color:#999;font-size:14px}

.empty-state{text-align:center;padding:40px 0}
.empty-text{color:#999;font-size:14px}

.banner-list{display:flex;flex-direction:column;gap:12px}
.banner-item{background:#f9f9f9;border-radius:8px;padding:12px;display:flex;flex-direction:column;gap:8px}
.banner-preview{width:100%;height:120px;border-radius:8px;overflow:hidden;background:#f5f5f5}
.banner-image{width:100%;height:100%}
.banner-info{display:flex;align-items:center;justify-content:space-between}
.banner-index{color:#666;font-size:14px}
.banner-actions{display:flex;gap:12px;justify-content:flex-end}

.announcement-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.announcement-title-wrapper{flex:1;display:flex;flex-direction:column;gap:4px}
.announcement-title{color:#333;font-size:15px;font-weight:600}
.announcement-type{color:#999;font-size:12px}
.announcement-actions{display:flex;align-items:center;gap:8px}
.announcement-status{color:#52c41a;font-size:12px;background:#f6ffed;padding:2px 8px;border-radius:4px}
.announcement-status.inactive{color:#ff4d4f;background:#fff1f0}
.announcement-delete{color:#ff4d4f;font-size:13px;cursor:pointer}
.announcement-delete:active{opacity:0.7}

/* 弹窗样式 */
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:1000;display:flex;align-items:center;justify-content:center}
.modal-content{background:#fff;border-radius:12px;width:90%;max-width:500px;max-height:80vh;display:flex;flex-direction:column}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:16px;border-bottom:1px solid #f0f0f0}
.modal-title{font-size:18px;color:#333;font-weight:600}
.modal-close{font-size:24px;color:#999;cursor:pointer}
.modal-body{flex:1;overflow-y:auto;padding:16px}
.modal-footer{display:flex;padding:16px;border-top:1px solid #f0f0f0;gap:12px}
.modal-btn{flex:1;padding:12px;text-align:center;border-radius:8px;font-size:15px}
.modal-btn.cancel{background:#f5f5f5;color:#666}
.modal-btn.confirm{background:#1677ff;color:#fff}

.form-item{margin-bottom:20px}
.form-label{color:#333;font-size:15px;font-weight:600;margin-bottom:8px;display:block}
.form-textarea{width:100%;min-height:100px;padding:12px;border:1px solid #d9d9d9;border-radius:8px;font-size:14px;color:#333;background:#fafafa}
.form-textarea:focus{border-color:#1677ff;background:#fff}

.target-type-selector{display:flex;gap:12px}
.target-type-item{flex:1;padding:16px;border:2px solid #d9d9d9;border-radius:8px;display:flex;flex-direction:column;align-items:center;gap:8px;cursor:pointer;transition:all 0.3s}
.target-type-item.active{border-color:#1677ff;background:#e6f7ff}
.target-type-icon{font-size:32px}
.target-type-text{color:#333;font-size:14px;font-weight:600}
.target-type-item.active .target-type-text{color:#1677ff}

