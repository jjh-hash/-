<!-- 登录功能示例页面 -->
<view class="container">
  <view class="header">
    <text class="title">微信用户登录功能测试</text>
    <text class="subtitle">测试基于云开发的微信用户登录功能</text>
  </view>

  <!-- 登录状态显示 -->
  <view class="status-section">
    <view class="status-item">
      <text class="status-label">登录状态：</text>
      <text class="status-value {{isLoggedIn ? 'logged-in' : 'not-logged-in'}}">
        {{isLoggedIn ? '已登录' : '未登录'}}
      </text>
    </view>
    
    <view wx:if="{{userInfo}}" class="user-info">
      <text class="info-label">用户信息：</text>
      <view class="info-content">
        <text class="info-item">昵称：{{userInfo.nickname}}</text>
        <text class="info-item">OpenID：{{userInfo.openid}}</text>
        <text class="info-item">角色：{{userInfo.role}}</text>
        <text class="info-item">状态：{{userInfo.status}}</text>
        <text class="info-item">创建时间：{{userInfo.createdAt}}</text>
        <text class="info-item">最后登录：{{userInfo.lastLoginAt}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button 
      class="action-btn primary" 
      bindtap="handleLogin"
      disabled="{{loading}}"
      loading="{{loading}}"
    >
      {{loading ? '登录中...' : '微信登录'}}
    </button>

    <button 
      wx:if="{{isLoggedIn}}"
      class="action-btn danger" 
      bindtap="handleLogout"
    >
      退出登录
    </button>

    <button 
      class="action-btn secondary" 
      bindtap="handleGetUserInfo"
    >
      获取用户信息（自动登录）
    </button>

    <button 
      class="action-btn secondary" 
      bindtap="handleRequireLoginAction"
    >
      需要登录的操作示例
    </button>

    <button 
      class="action-btn secondary" 
      bindtap="handleShowLoginModal"
    >
      显示登录弹窗
    </button>

    <button 
      wx:if="{{userInfo}}"
      class="action-btn secondary" 
      bindtap="handleCopyUserInfo"
    >
      复制用户信息
    </button>

    <button 
      class="action-btn secondary" 
      bindtap="handleGoToOtherPage"
    >
      跳转其他页面测试
    </button>
  </view>

  <!-- 使用说明 -->
  <view class="help-section">
    <text class="help-title">使用说明</text>
    <view class="help-content">
      <text class="help-item">1. 点击"微信登录"按钮测试登录功能</text>
      <text class="help-item">2. 登录成功后会显示用户信息</text>
      <text class="help-item">3. 可以测试自动登录和登出功能</text>
      <text class="help-item">4. 在其他页面中可以使用UserAuth工具类</text>
    </view>
  </view>
</view>