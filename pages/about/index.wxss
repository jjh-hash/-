.page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.status-bar {
  width: 100%;
  background: #fff;
}

.nav-bar {
  height: 44px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
}

.back-btn {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 20px;
  color: #333;
}

.nav-title {
  font-size: 18px;
  color: #333;
  font-weight: 600;
}

.nav-right {
  width: 44px;
}

.content {
  flex: 1;
  overflow-y: auto;
}

.about-container {
  padding: 20px;
}

.about-content {
  background: #fff;
  border-radius: 12px;
  padding: 24px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.about-text {
  font-size: 16px;
  line-height: 1.8;
  color: #333;
  text-align: justify;
  display: block;
}

