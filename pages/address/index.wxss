/* 我的地址 - 设计系统 */
.page {
  background: var(--color-bg-page);
  min-height: 100vh;
}

.content {
  height: calc(100vh - 120px);
  overflow: hidden;
}

/* 空态 */
.empty {
  padding: 56px 32px;
  text-align: center;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon-wrap {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
}

.empty-icon {
  font-size: 40px;
  line-height: 1;
  display: block;
}

.empty-lines {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

.empty-title {
  display: block;
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text);
}

.empty-sub {
  display: block;
  font-size: 14px;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.list {
  height: 100%;
}

.scroll-view {
  height: 100%;
}

.scroll-inner {
  padding: var(--space-page) 0 24px;
}

.scroll-bottom-spacer {
  height: calc(24px + env(safe-area-inset-bottom, 0px));
}

/* 地址卡片 */
.addr-item {
  position: relative;
  background: var(--color-bg-card);
  margin: 0 var(--space-page) var(--space-item);
  padding: var(--space-block);
  padding-left: calc(var(--space-block) + 4px);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  transition: box-shadow var(--transition-fast), border-color var(--transition-fast);
  border-left: 4px solid transparent;
}

.addr-item:first-child {
  margin-top: 0;
}

.addr-item-default {
  border-left-color: var(--color-primary);
  box-shadow: var(--shadow-card-hover);
}

.addr-item:active {
  box-shadow: var(--shadow-card-hover);
}

.addr-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.addr-name-row {
  display: flex;
  align-items: baseline;
  gap: 12px;
  flex-wrap: wrap;
}

.addr-name {
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text);
}

.addr-phone {
  font-size: 14px;
  color: var(--color-text-secondary);
}

.addr-default {
  margin-left: auto;
  flex-shrink: 0;
}

.default-tag {
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-size: 12px;
  font-weight: 500;
  padding: 4px 10px;
  border-radius: var(--radius-tag);
}

.addr-body {
  margin-bottom: 12px;
}

.addr-detail-wrap {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.addr-icon {
  font-size: 16px;
  margin-top: 2px;
  flex-shrink: 0;
}

.addr-detail {
  flex: 1;
  font-size: 14px;
  color: var(--color-text);
  line-height: 1.55;
  word-break: break-all;
}

.addr-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
}

.addr-btn {
  font-size: 13px;
  padding: 6px 12px;
  min-height: 32px;
  line-height: 20px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-btn);
  transition: opacity var(--transition-fast);
}

.addr-btn:active {
  opacity: 0.85;
}

.addr-set-default {
  color: var(--color-primary);
  background: var(--color-primary-light);
}

.addr-delete {
  color: var(--color-danger);
  background: rgba(239, 68, 68, 0.08);
}

/* 底部按钮 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: var(--color-bg-page);
  padding: var(--space-page);
  padding-bottom: calc(var(--space-page) + env(safe-area-inset-bottom));
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.08);
}

.btn-add {
  width: 100%;
  height: 48px;
  min-height: var(--min-tap);
  line-height: 48px;
  background: var(--color-primary) !important;
  color: #fff !important;
  border: none !important;
  border-radius: var(--radius-btn);
  font-size: 16px;
  font-weight: 600;
  transition: opacity var(--transition-fast);
}

.btn-add::after {
  border: none !important;
}

.btn-add:active {
  opacity: 0.9;
}
