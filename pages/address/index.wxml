<view class="page">
  <!-- 自定义导航 -->
  <view class="nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <text class="back" bindtap="onBack">◀</text>
      <text class="title">我的地址</text>
    </view>
  </view>

  <view class="content">
    <view class="empty" wx:if="{{addresses.length === 0}}">
      <text class="empty-title">暂无地址</text>
      <text class="empty-sub">点击下方按钮新增一个收货地址</text>
    </view>

    <view class="list" wx:if="{{addresses.length > 0}}">
      <block wx:for="{{addresses}}" wx:key="id">
        <view class="addr-item">
          <text class="addr-name">{{item.name}}</text>
          <text class="addr-desc">{{item.detail}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="footer">
    <button class="btn-add" type="default" size="default" bindtap="onAdd">新增地址</button>
  </view>
</view>

