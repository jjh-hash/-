<view class="page">
  <!-- 导航栏 -->
  <view class="navbar">
    <view class="navbar-content">
      <text class="back-btn" bindtap="onBackTap">◀</text>
      <text class="navbar-title">评价订单</text>
      <view class="placeholder"></view>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 星级评分 -->
    <view class="section">
      <view class="section-title">为本次服务评分</view>
      <view class="rating-container">
        <view 
          class="star {{index < rating ? 'active' : ''}}"
          wx:for="{{5}}"
          wx:key="index"
          data-rating="{{index + 1}}"
          bindtap="onRatingTap">
          ★
        </view>
      </view>
    </view>

    <!-- 评论内容 -->
    <view class="section">
      <view class="section-title">分享您的体验（选填）</view>
      <textarea 
        class="textarea"
        placeholder="说说您对这次体验的看法吧...（与图片至少填写一项）"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="500"
        show-confirm-bar="{{false}}">
      </textarea>
      <view class="char-count">{{content.length}}/500</view>
    </view>

    <!-- 上传图片 -->
    <view class="section">
      <view class="section-title">上传照片（选填）</view>
      <view class="image-container">
        <!-- 已上传的图片 -->
        <view 
          class="image-item"
          wx:for="{{images}}"
          wx:key="index">
          <image 
            class="image" 
            src="{{item}}" 
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="onPreviewImage" />
          <view 
            class="delete-btn"
            data-index="{{index}}"
            bindtap="onDeleteImage">
            ×
          </view>
        </view>

        <!-- 添加图片按钮 -->
        <view 
          class="add-image-btn"
          wx:if="{{images.length < maxImages}}"
          bindtap="onChooseImage">
          <text class="add-icon">+</text>
          <text class="add-text">添加照片</text>
        </view>
      </view>
      <view class="image-tip">最多上传{{maxImages}}张照片（与评论至少填写一项）</view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button 
        class="submit-btn {{isSubmitting ? 'disabled' : ''}}"
        bindtap="onSubmitReview"
        disabled="{{isSubmitting}}">
        {{isSubmitting ? '提交中...' : '提交评价'}}
      </button>
    </view>
  </scroll-view>
</view>

