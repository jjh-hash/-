.page{min-height:100vh;background:#f5f5f5;padding-bottom:80px}
.status-bar{width:100%}
.nav{height:44px;background:#fff;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:center;position:relative}
.back{position:absolute;left:12px;color:#333;font-size:18px}
.title{font-size:18px;color:#333;font-weight:600}

.form-container{padding:12px}
.section{background:#fff;border-radius:12px;padding:16px;margin-bottom:12px}
.section-title{font-size:16px;color:#333;font-weight:600;margin-bottom:16px;display:block}

.form-item{display:flex;align-items:center;padding:12px 0;border-bottom:1px solid #f5f5f5;position:relative}
.form-item:last-child{border-bottom:none}
.label{color:#333;font-size:15px;width:80px;flex-shrink:0}
.input{flex:1;color:#333;font-size:15px;text-align:right}
.input::placeholder{color:#999}

.select-value{flex:1;display:flex;align-items:center;justify-content:flex-end}
.placeholder{color:#999;font-size:15px}
.arrow{color:#999;font-size:14px;margin-left:8px}

.upload-item{flex-direction:column;align-items:flex-start;padding:16px 0}
.upload-hint{color:#999;font-size:12px;margin-top:4px;margin-bottom:12px}
.upload-area{width:80px;height:80px;border:1px dashed #ddd;border-radius:8px;display:flex;align-items:center;justify-content:center;background:#fafafa}
.uploaded-image{width:100%;height:100%;border-radius:8px}
.upload-placeholder{display:flex;align-items:center;justify-content:center;width:100%;height:100%}
.camera-icon{font-size:24px;color:#999}

.save-btn{position:fixed;left:12px;right:12px;bottom:20px;height:44px;background:#1677ff;color:#fff;border-radius:22px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:500;z-index:100}

.offline-btn{position:fixed;left:12px;right:12px;bottom:80px;height:44px;background:#ff4d4f;color:#fff;border-radius:22px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:500;z-index:100}

/* 规格管理样式 */
.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.add-spec-group-btn{display:flex;align-items:center;padding:6px 12px;background:#1677ff;color:#fff;border-radius:6px;font-size:14px}
.add-icon{margin-right:4px;font-size:16px}
.add-text{font-size:14px}

.empty-specs{padding:20px;text-align:center}
.empty-text{color:#999;font-size:14px}

.spec-groups{margin-top:12px}
.spec-group{background:#fafafa;border-radius:8px;padding:12px;margin-bottom:12px;border:1px solid #eee}
.spec-group-header{display:flex;align-items:center;margin-bottom:12px}
.spec-group-name-input{flex:1;padding:8px 12px;background:#fff;border-radius:6px;font-size:14px;color:#333;border:1px solid #ddd}
.delete-group-btn{padding:8px;margin-left:8px}

/* 规格组类型选择 */
.spec-group-type{display:flex;align-items:center;margin-bottom:12px;padding:8px 0}
.spec-type-label{font-size:13px;color:#666;margin-right:8px}
.spec-type-options{display:flex;gap:8px}
.spec-type-item{padding:4px 12px;background:#fff;border:1px solid #ddd;border-radius:4px;font-size:13px;color:#666;cursor:pointer}
.spec-type-item.active{background:#1677ff;border-color:#1677ff;color:#fff}

.spec-options{margin-top:8px}
.spec-option-item{display:flex;align-items:center;padding:8px 0;border-bottom:1px solid #eee}
.spec-option-item:last-child{border-bottom:none}
.spec-option-name{flex:1;padding:6px 10px;background:#fff;border-radius:4px;font-size:14px;color:#333;border:1px solid #ddd;margin-right:8px}
.spec-option-price-label{color:#666;font-size:13px;margin-right:4px}
.spec-option-price{width:60px;padding:6px 8px;background:#fff;border-radius:4px;font-size:14px;color:#333;border:1px solid #ddd;text-align:center}
.spec-option-price-unit{color:#666;font-size:13px;margin-left:4px;margin-right:8px}
.delete-option-btn{width:24px;height:24px;display:flex;align-items:center;justify-content:center;background:#ff4d4f;border-radius:50%;color:#fff}
.delete-icon-small{font-size:18px;line-height:1}

.add-option-btn{display:flex;align-items:center;justify-content:center;padding:8px;margin-top:8px;border:1px dashed #ddd;border-radius:6px;background:#fff}
.add-icon-small{margin-right:4px;color:#1677ff;font-size:16px}
.add-option-text{color:#1677ff;font-size:13px}
.delete-icon{font-size:16px}

/* 分类选择弹窗样式 */
.category-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.category-modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.category-modal {
  width: 100%;
  background: #fff;
  border-radius: 16px 16px 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.category-modal-overlay.show .category-modal {
  transform: translateY(0);
}

.category-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  border-bottom: 1px solid #f0f0f0;
  flex-shrink: 0;
}

.category-modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}

.category-modal-close {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: #999;
}

.category-modal-content {
  flex: 1;
  overflow-y: auto;
  min-height: 0;
}

.category-modal-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
}

.category-modal-item:last-child {
  border-bottom: none;
}

.category-modal-item.selected {
  background: #f8f9ff;
}

.category-modal-item-name {
  font-size: 16px;
  color: #333;
}

.category-modal-item.selected .category-modal-item-name {
  color: #1677ff;
  font-weight: 600;
}

.category-modal-item-check {
  font-size: 18px;
  color: #1677ff;
  font-weight: 600;
}