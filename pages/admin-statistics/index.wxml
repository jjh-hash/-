<view class="page">
  <!-- 状态栏 -->
  

  <!-- 标签栏 -->
  <view class="tabs">
    <block wx:for="{{tabs}}" wx:key="key">
      <view 
        class="tab-item {{currentTab === item.key ? 'active' : ''}}"
        bindtap="onTabChange"
        data-tab="{{item.key}}"
      >
        {{item.name}}
      </view>
    </block>
  </view>

  <!-- 日期范围选择 -->
  <view class="date-range">
    <picker 
      bindchange="onDateRangeChange" 
      value="{{dateRange}}" 
      range="['近一周', '近一月', '近三月']"
    >
      <view class="picker-text">
        <text wx:if="{{dateRange === 'week'}}">近一周</text>
        <text wx:elif="{{dateRange === 'month'}}">近一月</text>
        <text wx:elif="{{dateRange === 'quarter'}}">近三月</text>
      </view>
    </picker>
  </view>

  <!-- 数据概览 -->
  <view wx:if="{{currentTab === 'overview'}}" class="content">
    <!-- 核心数据 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">💰</text>
        <text class="stat-label">总营收</text>
        <text class="stat-number">¥{{overviewStats.totalRevenue}}</text>
        <text class="stat-trend {{overviewStats.revenueGrowth >= 0 ? 'positive' : 'negative'}}">
          {{overviewStats.revenueGrowth >= 0 ? '+' : ''}}{{overviewStats.revenueGrowth}}%
        </text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">🏪</text>
        <text class="stat-label">商家总数</text>
        <text class="stat-number">{{overviewStats.merchantCount}}</text>
        <text class="stat-trend {{overviewStats.merchantGrowth >= 0 ? 'positive' : 'negative'}}">
          {{overviewStats.merchantGrowth >= 0 ? '+' : ''}}{{overviewStats.merchantGrowth}}%
        </text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">📦</text>
        <text class="stat-label">订单总数</text>
        <text class="stat-number">{{overviewStats.orderCount}}</text>
        <text class="stat-trend {{overviewStats.orderGrowth >= 0 ? 'positive' : 'negative'}}">
          {{overviewStats.orderGrowth >= 0 ? '+' : ''}}{{overviewStats.orderGrowth}}%
        </text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">👥</text>
        <text class="stat-label">用户总数</text>
        <text class="stat-number">{{overviewStats.userCount}}</text>
        <text class="stat-trend {{overviewStats.userGrowth >= 0 ? 'positive' : 'negative'}}">
          {{overviewStats.userGrowth >= 0 ? '+' : ''}}{{overviewStats.userGrowth}}%
        </text>
      </view>
    </view>
    
    <!-- 活跃用户 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">🟢</text>
        <text class="stat-label">日活跃用户</text>
        <text class="stat-number">{{overviewStats.dailyActiveUsers}}</text>
        <text class="stat-trend {{overviewStats.dauGrowth >= 0 ? 'positive' : 'negative'}}">
          {{overviewStats.dauGrowth >= 0 ? '+' : ''}}{{overviewStats.dauGrowth}}%
        </text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">🌙</text>
        <text class="stat-label">月活跃用户</text>
        <text class="stat-number">{{overviewStats.monthlyActiveUsers}}</text>
        <text class="stat-trend {{overviewStats.mauGrowth >= 0 ? 'positive' : 'negative'}}">
          {{overviewStats.mauGrowth >= 0 ? '+' : ''}}{{overviewStats.mauGrowth}}%
        </text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">📦</text>
        <text class="stat-label">今日订单</text>
        <text class="stat-number">{{overviewStats.todayOrderCount}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">💰</text>
        <text class="stat-label">今日营收</text>
        <text class="stat-number">¥{{overviewStats.todayIncome}}</text>
      </view>
    </view>
    
    <!-- 订单概况 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">⏳</text>
        <text class="stat-label">待处理订单</text>
        <text class="stat-number">{{overviewStats.pendingOrders}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">✅</text>
        <text class="stat-label">已完成订单</text>
        <text class="stat-number">{{overviewStats.completedOrders}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">📊</text>
        <text class="stat-label">完成率</text>
        <text class="stat-number">{{overviewStats.completionRate}}%</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">💵</text>
        <text class="stat-label">平均订单金额</text>
        <text class="stat-number">¥{{overviewStats.avgOrderValue}}</text>
        <text class="stat-trend {{overviewStats.avgOrderGrowth >= 0 ? 'positive' : 'negative'}}">
          {{overviewStats.avgOrderGrowth >= 0 ? '+' : ''}}{{overviewStats.avgOrderGrowth}}%
        </text>
      </view>
    </view>
  </view>

  <!-- 订单统计 -->
  <view wx:elif="{{currentTab === 'orders'}}" class="content">
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">📦</text>
        <text class="stat-label">总订单数</text>
        <text class="stat-number">{{orderStats.totalOrders}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">✅</text>
        <text class="stat-label">已完成</text>
        <text class="stat-number">{{orderStats.completedOrders}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">⏳</text>
        <text class="stat-label">待处理</text>
        <text class="stat-number">{{orderStats.pendingOrders}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">❌</text>
        <text class="stat-label">已取消</text>
        <text class="stat-number">{{orderStats.cancelledOrders}}</text>
      </view>
    </view>
    
    <view class="revenue-card">
      <text class="revenue-label">总营收</text>
      <text class="revenue-amount">¥{{orderStats.totalRevenue}}</text>
    </view>
    
    <!-- 订单指标 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">📊</text>
        <text class="stat-label">完成率</text>
        <text class="stat-number">{{orderStats.completionRate}}%</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">💵</text>
        <text class="stat-label">平均订单金额</text>
        <text class="stat-number">¥{{orderStats.avgOrderValue}}</text>
      </view>
    </view>
    
    <!-- 订单金额分布 -->
    <view class="chart-container">
      <view class="chart-title">订单金额分布</view>
      <view class="chart-wrapper">
        <view class="chart-bars">
          <view wx:for="{{['0-50', '50-100', '100-200', '200-500', '500+']}}" wx:key="*this" class="chart-bar-item">
            <view class="chart-bar-wrapper">
              <view 
                class="chart-bar" 
                style="height: {{orderStats.amountDistributionHeights[item] || 0}}rpx"
              ></view>
            </view>
            <text class="chart-label">{{item}}元</text>
            <text class="chart-value">{{orderStats.amountDistribution[item] || 0}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 订单时段分布 -->
    <view class="chart-container">
      <view class="chart-title">订单时段分布</view>
      <view class="chart-wrapper">
        <view class="chart-bars">
          <view wx:for="{{['早餐', '午餐', '下午茶', '晚餐', '夜宵']}}" wx:key="*this" class="chart-bar-item">
            <view class="chart-bar-wrapper">
              <view 
                class="chart-bar time-bar" 
                style="height: {{orderStats.timeDistributionHeights[item] || 0}}rpx"
              ></view>
            </view>
            <text class="chart-label">{{item}}</text>
            <text class="chart-value">{{orderStats.timeDistribution[item] || 0}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 订单趋势图 -->
    <view class="chart-container">
      <view class="chart-title">订单趋势</view>
      <view class="chart-wrapper">
        <view class="chart-bars">
          <view wx:for="{{orderChartData.dates}}" wx:key="index" class="chart-bar-item">
            <view class="chart-bar-wrapper">
              <view 
                class="chart-bar" 
                style="height: {{orderChartData.orderHeights[index] || 0}}rpx"
              ></view>
            </view>
            <text class="chart-label">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 营收趋势图 -->
    <view class="chart-container">
      <view class="chart-title">营收趋势</view>
      <view class="chart-wrapper">
        <view class="chart-bars">
          <view wx:for="{{orderChartData.dates}}" wx:key="index" class="chart-bar-item">
            <view class="chart-bar-wrapper">
              <view 
                class="chart-bar revenue-bar" 
                style="height: {{orderChartData.revenueHeights[index] || 0}}rpx"
              ></view>
            </view>
            <text class="chart-label">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 用户统计 -->
  <view wx:elif="{{currentTab === 'users'}}" class="content">
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">👥</text>
        <text class="stat-label">总用户数</text>
        <text class="stat-number">{{userStats.totalUsers}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">🟢</text>
        <text class="stat-label">活跃用户</text>
        <text class="stat-number">{{userStats.activeUsers}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">📈</text>
        <text class="stat-label">今日新增</text>
        <text class="stat-number">{{userStats.newUsersToday}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">📊</text>
        <text class="stat-label">本周新增</text>
        <text class="stat-number">{{userStats.newUsersThisWeek}}</text>
      </view>
    </view>
    
    <!-- 用户增长趋势图 -->
    <view class="chart-container">
      <view class="chart-title">用户增长趋势</view>
      <view class="chart-wrapper">
        <view class="chart-bars">
          <view wx:for="{{userChartData.dates}}" wx:key="index" class="chart-bar-item">
            <view class="chart-bar-wrapper">
              <view 
                class="chart-bar" 
                style="height: {{userChartData.userHeights[index] || 0}}rpx"
              ></view>
            </view>
            <text class="chart-label">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 用户活跃度趋势图 -->
    <view class="chart-container">
      <view class="chart-title">用户活跃度趋势</view>
      <view class="chart-wrapper">
        <view class="chart-bars">
          <view wx:for="{{userChartData.dates}}" wx:key="index" class="chart-bar-item">
            <view class="chart-bar-wrapper">
              <view 
                class="chart-bar active-bar" 
                style="height: {{userChartData.activeUserHeights[index] || 0}}rpx"
              ></view>
            </view>
            <text class="chart-label">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 用户排行榜 -->
    <view class="ranking-container">
      <view class="ranking-title">用户排行榜（TOP 10）</view>
      <view class="ranking-list">
        <view wx:for="{{userStats.userRanking}}" wx:key="userId" class="ranking-item">
          <view class="ranking-rank">{{index + 1}}</view>
          <view class="ranking-info">
            <text class="ranking-name">用户ID: {{item.userId}}</text>
            <text class="ranking-desc">订单数: {{item.orderCount}} | 消费金额: ¥{{item.totalAmount}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 用户订单数分布 -->
    <view class="chart-container">
      <view class="chart-title">用户订单数分布</view>
      <view class="chart-wrapper">
        <view class="chart-bars">
          <view wx:for="{{['1单', '2-5单', '6-10单', '11-20单', '20+单']}}" wx:key="*this" class="chart-bar-item">
            <view class="chart-bar-wrapper">
              <view 
                class="chart-bar" 
                style="height: {{userStats.orderCountDistributionHeights[item] || 0}}rpx"
              ></view>
            </view>
            <text class="chart-label">{{item}}</text>
            <text class="chart-value">{{userStats.orderCountDistribution[item] || 0}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 用户消费金额分布 -->
    <view class="chart-container">
      <view class="chart-title">用户消费金额分布</view>
      <view class="chart-wrapper">
        <view class="chart-bars">
          <view wx:for="{{['0-100', '100-500', '500-1000', '1000-5000', '5000+']}}" wx:key="*this" class="chart-bar-item">
            <view class="chart-bar-wrapper">
              <view 
                class="chart-bar revenue-bar" 
                style="height: {{userStats.amountDistributionHeights[item] || 0}}rpx"
              ></view>
            </view>
            <text class="chart-label">{{item}}元</text>
            <text class="chart-value">{{userStats.amountDistribution[item] || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view wx:elif="{{currentTab === 'merchants'}}" class="content">
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">🏪</text>
        <text class="stat-label">总商家数</text>
        <text class="stat-number">{{merchantStats.totalMerchants}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">🟢</text>
        <text class="stat-label">营业中</text>
        <text class="stat-number">{{merchantStats.activeMerchants}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">⏳</text>
        <text class="stat-label">待审核</text>
        <text class="stat-number">{{merchantStats.pendingMerchants}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">⏸️</text>
        <text class="stat-label">已暂停</text>
        <text class="stat-number">{{merchantStats.suspendedMerchants}}</text>
      </view>
    </view>
    
    <!-- 商家增长趋势图 -->
    <view class="chart-container">
      <view class="chart-title">商家增长趋势</view>
      <view class="chart-wrapper">
        <view class="chart-bars">
          <view wx:for="{{merchantChartData.dates}}" wx:key="index" class="chart-bar-item">
            <view class="chart-bar-wrapper">
              <view 
                class="chart-bar merchant-bar" 
                style="height: {{merchantChartData.merchantHeights[index] || 0}}rpx"
              ></view>
            </view>
            <text class="chart-label">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 商家详细指标 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">💵</text>
        <text class="stat-label">平均订单金额</text>
        <text class="stat-number">¥{{merchantStats.avgOrderValue}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">📦</text>
        <text class="stat-label">平均日订单数</text>
        <text class="stat-number">{{merchantStats.avgDailyOrders}}</text>
      </view>
    </view>
    
    <!-- 商家排行榜 -->
    <view class="ranking-container">
      <view class="ranking-title">商家排行榜（TOP 10）</view>
      <view class="ranking-list">
        <view wx:for="{{merchantStats.merchantRanking}}" wx:key="storeId" class="ranking-item">
          <view class="ranking-rank">{{index + 1}}</view>
          <view class="ranking-info">
            <text class="ranking-name">{{item.storeName}}</text>
            <text class="ranking-desc">订单数: {{item.orderCount}} | 销售额: ¥{{item.totalSales}} | 平台服务费: ¥{{item.platformFee}}</text>
            <text class="ranking-desc">今日订单: {{item.dailyOrderCount}} | 平均订单金额: ¥{{item.avgOrderValue}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>
</view>
